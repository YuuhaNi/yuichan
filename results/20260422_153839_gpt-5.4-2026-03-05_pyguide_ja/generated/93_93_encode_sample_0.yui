標準ライブラリを使う

encode = 入力 message に対し {
   result = ""
   i = 0

   messageの大きさ回くり返す{
      c = message[i]
      ch = 文字列化(c)

      もしchが"a"ならば{
         resultに"C"[0]を追加する
      }そうでなければ{
         もしchが"e"ならば{
            resultに"G"[0]を追加する
         }そうでなければ{
            もしchが"i"ならば{
               resultに"K"[0]を追加する
            }そうでなければ{
               もしchが"o"ならば{
                  resultに"Q"[0]を追加する
               }そうでなければ{
                  もしchが"u"ならば{
                     resultに"W"[0]を追加する
                  }そうでなければ{
                     もしchが"A"ならば{
                        resultに"c"[0]を追加する
                     }そうでなければ{
                        もしchが"E"ならば{
                           resultに"g"[0]を追加する
                        }そうでなければ{
                           もしchが"I"ならば{
                              resultに"k"[0]を追加する
                           }そうでなければ{
                              もしchが"O"ならば{
                                 resultに"q"[0]を追加する
                              }そうでなければ{
                                 もしchが"U"ならば{
                                    resultに"w"[0]を追加する
                                 }そうでなければ{
                                    もしcが97以上ならば{
                                       もしcが122以下ならば{
                                          resultに差(c, 32)を追加する
                                       }そうでなければ{
                                          resultにcを追加する
                                       }
                                    }そうでなければ{
                                       もしcが65以上ならば{
                                          もしcが90以下ならば{
                                             resultに和(c, 32)を追加する
                                          }そうでなければ{
                                             resultにcを追加する
                                          }
                                       }そうでなければ{
                                          resultにcを追加する
                                       }
                                    }
                                 }
                              }
                           }
                        }
                     }
                  }
               }
            }
         }
      }

      iを増やす
   }

   resultが答え
}