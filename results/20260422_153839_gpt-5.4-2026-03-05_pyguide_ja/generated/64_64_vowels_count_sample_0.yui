標準ライブラリを使う

vowels_count = 入力 s に対し {
   count = 0
   i = 0
   sの大きさ回くり返す{
      c = s[i]
      もしcが"a"[0]ならば{ countを増やす }
      そうでなければ{
         もしcが"e"[0]ならば{ countを増やす }
         そうでなければ{
            もしcが"i"[0]ならば{ countを増やす }
            そうでなければ{
               もしcが"o"[0]ならば{ countを増やす }
               そうでなければ{
                  もしcが"u"[0]ならば{ countを増やす }
               }
            }
         }
      }
      iを増やす
   }
   countが答え
}