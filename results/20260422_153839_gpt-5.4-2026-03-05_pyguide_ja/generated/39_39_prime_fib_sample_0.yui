標準ライブラリを使う

prime_fib = 入力 n に対し {
   count = 0
   a = 0
   b = 1

   100000回くり返す{
      c = 和(a, b)
      a = b
      b = c

      もしaが2以上ならば{
         prime = 真
         d = 2

         a回くり返す{
            もしdがa以上ならば{
               くり返しを抜ける
            }
            もし剰余(a, d)が0ならば{
               prime = 偽
               くり返しを抜ける
            }
            dを増やす
         }

         もしprimeが真ならば{
            countを増やす
            もしcountがnならば{
               aが答え
            }
         }
      }
   }
}