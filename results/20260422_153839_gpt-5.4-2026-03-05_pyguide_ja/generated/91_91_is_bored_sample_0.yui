標準ライブラリを使う

is_bored = 入力 S に対し {
   count = 0
   start = 真
   i = 0

   Sの大きさ回くり返す{
      c = S[i]

      もしstartが真ならば{
         もしcが" "[0]ならば{
         }そうでなければ{
            もしcが"I"[0]ならば{
               もし和(i,1)がSの大きさより小さいならば{
                  もしS[和(i,1)]が" "[0]ならば{
                     countを増やす
                  }
               }
            }
            start = 偽
         }
      }

      もしcが"."[0]ならば{
         start = 真
      }
      もしcが"?"[0]ならば{
         start = 真
      }
      もしcが"!"[0]ならば{
         start = 真
      }

      iを増やす
   }

   countが答え
}