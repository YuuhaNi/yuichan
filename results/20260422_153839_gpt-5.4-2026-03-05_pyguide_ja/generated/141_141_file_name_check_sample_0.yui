標準ライブラリを使う

file_name_check = 入力 file_name に対し {
   n = file_nameの大きさ
   dot_count = 0
   dot_pos = 0
   digit_run = 0
   i = 0

   n回くり返す{
      c = file_name[i]

      もしcが"."[0]ならば{
         dot_countを増やす
         dot_pos = i
         digit_run = 0
      }そうでなければ{
         もしcが"0"[0]以上ならば{
            もしcが"9"[0]以下ならば{
               digit_runを増やす
               もしdigit_runが3以上ならば{
                  "No"が答え
               }
            }そうでなければ{
               digit_run = 0
            }
         }そうでなければ{
            digit_run = 0
         }
      }

      iを増やす
   }

   もしdot_countが1以外ならば{
      "No"が答え
   }

   もしdot_posが0ならば{
      "No"が答え
   }

   first = file_name[0]
   is_letter = 偽

   もしfirstが"a"[0]以上ならば{
      もしfirstが"z"[0]以下ならば{
         is_letter = 真
      }
   }
   もしfirstが"A"[0]以上ならば{
      もしfirstが"Z"[0]以下ならば{
         is_letter = 真
      }
   }

   もしis_letterが偽ならば{
      "No"が答え
   }

   ext_len = 差(n, 和(dot_pos, 1))
   もしext_lenが3以外ならば{
      "No"が答え
   }

   ext = ""
   j = 和(dot_pos, 1)
   ext_len回くり返す{
      extにfile_name[j]を追加する
      jを増やす
   }

   もしextが"txt"ならば{
      "Yes"が答え
   }
   もしextが"exe"ならば{
      "Yes"が答え
   }
   もしextが"dll"ならば{
      "Yes"が答え
   }

   "No"が答え
}