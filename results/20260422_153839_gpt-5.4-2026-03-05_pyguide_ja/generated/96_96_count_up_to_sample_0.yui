標準ライブラリを使う

count_up_to = 入力 n に対し {
   primes = []
   i = 2

   n回くり返す{
      もしiがn以上ならば{
         くり返しを抜ける
      }

      is_prime = 真
      d = 2

      i回くり返す{
         もしdがi以上ならば{
            くり返しを抜ける
         }
         もし剰余(i, d)が0ならば{
            is_prime = 偽
            くり返しを抜ける
         }
         dを増やす
      }

      もしis_primeが真ならば{
         primesにiを追加する
      }
      iを増やす
   }

   primesが答え
}