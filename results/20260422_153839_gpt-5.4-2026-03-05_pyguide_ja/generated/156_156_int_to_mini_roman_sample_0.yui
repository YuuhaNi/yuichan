標準ライブラリを使う

int_to_mini_roman = 入力 number に対し {
   result = ""

   1000回くり返す{
      もしnumberが1000以上ならば{
         result = "{result}m"
         number = 差(number, 1000)
      }そうでなければ{
         もしnumberが900以上ならば{
            result = "{result}cm"
            number = 差(number, 900)
         }そうでなければ{
            もしnumberが500以上ならば{
               result = "{result}d"
               number = 差(number, 500)
            }そうでなければ{
               もしnumberが400以上ならば{
                  result = "{result}cd"
                  number = 差(number, 400)
               }そうでなければ{
                  もしnumberが100以上ならば{
                     result = "{result}c"
                     number = 差(number, 100)
                  }そうでなければ{
                     もしnumberが90以上ならば{
                        result = "{result}xc"
                        number = 差(number, 90)
                     }そうでなければ{
                        もしnumberが50以上ならば{
                           result = "{result}l"
                           number = 差(number, 50)
                        }そうでなければ{
                           もしnumberが40以上ならば{
                              result = "{result}xl"
                              number = 差(number, 40)
                           }そうでなければ{
                              もしnumberが10以上ならば{
                                 result = "{result}x"
                                 number = 差(number, 10)
                              }そうでなければ{
                                 もしnumberが9ならば{
                                    result = "{result}ix"
                                    number = 差(number, 9)
                                 }そうでなければ{
                                    もしnumberが5以上ならば{
                                       result = "{result}v"
                                       number = 差(number, 5)
                                    }そうでなければ{
                                       もしnumberが4ならば{
                                          result = "{result}iv"
                                          number = 差(number, 4)
                                       }そうでなければ{
                                          もしnumberが1以上ならば{
                                             result = "{result}i"
                                             numberを減らす
                                          }そうでなければ{
                                             くり返しを抜ける
                                          }
                                       }
                                    }
                                 }
                              }
                           }
                        }
                     }
                  }
               }
            }
         }
      }
   }

   resultが答え
}