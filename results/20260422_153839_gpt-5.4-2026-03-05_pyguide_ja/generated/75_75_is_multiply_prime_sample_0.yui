標準ライブラリを使う

is_multiply_prime = 入力 a に対し {
   i = 2
   99回くり返す{
      もし剰余(a, i)が0ならば{
         b = 商(a, i)
         j = 2
         99回くり返す{
            もし剰余(b, j)が0ならば{
               k = 商(b, j)

               pi = 真
               d = 2
               i回くり返す{
                  もしdがiより小さいならば{
                     もし剰余(i, d)が0ならば{
                        pi = 偽
                     }
                     dを増やす
                  }
               }

               pj = 真
               d = 2
               j回くり返す{
                  もしdがjより小さいならば{
                     もし剰余(j, d)が0ならば{
                        pj = 偽
                     }
                     dを増やす
                  }
               }

               pk = 真
               d = 2
               k回くり返す{
                  もしdがkより小さいならば{
                     もし剰余(k, d)が0ならば{
                        pk = 偽
                     }
                     dを増やす
                  }
               }

               もしpiが真ならば{
                  もしpjが真ならば{
                     もしpkが真ならば{
                        真が答え
                     }
                  }
               }
            }
            jを増やす
         }
      }
      iを増やす
   }
   偽が答え
}