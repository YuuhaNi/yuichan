標準ライブラリを使う

remove_vowels = 入力 text に対し {
   result = ""
   i = 0
   textの大きさ回くり返す{
      c = text[i]
      もしcが"a"[0]ならば{
      }そうでなければ{
         もしcが"i"[0]ならば{
         }そうでなければ{
            もしcが"u"[0]ならば{
            }そうでなければ{
               もしcが"e"[0]ならば{
               }そうでなければ{
                  もしcが"o"[0]ならば{
                  }そうでなければ{
                     もしcが"A"[0]ならば{
                     }そうでなければ{
                        もしcが"I"[0]ならば{
                        }そうでなければ{
                           もしcが"U"[0]ならば{
                           }そうでなければ{
                              もしcが"E"[0]ならば{
                              }そうでなければ{
                                 もしcが"O"[0]ならば{
                                 }そうでなければ{
                                    resultにcを追加する
                                 }
                              }
                           }
                        }
                     }
                  }
               }
            }
         }
      }
      iを増やす
   }
   resultが答え
}