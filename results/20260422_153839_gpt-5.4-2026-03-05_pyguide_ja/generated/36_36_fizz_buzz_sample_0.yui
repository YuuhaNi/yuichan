標準ライブラリを使う

fizz_buzz = 入力 n に対し {
   count = 0
   i = 0

   n回くり返す{
      もしiが0より大きいならば{
         もし剰余(i, 11)が0ならば{
            x = i
            もしxが0ならば{
            }そうでなければ{
               10回くり返す{
                  もしxが0ならば{
                     くり返しを抜ける
                  }
                  もし剰余(x, 10)が7ならば{
                     countを増やす
                  }
                  x = 商(x, 10)
               }
            }
         }そうでなければ{
            もし剰余(i, 13)が0ならば{
               x = i
               もしxが0ならば{
               }そうでなければ{
                  10回くり返す{
                     もしxが0ならば{
                        くり返しを抜ける
                     }
                     もし剰余(x, 10)が7ならば{
                        countを増やす
                     }
                     x = 商(x, 10)
                  }
               }
            }
         }
      }
      iを増やす
   }

   countが答え
}