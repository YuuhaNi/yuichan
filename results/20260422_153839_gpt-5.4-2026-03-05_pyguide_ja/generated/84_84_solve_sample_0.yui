標準ライブラリを使う

solve = 入力 N に対し {
   sum = 0
   s = 文字列化(N)
   i = 0

   sの大きさ回くり返す{
      sum = 和(sum, 差(s[i], "0"[0]))
      iを増やす
   }

   もしsumが0ならば{
      "0"が答え
   }

   bits = ""
   tmp = sum

   sum回くり返す{
      もしtmpが0ならば{
         くり返しを抜ける
      }
      bits = "{剰余(tmp, 2)}{bits}"
      tmp = 商(tmp, 2)
   }

   bitsが答え
}