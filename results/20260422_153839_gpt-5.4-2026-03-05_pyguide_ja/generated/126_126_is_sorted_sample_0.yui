標準ライブラリを使う

is_sorted = 入力 lst に対し {
   もしlstの大きさが1ならば{
      真が答え
   }

   i = 1
   dup = 1

   差(lstの大きさ, 1)回くり返す{
      もしlst[i]がlst[差(i,1)]より小さいならば{
         偽が答え
      }

      もしlst[i]がlst[差(i,1)]ならば{
         dupを増やす
         もしdupが3以上ならば{
            偽が答え
         }
      }そうでなければ{
         dup = 1
      }

      iを増やす
   }

   真が答え
}