標準ライブラリを使う

median = 入力 l に対し {
   n = lの大きさ
   i = 0

   n回くり返す{
      j = 0
      limit = 差(n, 1)
      limit回くり返す{
         nj = 和(j, 1)
         もしl[j]がl[nj]より大きいならば{
            tmp = l[j]
            l[j] = l[nj]
            l[nj] = tmp
         }
         jを増やす
      }
      iを増やす
   }

   half = 商(n, 2)

   もし剰余(n, 2)が1ならば{
      l[half]が答え
   }
   そうでなければ{
      a = l[差(half, 1)]
      b = l[half]
      商(和(小数化(a), 小数化(b)), 2.0)が答え
   }
}