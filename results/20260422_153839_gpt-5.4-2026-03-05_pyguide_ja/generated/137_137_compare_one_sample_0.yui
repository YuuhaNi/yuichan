標準ライブラリを使う

compare_one = 入力 a, b に対し {
   sa = 文字列化(a)
   sb = 文字列化(b)

   aa = sa
   bb = sb

   i = 0
   saの大きさ回くり返す{
      もしaa[i]が","[0]ならば{
         aa[i] = "."[0]
      }
      iを増やす
   }

   i = 0
   sbの大きさ回くり返す{
      もしbb[i]が","[0]ならば{
         bb[i] = "."[0]
      }
      iを増やす
   }

   na = 小数化(aa)
   nb = 小数化(bb)

   もしnaがnbならば{
      値なしが答え
   }
   そうでなければ{
      もしnaがnbより大きいならば{
         aが答え
      }
      そうでなければ{
         bが答え
      }
   }
}