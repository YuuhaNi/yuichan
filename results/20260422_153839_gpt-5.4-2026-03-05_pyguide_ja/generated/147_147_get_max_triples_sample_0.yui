標準ライブラリを使う

get_max_triples = 入力 n に対し {
   a = []
   i = 0

   n回くり返す{
      iを増やす
      aに差(積(i,i), i, -1)を追加する
   }

   ans = []
   i = 0
   aの大きさ回くり返す{
      j = 和(i, 1)
      aの大きさ回くり返す{
         もしjがaの大きさ以上ならば{
            くり返しを抜ける
         }

         k = 和(j, 1)
         aの大きさ回くり返す{
            もしkがaの大きさ以上ならば{
               くり返しを抜ける
            }

            s = 和(a[i], a[j], a[k])
            もし剰余(s, 3)が0ならば{
               ansに[a[i], a[j], a[k]]を追加する
            }
            kを増やす
         }
         jを増やす
      }
      iを増やす
   }

   ansが答え
}