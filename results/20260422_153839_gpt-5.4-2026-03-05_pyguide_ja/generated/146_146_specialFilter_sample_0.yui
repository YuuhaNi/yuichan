標準ライブラリを使う

specialFilter = 入力 nums に対し {
   count = 0
   i = 0

   numsの大きさ回くり返す{
      n = nums[i]

      もしnが10より大きいならば{
         last = 剰余(n, 10)
         first = n

         n回くり返す{
            もしfirstが10より小さいならば{
               くり返しを抜ける
            }
            first = 商(first, 10)
         }

         もしlastが1ならば{
            もしfirstが1ならば{ countを増やす }
            そうでなければ{
               もしfirstが3ならば{ countを増やす }
               そうでなければ{
                  もしfirstが5ならば{ countを増やす }
                  そうでなければ{
                     もしfirstが7ならば{ countを増やす }
                     そうでなければ{
                        もしfirstが9ならば{ countを増やす }
                     }
                  }
               }
            }
         }
         そうでなければ{
            もしlastが3ならば{
               もしfirstが1ならば{ countを増やす }
               そうでなければ{
                  もしfirstが3ならば{ countを増やす }
                  そうでなければ{
                     もしfirstが5ならば{ countを増やす }
                     そうでなければ{
                        もしfirstが7ならば{ countを増やす }
                        そうでなければ{
                           もしfirstが9ならば{ countを増やす }
                        }
                     }
                  }
               }
            }
            そうでなければ{
               もしlastが5ならば{
                  もしfirstが1ならば{ countを増やす }
                  そうでなければ{
                     もしfirstが3ならば{ countを増やす }
                     そうでなければ{
                        もしfirstが5ならば{ countを増やす }
                        そうでなければ{
                           もしfirstが7ならば{ countを増やす }
                           そうでなければ{
                              もしfirstが9ならば{ countを増やす }
                           }
                        }
                     }
                  }
               }
               そうでなければ{
                  もしlastが7ならば{
                     もしfirstが1ならば{ countを増やす }
                     そうでなければ{
                        もしfirstが3ならば{ countを増やす }
                        そうでなければ{
                           もしfirstが5ならば{ countを増やす }
                           そうでなければ{
                              もしfirstが7ならば{ countを増やす }
                              そうでなければ{
                                 もしfirstが9ならば{ countを増やす }
                              }
                           }
                        }
                     }
                  }
                  そうでなければ{
                     もしlastが9ならば{
                        もしfirstが1ならば{ countを増やす }
                        そうでなければ{
                           もしfirstが3ならば{ countを増やす }
                           そうでなければ{
                              もしfirstが5ならば{ countを増やす }
                              そうでなければ{
                                 もしfirstが7ならば{ countを増やす }
                                 そうでなければ{
                                    もしfirstが9ならば{ countを増やす }
                                 }
                              }
                           }
                        }
                     }
                  }
               }
            }
         }
      }

      iを増やす
   }

   countが答え
}