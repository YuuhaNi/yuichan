標準ライブラリを使う

simplify = 入力 x, n に対し {
   xi = 0
   ni = 0
   xa = 0
   na = 0
   xnum = 0
   xden = 0
   nnum = 0
   nden = 0

   xの大きさ回くり返す{
      もしx[xi]が"/"[0]ならば{
         くり返しを抜ける
      }
      xnum = 和(積(xnum, 10), 差(x[xi], "0"[0]))
      xiを増やす
   }
   xiを増やす
   xの大きさ回くり返す{
      もしxiがxの大きさならば{
         くり返しを抜ける
      }
      xden = 和(積(xden, 10), 差(x[xi], "0"[0]))
      xiを増やす
   }

   nの大きさ回くり返す{
      もしn[ni]が"/"[0]ならば{
         くり返しを抜ける
      }
      nnum = 和(積(nnum, 10), 差(n[ni], "0"[0]))
      niを増やす
   }
   niを増やす
   nの大きさ回くり返す{
      もしniがnの大きさならば{
         くり返しを抜ける
      }
      nden = 和(積(nden, 10), 差(n[ni], "0"[0]))
      niを増やす
   }

   もし剰余(積(xnum, nnum), 積(xden, nden))が0ならば{
      真が答え
   }
   そうでなければ{
      偽が答え
   }
}