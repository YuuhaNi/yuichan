標準ライブラリを使う

odd_count = 入力 lst に対し {
   result = []
   i = 0

   lstの大きさ回くり返す{
      s = lst[i]
      j = 0
      count = 0

      sの大きさ回くり返す{
         c = s[j]
         もしcが"1"[0]ならば{ countを増やす }
         もしcが"3"[0]ならば{ countを増やす }
         もしcが"5"[0]ならば{ countを増やす }
         もしcが"7"[0]ならば{ countを増やす }
         もしcが"9"[0]ならば{ countを増やす }
         jを増やす
      }

      text = "the number of odd elements {count}n the str{count}ng {count} of the {count}nput."
      resultにtextを追加する
      iを増やす
   }

   resultが答え
}