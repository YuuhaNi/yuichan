標準ライブラリを使う

sort_array = 入力 arr に対し {
   n = arrの大きさ
   i = 0

   n回くり返す{
      j = 0
      limit = 差(n, 1)
      limit回くり返す{
         a = arr[j]
         b = arr[和(j, 1)]

         ca = 0
         cb = 0

         ta = 絶対値(a)
         tb = 絶対値(b)

         もしtaが0ならば{
         }そうでなければ{
            ta回くり返す{
               もしtaが0ならば{
                  くり返しを抜ける
               }
               もし剰余(ta, 2)が1ならば{
                  caを増やす
               }
               ta = 商(ta, 2)
            }
         }

         もしtbが0ならば{
         }そうでなければ{
            tb回くり返す{
               もしtbが0ならば{
                  くり返しを抜ける
               }
               もし剰余(tb, 2)が1ならば{
                  cbを増やす
               }
               tb = 商(tb, 2)
            }
         }

         swap = 偽
         もしcaがcbより大きいならば{
            swap = 真
         }そうでなければ{
            もしcaがcbならば{
               もしaがbより大きいならば{
                  swap = 真
               }
            }
         }

         もしswapが真ならば{
            temp = arr[j]
            arr[j] = arr[和(j, 1)]
            arr[和(j, 1)] = temp
         }

         jを増やす
      }
      iを増やす
   }

   arrが答え
}