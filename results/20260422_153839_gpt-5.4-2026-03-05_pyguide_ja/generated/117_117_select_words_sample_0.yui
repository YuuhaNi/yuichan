標準ライブラリを使う

select_words = 入力 s, n に対し {
   result = []
   word = ""
   consonants = 0
   i = 0

   sの大きさ回くり返す{
      c = s[i]

      もしcが" "[0]ならば{
         もしwordの大きさが0より大きいならば{
            もしconsonantsがnならば{
               resultにwordを追加する
            }
            word = ""
            consonants = 0
         }
      }そうでなければ{
         wordにcを追加する

         もしcが"a"[0]ならば{
         }そうでなければ{
            もしcが"e"[0]ならば{
            }そうでなければ{
               もしcが"i"[0]ならば{
               }そうでなければ{
                  もしcが"o"[0]ならば{
                  }そうでなければ{
                     もしcが"u"[0]ならば{
                     }そうでなければ{
                        もしcが"A"[0]ならば{
                        }そうでなければ{
                           もしcが"E"[0]ならば{
                           }そうでなければ{
                              もしcが"I"[0]ならば{
                              }そうでなければ{
                                 もしcが"O"[0]ならば{
                                 }そうでなければ{
                                    もしcが"U"[0]ならば{
                                    }そうでなければ{
                                       consonantsを増やす
                                    }
                                 }
                              }
                           }
                        }
                     }
                  }
               }
            }
         }
      }

      iを増やす
   }

   もしwordの大きさが0より大きいならば{
      もしconsonantsがnならば{
         resultにwordを追加する
      }
   }

   resultが答え
}