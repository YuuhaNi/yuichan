標準ライブラリを使う

valid_date = 入力 date に対し {
   もしdateが""ならば{
      偽が答え
   }

   もしdateの大きさが10以外ならば{
      偽が答え
   }

   もしdate[2]が"-"[0]以外ならば{
      偽が答え
   }

   もしdate[5]が"-"[0]以外ならば{
      偽が答え
   }

   month_s = ""
   month_sにdate[0]を追加する
   month_sにdate[1]を追加する

   day_s = ""
   day_sにdate[3]を追加する
   day_sにdate[4]を追加する

   year_s = ""
   year_sにdate[6]を追加する
   year_sにdate[7]を追加する
   year_sにdate[8]を追加する
   year_sにdate[9]を追加する

   month = 整数化(month_s)
   day = 整数化(day_s)

   もしmonthが1より小さいならば{
      偽が答え
   }

   もしmonthが12より大きいならば{
      偽が答え
   }

   もしdayが1より小さいならば{
      偽が答え
   }

   もしmonthが2ならば{
      もしdayが29より大きいならば{
         偽が答え
      }
      真が答え
   }

   もしmonthが4ならば{
      もしdayが30より大きいならば{
         偽が答え
      }
      真が答え
   }

   もしmonthが6ならば{
      もしdayが30より大きいならば{
         偽が答え
      }
      真が答え
   }

   もしmonthが9ならば{
      もしdayが30より大きいならば{
         偽が答え
      }
      真が答え
   }

   もしmonthが11ならば{
      もしdayが30より大きいならば{
         偽が答え
      }
      真が答え
   }

   もしdayが31より大きいならば{
      偽が答え
   }

   真が答え
}