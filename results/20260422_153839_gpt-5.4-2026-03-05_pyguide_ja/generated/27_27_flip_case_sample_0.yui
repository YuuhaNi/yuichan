標準ライブラリを使う

flip_case = 入力 string に対し {
   i = 0
   stringの大きさ回くり返す{
      c = string[i]

      もしcが97以上ならば{
         もしcが122以下ならば{
            string[i] = 差(c, 32)
         }
      }
      そうでなければ{
         もしcが65以上ならば{
            もしcが90以下ならば{
               string[i] = 和(c, 32)
            }
         }
      }

      iを増やす
   }
   stringが答え
}