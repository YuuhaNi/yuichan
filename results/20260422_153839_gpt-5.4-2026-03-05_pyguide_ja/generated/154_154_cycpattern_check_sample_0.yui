標準ライブラリを使う

cycpattern_check = 入力 a, b に対し {
   n = bの大きさ
   i = 0

   n回くり返す{
      ok = 真
      j = 0

      n回くり返す{
         k = 剰余(和(i, j), n)
         もしaの大きさがj以下ならば{
            ok = 偽
            くり返しを抜ける
         }
         もしa[j]がb[k]以外ならば{
            ok = 偽
            くり返しを抜ける
         }
         jを増やす
      }

      もしokが真ならば{
         真が答え
      }
      iを増やす
   }

   start = 0
   aの大きさ回くり返す{
      ok2 = 真
      j2 = 0

      n回くり返す{
         pos = 和(start, j2)
         もしaの大きさがpos以下ならば{
            ok2 = 偽
            くり返しを抜ける
         }
         もしa[pos]がb[j2]以外ならば{
            ok2 = 偽
            くり返しを抜ける
         }
         j2を増やす
      }

      もしok2が真ならば{
         真が答え
      }
      startを増やす
   }

   偽が答え
}