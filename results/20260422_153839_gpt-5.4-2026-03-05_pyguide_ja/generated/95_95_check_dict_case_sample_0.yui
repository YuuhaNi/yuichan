標準ライブラリを使う

check_dict_case = 入力 dict に対し {
   keys = 配列化(dict)
   もしkeysの大きさが0ならば{
      偽が答え
   }

   i = 0
   all_lower = 真
   all_upper = 真

   keysの大きさ回くり返す{
      k = keys[i]

      もし文字列判定(k)が偽ならば{
         偽が答え
      }

      もしkが文字列化(小文字化(k))以外ならば{
         all_lower = 偽
      }
      もしkが文字列化(大文字化(k))以外ならば{
         all_upper = 偽
      }

      iを増やす
   }

   もしall_lowerが真ならば{
      真が答え
   }
   そうでなければ{
      もしall_upperが真ならば{
         偽が答え
      }
      そうでなければ{
         偽が答え
      }
   }
}