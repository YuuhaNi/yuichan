標準ライブラリを使う

by_length = 入力 arr に対し {
   nums = []
   i = 0

   arrの大きさ回くり返す{
      x = arr[i]
      もしxが1以上ならば{
         もしxが9以下ならば{
            numsにxを追加する
         }
      }
      iを増やす
   }

   result = []
   d = 9
   9回くり返す{
      i = 0
      numsの大きさ回くり返す{
         もしnums[i]がdならば{
            もしdが1ならば{ resultに"One"を追加する }
            そうでなければ{
               もしdが2ならば{ resultに"Two"を追加する }
               そうでなければ{
                  もしdが3ならば{ resultに"Three"を追加する }
                  そうでなければ{
                     もしdが4ならば{ resultに"Four"を追加する }
                     そうでなければ{
                        もしdが5ならば{ resultに"Five"を追加する }
                        そうでなければ{
                           もしdが6ならば{ resultに"Six"を追加する }
                           そうでなければ{
                              もしdが7ならば{ resultに"Seven"を追加する }
                              そうでなければ{
                                 もしdが8ならば{ resultに"Eight"を追加する }
                                 そうでなければ{
                                    もしdが9ならば{ resultに"Nine"を追加する }
                                 }
                              }
                           }
                        }
                     }
                  }
               }
            }
         }
         iを増やす
      }
      d = 差(d, 1)
   }

   resultが答え
}