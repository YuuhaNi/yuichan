標準ライブラリを使う

check_if_last_char_is_a_letter = 入力 txt に対し {
   もしtxtの大きさが0ならば{
      偽が答え
   }

   n = txtの大きさ
   last = txt[差(n,1)]

   もしlastが" "ならば{
      偽が答え
   }

   i = 0
   is_letter = 偽
   52回くり返す{
      もしiが26より小さいならば{
         code = 和(97, i)
      }そうでなければ{
         code = 和(65, 差(i,26))
      }

      もしlastがcodeならば{
         is_letter = 真
         くり返しを抜ける
      }
      iを増やす
   }

   もしis_letterが偽ならば{
      偽が答え
   }

   もしnが1ならば{
      真が答え
   }

   prev = txt[差(n,2)]
   もしprevが" "ならば{
      真が答え
   }そうでなければ{
      偽が答え
   }
}