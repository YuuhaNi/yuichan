標準ライブラリを使う

find_closest_elements = 入力 numbers に対し {
   n = numbersの大きさ
   a = numbers[0]
   b = numbers[1]
   もしaがbより大きいならば{
      t = a
      a = b
      b = t
   }
   best_diff = 絶対値(差(numbers[0], numbers[1]))

   i = 0
   n回くり返す{
      j = 和(i, 1)
      n回くり返す{
         もしjがn以上ならば{
            くり返しを抜ける
         }

         x = numbers[i]
         y = numbers[j]
         diff = 絶対値(差(x, y))

         もしdiffがbest_diffより小さいならば{
            best_diff = diff
            もしxがy以下ならば{
               a = x
               b = y
            }そうでなければ{
               a = y
               b = x
            }
         }

         j = 和(j, 1)
      }
      iを増やす
   }

   [a, b]が答え
}