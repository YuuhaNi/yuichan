標準ライブラリを使う

sort_array = 入力 array に対し {
   result = []
   i = 0
   arrayの大きさ回くり返す{
      resultにarray[i]を追加する
      iを増やす
   }

   n = resultの大きさ
   もしnが1以下ならば{
      resultが答え
   }

   first = result[0]
   last = result[差(n,1)]
   sum = 和(first, last)
   asc = 偽
   もし剰余(sum, 2)が1ならば{
      asc = 真
   }

   i = 0
   n回くり返す{
      j = 0
      差(n, 1)回くり返す{
         a = result[j]
         b = result[和(j,1)]
         swap = 偽

         もしascが真ならば{
            もしaがbより大きいならば{
               swap = 真
            }
         }そうでなければ{
            もしaがbより小さいならば{
               swap = 真
            }
         }

         もしswapが真ならば{
            temp = result[j]
            result[j] = result[和(j,1)]
            result[和(j,1)] = temp
         }
         jを増やす
      }
      iを増やす
   }

   resultが答え
}