標準ライブラリを使う

solve = 入力 s に対し {
   result = ""
   found = 偽
   i = 0

   sの大きさ回くり返す{
      c = s[i]
      code = 整数化(c)

      もしcodeが65以上ならば{
         もしcodeが90以下ならば{
            resultに文字列化(差(code, 32))を追加する
            found = 真
         }そうでなければ{
            もしcodeが97以上ならば{
               もしcodeが122以下ならば{
                  resultに文字列化(和(code, 32))を追加する
                  found = 真
               }そうでなければ{
                  resultにcを追加する
               }
            }そうでなければ{
               resultにcを追加する
            }
         }
      }そうでなければ{
         もしcodeが97以上ならば{
            もしcodeが122以下ならば{
               resultに文字列化(和(code, 32))を追加する
               found = 真
            }そうでなければ{
               resultにcを追加する
            }
         }そうでなければ{
            resultにcを追加する
         }
      }

      iを増やす
   }

   もしfoundが真ならば{
      resultが答え
   }

   rev = ""
   i = sの大きさ
   sの大きさ回くり返す{
      i = 差(i, 1)
      revにs[i]を追加する
   }
   revが答え
}