標準ライブラリを使う

even_odd_palindrome = 入力 n に対し {
   even = 0
   odd = 0
   i = 0

   n回くり返す{
      iを増やす
      s = 文字列化(i)
      j = 0
      ok = 真
      half = 商(sの大きさ, 2)

      half回くり返す{
         もしs[j]がs[差(差(sの大きさ, 1), j)]以外ならば{
            ok = 偽
            くり返しを抜ける
         }
         jを増やす
      }

      もしokが真ならば{
         もし剰余(i, 2)が0ならば{
            evenを増やす
         }そうでなければ{
            oddを増やす
         }
      }
   }

   [even, odd]が答え
}