標準ライブラリを使う

hex_key = 入力 num に対し {
   count = 0
   i = 0
   numの大きさ回くり返す{
      ch = 文字列化(num[i])
      もしchが"2"ならば{
         countを増やす
      }そうでなければ{
         もしchが"3"ならば{
            countを増やす
         }そうでなければ{
            もしchが"5"ならば{
               countを増やす
            }そうでなければ{
               もしchが"7"ならば{
                  countを増やす
               }そうでなければ{
                  もしchが"B"ならば{
                     countを増やす
                  }そうでなければ{
                     もしchが"D"ならば{
                        countを増やす
                     }
                  }
               }
            }
         }
      }
      iを増やす
   }
   countが答え
}