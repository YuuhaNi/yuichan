標準ライブラリを使う

count_nums = 入力 arr に対し {
   count = 0
   i = 0

   arrの大きさ回くり返す{
      n = arr[i]
      s = 0

      もしnが0より小さいならば{
         s = 差(0, 剰余(差(0, n), 10))
         n = 商(差(0, n), 10)
      }そうでなければ{
         s = 剰余(n, 10)
         n = 商(n, 10)
      }

      もしnが0より大きいならば{
         n回くり返す{
            もしnが0ならば{
               くり返しを抜ける
            }
            s = 和(s, 剰余(n, 10))
            n = 商(n, 10)
         }
      }

      もしsが0より大きいならば{
         countを増やす
      }

      iを増やす
   }

   countが答え
}