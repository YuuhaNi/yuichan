標準ライブラリを使う

pluck = 入力 arr に対し {
   n = arrの大きさ
   もしnが0ならば{
      []が答え
   }

   found = 偽
   best_value = 0
   best_index = 0
   i = 0

   n回くり返す{
      v = arr[i]
      r = 剰余(v, 2)

      もしrが0ならば{
         もしfoundが偽ならば{
            found = 真
            best_value = v
            best_index = i
         }そうでなければ{
            もしvがbest_valueより小さいならば{
               best_value = v
               best_index = i
            }
         }
      }
      iを増やす
   }

   もしfoundが偽ならば{
      []が答え
   }

   [best_value, best_index]が答え
}