標準ライブラリを使う

get_max_triples = 入力 n に対し {
    # 配列aを作成: a[i] = i*i - i + 1
    a = []
    i = 1から n まで {
        a に (i * i - i + 1) を追加
    }
    
    # 三つ組の個数をカウント
    count = 0
    
    # i < j < k の全ての組み合わせをチェック
    i = 0から n-3 まで {
        j = i+1から n-2 まで {
            k = j+1から n-1 まで {
                # a[i] + a[j] + a[k] が3の倍数か判定
                もし (a[i] + a[j] + a[k]) % 3 == 0 ならば {
                    count = count + 1
                }
            }
        }
    }
    
    count を返す
}