標準ライブラリを使う

prime_fib = 入力 n に対し {
    素数判定 = 入力 num に対し {
        num < 2 の場合 { 偽を返す }
        num == 2 の場合 { 真を返す }
        num % 2 == 0 の場合 { 偽を返す }
        
        i = 3
        ループ i * i <= num の間 {
            num % i == 0 の場合 { 偽を返す }
            i = i + 2
        }
        真を返す
    }
    
    count = 0
    a = 0
    b = 1
    
    ループ 真 の間 {
        c = a + b
        素数判定(c) の場合 {
            count = count + 1
            count == n の場合 { c を返す }
        }
        a = b
        b = c
    }
}