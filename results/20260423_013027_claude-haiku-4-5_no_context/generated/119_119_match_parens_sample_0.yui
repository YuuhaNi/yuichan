標準ライブラリを使う

match_parens = 入力 lst に対し {
    s1 = lst[0]
    s2 = lst[1]
    
    # 2つの順序を試す
    結果1 = is_good(s1 + s2)
    結果2 = is_good(s2 + s1)
    
    # どちらかが良い文字列なら 'Yes'
    もし (結果1 または 結果2) ならば {
        'Yes' を返す
    } そうでなければ {
        'No' を返す
    }
}

# 文字列が「良い」かどうかを判定する補助関数
is_good = 入力 s に対し {
    balance = 0
    
    s の各文字 c に対し {
        もし (c == '(') ならば {
            balance = balance + 1
        } そうでなければ {
            balance = balance - 1
        }
        
        # balance が負になったら、閉じ括弧が多すぎる
        もし (balance < 0) ならば {
            偽 を返す
        }
    }
    
    # 最後に balance が 0 なら良い文字列
    balance == 0 を返す
}