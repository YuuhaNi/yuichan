標準ライブラリを使う

anti_shuffle = 入力 s に対し {

anti_shuffle = 入力 s に対し {
  s を空白で分割した各単語に対し、
  その単語の文字をASCII値でソートして結合し、
  空白で再度結合する
}
anti_shuffle = 入力 s に対し {
  単語リスト = s を " " で分割
  
  処理済み単語リスト = 単語リスト の各要素 word に対し {
    文字リスト = word を文字配列に変換
    ソート済み文字 = 文字リスト をASCII値で昇順ソート
    ソート済み単語 = ソート済み文字を文字列に結合
    戻す ソート済み単語
  }
  
  戻す 処理済み単語リスト を " " で結合
}