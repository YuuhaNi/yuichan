標準ライブラリを使う

pluck = 入力 arr に対し {
  もし arr が空 ならば {
    返す []
  }
  
  最小偶数値 = なし
  最小インデックス = -1
  
  arr の各要素について インデックス i で値 v に対し {
    もし v が偶数 ならば {
      もし 最小偶数値 が なし または v < 最小偶数値 ならば {
        最小偶数値 = v
        最小インデックス = i
      }
    }
  }
  
  もし 最小偶数値 が なし ならば {
    返す []
  }
  
  返す [最小偶数値, 最小インデックス]
}