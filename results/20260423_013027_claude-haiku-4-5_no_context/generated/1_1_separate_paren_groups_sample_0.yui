標準ライブラリを使う

separate_paren_groups = 入力 paren_string に対し {
    空白を削除 = paren_string を " " で置換("") に対し
    結果リスト = []
    現在の括弧 = ""
    括弧カウント = 0
    
    空白を削除 の各文字 char に対し {
        char が "(" の場合 {
            現在の括弧 = 現在の括弧 + char
            括弧カウント = 括弧カウント + 1
        }
        char が ")" の場合 {
            現在の括弧 = 現在の括弧 + char
            括弧カウント = 括弧カウント - 1
            
            括弧カウント が 0 の場合 {
                結果リスト を 現在の括弧 で追加
                現在の括弧 = ""
            }
        }
    }
    
    結果リスト を返す
}