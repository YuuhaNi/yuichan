標準ライブラリを使う

odd_count = 入力 lst に対し {

odd_count = 入力 lst に対し {
  結果 = []
  
  lst の各要素 s に対し {
    奇数カウント = 0
    s の各文字 c に対し {
      数値 = c を数値に変換
      数値 % 2 == 1 ならば {
        奇数カウント = 奇数カウント + 1
      }
    }
    
    テンプレート = "the number of odd elements in the string i of the input."
    結果文字列 = テンプレート を 'i' で 奇数カウント に置換
    
    結果 に 結果文字列 を追加
  }
  
  結果 を返す
}