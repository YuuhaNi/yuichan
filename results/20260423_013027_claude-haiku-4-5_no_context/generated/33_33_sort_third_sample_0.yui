標準ライブラリを使う

sort_third = 入力 l に対し {
    インデックス3の倍数の要素を抽出 = l を列挙して (インデックス, 値) の時 インデックス % 3 == 0 なら 値
    ソート済み要素 = インデックス3の倍数の要素を抽出 をソート
    
    結果 = []
    ソート済みインデックス = 0
    
    l を列挙して (インデックス, 値) の時 {
        もし インデックス % 3 == 0 なら {
            結果 に ソート済み要素[ソート済みインデックス] を追加
            ソート済みインデックス = ソート済みインデックス + 1
        } そうでなければ {
            結果 に 値 を追加
        }
    }
    
    結果 を返す
}