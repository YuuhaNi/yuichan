標準ライブラリを使う

fizz_buzz = 入力 n に対し {

fizz_buzz = 入力 n に対し {
  合計 = 0
  i = 1
  繰り返す (i < n) {
    もし (i % 11 == 0 || i % 13 == 0) {
      文字列 = i を文字列に変換
      j = 0
      繰り返す (j < 文字列の長さ) {
        もし (文字列[j] == '7') {
          合計 = 合計 + 1
        }
        j = j + 1
      }
    }
    i = i + 1
  }
  合計を返す
}