標準ライブラリを使う

encrypt = 入力 s に対し {
  結果 = ""
  s の各文字 c に対し {
    もし c が小文字アルファベットなら {
      位置 = c の文字コード - 'a' の文字コード
      新位置 = (位置 * 2 + 2) % 26
      結果 = 結果 + (新位置 + 'a' の文字コード を文字に変換)
    } そうでなく c が大文字アルファベットなら {
      位置 = c の文字コード - 'A' の文字コード
      新位置 = (位置 * 2 + 2) % 26
      結果 = 結果 + (新位置 + 'A' の文字コード を文字に変換)
    } そうでなければ {
      結果 = 結果 + c
    }
  }
  結果 を返す
}