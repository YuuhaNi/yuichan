標準ライブラリを使う

encode = 入力 message に対し {

encode = 入力 message に対し {
  母音マップ = {'a': 'Y', 'e': 'C', 'i': 'G', 'o': 'K', 'u': 'Q',
                'A': 'y', 'E': 'c', 'I': 'g', 'O': 'k', 'U': 'q'}
  
  結果 = ""
  
  message の各文字 char に対し {
    もし char が母音マップ に含まれるなら {
      結果 = 結果 + 母音マップ[char]
    } そうでなければ {
      もし char が英字なら {
        結果 = 結果 + char の大文字小文字を反転
      } そうでなければ {
        結果 = 結果 + char
      }
    }
  }
  
  戻す 結果
}