標準ライブラリを使う

is_nested = 入力 string に対し {

is_nested = 入力 string に対し {
    深さ = 0
    最大深さ = 0
    
    string の各文字 char に対し {
        char が '[' の場合 {
            深さ = 深さ + 1
            最大深さ = max(最大深さ, 深さ)
        }
        char が ']' の場合 {
            深さ = 深さ - 1
        }
        深さ < 0 の場合 {
            False を返す
        }
    }
    
    深さ != 0 の場合 {
        False を返す
    }
    
    最大深さ >= 2 を返す
}