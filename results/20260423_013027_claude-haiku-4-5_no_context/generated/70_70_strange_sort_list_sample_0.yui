標準ライブラリを使う

strange_sort_list = 入力 lst に対し {

strange_sort_list = 入力 lst に対し {
  もし lst が空 ならば {
    []を返す
  }
  
  ソート済み = lst を昇順でソート
  結果 = []
  左 = 0
  右 = ソート済み の長さ - 1
  左から右へ = 真
  
  繰り返す (左 <= 右) {
    もし 左から右へ ならば {
      結果 に ソート済み[左] を追加
      左 = 左 + 1
      左から右へ = 偽
    } そうでなければ {
      結果 に ソート済み[右] を追加
      右 = 右 - 1
      左から右へ = 真
    }
  }
  
  結果を返す
}