標準ライブラリを使う

filter_by_prefix = 入力 strings, prefix に対し {

filter_by_prefix = 入力 strings, prefix に対し {
  strings.filter(文字列 => 文字列.startsWith(prefix))
}
filter_by_prefix = 入力 strings, prefix に対し {
  結果 = []
  strings.each(文字列 => {
    もし 文字列.startsWith(prefix) ならば {
      結果.push(文字列)
    }
  })
  結果を返す
}