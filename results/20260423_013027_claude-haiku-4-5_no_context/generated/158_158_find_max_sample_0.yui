標準ライブラリを使う

find_max = 入力 words に対し {

find_max = 入力 words に対し {
  最大単語 = ""
  最大文字数 = 0
  
  words の各要素 word に対し {
    固有文字 = word を文字に分割して重複を除去
    固有文字数 = 固有文字の長さ
    
    もし (固有文字数 > 最大文字数) または 
       (固有文字数 == 最大文字数 かつ word < 最大単語) ならば {
      最大単語 = word
      最大文字数 = 固有文字数
    }
  }
  
  最大単語を返す
}