標準ライブラリを使う

minPath = 入力 grid, k に対し {
    N = grid の長さ
    
    # グリッド内の値から座標へのマッピングを作成
    位置マップ = {}
    i = 0 から N - 1 まで {
        j = 0 から N - 1 まで {
            位置マップ[grid[i][j]] = [i, j]
        }
    }
    
    # BFS で最短経路を探索
    最小経路 = なし
    
    # キュー: [現在行, 現在列, 訪問済みセル値のリスト]
    キュー = []
    
    # すべてのセルからスタート可能
    i = 0 から N - 1 まで {
        j = 0 から N - 1 まで {
            キュー に追加 [i, j, [grid[i][j]]]
        }
    }
    
    キュー が空でない 間 {
        現在 = キュー から取り出す
        行 = 現在[0]
        列 = 現在[1]
        経路 = 現在[2]
        
        # 長さ k に達した場合
        経路 の長さ == k の場合 {
            最小経路 が なし または 経路 < 最小経路 の場合 {
                最小経路 = 経路
            }
            続行
        }
        
        # 隣接セルを探索（上下左右）
        方向 = [[-1, 0], [1, 0], [0, -1], [0, 1]]
        方向 の各要素 d に対し {
            新行 = 行 + d[0]
            新列 = 列 + d[1]
            
            # グリッド内かチェック
            新行 >= 0 かつ 新行 < N かつ 新列 >= 0 かつ 新列 < N の場合 {
                新経路 = 経路 + [grid[新行][新列]]
                キュー に追加 [新行, 新列, 新経路]
            }
        }
    }
    
    最小経路 を返す
}