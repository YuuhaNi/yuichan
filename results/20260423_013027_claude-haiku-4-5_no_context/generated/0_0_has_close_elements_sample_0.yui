標準ライブラリを使う

has_close_elements = 入力 numbers, threshold に対し {

has_close_elements = 入力 numbers, threshold に対し {
  i = 0
  numbers の長さを len とする
  
  i < len - 1 の間 {
    j = i + 1
    j < len の間 {
      差 = numbers[i] - numbers[j]
      差 < 0 ならば {
        差 = 0 - 差
      }
      
      差 < threshold ならば {
        真を返す
      }
      
      j = j + 1
    }
    i = i + 1
  }
  
  偽を返す
}