標準ライブラリを使う

intersection = 入力 interval1, interval2 に対し {
    # 区間の交差部分を計算
    交差_start = 最大値(interval1[0], interval2[0])
    交差_end = 最小値(interval1[1], interval2[1])
    
    # 交差部分が存在するか確認
    もし 交差_start > 交差_end ならば {
        戻す "NO"
    }
    
    # 交差部分の長さを計算
    長さ = 交差_end - 交差_start + 1
    
    # 素数判定関数
    素数判定 = 入力 n に対し {
        もし n < 2 ならば {
            戻す 偽
        }
        もし n == 2 ならば {
            戻す 真
        }
        もし n % 2 == 0 ならば {
            戻す 偽
        }
        i = 3
        繰り返す i * i <= n の間 {
            もし n % i == 0 ならば {
                戻す 偽
            }
            i = i + 2
        }
        戻す 真
    }
    
    # 長さが素数かどうかを判定
    もし 素数判定(長さ) ならば {
        戻す "YES"
    } そうでなければ {
        戻す "NO"
    }
}