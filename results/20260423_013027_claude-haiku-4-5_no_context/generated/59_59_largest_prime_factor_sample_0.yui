標準ライブラリを使う

largest_prime_factor = 入力 n に対し {

largest_prime_factor = 入力 n に対し {
    最大素因数 = 2
    
    割り切れる間 (n % 2 == 0) {
        最大素因数 = 2
        n = n / 2
    }
    
    因数 = 3
    割り切れる間 (因数 * 因数 <= n) {
        割り切れる間 (n % 因数 == 0) {
            最大素因数 = 因数
            n = n / 因数
        }
        因数 = 因数 + 2
    }
    
    もし (n > 2) {
        最大素因数 = n
    }
    
    最大素因数
}