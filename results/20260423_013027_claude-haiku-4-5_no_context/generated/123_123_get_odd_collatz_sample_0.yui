標準ライブラリを使う

get_odd_collatz = 入力 n に対し {
    奇数リスト = []
    
    現在値 = n
    繰り返す (現在値 != 1) {
        もし (現在値 % 2 == 1) {
            奇数リスト に 現在値 を追加
        }
        
        もし (現在値 % 2 == 0) {
            現在値 = 現在値 / 2
        } そうでなければ {
            現在値 = 現在値 * 3 + 1
        }
    }
    
    奇数リスト に 1 を追加
    
    奇数リスト をソート
    
    戻す 奇数リスト
}