標準ライブラリを使う

get_row = 入力 lst, x に対し {

get_row = 入力 lst, x に対し {
  結果 = []
  
  lst を行インデックス, 行 で反復 {
    行 を列インデックス, 要素 で反復 {
      要素 == x の場合 {
        結果.追加((行インデックス, 列インデックス))
      }
    }
  }
  
  結果.ソート((a, b) に対し {
    a[0] != b[0] の場合 {
      a[0] - b[0] を返す
    }
    b[1] - a[1] を返す
  })
  
  結果 を返す
}