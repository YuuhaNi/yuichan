標準ライブラリを使う

sort_even = 入力 l に対し {

sort_even = 入力 l に対し {
  偶数インデックス = l から インデックス i で i % 2 == 0 の要素を抽出
  ソート済み偶数 = 偶数インデックス をソート
  
  結果 = []
  ソート済みカウンタ = 0
  
  l の各要素 e とインデックス i に対し {
    i % 2 == 0 のとき {
      結果 に ソート済み偶数[ソート済みカウンタ] を追加
      ソート済みカウンタ = ソート済みカウンタ + 1
    } そうでなければ {
      結果 に e を追加
    }
  }
  
  結果 を返す
}