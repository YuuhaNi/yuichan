標準ライブラリを使う

get_closest_vowel = 入力 word に対し {
  母音 = "aeiouAEIOU"
  長さ = word の長さ
  
  もし 長さ < 3 ならば {
    "" を返す
  }
  
  i = 長さ - 2 から 1 まで -1 ずつ {
    現在文字 = word[i]
    左文字 = word[i - 1]
    右文字 = word[i + 1]
    
    もし (現在文字 が 母音 に含まれる) かつ
       (左文字 が 母音 に含まれない) かつ
       (右文字 が 母音 に含まれない) ならば {
      現在文字 を返す
    }
  }
  
  "" を返す
}