標準ライブラリを使う

solve = 入力 N に対し {
    # 各桁の総和を計算
    桁の総和 = 0
    N文字列 = N を文字列に変換
    
    N文字列 の各文字 c に対し {
        桁の総和 = 桁の総和 + (c を整数に変換)
    }
    
    # 桁の総和を2進数に変換
    もし 桁の総和 = 0 ならば {
        返す "0"
    }
    
    2進数文字列 = ""
    一時値 = 桁の総和
    
    一時値 > 0 の間 {
        余り = 一時値 % 2
        2進数文字列 = (余り を文字列に変換) + 2進数文字列
        一時値 = 一時値 / 2
    }
    
    返す 2進数文字列
}