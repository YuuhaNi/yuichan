標準ライブラリを使う

compare_one = 入力 a, b に対し {
    # 値を数値に変換する関数
    値を数値化 = 入力 x に対し {
        もし x が数値なら {
            x を返す
        } そうでなければ {
            # 文字列の場合、カンマをピリオドに統一して数値化
            正規化 = x を文字列化して "," を "." に置換
            正規化 を浮動小数点数化して返す
        }
    }
    
    # 元の型を保持するための型判定
    a_型 = a の型
    b_型 = b の型
    
    # 数値に変換
    a_値 = 値を数値化(a)
    b_値 = 値を数値化(b)
    
    # 値が同じ場合はNoneを返す
    もし a_値 == b_値 なら {
        None を返す
    }
    
    # より大きい値を元の型で返す
    もし a_値 > b_値 なら {
        a を返す
    } そうでなければ {
        b を返す
    }
}