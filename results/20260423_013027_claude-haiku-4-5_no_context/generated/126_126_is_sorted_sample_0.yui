標準ライブラリを使う

is_sorted = 入力 lst に対し {

is_sorted = 入力 lst に対し {
  もし lst の長さ <= 1 なら {
    真を返す
  }
  
  i = 0
  i < lst の長さ - 1 の間 {
    現在 = lst[i]
    次 = lst[i + 1]
    
    もし 現在 > 次 なら {
      偽を返す
    }
    
    もし 現在 == 次 かつ i + 2 < lst の長さ かつ 次 == lst[i + 2] なら {
      偽を返す
    }
    
    i = i + 1
  }
  
  真を返す
}