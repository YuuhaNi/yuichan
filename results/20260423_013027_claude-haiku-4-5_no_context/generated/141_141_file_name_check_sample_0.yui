標準ライブラリを使う

file_name_check = 入力 file_name に対し {
  # ドットの個数をチェック
  ドット数 = 0
  i = 0
  繰り返す (i < file_name の長さ) {
    もし (file_name[i] == '.') {
      ドット数 = ドット数 + 1
    }
    i = i + 1
  }
  
  # ドットがちょうど1つでなければ 'No'
  もし (ドット数 != 1) {
    戻す 'No'
  }
  
  # ドットの位置を探す
  ドット位置 = 0
  i = 0
  繰り返す (i < file_name の長さ) {
    もし (file_name[i] == '.') {
      ドット位置 = i
      抜ける
    }
    i = i + 1
  }
  
  # ドットの前の部分を取得
  前部分 = file_name の 0 から ドット位置 までの部分文字列
  
  # ドットの後の部分を取得
  後部分 = file_name の (ドット位置 + 1) から (file_name の長さ) までの部分文字列
  
  # 前部分が空でないかチェック
  もし (前部分 の長さ == 0) {
    戻す 'No'
  }
  
  # 前部分が英文字で始まるかチェック
  最初の文字 = 前部分[0]
  もし (!((最初の文字 >= 'a' && 最初の文字 <= 'z') || (最初の文字 >= 'A' && 最初の文字 <= 'Z'))) {
    戻す 'No'
  }
  
  # 前部分に3桁以上の連続した数字がないかチェック
  連続数字 = 0
  i = 0
  繰り返す (i < 前部分 の長さ) {
    もし (前部分[i] >= '0' && 前部分[i] <= '9') {
      連続数字 = 連続数字 + 1
      もし (連続数字 >= 3) {
        戻す 'No'
      }
    } そうでなければ {
      連続数字 = 0
    }
    i = i + 1
  }
  
  # 後部分が有効な拡張子かチェック
  もし (後部分 == 'txt' || 後部分 == 'exe' || 後部分 == 'dll') {
    戻す 'Yes'
  } そうでなければ {
    戻す 'No'
  }
}