標準ライブラリを使う

find_closest_elements = 入力 numbers に対し {
    ソート済み = numbers を昇順でソート
    
    最小差分 = 無限大
    最小ペア = (ソート済み[0], ソート済み[1])
    
    i を 0 から (ソート済みの長さ - 2) まで繰り返す {
        差分 = ソート済み[i + 1] - ソート済み[i]
        
        もし (差分 < 最小差分) ならば {
            最小差分 = 差分
            最小ペア = (ソート済み[i], ソート済み[i + 1])
        }
    }
    
    最小ペアを返す
}