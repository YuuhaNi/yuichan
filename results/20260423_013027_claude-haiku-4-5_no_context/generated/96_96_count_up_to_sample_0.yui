標準ライブラリを使う

count_up_to = 入力 n に対し {

count_up_to = 入力 n に対し {
  もし n <= 2 ならば {
    []を返す
  }
  
  素数リスト = []
  
  i = 2 から n - 1 まで繰り返す {
    is_prime = 真
    
    j = 2 から i の平方根 まで繰り返す {
      もし i % j == 0 ならば {
        is_prime = 偽
        抜ける
      }
    }
    
    もし is_prime ならば {
      素数リスト = 素数リスト + [i]
    }
  }
  
  素数リストを返す
}