標準ライブラリを使う

move_one_ball = 入力 arr に対し {
  もし arr が空 ならば {
    真を返す
  }
  
  変数 n = arr の長さ
  変数 回数 = 0
  
  繰り返す (回数 < n) {
    変数 ソート済み = 真
    変数 i = 0
    
    繰り返す (i < n - 1) {
      もし arr[i] > arr[i + 1] ならば {
        ソート済み = 偽
        抜ける
      }
      i = i + 1
    }
    
    もし ソート済み ならば {
      真を返す
    }
    
    # 右シフト操作を実行
    変数 最後の要素 = arr[n - 1]
    変数 j = n - 1
    
    繰り返す (j > 0) {
      arr[j] = arr[j - 1]
      j = j - 1
    }
    
    arr[0] = 最後の要素
    回数 = 回数 + 1
  }
  
  偽を返す
}