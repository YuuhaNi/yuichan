標準ライブラリを使う

flip_case = 入力 string に対し {

flip_case = 入力 string に対し {
  string を文字ごとに処理して {
    もし 文字が英小文字なら {
      文字を英大文字に変換
    } そうでなく 文字が英大文字なら {
      文字を英小文字に変換
    } そうでなければ {
      文字をそのまま返す
    }
  } を結合して返す
}
flip_case = 入力 string に対し {
  string の各文字を {
    文字が英小文字 ? 文字.大文字化 : (文字が英大文字 ? 文字.小文字化 : 文字)
  } で変換して結合
}