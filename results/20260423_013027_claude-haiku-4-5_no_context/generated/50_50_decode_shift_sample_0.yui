標準ライブラリを使う

decode_shift = 入力 s に対し {
  結果 = ""
  s の各文字 c に対し {
    もし c が大文字アルファベットなら {
      コード = c の文字コード
      シフト後 = ((コード - 'A' の文字コード + 5) % 26) + 'A' の文字コード
      結果 = 結果 + シフト後 を文字に変換
    } そうでなく c が小文字アルファベットなら {
      コード = c の文字コード
      シフト後 = ((コード - 'a' の文字コード + 5) % 26) + 'a' の文字コード
      結果 = 結果 + シフト後 を文字に変換
    } そうでなければ {
      結果 = 結果 + c
    }
  }
  結果 を返す
}