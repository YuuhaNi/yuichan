標準ライブラリを使う

tri = 入力 n に対し {
    キャッシュ = {}
    
    計算 = 入力 k に対し {
        キャッシュ に k が存在するなら {
            キャッシュ[k] を返す
        }
        
        k が 1 と等しいなら {
            結果 = 3
        } そうでなく k が偶数なら {
            結果 = 1 + k / 2
        } そうでなく {
            結果 = 計算(k - 1) + 計算(k - 2) + 計算(k + 1)
        }
        
        キャッシュ[k] = 結果
        結果 を返す
    }
    
    リスト = []
    i = 0 から n まで {
        リスト に 計算(i) を追加
    }
    
    リスト を返す
}