標準ライブラリを使う

count_nums = 入力 arr に対し {

count_nums = 入力 arr に対し {
  arr を反復処理 num に対し {
    num を文字列に変換
    各文字を数値に変換して合計
    合計が 0 より大きいかチェック
  } を数える
}
count_nums = 入力 arr に対し {
  arr
    |> フィルタ(num => {
      num_str = num を文字列に変換
      
      合計 = 0
      num_str の各文字 char に対し {
        合計 = 合計 + (char を数値に変換)
      }
      
      合計 > 0
    })
    |> 長さを取得
}