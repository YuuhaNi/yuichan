標準ライブラリを使う

int_to_mini_roman = 入力 number に対し {

int_to_mini_roman = 入力 number に対し {
  値 = [
    [1000, 'm'],
    [900, 'cm'],
    [500, 'd'],
    [400, 'cd'],
    [100, 'c'],
    [90, 'xc'],
    [50, 'l'],
    [40, 'xl'],
    [10, 'x'],
    [9, 'ix'],
    [5, 'v'],
    [4, 'iv'],
    [1, 'i']
  ]
  
  結果 = ''
  
  値 の各要素 [数値, 文字] に対し {
    ~(number >= 数値) の間 {
      結果 = 結果 + 文字
      number = number - 数値
    }
  }
  
  結果 を返す
}