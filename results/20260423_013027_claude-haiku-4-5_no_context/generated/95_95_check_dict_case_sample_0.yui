標準ライブラリを使う

check_dict_case = 入力 dict に対し {

check_dict_case = 入力 dict に対し {
    もし dict が空 ならば {
        False を返す
    }
    
    全て_小文字 = True
    全て_大文字 = True
    
    dict の各キー key に対し {
        もし key が文字列でない ならば {
            False を返す
        }
        
        もし key が全て小文字でない ならば {
            全て_小文字 = False
        }
        
        もし key が全て大文字でない ならば {
            全て_大文字 = False
        }
    }
    
    もし 全て_小文字 ならば {
        True を返す
    } そうでなく もし 全て_大文字 ならば {
        True を返す
    } そうでなく {
        False を返す
    }
}