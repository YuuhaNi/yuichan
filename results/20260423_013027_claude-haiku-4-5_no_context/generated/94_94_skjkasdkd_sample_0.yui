標準ライブラリを使う

skjkasdkd = 入力 lst に対し {
    素数判定 = 関数 n に対し {
        もし n < 2 ならば 偽を返す
        もし n == 2 ならば 真を返す
        もし n % 2 == 0 ならば 偽を返す
        
        i = 3
        ループ i * i <= n の間 {
            もし n % i == 0 ならば 偽を返す
            i = i + 2
        }
        真を返す
    }
    
    桁数の和 = 関数 n に対し {
        合計 = 0
        ループ n > 0 の間 {
            合計 = 合計 + (n % 10)
            n = n / 10
        }
        合計を返す
    }
    
    最大素数 = 0
    ループ lst の各要素 x に対し {
        もし 素数判定(x) かつ x > 最大素数 ならば {
            最大素数 = x
        }
    }
    
    桁数の和(最大素数)を返す
}