標準ライブラリを使う

solve = 入力 s に対し {
    アルファベット含む = 偽
    結果 = ""
    
    s の各文字 c に対し {
        もし c が大文字なら {
            結果 = 結果 + c の小文字
            アルファベット含む = 真
        } そうでなく c が小文字なら {
            結果 = 結果 + c の大文字
            アルファベット含む = 真
        } そうでなく {
            結果 = 結果 + c
        }
    }
    
    もし アルファベット含む が 偽なら {
        結果 = 結果 を逆順にする
    }
    
    結果 を返す
}