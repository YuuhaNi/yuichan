標準ライブラリを使う

sort_array = 入力 array に対し {
   もし array の大きさ が 0 ならば {
      [] が答え
   }
   そうでなければ {
      最初 = array[0]
      最後 = array[差(array の大きさ, 1)]
      合計 = 和(最初, 最後)
      
      # コピーを作成
      コピー = []
      array の大きさ 回くり返す {
         i = 差(array の大きさ, 1)
         0 回くり返す {
            i を減らす
         }
      }
      
      # より簡潔なコピー方法
      i = 0
      array の大きさ 回くり返す {
         コピーに array[i] を追加する
         i を増やす
      }
      
      # 合計が奇数なら昇順、偶数なら降順
      もし 剰余(合計, 2) が 1 ならば {
         # 昇順ソート（バブルソート）
         j = 0
         コピー の大きさ 回くり返す {
            k = 0
            差(コピー の大きさ, 1) 回くり返す {
               もし コピー[k] が コピー[和(k, 1)] より大きい ならば {
                  temp = コピー[k]
                  コピー[k] = コピー[和(k, 1)]
                  コピー[和(k, 1)] = temp
               }
               k を増やす
            }
            j を増やす
         }
      }
      そうでなければ {
         # 降順ソート（バブルソート）
         j = 0
         コピー の大きさ 回くり返す {
            k = 0
            差(コピー の大きさ, 1) 回くり返す {
               もし コピー[k] が コピー[和(k, 1)] より小さい ならば {
                  temp = コピー[k]
                  コピー[k] = コピー[和(k, 1)]
                  コピー[和(k, 1)] = temp
               }
               k を増やす
            }
            j を増やす
         }
      }
      
      コピー が答え
   }
}