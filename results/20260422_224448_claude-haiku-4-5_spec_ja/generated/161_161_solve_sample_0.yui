標準ライブラリを使う

solve = 入力 s に対し {
   アルファベット含む = 偽
   結果 = ""
   
   s の大きさ 回くり返す {
      i = 0
      もし i が s の大きさ より小さい ならば {
         文字コード = s[i]
         
         # 大文字 A-Z: 65-90
         もし文字コードが65以上ならば {
            もし文字コードが90以下ならば {
               アルファベット含む = 真
               # 大文字を小文字に
               結果に和(文字コード, 32)を追加する
               i を増やす
            }
         }
         
         # 小文字 a-z: 97-122
         もし文字コードが97以上ならば {
            もし文字コードが122以下ならば {
               アルファベット含む = 真
               # 小文字を大文字に
               結果に差(文字コード, 32)を追加する
               i を増やす
            }
         }
         
         # アルファベット以外
         もしアルファベット含むが偽ならば {
            結果に文字コードを追加する
            i を増やす
         }
      }
   }
   
   # アルファベットが含まれていない場合は逆順にする
   もしアルファベット含むが偽ならば {
      逆順結果 = ""
      s の大きさ 回くり返す {
         逆順結果に s[差(s の大きさ, 1)]を追加する
      }
      逆順結果 が答え
   }
   
   結果 が答え
}
標準ライブラリを使う

solve = 入力 s に対し {
   アルファベット含む = 偽
   結果 = ""
   i = 0
   
   s の大きさ 回くり返す {
      文字コード = s[i]
      
      # 大文字 A-Z: 65-90
      もし文字コードが65以上ならば {
         もし文字コードが90以下ならば {
            アルファベット含む = 真
            # 大文字を小文字に
            結果に和(文字コード, 32)を追加する
            i を増やす
         }
      }
      
      # 小文字 a-z: 97-122
      もし文字コードが97以上ならば {
         もし文字コードが122以下ならば {
            アルファベット含む = 真
            # 小文字を大文字に
            結果に差(文字コード, 32)を追加する
            i を増やす
         }
      }
      
      # アルファベット以外
      もしアルファベット含むが偽ならば {
         結果に文字コードを追加する
      }
      
      i を増やす
   }
   
   # アルファベットが含まれていない場合は逆順にする
   もしアルファベット含むが偽ならば {
      逆順結果 = ""
      j = 差(s の大きさ, 1)
      s の大きさ 回くり返す {
         逆順結果に s[j]を追加する
         j を減らす
      }
      逆順結果 が答え
   }
   
   結果 が答え
}