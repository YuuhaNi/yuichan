標準ライブラリを使う

hex_key = 入力 num に対し {
   素数リスト = ["2", "3", "5", "7", "B", "D"]
   カウント = 0
   
   numの大きさ回くり返す {
      i = 0
      素数リストの大きさ回くり返す {
         もしnum[i]が素数リスト[i]ならば {
            カウントを増やす
            くり返しを抜ける
         }
         iを増やす
      }
   }
   
   カウント が答え
}
標準ライブラリを使う

hex_key = 入力 num に対し {
   素数リスト = ["2", "3", "5", "7", "B", "D"]
   カウント = 0
   
   numの大きさ回くり返す {
      i = 0
      もし num[i] が素数リスト のいずれか ならば {
         カウントを増やす
      }
   }
   
   カウント が答え
}
標準ライブラリを使う

hex_key = 入力 num に対し {
   素数文字 = ["2", "3", "5", "7", "B", "D"]
   カウント = 0
   インデックス = 0
   
   numの大きさ回くり返す {
      現在の文字 = num[インデックス]
      j = 0
      素数文字の大きさ回くり返す {
         もし現在の文字 が 素数文字[j] ならば {
            カウントを増やす
            くり返しを抜ける
         }
         jを増やす
      }
      インデックスを増やす
   }
   
   カウント が答え
}