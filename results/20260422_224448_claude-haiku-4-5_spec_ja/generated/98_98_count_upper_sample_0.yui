標準ライブラリを使う

count_upper = 入力 s に対し {
   count = 0
   i = 0
   sの大きさ回くり返す {
      もしi が 2 で割った剰余が 0 ならば {
         char_code = s[i]
         もし char_code が 65 以上 ならば {
            もし char_code が 90 以下 ならば {
               もし char_code が 65 以外 ならば {
                  もし char_code が 69 以外 ならば {
                     もし char_code が 73 以外 ならば {
                        もし char_code が 79 以外 ならば {
                           もし char_code が 85 以外 ならば {
                              何もしない
                           }
                           そうでなければ {
                              countを増やす
                           }
                        }
                        そうでなければ {
                           countを増やす
                        }
                     }
                     そうでなければ {
                        countを増やす
                     }
                  }
                  そうでなければ {
                     countを増やす
                  }
               }
               そうでなければ {
                  countを増やす
               }
            }
         }
      }
      iを増やす
   }
   count が答え
}