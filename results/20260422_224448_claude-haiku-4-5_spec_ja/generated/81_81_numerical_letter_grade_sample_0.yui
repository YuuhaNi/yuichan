標準ライブラリを使う

numerical_letter_grade = 入力 grades に対し {
   result = []
   length = gradesの大きさ
   i = 0
   length回くり返す {
      gpa = grades[i]
      もしgpaが4.0ならば {
         resultに"A+"を追加する
      }
      そうでなければ {
         もしgpaが3.7より大きいならば {
            resultに"A"を追加する
         }
         そうでなければ {
            もしgpaが3.3より大きいならば {
               resultに"A-"を追加する
            }
            そうでなければ {
               もしgpaが3.0より大きいならば {
                  resultに"B+"を追加する
               }
               そうでなければ {
                  もしgpaが2.7より大きいならば {
                     resultに"B"を追加する
                  }
                  そうでなければ {
                     もしgpaが2.3より大きいならば {
                        resultに"B-"を追加する
                     }
                     そうでなければ {
                        もしgpaが2.0より大きいならば {
                           resultに"C+"を追加する
                        }
                        そうでなければ {
                           もしgpaが1.7より大きいならば {
                              resultに"C"を追加する
                           }
                           そうでなければ {
                              もしgpaが1.3より大きいならば {
                                 resultに"C-"を追加する
                              }
                              そうでなければ {
                                 もしgpaが1.0より大きいならば {
                                    resultに"D+"を追加する
                                 }
                                 そうでなければ {
                                    もしgpaが0.7より大きいならば {
                                       resultに"D"を追加する
                                    }
                                    そうでなければ {
                                       もしgpaが0.0より大きいならば {
                                          resultに"D-"を追加する
                                       }
                                       そうでなければ {
                                          resultに"E"を追加する
                                       }
                                    }
                                 }
                              }
                           }
                        }
                     }
                  }
               }
            }
         }
      }
      iを増やす
   }
   result が答え
}