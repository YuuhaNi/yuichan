標準ライブラリを使う

iscube = 入力 a に対し {
   もしaが0ならば {
      真 が答え
   }
   
   もしaが0より大きいならば {
      x = 整数化(平方根(平方根(a)))
      もし積(x, x, x)がaならば {
         真 が答え
      }
      そうでなければ {
         偽 が答え
      }
   }
   
   そうでなければ {
      x = 整数化(平方根(平方根(絶対値(a))))
      もし積(x, x, x)が絶対値(a)ならば {
         真 が答え
      }
      そうでなければ {
         偽 が答え
      }
   }
}