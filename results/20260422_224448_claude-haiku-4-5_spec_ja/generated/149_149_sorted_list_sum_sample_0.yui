標準ライブラリを使う

sorted_list_sum = 入力 lst に対し {
   filtered = []
   
   # 奇数の長さを持つ文字列を削除
   i = 0
   lst の大きさ 回くり返す {
      word = lst[i]
      length = word の大きさ
      remainder = 剰余(length, 2)
      
      もし remainder が 0 ならば {
         filtered に word を追加する
      }
      
      i を増やす
   }
   
   # バブルソート：長さで昇順、同じ長さならアルファベット順
   n = filtered の大きさ
   
   i = 0
   n 回くり返す {
      j = 0
      差(n, 1) 回くり返す {
         word1 = filtered[j]
         word2 = filtered[差(j, 1)]
         len1 = word1 の大きさ
         len2 = word2 の大きさ
         
         # 長さで比較
         もし len1 が len2 より大きい ならば {
            filtered[j] = word2
            filtered[差(j, 1)] = word1
         }
         そうでなければ {
            # 長さが同じ場合、アルファベット順で比較
            もし len1 が len2 ならば {
               もし word1 が word2 より大きい ならば {
                  filtered[j] = word2
                  filtered[差(j, 1)] = word1
               }
            }
         }
         
         j を増やす
      }
      
      i を増やす
   }
   
   filtered が答え
}