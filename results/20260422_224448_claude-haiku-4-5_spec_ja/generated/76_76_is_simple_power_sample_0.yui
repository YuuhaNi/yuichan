標準ライブラリを使う

is_simple_power = 入力 x, n に対し {
   もしxが1ならば {
      真 が答え
   }
   
   もしnが1以下ならば {
      偽 が答え
   }
   
   current = 1
   
   100回くり返す {
      current = 積(current, n)
      
      もしcurrentがxならば {
         真 が答え
      }
      
      もしcurrentがxより大きいならば {
         くり返しを抜ける
      }
   }
   
   偽 が答え
}