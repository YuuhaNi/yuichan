標準ライブラリを使う

valid_date = 入力 date に対し {
   # 空文字列チェック
   もし date の大きさ が 0 ならば {
      偽 が答え
   }
   
   # フォーマットチェック: mm-dd-yyyy
   # ハイフンの位置を確認
   もし date[2] が 45 以外 ならば {
      偽 が答え
   }
   もし date[5] が 45 以外 ならば {
      偽 が答え
   }
   
   # 長さが10であることを確認
   もし date の大きさ が 10 以外 ならば {
      偽 が答え
   }
   
   # 月を抽出（最初の2文字）
   month_str = ""
   month_str に date[0] を追加する
   month_str に date[1] を追加する
   month = 整数化(month_str)
   
   # 日を抽出（3番目と4番目の文字）
   day_str = ""
   day_str に date[3] を追加する
   day_str に date[4] を追加する
   day = 整数化(day_str)
   
   # 年を抽出（最後の4文字）
   year_str = ""
   year_str に date[6] を追加する
   year_str に date[7] を追加する
   year_str に date[8] を追加する
   year_str に date[9] を追加する
   year = 整数化(year_str)
   
   # 月の範囲チェック
   もし month が 1 より小さい ならば {
      偽 が答え
   }
   もし month が 12 より大きい ならば {
      偽 が答え
   }
   
   # 日の範囲チェック
   もし month が 1 ならば {
      もし day が 1 より小さい ならば {
         偽 が答え
      }
      もし day が 31 より大きい ならば {
         偽 が答え
      }
   }
   そうでなければ {
      もし month が 3 ならば {
         もし day が 1 より小さい ならば {
            偽 が答え
         }
         もし day が 31 より大きい ならば {
            偽 が答え
         }
      }
      そうでなければ {
         もし month が 5 ならば {
            もし day が 1 より小さい ならば {
               偽 が答え
            }
            もし day が 31 より大きい ならば {
               偽 が答え
            }
         }
         そうでなければ {
            もし month が 7 ならば {
               もし day が 1 より小さい ならば {
                  偽 が答え
               }
               もし day が 31 より大きい ならば {
                  偽 が答え
               }
            }
            そうでなければ {
               もし month が 8 ならば {
                  もし day が 1 より小さい ならば {
                     偽 が答え
                  }
                  もし day が 31 より大きい ならば {
                     偽 が答え
                  }
               }
               そうでなければ {
                  もし month が 10 ならば {
                     もし day が 1 より小さい ならば {
                        偽 が答え
                     }
                     もし day が 31 より大きい ならば {
                        偽 が答え
                     }
                  }
                  そうでなければ {
                     もし month が 12 ならば {
                        もし day が 1 より小さい ならば {
                           偽 が答え
                        }
                        もし day が 31 より大きい ならば {
                           偽 が答え
                        }
                     }
                     そうでなければ {
                        もし month が 4 ならば {
                           もし day が 1 より小さい ならば {
                              偽 が答え
                           }
                           もし day が 30 より大きい ならば {
                              偽 が答え
                           }
                        }
                        そうでなければ {
                           もし month が 6 ならば {
                              もし day が 1 より小さい ならば {
                                 偽 が答え
                              }
                              もし day が 30 より大きい ならば {
                                 偽 が答え
                              }
                           }
                           そうでなければ {
                              もし month が 9 ならば {
                                 もし day が 1 より小さい ならば {
                                    偽 が答え
                                 }
                                 もし day が 30 より大きい ならば {
                                    偽 が答え
                                 }
                              }
                              そうでなければ {
                                 もし month が 11 ならば {
                                    もし day が 1 より小さい ならば {
                                       偽 が答え
                                    }
                                    もし day が 30 より大きい ならば {
                                       偽 が答え
                                    }
                                 }
                                 そうでなければ {
                                    もし month が 2 ならば {
                                       もし day が 1 より小さい ならば {
                                          偽 が答え
                                       }
                                       もし day が 29 より大きい ならば {
                                          偽 が答え
                                       }
                                    }
                                 }
                              }
                           }
                        }
                     }
                  }
               }
            }
         }
      }
   }
   
   真 が答え
}