標準ライブラリを使う

素数判定 = 入力 x に対し {
   もしxが2より小さいならば {
      偽 が答え
   }
   もしxが2ならば {
      真 が答え
   }
   もしxが2で割った剰余が0ならば {
      偽 が答え
   }
   i = 3
   もしiの積(iが)がxより大きいならば {
      真 が答え
   }
   i回くり返す {
      もしxがiで割った剰余が0ならば {
         偽 が答え
      }
      iを増やす
   }
   真 が答え
}

prime_fib = 入力 n に対し {
   count = 0
   a = 0
   b = 1
   
   値なし が答え
   
   くり返す {
      c = 和(a, b)
      もしc素数判定(c)が真ならば {
         countを増やす
         もしcountがnならば {
            c が答え
         }
      }
      a = b
      b = c
   }
}