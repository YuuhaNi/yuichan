標準ライブラリを使う

sum_squares = 入力 lst に対し {
   合計 = 0
   i = 0
   lstの大きさ回くり返す {
      要素 = lst[i]
      余り3 = 剰余(i, 3)
      余り4 = 剰余(i, 4)
      
      もし余り3が0ならば {
         合計 = 和(合計, 積(要素, 要素))
      }
      そうでなければ {
         もし余り4が0ならば {
            合計 = 和(合計, 積(積(要素, 要素), 要素))
         }
         そうでなければ {
            合計 = 和(合計, 要素)
         }
      }
      
      iを増やす
   }
   合計 が答え
}