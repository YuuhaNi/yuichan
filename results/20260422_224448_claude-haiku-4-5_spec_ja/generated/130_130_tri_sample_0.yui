標準ライブラリを使う

tri = 入力 n に対し {
   result = []
   
   tri_calc = 入力 k に対し {
      もし k が 1 ならば {
         3 が答え
      }
      そうでなければ {
         もし k が 2 で剰余(k, 2) が 0 ならば {
            和(1, 商(k, 2)) が答え
         }
         そうでなければ {
            和(tri_calc(差(k, 1)), tri_calc(差(k, 2)), tri_calc(和(k, 1))) が答え
         }
      }
   }
   
   i = 1
   和(n, 1) 回くり返す {
      result に tri_calc(i) を追加する
      i を増やす
   }
   
   result が答え
}