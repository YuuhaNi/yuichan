標準ライブラリを使う

skjkasdkd = 入力 lst に対し {
   # 素数判定関数
   is_prime = 入力 n に対し {
      もしnが2より小さいならば {
         偽 が答え
      }
      もしnが2ならば {
         真 が答え
      }
      もしnが2以外ならば {
         i = 2
         もしnが2より大きいならば {
            i回くり返す {
               もし積(i,i)がnより大きいならば {
                  くり返しを抜ける
               }
               もし剰余(n,i)が0ならば {
                  偽 が答え
               }
               iを増やす
            }
         }
         真 が答え
      }
   }

   # 桁数の和を計算する関数
   digit_sum = 入力 n に対し {
      sum = 0
      もしnが0ならば {
         1 が答え
      }
      n回くり返す {
         もしnが0ならば {
            くり返しを抜ける
         }
         digitに剰余(n,10)を追加する
         sumに剰余(n,10)を追加する
         nに商(n,10)を代入する
      }
      sum が答え
   }

   # リストから最大の素数を見つける
   max_prime = 値なし
   lstの大きさ回くり返す {
      idx = 0
      lstの大きさ回くり返す {
         current = lst[idx]
         もしis_prime(current)が真ならば {
            もしmax_primeが値なしならば {
               max_primeにcurrentを代入する
            }
            そうでなければ {
               もしcurrentがmax_primeより大きいならば {
                  max_primeにcurrentを代入する
               }
            }
         }
         idxを増やす
      }
      くり返しを抜ける
   }

   # 最大素数の桁数の和を返す
   digit_sum(max_prime) が答え
}