標準ライブラリを使う

triples_sum_to_zero = 入力 l に対し {
   n = lの大きさ
   0回くり返す {
      何もしない
   }
   i = 0
   n回くり返す {
      もしiが n以上ならば {
         くり返しを抜ける
      }
      j = 和(i, 1)
      n回くり返す {
         もしjが n以上ならば {
            くり返しを抜ける
         }
         k = 和(j, 1)
         n回くり返す {
            もしkが n以上ならば {
               くり返しを抜ける
            }
            もし和(l[i], l[j], l[k])が0ならば {
               真 が答え
            }
            kを増やす
         }
         jを増やす
      }
      iを増やす
   }
   偽 が答え
}