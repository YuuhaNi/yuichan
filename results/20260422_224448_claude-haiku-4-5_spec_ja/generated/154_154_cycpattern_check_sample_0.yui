標準ライブラリを使う

cycpattern_check = 入力 a, b に対し {
   もしbの大きさが0ならば {
      真 が答え
   }
   
   i = 0
   bの大きさ回くり返す {
      # b を i 文字分回転させた文字列を作る
      rotated = ""
      bの大きさ回くり返す {
         charCode = b[和(i, i)]
         rotatedにcharCodeを追加する
         i = 和(i, 1)
         もしiがbの大きさ以上ならば {
            i = 差(i, bの大きさ)
         }
      }
      
      # rotated が a の部分文字列かチェック
      j = 0
      差(aの大きさ, rotatedの大きさ)を増やす
      差(aの大きさ, rotatedの大きさ)回くり返す {
         match = 真
         rotatedの大きさ回くり返す {
            もしa[和(j, i)]がrotated[i]以外ならば {
               match = 偽
               くり返しを抜ける
            }
            iを増やす
         }
         
         もしmatchが真ならば {
            真 が答え
         }
         jを増やす
      }
   }
   
   偽 が答え
}
標準ライブラリを使う

cycpattern_check = 入力 a, b に対し {
   もしbの大きさが0ならば {
      真 が答え
   }
   
   doubled = b
   bの大きさ回くり返す {
      doubled = 文字列化(doubled)
   }
   
   もし文字列化(doubled)がaのいずれかならば {
      真 が答え
   }
   
   偽 が答え
}
標準ライブラリを使う

cycpattern_check = 入力 a, b に対し {
   もしbの大きさが0ならば {
      真 が答え
   }
   
   # b を2倍にした文字列を作成
   doubled = ""
   2回くり返す {
      bの大きさ回くり返す {
         doubledにb[i]を追加する
      }
   }
   
   # doubled が a の部分文字列かチェック
   i = 0
   差(aの大きさ, bの大きさ)を増やす
   差(aの大きさ, bの大きさ)回くり返す {
      match = 真
      bの大きさ回くり返す {
         もしa[和(i, i)]がdoubled[和(i, i)]以外ならば {
            match = 偽
            くり返しを抜ける
         }
      }
      もしmatchが真ならば {
         真 が答え
      }
      iを増やす
   }
   
   偽 が答え
}