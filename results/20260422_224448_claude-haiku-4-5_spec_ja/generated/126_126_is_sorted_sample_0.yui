標準ライブラリを使う

is_sorted = 入力 lst に対し {
   i = 0
   前の値 = 値なし
   重複カウント = 0
   
   lstの大きさ回くり返す {
      現在の値 = lst[i]
      
      もし前の値が値なし以外ならば {
         もし現在の値が前の値より小さいならば {
            偽 が答え
         }
         
         もし現在の値が前の値ならば {
            重複カウントを増やす
            もし重複カウントが1より大きいならば {
               偽 が答え
            }
         }
         そうでなければ {
            重複カウント = 0
         }
      }
      
      前の値 = 現在の値
      iを増やす
   }
   
   真 が答え
}