標準ライブラリを使う

encode = 入力 message に対し {
   result = ""
   messageの大きさを n とする
   n回くり返す {
      i = 0
      i < messageの大きさ ならば {
         char = message[i]
         # 文字コードを取得
         code = char
         
         # 大文字小文字の入れ替え
         もし code が 65以上ならば {
            もし code が 90以下ならば {
               # 大文字 A-Z (65-90) → 小文字に
               code = 和(code, 32)
            }
            そうでなければ {
               もし code が 97以上ならば {
                  もし code が 122以下ならば {
                     # 小文字 a-z (97-122) → 大文字に
                     code = 差(code, 32)
                  }
               }
            }
         }
         
         # 母音を置き換え
         もし code が 65ならば {
            # A → 2つ前 = ? (実装上は Y の手前)
            code = 89
         }
         そうでなければ {
            もし code が 69ならば {
               # E → C
               code = 67
            }
            そうでなければ {
               もし code が 73ならば {
                  # I → G
                  code = 71
               }
               そうでなければ {
                  もし code が 79ならば {
                     # O → M
                     code = 77
                  }
                  そうでなければ {
                     もし code が 85ならば {
                        # U → S
                        code = 83
                     }
                     そうでなければ {
                        もし code が 97ならば {
                           # a → y
                           code = 121
                        }
                        そうでなければ {
                           もし code が 101ならば {
                              # e → c
                              code = 99
                           }
                           そうでなければ {
                              もし code が 105ならば {
                                 # i → g
                                 code = 103
                              }
                              そうでなければ {
                                 もし code が 111ならば {
                                    # o → m
                                    code = 109
                                 }
                                 そうでなければ {
                                    もし code が 117ならば {
                                       # u → s
                                       code = 115
                                    }
                                 }
                              }
                           }
                        }
                     }
                  }
               }
            }
         }
         
         result に code を追加する
         i を増やす
      }
   }
   result が答え
}