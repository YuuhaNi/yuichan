標準ライブラリを使う

same_chars = 入力 s0, s1 に対し {
   chars0 = [値なし]
   i = 0
   s0の大きさ回くり返す {
      c = s0[i]
      found = 偽
      j = 0
      chars0の大きさ回くり返す {
         もしchars0[j]がcならば {
            found = 真
         }
         jを増やす
      }
      もしfoundが偽ならば {
         chars0にcを追加する
      }
      iを増やす
   }
   
   chars1 = [値なし]
   i = 0
   s1の大きさ回くり返す {
      c = s1[i]
      found =偽
      j = 0
      chars1の大きさ回くり返す {
         もしchars1[j]がcならば {
            found = 真
         }
         jを増やす
      }
      もしfoundが偽ならば {
         chars1にcを追加する
      }
      iを増やす
   }
   
   もしchars0の大きさがchars1の大きさならば {
      match = 真
      i = 0
      chars0の大きさ回くり返す {
         found = 偽
         j = 0
         chars1の大きさ回くり返す {
            もしchars0[i]がchars1[j]ならば {
               found = 真
            }
            jを増やす
         }
         もしfoundが偽ならば {
            match = 偽
         }
         iを増やす
      }
      match が答え
   }
   そうでなければ {
      偽 が答え
   }
}