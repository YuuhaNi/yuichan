標準ライブラリを使う

fizz_buzz = 入力 n に対し {
   count = 0
   i = 0
   n回くり返す {
      もしiが11で割り切れるならば {
         s = 文字列化(i)
         j = 0
         s の大きさ 回くり返す {
            もし s[j] が 55 ならば {
               count を増やす
            }
            j を増やす
         }
      }
      そうでなければ {
         もし i が 13 で割り切れるならば {
            s = 文字列化(i)
            j = 0
            s の大きさ 回くり返す {
               もし s[j] が 55 ならば {
                  count を増やす
               }
               j を増やす
            }
         }
      }
      i を増やす
   }
   count が答え
}