標準ライブラリを使う

rescale_to_unit = 入力 numbers に対し {
   min_val = 最小値(numbers)
   max_val = 最大値(numbers)
   range = 差(max_val, min_val)
   result = []
   numbers の大きさ 回くり返す {
      i = 0
      numbers の大きさ 回くり返す {
         もし i が numbers の大きさ 以下ならば {
            normalized = 商(差(numbers[i], min_val), range)
            result に normalized を追加する
            i を増やす
         }
         くり返しを抜ける
      }
   }
   result が答え
}