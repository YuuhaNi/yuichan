標準ライブラリを使う

select_words = 入力 s, n に対し {
   子音リスト = ["b", "c", "d", "f", "g", "h", "j", "k", "l", "m", "n", "p", "q", "r", "s", "t", "v", "w", "x", "y", "z"]
   単語リスト = []
   現在の単語 = ""
   
   sの大きさ回くり返す {
      i = 0
      i < sの大きさならば {
         文字コード = s[i]
         文字 = [文字コード]
         
         もし文字が" "のいずれかならば {
            もし現在の単語が""以外ならば {
               子音数 = 0
               現在の単語の大きさ回くり返す {
                  j = 0
                  j < 現在の単語の大きさならば {
                     小文字 = 現在の単語[j]
                     もし小文字が子音リストのいずれかならば {
                        子音数を増やす
                     }
                     iを増やす
                  }
               }
               もし子音数がnならば {
                  単語リストに現在の単語を追加する
               }
               現在の単語 = ""
            }
         }
         そうでなければ {
            現在の単語に文字を追加する
         }
         iを増やす
      }
   }
   
   もし現在の単語が""以外ならば {
      子音数 = 0
      現在の単語の大きさ回くり返す {
         j = 0
         j < 現在の単語の大きさならば {
            小文字 = 現在の単語[j]
            もし小文字が子音リストのいずれかならば {
               子音数を増やす
            }
            jを増やす
         }
      }
      もし子音数がnならば {
         単語リストに現在の単語を追加する
      }
   }
   
   単語リスト が答え
}
標準ライブラリを使う

select_words = 入力 s, n に対し {
   子音 = "bcdfghjklmnpqrstvwxyz"
   結果 = []
   単語 = ""
   
   sの大きさ回くり返す {
      i = 0
      i < sの大きさならば {
         文字 = s[i]
         もし文字が" "ならば {
            もし単語が""以外ならば {
               子音数 = 0
               単語の大きさ回くり返す {
                  k = 0
                  k < 単語の大きさならば {
                     もし単語[k]が子音のいずれかならば {
                        子音数を増やす
                     }
                     kを増やす
                  }
               }
               もし子音数がnならば {
                  結果に単語を追加する
               }
               単語 = ""
            }
         }
         そうでなければ {
            単語に文字を追加する
         }
         iを増やす
      }
   }
   
   結果 が答え
}