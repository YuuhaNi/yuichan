標準ライブラリを使う

find_max = 入力 words に対し {
   max_word = ""
   max_unique = 0
   
   words の大きさ 回くり返す {
      i = 0
      word = words[i]
      unique_chars = []
      
      word の大きさ 回くり返す {
         j = 0
         char = word[j]
         found = 偽
         
         unique_chars の大きさ 回くり返す {
            k = 0
            もし char が unique_chars[k] ならば {
               found = 真
               くり返しを抜ける
            }
            k を増やす
         }
         
         もし found が 偽 ならば {
            unique_chars に char を追加する
         }
         j を増やす
      }
      
      unique_count = unique_chars の大きさ
      
      もし unique_count が max_unique より大きい ならば {
         max_word = word
         max_unique = unique_count
      }
      そうでなければ {
         もし unique_count が max_unique ならば {
            もし word が max_word より小さい ならば {
               max_word = word
            }
         }
      }
      i を増やす
   }
   
   max_word が答え
}