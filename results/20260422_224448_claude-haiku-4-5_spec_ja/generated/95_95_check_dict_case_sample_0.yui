標準ライブラリを使う

check_dict_case = 入力 dict に対し {
   # 辞書が空の場合はFalseを返す
   もし dict の大きさ が 0 ならば {
      偽 が答え
   }
   
   # 最初のキーで大文字/小文字を判定
   first_key = 値なし
   is_lowercase = 値なし
   
   # キーを順に確認
   i = 0
   N回くり返す {
      もし i が dict の大きさ より小さい ならば {
         # キーを取得（オブジェクトのキーは文字列）
         key = dict[i]
         
         # キーが文字列でない場合はFalseを返す
         もし 文字列判定(key) が 偽 ならば {
            偽 が答え
         }
         
         # 最初のキーで判定方向を決める
         もし first_key が 値なし ならば {
            first_key = key
            # キーの最初の文字で判定
            first_char = key[0]
            # 小文字（a-z: 97-122）か大文字（A-Z: 65-90）かを判定
            もし first_char が 97 以上 ならば {
               もし first_char が 122 以下 ならば {
                  is_lowercase = 真
               }
               そうでなければ {
                  is_lowercase = 偽
               }
            }
            そうでなければ {
               is_lowercase = 偽
            }
         }
         
         # 各文字が判定方向と一致するか確認
         j = 0
         key の大きさ 回くり返す {
            char = key[j]
            もし is_lowercase が 真 ならば {
               # 小文字であるべき
               もし char が 97 未満 ならば {
                  偽 が答え
               }
               もし char が 122 より大きい ならば {
                  偽 が答え
               }
            }
            そうでなければ {
               # 大文字であるべき
               もし char が 65 未満 ならば {
                  偽 が答え
               }
               もし char が 90 より大きい ならば {
                  偽 が答え
               }
            }
            j を増やす
         }
         
         i を増やす
      }
   }
   
   is_lowercase が答え
}