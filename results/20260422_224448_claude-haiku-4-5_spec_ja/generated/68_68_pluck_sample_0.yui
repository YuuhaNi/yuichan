標準ライブラリを使う

pluck = 入力 arr に対し {
   もしarrの大きさが0ならば {
      []が答え
   }
   
   最小偶数値 = 値なし
   最小インデックス = 値なし
   
   arrの大きさ回くり返す {
      i = 0
      arrの大きさ回くり返す {
         現在値 = arr[i]
         
         もし現在値が2で割った剰余が0ならば {
            もし最小偶数値が値なしならば {
               最小偶数値 = 現在値
               最小インデックス = i
            }
            そうでなければ {
               もし現在値が最小偶数値より小さいならば {
                  最小偶数値 = 現在値
                  最小インデックス = i
               }
            }
         }
         
         iを増やす
      }
      
      くり返しを抜ける
   }
   
   もし最小偶数値が値なしならば {
      []が答え
   }
   そうでなければ {
      [最小偶数値, 最小インデックス]が答え
   }
}