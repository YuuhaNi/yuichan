標準ライブラリを使う

is_happy = 入力 s に対し {
   もしsの大きさが3より小さいならば {
      偽 が答え
   }
   
   i = 0
   もしsの大きさが3以上ならば {
      sの大きさを減らす
      sの大きさを減らす
      1回くり返す {
         sの大きさを増やす
         sの大きさを増やす
      }
   }
   
   i = 0
   sの大きさを減らす
   sの大きさを減らす
   N = sの大きさ
   
   N回くり返す {
      もしs[i]がs[差(i,1)]以外ならば {
         もしs[i]がs[差(i,2)]以外ならば {
            もしs[差(i,1)]がs[差(i,2)]以外ならば {
               iを増やす
            }
            そうでなければ {
               偽 が答え
            }
         }
         そうでなければ {
            偽 が答え
         }
      }
      そうでなければ {
         偽 が答え
      }
   }
   
   真 が答え
}
