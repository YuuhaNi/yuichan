標準ライブラリを使う

vowels_count = 入力 s に対し {
   count = 0
   i = 0
   s の大きさ 回くり返す {
      char = s[i]
      もし char が 97 ならば {
         count を増やす
      }
      そうでなければ {
         もし char が 101 ならば {
            count を増やす
         }
         そうでなければ {
            もし char が 105 ならば {
               count を増やす
            }
            そうでなければ {
               もし char が 111 ならば {
                  count を増やす
               }
               そうでなければ {
                  もし char が 117 ならば {
                     count を増やす
                  }
               }
            }
         }
      }
      i を増やす
   }
   count が答え
}