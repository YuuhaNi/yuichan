標準ライブラリを使う

is_multiply_prime = 入力 a に対し {
   prime_factors = []
   n = a
   divisor = 2
   
   # 素因数分解
   {divisor}の大きさが0以外ならば {
      もしn が divisor 以上ならば {
         もし剰余(n, divisor)が0ならば {
            prime_factorsにdivisorを追加する
            n = 商(n, divisor)
         }
         そうでなければ {
            divisorを増やす
         }
      }
         そうでなければ {
            もしnが1以外ならば {
               prime_factorsにnを追加する
            }
            くり返しを抜ける
         }
      }
   }
   
   # 素因数が正確に3つかチェック
   もしprime_factorsの大きさが3ならば {
      真 が答え
   }
   そうでなければ {
      偽 が答え
   }
}