標準ライブラリを使う

next_smallest = 入力 lst に対し {
   もしlstの大きさが2より小さいならば {
      値なし が答え
   }
   
   最小 = lst[0]
   次最小 = 値なし
   
   lstの大きさ回くり返す {
      i = 0
      i < lstの大きさ {
         現在値 = lst[i]
         
         もし現在値が最小より小さいならば {
            次最小 = 最小
            最小 = 現在値
         }
         そうでなければ {
            もし現在値が最小以外ならば {
               もし次最小が値なしならば {
                  次最小 = 現在値
               }
               そうでなければ {
                  もし現在値が次最小より小さいならば {
                     次最小 = 現在値
                  }
               }
            }
         }
         
         iを増やす
      }
   }
   
   次最小 が答え
}