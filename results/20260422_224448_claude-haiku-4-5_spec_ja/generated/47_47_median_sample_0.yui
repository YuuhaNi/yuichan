標準ライブラリを使う

median = 入力 l に対し {
   sorted = l
   n = sortedの大きさ
   
   # バブルソート
   n回くり返す {
      i = 0
      差(n, 1)回くり返す {
         もしsorted[i]がsorted[和(i, 1)]より大きいならば {
            temp = sorted[i]
            sorted[i] = sorted[和(i, 1)]
            sorted[和(i, 1)] = temp
         }
         iを増やす
      }
   }
   
   # 中央値を計算
   もし剰余(n, 2)が0ならば {
      # 偶数個：中央の2つの平均
      mid1 = sorted[商(差(n, 1), 2)]
      mid2 = sorted[商(n, 2)]
      和(mid1, mid2)の大きさ が答え
   }
   そうでなければ {
      # 奇数個：中央の値
      sorted[商(n, 2)] が答え
   }
}