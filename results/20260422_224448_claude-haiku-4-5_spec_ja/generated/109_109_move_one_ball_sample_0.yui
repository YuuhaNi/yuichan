標準ライブラリを使う

move_one_ball = 入力 arr に対し {
   # 配列が空または要素が1つ以下の場合はTrue
   もしarrの大きさが0ならば {
      真 が答え
   }
   もしarrの大きさが1ならば {
      真 が答え
   }

   # 配列の長さを取得
   N = arrの大きさ
   
   # 最大N回のシフト操作を試す
   shift_count = 0
   N回くり返す {
      # 現在の配列がソート済みかチェック
      is_sorted = 真
      差(N, 1)回くり返す {
         i = shift_count
         もしarr[i]がarr[和(i, 1)]より大きいならば {
            is_sorted = 偽
            くり返しを抜ける
         }
         i = 和(i, 1)
      }
      
      もしis_sortedが真ならば {
         真 が答え
      }
      
      # 右シフト操作を実行
      last_element = arr[差(N, 1)]
      shift_count = 0
      差(N, 1)回くり返す {
         arr[差(N, 1, shift_count)] = arr[差(N, 2, shift_count)]
         shift_count = 和(shift_count, 1)
      }
      arr[0] = last_element
      
      shift_count = 和(shift_count, 1)
   }
   
   # N回のシフト後もソートされていない場合
   偽 が答え
}