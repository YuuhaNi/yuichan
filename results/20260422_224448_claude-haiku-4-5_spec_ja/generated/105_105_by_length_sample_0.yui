標準ライブラリを使う

by_length = 入力 arr に対し {
   # 1から9までの数値のみをフィルタリング
   filtered = []
   i = 0
   arr の大きさ 回くり返す {
      もし arr[i] が 1 以上 ならば {
         もし arr[i] が 9 以下 ならば {
            filtered に arr[i] を追加する
         }
      }
      i を増やす
   }
   
   # 空配列の場合は空配列を返す
   もし filtered の大きさ が 0 ならば {
      [] が答え
   }
   
   # ソート（バブルソート）
   sorted_arr = filtered
   n = sorted_arr の大きさ
   i = 0
   n 回くり返す {
      j = 0
      差(n, 1) 回くり返す {
         もし sorted_arr[j] が sorted_arr[差(j, 1)] より大きい ならば {
            temp = sorted_arr[j]
            sorted_arr[j] = sorted_arr[差(j, 1)]
            sorted_arr[差(j, 1)] = temp
         }
         j を増やす
      }
      i を増やす
   }
   
   # 逆順にする
   reversed_arr = []
   i = 差(sorted_arr の大きさ, 1)
   0 回くり返す {
      くり返しを抜ける
   }
   i = 差(sorted_arr の大きさ, 1)
   もし i が 0 以上 ならば {
      i を増やす
      i 回くり返す {
         i を減らす
         reversed_arr に sorted_arr[i] を追加する
      }
   }
   
   # 数字を名前に置き換える
   names = ["One", "Two", "Three", "Four", "Five", "Six", "Seven", "Eight", "Nine"]
   result = []
   i = 0
   reversed_arr の大きさ 回くり返す {
      num = reversed_arr[i]
      result に names[差(num, 1)] を追加する
      i を増やす
   }
   
   result が答え
}