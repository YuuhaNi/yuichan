標準ライブラリを使う

search = 入力 lst に対し {
   result = -1
   i = 1
   lstの大きさを max_val とする
   
   max_val回くり返す {
      もし i が 0より大きい ならば {
         count = 0
         j = 0
         lstの大きさを len とする
         
         len回くり返す {
            もし lst[j] が i ならば {
               countを増やす
            }
            jを増やす
         }
         
         もし count が i以上 ならば {
            もし i が result より大きい ならば {
               result = i
            }
         }
      }
      iを増やす
   }
   
   result が答え
}