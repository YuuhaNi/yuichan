標準ライブラリを使う

will_it_fly = 入力 q, w に対し {
   # qの要素の合計を計算
   合計 = 和(q)
   
   # 合計が最大荷重を超えているかチェック
   もし合計がwより大きいならば {
      偽 が答え
   }
   
   # qがバランス（回文）しているかチェック
   i = 0
   バランス済み = 真
   
   (qの大きさ)回くり返す {
      もしq[i]がq[(qの大きさ)差(1,i)以外]ならば {
         バランス済み = 偽
         くり返しを抜ける
      }
      iを増やす
   }
   
   バランス済み が答え
}