標準ライブラリを使う

rounded_avg = 入力 n, m に対し {
   もしnがmより大きいならば {
      -1 が答え
   }
   
   合計 = 和(n, m)
   個数 = 差(m, n)
   個数を増やす
   平均 = 商(合計, 個数)
   
   # 四捨五入処理
   余り = 剰余(合計, 個数)
   2倍余り = 積(2, 余り)
   
   もし2倍余りがm以上ならば {
      平均を増やす
   }
   
   # 2進数に変換
   結果 = "0b"
   もし平均が0ならば {
      結果 = "0b0"
   }
   そうでなければ {
      ビット列 = []
      作業用 = 平均
      
      作業用が0以外ならば {
         100回くり返す {
            もし作業用が0ならば {
               くり返しを抜ける
            }
            ビット = 剰余(作業用, 2)
            ビット列にビットを追加する
            作業用 = 商(作業用, 2)
         }
      }
      
      # ビット列を逆順にして文字列化
      i = 差(ビット列の大きさ, 1)
      i以上が0ならば {
         100回くり返す {
            もしiが0以外ならば {
               結果 = "{結果}{ビット列[i]}"
               iを減らす
            }
            そうでなければ {
               結果 = "{結果}{ビット列[0]}"
               くり返しを抜ける
            }
         }
      }
   }
   
   結果 が答え
}