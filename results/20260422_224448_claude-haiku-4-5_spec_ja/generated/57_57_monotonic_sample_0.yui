標準ライブラリを使う

monotonic = 入力 l に対し {
   もしlの大きさが2より小さいならば {
      真 が答え
   }
   
   increasing = 真
   decreasing = 真
   
   1回くり返す {
      i = 0
      lの大きさを減らす
      lの大きさ回くり返す {
         もしl[i]がl[和(i,1)]より大きいならば {
            increasing = 偽
         }
         もしl[i]がl[和(i,1)]より小さいならば {
            decreasing = 偽
         }
         iを増やす
      }
   }
   
   もしincreasingが真ならば {
      真 が答え
   }
   そうでなければ {
      もしdecreasingが真ならば {
         真 が答え
      }
      そうでなければ {
         偽 が答え
      }
   }
}