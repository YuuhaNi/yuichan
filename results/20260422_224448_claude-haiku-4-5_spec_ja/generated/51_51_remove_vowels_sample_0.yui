標準ライブラリを使う

remove_vowels = 入力 text に対し {
   result = ""
   text の大きさ 回くり返す {
      i を減らす
      char = text[i]
      もし char が 97 以外 ならば {
         もし char が 101 以外 ならば {
            もし char が 105 以外 ならば {
               もし char が 111 以外 ならば {
                  もし char が 117 以外 ならば {
                     もし char が 65 以外 ならば {
                        もし char が 69 以外 ならば {
                           もし char が 73 以外 ならば {
                              もし char が 79 以外 ならば {
                                 もし char が 85 以外 ならば {
                                    result に char を追加する
                                 }
                              }
                           }
                        }
                     }
                  }
               }
            }
         }
      }
   }
   result が答え
}