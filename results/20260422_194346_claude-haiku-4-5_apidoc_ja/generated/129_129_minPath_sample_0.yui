標準ライブラリを使う

minPath = 入力 grid, k に対し {
  n = 配列化(grid) の 長さ
  
  # グリッド内の各値の位置を記録するマップを作成
  位置マップ = {}
  i = 0
  繰り返す (i < n) {
    j = 0
    繰り返す (j < n) {
      値 = grid[i][j]
      位置マップ[値] = [i, j]
      j = 和(j, 1)
    }
    i = 和(i, 1)
  }
  
  # 最小の経路を見つけるためのBFS
  最小経路 = 値なし
  
  # すべてのセルからスタート
  開始行 = 0
  繰り返す (開始行 < n) {
    開始列 = 0
    繰り返す (開始列 < n) {
      # (開始行, 開始列) からスタート
      キュー = [[開始行, 開始列, [grid[開始行][開始列]]]]
      
      繰り返す (キュー の 長さ > 0) {
        現在 = キュー[0]
        キュー = キュー の 1 番目から最後まで
        
        行 = 現在[0]
        列 = 現在[1]
        経路 = 現在[2]
        
        # 経路の長さが k に達した場合
        もし (経路 の 長さ = k) {
          もし (最小経路 = 値なし または 経路 < 最小経路) {
            最小経路 = 経路
          }
        } そうでなく もし (経路 の 長さ < k) {
          # 隣接セルを探索（上下左右）
          方向 = [[0, 1], [0, -1], [1, 0], [-1, 0]]
          d = 0
          繰り返す (d < 4) {
            新行 = 和(行, 方向[d][0])
            新列 = 和(列, 方向[d][1])
            
            # グリッド内かチェック
            もし (新行 >= 0 かつ 新行 < n かつ 新列 >= 0 かつ 新列 < n) {
              新経路 = 経路 + [grid[新行][新列]]
              キュー = キュー + [[新行, 新列, 新経路]]
            }
            
            d = 和(d, 1)
          }
        }
      }
      
      開始列 = 和(開始列, 1)
    }
    開始行 = 和(開始行, 1)
  }
  
  最小経路
}