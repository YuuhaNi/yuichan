標準ライブラリを使う

even_odd_palindrome = 入力 n に対し {
    偶数個数 = 0
    奇数個数 = 0
    
    i = 1
    繰り返す (i <= n) {
        文字列 = 文字列化(i)
        反転文字列 = ""
        j = 文字列の長さ - 1
        繰り返す (j >= 0) {
            反転文字列 = 反転文字列 + 文字列[j]
            j = j - 1
        }
        
        もし (文字列 == 反転文字列) {
            もし (剰余(i, 2) == 0) {
                偶数個数 = 偶数個数 + 1
            } そうでなければ {
                奇数個数 = 奇数個数 + 1
            }
        }
        
        i = i + 1
    }
    
    (偶数個数, 奇数個数)
}