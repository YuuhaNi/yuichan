標準ライブラリを使う

histogram = 入力 test に対し {
  もし test == '' ならば {
    {}を返す
  }
  
  文字列群 = test を ' ' で分割
  カウント = {}
  
  文字群に対し各 char で {
    もし char が カウント に含まれるならば {
      カウント[char] = カウント[char] + 1
    } でなければ {
      カウント[char] = 1
    }
  }
  
  最大数 = 0
  カウント の値群に対し各 count で {
    もし count > 最大数 ならば {
      最大数 = count
    }
  }
  
  結果 = {}
  カウント の項目群に対し各 (char, count) で {
    もし count == 最大数 ならば {
      結果[char] = count
    }
  }
  
  結果を返す
}