標準ライブラリを使う

fix_spaces = 入力 text に対し {
  結果 = ""
  連続空白数 = 0
  
  i = 0
  text の長さを len とする
  
  i < len の間 {
    文字 = text[i]
    
    文字 == " " の場合 {
      連続空白数 = 連続空白数 + 1
    } そうでなければ {
      連続空白数 > 1 の場合 {
        結果 = 結果 + "-"
      } そうでなければ 連続空白数 == 1 の場合 {
        結果 = 結果 + "_"
      }
      
      結果 = 結果 + 文字
      連続空白数 = 0
    }
    
    i = i + 1
  }
  
  連続空白数 > 1 の場合 {
    結果 = 結果 + "-"
  } そうでなければ 連続空白数 == 1 の場合 {
    結果 = 結果 + "_"
  }
  
  結果を返す
}