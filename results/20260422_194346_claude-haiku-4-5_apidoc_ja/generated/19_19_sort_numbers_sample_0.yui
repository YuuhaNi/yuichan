標準ライブラリを使う

sort_numbers = 入力 numbers に対し {
    単語リスト = ['zero', 'one', 'two', 'three', 'four', 'five', 'six', 'seven', 'eight', 'nine']
    
    分割結果 = numbers を ' ' で分割
    
    インデックスリスト = []
    分割結果 の各要素 word に対し {
        i = 0
        繰り返す i < 10 の間 {
            単語リスト[i] が word と等しい場合 {
                インデックスリスト に i を追加
                i = 10
            }
            i = i + 1
        }
    }
    
    ソート済み = インデックスリスト をソート
    
    結果リスト = []
    ソート済み の各要素 idx に対し {
        結果リスト に 単語リスト[idx] を追加
    }
    
    結果リスト を ' ' で結合
}