標準ライブラリを使う

sort_even = 入力 l に対し {
    偶数インデックス = []
    奇数インデックス = []
    
    i = 0
    l の各要素 x に対し {
        もし 剰余(i, 2) = 0 ならば {
            偶数インデックス を追加(x)
        } そうでなければ {
            奇数インデックス を追加(x)
        }
        i = 和(i, 1)
    }
    
    偶数インデックス をソート
    
    結果 = []
    i = 0
    j = 0
    k = 0
    
    l の各要素 に対し {
        もし 剰余(i, 2) = 0 ならば {
            結果 を追加(偶数インデックス[j])
            j = 和(j, 1)
        } そうでなければ {
            結果 を追加(奇数インデックス[k])
            k = 和(k, 1)
        }
        i = 和(i, 1)
    }
    
    結果
}