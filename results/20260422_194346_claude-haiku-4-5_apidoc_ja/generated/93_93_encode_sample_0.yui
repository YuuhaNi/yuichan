標準ライブラリを使う

encode = 入力 message に対し {
    母音マップ = {"a": "Y", "e": "C", "i": "G", "o": "M", "u": "Q",
                   "A": "y", "E": "c", "I": "g", "O": "m", "U": "q"}
    
    結果 = ""
    文字コード配列 = 配列化(message)
    
    i = 0
    i < 長さ(文字コード配列) の間 {
        文字コード = 文字コード配列[i]
        文字 = 文字列化(文字コード)
        
        もし 母音マップ に 文字 が含まれるなら {
            結果 = 結果 + 母音マップ[文字]
        } そうでなければ {
            もし 文字 >= "a" かつ 文字 <= "z" なら {
                結果 = 結果 + 大文字化(文字)
            } そうでなければ もし 文字 >= "A" かつ 文字 <= "Z" なら {
                結果 = 結果 + 小文字化(文字)
            } そうでなければ {
                結果 = 結果 + 文字
            }
        }
        
        i = i + 1
    }
    
    結果を返す
}