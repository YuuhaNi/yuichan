標準ライブラリを使う

is_sorted = 入力 lst に対し {
  もし 配列判定(lst) でなければ {
    偽を返す
  }
  
  もし 最小値(lst) == 値なし ならば {
    真を返す
  }
  
  i = 0
  繰り返す i < 長さ(lst) - 1 の間 {
    現在 = lst[i]
    次 = lst[i + 1]
    
    もし 現在 > 次 ならば {
      偽を返す
    }
    
    もし 現在 == 次 ならば {
      カウント = 0
      j = 0
      繰り返す j < 長さ(lst) の間 {
        もし lst[j] == 現在 ならば {
          カウント = カウント + 1
        }
        j = j + 1
      }
      
      もし カウント > 1 ならば {
        偽を返す
      }
    }
    
    i = i + 1
  }
  
  真を返す
}