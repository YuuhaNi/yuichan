標準ライブラリを使う

triples_sum_to_zero = 入力 l に対し {
  i = 0
  繰り返す (i < 長さ(l)) {
    j = 足す(i, 1)
    繰り返す (j < 長さ(l)) {
      k = 足す(j, 1)
      繰り返す (k < 長さ(l)) {
        もし (等しい(和(l[i], l[j], l[k]), 0)) {
          戻す 真
        }
        k = 足す(k, 1)
      }
      j = 足す(j, 1)
    }
    i = 足す(i, 1)
  }
  戻す 偽
}