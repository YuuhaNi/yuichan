標準ライブラリを使う

odd_count = 入力 lst に対し {
  結果 = []
  
  i = 0
  繰り返す (i < 長さ(lst)) {
    文字列 = lst[i]
    
    # 奇数の個数をカウント
    奇数個数 = 0
    j = 0
    繰り返す (j < 長さ(文字列)) {
      文字コード = 整数化(文字列化(文字列[j]))
      数字 = 整数化(文字列[j])
      
      # 数字が奇数かチェック
      剰余値 = 剰余(数字, 2)
      もし (剰余値 == 1) {
        奇数個数 = 奇数個数 + 1
      }
      
      j = j + 1
    }
    
    # テンプレート文字列内の 'i' を奇数個数に置換
    テンプレート = "the number of odd elements in the string i of the input."
    置換後 = ""
    k = 0
    繰り返す (k < 長さ(テンプレート)) {
      文字 = テンプレート[k]
      もし (文字 == "i") {
        置換後 = 置換後 + 文字列化(奇数個数)
      } そうでなければ {
        置換後 =置換後 + 文字
      }
      k = k + 1
    }
    
    結果 = 結果 + [置換後]
    i = i + 1
  }
  
  結果を返す
}