標準ライブラリを使う

digitSum = 入力 s に対し {
    配列 = 配列化(s)
    合計 = 0
    
    i = 0
    i < 長さ(配列) の間 {
        文字コード = 配列[i]
        
        # 英大文字のASCIIコード範囲は 65('A') ～ 90('Z')
        文字コード >= 65 かつ 文字コード <= 90 ならば {
            合計 = 和(合計, 文字コード)
        }
        
        i = 和(i, 1)
    }
    
    合計 を返す
}