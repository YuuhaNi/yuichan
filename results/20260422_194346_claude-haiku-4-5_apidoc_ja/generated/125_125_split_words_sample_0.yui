標準ライブラリを使う

split_words = 入力 txt に対し {
  もし (txt に " " が含まれるか) ならば {
    txt を " " で分割
  } そうでなく (txt に "," が含まれるか) ならば {
    txt を "," で分割
  } そうでなく {
    カウント = 0
    各 文字 を txt で {
      もし (文字 >= "a" かつ 文字 <= "z") ならば {
        インデックス = 文字コード(文字) - 文字コード("a")
        もし (インデックス が奇数) ならば {
          カウント = カウント + 1
        }
      }
    }
    カウント
  }
}
標準ライブラリを使う

split_words = 入力 txt に対し {
  もし (txt に " " が含まれるか) ならば {
    txt を " " で分割
  } そうでなく (txt に "," が含まれるか) ならば {
    txt を "," で分割
  } そうでなく {
    配列化(txt)
      |> フィルタ(x => x >= 97 かつ x <= 122)
      |> フィルタ(x => (x - 97) % 2 == 1)
      |> 長さ
  }
}