標準ライブラリを使う

get_max_triples = 入力 n に対し {
    # 配列 a を作成: a[i] = i * i - i + 1
    a = []
    i = 1
    繰り返す (i <= n) {
        値 = 積(i, i) - i + 1
        a = 配列に追加(a, 値)
        i = i + 1
    }
    
    # 三つ組の個数をカウント
    count = 0
    i = 0
    繰り返す (i < n) {
        j = i + 1
        繰り返す (j < n) {
            k = j + 1
            繰り返す (k < n) {
                # a[i] + a[j] + a[k] が3の倍数か判定
                合計 = a[i] + a[j] + a[k]
                余り = 剰余(合計, 3)
                もし (余り == 0) {
                    count = count + 1
                }
                k = k + 1
            }
            j = j + 1
        }
        i = i + 1
    }
    
    count を返す
}

n = 整数化(入力を得る)
結果 = get_max_triples(n)
結果を出力する