標準ライブラリを使う

words_in_sentence = 入力 sentence に対し {
  単語群 = sentence を " " で分割
  結果 = []
  
  単語群 の各 word に対し {
    長さ = word の長さ
    素数か = 真
    
    もし 長さ < 2 なら {
      素数か = 偽
    } でなければ {
      i = 2
      繰り返す i < 長さ の間 {
        もし 剰余(長さ, i) == 0 なら {
          素数か = 偽
          抜ける
        }
        i = i + 1
      }
    }
    
    もし 素数か なら {
      結果 に word を追加
    }
  }
  
  結果 を " " で結合して返す
}