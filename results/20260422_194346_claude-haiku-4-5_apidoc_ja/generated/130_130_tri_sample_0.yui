標準ライブラリを使う

tri = 入力 n に対し {
  キャッシュ = {}
  
  tri_helper = 入力 x に対し {
    x が キャッシュ に あるなら {
      キャッシュ[x] を返す
    }
    
    もし x == 1 ならば {
      結果 = 3
    } そうでなく x が 偶数 ならば {
      結果 = 和(1, 商(x, 2))
    } そうでなく {
      結果 = 和(tri_helper(差(x, 1)), tri_helper(差(x, 2)), tri_helper(和(x, 1)))
    }
    
    キャッシュ[x] = 結果
    結果 を返す
  }
  
  リスト = []
  i = 0
  i が 以下 n の間 {
    リスト に tri_helper(i) を追加
    i = 和(i, 1)
  }
  
  リスト を返す
}