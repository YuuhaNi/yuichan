標準ライブラリを使う

count_up_to = 入力 n に対し {
  もし n <= 2 ならば {
    []を返す
  }
  
  素数リスト = []
  候補 = 2
  
  繰り返す 候補 < n の間 {
    是素数 = 真
    除数 = 2
    
    繰り返す 除数 * 除数 <= 候補 の間 {
      もし 剰余(候補, 除数) == 0 ならば {
        是素数 = 偽
        抜ける
      }
      除数 = 除数 + 1
    }
    
    もし 是素数 ならば {
      素数リスト = 素数リスト + [候補]
    }
    
    候補 = 候補 + 1
  }
  
  素数リストを返す
}