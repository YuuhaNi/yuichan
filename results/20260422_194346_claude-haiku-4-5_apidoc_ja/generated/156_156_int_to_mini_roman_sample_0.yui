標準ライブラリを使う

int_to_mini_roman = 入力 number に対し {
  値_マッピング = [
    [1000, "m"],
    [900, "cm"],
    [500, "d"],
    [400, "cd"],
    [100, "c"],
    [90, "xc"],
    [50, "l"],
    [40, "xl"],
    [10, "x"],
    [9, "ix"],
    [5, "v"],
    [4, "iv"],
    [1, "i"]
  ]
  
  結果 = ""
  
  i = 0
  繰り返す (i < 長さ(値_マッピング)) {
    値 = 値_マッピング[i][0]
    文字 = 値_マッピング[i][1]
    
    繰り返す (number >= 値) {
      結果 = 結果 + 文字
      number = 差(number, 値)
    }
    
    i = i + 1
  }
  
  結果を返す
}