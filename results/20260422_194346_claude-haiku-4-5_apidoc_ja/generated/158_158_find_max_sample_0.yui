標準ライブラリを使う

find_max = 入力 words に対し {
  最大単語 = ""
  最大文字数 = 0
  
  words の各要素 word に対し {
    固有文字集合 = {}
    word の各文字 char に対し {
      固有文字集合[char] = 真
    }
    固有文字数 = 配列化(固有文字集合) の 長さ
    
    もし 固有文字数 > 最大文字数 ならば {
      最大文字数 = 固有文字数
      最大単語 = word
    } そうでなく もし 固有文字数 == 最大文字数 かつ word < 最大単語 ならば {
      最大単語 = word
    }
  }
  
  最大単語 を返す
}