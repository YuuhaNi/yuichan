標準ライブラリを使う

encrypt = 入力 s に対し {
  結果 = ""
  i = 0
  繰り返す (i < 文字列長(s)) {
    文字 = 文字列抽出(s, i, 1)
    文字コード = 文字コード値(文字)
    
    もし (文字コード >= 97 かつ 文字コード <= 122) {
      # 小文字の場合
      位置 = 文字コード - 97
      新位置 = (位置 * 2 + 2) % 26
      新文字コード = 新位置 + 97
      結果 = 結果 + 文字コード変換(新文字コード)
    } そうでなく もし (文字コード >= 65 かつ 文字コード <= 90) {
      # 大文字の場合
      位置 = 文字コード - 65
      新位置 = (位置 * 2 + 2) % 26
      新文字コード = 新位置 + 65
      結果 = 結果 + 文字コード変換(新文字コード)
    } そうでなく {
      # アルファベット以外はそのまま
      結果 = 結果 + 文字
    }
    
    i = i + 1
  }
  
  結果を返す
}