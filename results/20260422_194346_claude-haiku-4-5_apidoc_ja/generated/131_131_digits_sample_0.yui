標準ライブラリを使う

digits = 入力 n に対し {
    文字列 = 文字列化(n)
    長さ = 長さ(文字列)
    積結果 = 1
    奇数あり = 偽
    
    i = 0
    i < 長さ の間 {
        桁 = 部分文字列(文字列, i, i + 1)
        桁数値 = 整数化(桁)
        
        もし 剰余(桁数値, 2) == 1 ならば {
            積結果 = 積(積結果, 桁数値)
            奇数あり = 真
        }
        
        i = i + 1
    }
    
    もし 奇数あり ならば {
        積結果
    } そうでなければ {
        0
    }
}