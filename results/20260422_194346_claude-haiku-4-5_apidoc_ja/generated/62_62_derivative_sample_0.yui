標準ライブラリを使う

derivative = 入力 xs に対し {
    もし 配列判定(xs) が 偽 ならば {
        エラー "mismatch-argument"
    }
    
    もし 和(配列化(xs)) = 0 ならば {
        []
    } でなければ {
        結果 = []
        i = 1
        繰り返す i < 長さ(xs) の間 {
            結果 に 積(i, xs[i]) を追加
            i = 和(i, 1)
        }
        結果
    }
}