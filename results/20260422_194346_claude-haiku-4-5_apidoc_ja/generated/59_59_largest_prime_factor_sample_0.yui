標準ライブラリを使う

largest_prime_factor = 入力 n に対し {
    最大素因数 = 1
    
    # 2で割り切れなくなるまで割る
    もし 剰余(n, 2) = 0 なら {
        最大素因数 = 2
        n = 商(n, 2)
        繰り返す n > 1 の間 {
            もし 剰余(n, 2) = 0 なら {
                n = 商(n, 2)
            } でなければ {
                抜ける
            }
        }
    }
    
    # 3以上の奇数で割り切れなくなるまで割る
    i = 3
    繰り返す 積(i, i) ≤ n の間 {
        もし 剰余(n, i) = 0 なら {
            最大素因数 = i
            n = 商(n, i)
            繰り返す n > 1 の間 {
                もし 剰余(n, i) = 0 なら {
                    n = 商(n, i)
                } でなければ {
                    抜ける
                }
            }
        }
        i = 和(i, 2)
    }
    
    # nが1より大きければ、nそのものが素因数
    もし n > 1 なら {
        最大素因数 = n
    }
    
    最大素因数を返す
}