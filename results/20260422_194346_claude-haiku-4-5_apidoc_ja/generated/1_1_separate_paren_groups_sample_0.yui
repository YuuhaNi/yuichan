標準ライブラリを使う

separate_paren_groups = 入力 paren_string に対し {
    空白なし = 文字列化("")
    i = 0
    結果 = []
    現在の括弧 = 文字列化("")
    深さ = 0
    
    文字列の長さ = 文字列化(paren_string)の長さ
    
    i を 0 から 文字列化(文字列化(paren_string)の長さ) - 1 まで繰り返す {
        文字 = paren_string[i]
        
        もし 文字 = 文字列化(" ") ならば {
            続ける
        }
        
        現在の括弧 = 文字列化(現在の括弧) + 文字
        
        もし 文字 = 文字列化("(") ならば {
            深さ = 深さ + 1
        } そうでなく もし 文字 = 文字列化(")") ならば {
            深さ = 深さ - 1
            
            もし 深さ = 0 ならば {
                結果 = 結果 + [現在の括弧]
                現在の括弧 = 文字列化("")
            }
        }
    }
    
    結果を返す
}