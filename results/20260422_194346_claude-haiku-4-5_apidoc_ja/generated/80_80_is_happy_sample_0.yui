標準ライブラリを使う

is_happy = 入力 s に対し {
  もし 整数判定(文字列化(s)の長さ)が偽 ならば {
    長さ = 文字列化(s)の長さ
  } でなければ {
    長さ = s の長さ
  }
  
  もし 長さ < 3 ならば {
    偽を返す
  }
  
  i = 0
  繰り返す i < 長さ - 2 の間 {
    char1 = s[i]
    char2 = s[i + 1]
    char3 = s[i + 2]
    
    もし char1 == char2 または char2 == char3 または char1 == char3 ならば {
      偽を返す
    }
    
    i = i + 1
  }
  
  真を返す
}