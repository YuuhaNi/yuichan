標準ライブラリを使う

minSubArraySum = 入力 nums に対し {
  最小値 = 値なし
  現在の和 = 0
  
  i = 0
  i < 長さ(nums) の間 {
    現在の和 = 和(現在の和, nums[i])
    
    もし 最小値 = 値なし ならば {
      最小値 = 現在の和
    } でなければ {
      最小値 = 最小値(最小値, 現在の和)
    }
    
    もし 現在の和 > 0 ならば {
      現在の和 = 0
    }
    
    i = 和(i, 1)
  }
  
  最小値を返す
}