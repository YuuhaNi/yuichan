標準ライブラリを使う

sort_array = 入力 arr に対し {
  # 2進数表現における"1"の個数をカウントする関数
  count_ones = 入力 n に対し {
    もし n < 0 なら {
      戻す 0
    }
    
    count = 0
    while n > 0 {
      もし 剰余(n, 2) == 1 なら {
        count = 和(count, 1)
      }
      n = 商(n, 2)
    }
    戻す count
  }
  
  # ソート用の比較関数
  # 1の個数で比較し、同じ場合は値で比較
  compare = 入力 a, b に対し {
    ones_a = count_ones(a)
    ones_b = count_ones(b)
    
    もし ones_a == ones_b なら {
      # 1の個数が同じ場合は10進数で比較
      もし a < b なら {
        戻す -1
      } そうでなく もし a > b なら {
        戻す 1
      } そうでなく {
        戻す 0
      }
    } そうでなく {
      # 1の個数で比較
      もし ones_a < ones_b なら {
        戻す -1
      } そうでなく {
        戻す 1
      }
    }
  }
  
  # バブルソートで配列をソート
  n = 長さ(arr)
  i = 0
  while i < n {
    j = 0
    while j < 差(n, 1) {
      もし compare(arr[j], arr[足す(j, 1)]) > 0 なら {
        # スワップ
        temp = arr[j]
        arr[j] = arr[足す(j, 1)]
        arr[足す(j, 1)] = temp
      }
      j = 足す(j, 1)
    }
    i = 足す(i, 1)
  }
  
  戻す arr
}