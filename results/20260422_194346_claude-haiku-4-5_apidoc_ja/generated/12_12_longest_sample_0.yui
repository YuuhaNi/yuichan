標準ライブラリを使う

longest = 入力 strings に対し {
  もし 配列判定(strings) かつ 和(配列化(strings)) = 0 ならば {
    値なし を返す
  }
  
  最長 = strings[0]
  最長の長さ = 文字列化(最長) の 長さ
  
  i = 1 として i < 和(配列化(strings)) の間 {
    現在 = strings[i]
    現在の長さ = 文字列化(現在) の 長さ
    
    もし 現在の長さ > 最長の長さ ならば {
      最長 = 現在
      最長の長さ = 現在の長さ
    }
    
    i = i + 1
  }
  
  最長 を返す
}