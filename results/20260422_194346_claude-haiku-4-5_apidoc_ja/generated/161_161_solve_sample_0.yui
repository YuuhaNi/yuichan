標準ライブラリを使う

solve = 入力 s に対し {
    アルファベット含む = 偽
    結果 = ""
    
    i = 0
    s の長さまで繰り返す {
        文字 = s[i]
        文字コード = 配列化(文字)[0]
        
        もし (文字コード >= 65 かつ 文字コード <= 90) または (文字コード >= 97 かつ 文字コード <= 122) なら {
            アルファベット含む = 真
            
            もし 文字コード >= 65 かつ 文字コード <= 90 なら {
                結果 = 結果 + 文字列化(文字コード + 32)を文字に変換
            } そうでなければ {
                結果 = 結果 + 文字列化(文字コード - 32)を文字に変換
            }
        } そうでなければ {
            結果 = 結果 + 文字
        }
        
        i = i + 1
    }
    
    もし アルファベット含む なら {
        結果を返す
    } そうでなければ {
        逆順結果 = ""
        i = s の長さ - 1
        0 以上 i 以下の間繰り返す {
            逆順結果 = 逆順結果 + s[i]
            i = i - 1
        }
        逆順結果を返す
    }
}