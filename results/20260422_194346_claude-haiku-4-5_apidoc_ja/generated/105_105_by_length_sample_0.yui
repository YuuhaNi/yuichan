標準ライブラリを使う

by_length = 入力 arr に対し {
  数字名 = {
    1: "One",
    2: "Two",
    3: "Three",
    4: "Four",
    5: "Five",
    6: "Six",
    7: "Seven",
    8: "Eight",
    9: "Nine"
  }
  
  フィルタ済み = []
  i = 0
  繰り返す (i < 長さ(arr)) {
    値 = arr[i]
    もし (整数判定(値) かつ 値 >= 1 かつ 値 <= 9) {
      フィルタ済み を追加(値)
    }
    i = i + 1
  }
  
  もし (長さ(フィルタ済み) == 0) {
    戻す []
  }
  
  ソート済み = ソート(フィルタ済み)
  
  逆順 = []
  i = 長さ(ソート済み) - 1
  繰り返す (i >= 0) {
    逆順 を追加(ソート済み[i])
    i = i - 1
  }
  
  結果 = []
  i = 0
  繰り返す (i < 長さ(逆順)) {
    結果 を追加(数字名[逆順[i]])
    i = i + 1
  }
  
  戻す 結果
}