標準ライブラリを使う

pluck = 入力 arr に対し {
  もし 配列判定(arr) が 偽 ならば {
    返す []
  }
  
  もし 和(配列化(arr)) が 0 ならば {
    返す []
  }
  
  最小偶数値 = 値なし
  最小インデックス = 値なし
  
  i = 0
  繰り返す arr の各要素 node に対し {
    もし 剰余(node, 2) が 0 ならば {
      もし 最小偶数値 が 値なし ならば {
        最小偶数値 = node
        最小インデックス = i
      } そうでなく もし node が 最小偶数値 より小さい ならば {
        最小偶数値 = node
        最小インデックス = i
      }
    }
    i = 和(i, 1)
  }
  
  もし 最小偶数値 が 値なし ならば {
    返す []
  }
  
  返す [最小偶数値, 最小インデックス]
}