標準ライブラリを使う

numerical_letter_grade = 入力 grades に対し {
    結果 = []
    
    grades の各要素を gpa として {
        もし gpa == 4.0 ならば {
            結果 = 結果 + ["A+"]
        } そうでなく もし gpa > 3.7 ならば {
            結果 = 結果 + ["A"]
        } そうでなく もし gpa > 3.3 ならば {
            結果 = 結果 + ["A-"]
        } そうでなく もし gpa > 3.0 ならば {
            結果 = 結果 + ["B+"]
        } そうでなく もし gpa > 2.7 ならば {
            結果 = 結果 + ["B"]
        } そうでなく もし gpa > 2.3 ならば {
            結果 = 結果 + ["B-"]
        } そうでなく もし gpa > 2.0 ならば {
            結果 = 結果 + ["C+"]
        } そうでなく もし gpa > 1.7 ならば {
            結果 = 結果 + ["C"]
        } そうでなく もし gpa > 1.3 ならば {
            結果 = 結果 + ["C-"]
        } そうでなく もし gpa > 1.0 ならば {
            結果 = 結果 + ["D+"]
        } そうでなく もし gpa > 0.7 ならば {
            結果 = 結果 + ["D"]
        } そうでなく もし gpa > 0.0 ならば {
            結果 = 結果 + ["D-"]
        } そうでなく {
            結果 = 結果 + ["E"]
        }
    }
    
    結果 を返す
}