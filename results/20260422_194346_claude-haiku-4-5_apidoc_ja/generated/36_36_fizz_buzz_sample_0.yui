標準ライブラリを使う

fizz_buzz = 入力 n に対し {
  カウント = 0
  i = 0
  繰り返す (i < n) {
    もし ((剰余(i, 11) == 0 または 剰余(i, 13) == 0) かつ i != 0) {
      文字列 = 文字列化(i)
      j = 0
      繰り返す (j < 文字列の長さ(文字列)) {
        もし (文字列[j] == "7") {
          カウント = カウント + 1
        }
        j = j + 1
      }
    }
    i = i + 1
  }
  カウント
}