標準ライブラリを使う

count_nums = 入力 arr に対し {
  カウント = 0
  
  i = 0
  i < 配列の長さ(arr) の間 {
    num = arr[i]
    
    # 数値を文字列に変換して処理
    num_str = 文字列化(絶対値(num))
    
    # 各桁の合計を計算
    桁合計 = 0
    j = 0
    j < 文字列の長さ(num_str) の間 {
      桁合計 = 桁合計 + 整数化(文字列の部分(num_str, j, 1))
      j = j + 1
    }
    
    # 負の数の場合は最初の桁を負にする
    もし num < 0 ならば {
      桁合計 = 桁合計 * -1
    }
    
    # 桁合計が正の場合はカウント
    もし 桁合計 > 0 ならば {
      カウント = カウント + 1
    }
    
    i = i + 1
  }
  
  カウント を返す
}