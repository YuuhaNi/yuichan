標準ライブラリを使う

strange_sort_list = 入力 lst に対し {
  もし 配列判定(lst) かつ 和(配列化(lst)) == 0 ならば {
    値 []
  } そうでなければ {
    ソート済み = 組込みソート(lst)
    結果 = []
    左 = 0
    右 = 長さ(ソート済み) - 1
    
    繰り返す 左 <= 右 の間 {
      もし 左 == 右 ならば {
        結果 = 追加(結果, ソート済み[左])
        左 = 左 + 1
      } そうでなければ {
        結果 = 追加(結果, ソート済み[左])
        結果 = 追加(結果, ソート済み[右])
        左 = 左 + 1
        右 = 右 - 1
      }
    }
    
    値 結果
  }
}