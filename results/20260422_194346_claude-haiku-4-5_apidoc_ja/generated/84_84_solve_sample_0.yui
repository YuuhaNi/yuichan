標準ライブラリを使う

solve = 入力 N に対し {
    # 各桁の総和を計算
    桁の総和 = 0
    現在の値 = 絶対値(N)
    
    繰り返す (現在の値 > 0) {
        桁の総和 = 和(桁の総和, 剰余(現在の値, 10))
        現在の値 = 商(現在の値, 10)
    }
    
    # 桁の総和を2進数に変換
    もし (桁の総和 == 0) {
        返す "0"
    }
    
    2進数文字列 = ""
    繰り返す (桁の総和 > 0) {
        2進数文字列 = 文字列化(剰余(桁の総和, 2)) + 2進数文字列
        桁の総和 = 商(桁の総和, 2)
    }
    
    返す 2進数文字列
}