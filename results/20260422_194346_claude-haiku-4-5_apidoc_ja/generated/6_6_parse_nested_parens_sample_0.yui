標準ライブラリを使う

parse_nested_parens = 入力 paren_string に対し {
  グループ = 文字列分割(paren_string, ' ')
  結果 = []
  
  グループごと(グループ, グループ文字列 に対し {
    最大深さ = 0
    現在深さ = 0
    
    文字ごと(グループ文字列, 文字 に対し {
      もし 文字 = '(' なら {
        現在深さ = 和(現在深さ, 1)
        もし 現在深さ > 最大深さ なら {
          最大深さ = 現在深さ
        }
      } そうでなく もし 文字 = ')' なら {
        現在深さ = 差(現在深さ, 1)
      }
    })
    
    配列追加(結果, 最大深さ)
  })
  
  戻す 結果
}