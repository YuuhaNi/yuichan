標準ライブラリを使う

anti_shuffle = 入力 s に対し {
    単語群 = 文字列分割(s, " ")
    結果 = []
    
    単語群の各要素 word に対し {
        文字配列 = 配列化(word)
        ソート済み = 文字配列をソート
        ソート済み文字列 = ""
        
        ソート済みの各要素 char に対し {
            ソート済み文字列 = ソート済み文字列 + 文字コード変換(char)
        }
        
        結果に追加(ソート済み文字列)
    }
    
    結果を" "で結合
}
標準ライブラリを使う

anti_shuffle = 入力 s に対し {
    単語群 = 文字列分割(s, " ")
    処理済み単語群 = []
    
    単語群の各要素 word に対し {
        文字コード列 = 配列化(word)
        ソート済みコード = 文字コード列をソート
        ソート済み単語 = ""
        
        ソート済みコードの各要素 code に対し {
            ソート済み単語 = ソート済み単語 + 文字コード変換(code)
        }
        
        処理済み単語群に追加(ソート済み単語)
    }
    
    処理済み単語群を" "で結合
}