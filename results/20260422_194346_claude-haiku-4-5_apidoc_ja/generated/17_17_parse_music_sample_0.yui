標準ライブラリを使う

parse_music = 入力 music_string に対し {
    音符リスト = 配列化(music_string)
    結果 = []
    
    i = 0
    繰り返す (i < 長さ(音符リスト)) {
        現在 = 音符リスト[i]
        
        もし (現在 == "o") {
            次 = 音符リスト[i + 1]
            もし (次 == "'") {
                結果に4を追加
                i = i + 2
            } そうでなければ {
                i = i + 1
            }
        } そうでなければ もし (現在 == "|") {
            結果に2を追加
            i = i + 1
        } そうでなければ もし (現在 == ".") {
            結果に1を追加
            i = i + 1
        } そうでなければ {
            i = i + 1
        }
    }
    
    結果を返す
}
標準ライブラリを使う

parse_music = 入力 music_string に対し {
    parts = 文字列分割(music_string, " ")
    結果 = []
    
    parts の各要素 note に対し {
        もし (note == "o'") {
            結果に4を追加
        } そうでなければ もし (note == "o|'") {
            結果に2を追加
        } そうでなければ もし (note == ".|」") {
            結果に1を追加
        }
    }
    
    結果を返す
}