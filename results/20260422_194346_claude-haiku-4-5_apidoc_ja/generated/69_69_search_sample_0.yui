標準ライブラリを使う

search = 入力 lst に対し {
  結果 = -1
  
  i = 0
  i < 長さ(lst) の間 {
    num = lst[i]
    頻度 = 0
    
    j = 0
    j < 長さ(lst) の間 {
      lst[j] == num ならば {
        頻度 = 頻度 + 1
      }
      j = j + 1
    }
    
    num > 0 かつ 頻度 >= num かつ num > 結果 ならば {
      結果 = num
    }
    
    i = i + 1
  }
  
  結果
}