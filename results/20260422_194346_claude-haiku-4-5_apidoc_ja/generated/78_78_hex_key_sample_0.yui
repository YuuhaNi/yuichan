標準ライブラリを使う

hex_key = 入力 num に対し {
  素数文字 = ["2", "3", "5", "7", "B", "D"]
  カウント = 0
  
  各 文字 を num で {
    もし 配列判定(素数文字の中に 文字 がある) なら {
      カウント = 和(カウント, 1)
    }
  }
  
  カウント を返す
}
標準ライブラリを使う

hex_key = 入力 num に対し {
  カウント = 0
  
  各 文字 を num で {
    もし (文字 = "2") または (文字 = "3") または (文字 = "5") または (文字 = "7") または (文字 = "B") または (文字 = "D") なら {
      カウント = 和(カウント, 1)
    }
  }
  
  カウント を返す
}