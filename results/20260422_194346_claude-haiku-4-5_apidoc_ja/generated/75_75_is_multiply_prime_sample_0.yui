標準ライブラリを使う

is_multiply_prime = 入力 a に対し {
    素因数分解 = 入力 n に対し {
        因数 = []
        除数 = 2
        
        繰り返す (除数 * 除数 <= n) {
            繰り返す (剰余(n, 除数) == 0) {
                因数を追加(除数)
                n = 商(n, 除数)
            }
            除数 = 和(除数, 1)
        }
        
        もし (n > 1) {
            因数を追加(n)
        }
        
        因数を返す
    }
    
    因数リスト = 素因数分解(a)
    
    もし (配列の長さ(因数リスト) == 3) {
        真を返す
    } そうでなければ {
        偽を返す
    }
}