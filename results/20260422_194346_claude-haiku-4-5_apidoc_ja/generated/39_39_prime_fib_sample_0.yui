標準ライブラリを使う

prime_fib = 入力 n に対し {
    素数判定 = 入力 num に対し {
        もし num < 2 ならば {
            偽を返す
        }
        もし num == 2 ならば {
            真を返す
        }
        もし 剰余(num, 2) == 0 ならば {
            偽を返す
        }
        i = 3
        ループ i * i <= num の間 {
            もし 剰余(num, i) == 0 ならば {
                偽を返す
            }
            i = 和(i, 2)
        }
        真を返す
    }
    
    count = 0
    a = 1
    b = 1
    
    ループ count < n の間 {
        c = 和(a, b)
        もし 素数判定(c) ならば {
            count = 和(count, 1)
            もし count == n ならば {
                c を返す
            }
        }
        a = b
        b = c
    }
}