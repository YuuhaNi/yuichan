標準ライブラリを使う

skjkasdkd = 入力 lst に対し {
  素数判定 = 関数 n に対し {
    もし n < 2 ならば {
      偽を返す
    }
    もし n == 2 ならば {
      真を返す
    }
    もし 剰余(n, 2) == 0 ならば {
      偽を返す
    }
    i = 3
    繰り返す i * i <= n の間 {
      もし 剰余(n, i) == 0 ならば {
        偽を返す
      }
      i = i + 2
    }
    真を返す
  }

  最大素数 = 0
  各 num を lst で {
    もし 素数判定(num) かつ num > 最大素数 ならば {
      最大素数 = num
    }
  }

  桁数和 = 0
  各 digit を 配列化(文字列化(最大素数)) で {
    桁数和 = 桁数和 + 整数化(文字(digit))
  }

  桁数和を返す
}
標準ライブラリを使う

skjkasdkd = 入力 lst に対し {
  素数判定 = 関数 n に対し {
    もし n < 2 ならば {
      偽を返す
    }
    もし n == 2 ならば {
      真を返す
    }
    もし 剰余(n, 2) == 0 ならば {
      偽を返す
    }
    i = 3
    繰り返す i * i <= n の間 {
      もし 剰余(n, i) == 0 ならば {
        偽を返す
      }
      i = i + 2
    }
    真を返す
  }

  最大素数 = 0
  各 num を lst で {
    もし 素数判定(num) かつ num > 最大素数 ならば {
      最大素数 = num
    }
  }

  桁数和 = 0
  各 digit を 文字列化(最大素数) で {
    桁数和 = 桁数和 + 整数化(digit)
  }

  桁数和を返す
}