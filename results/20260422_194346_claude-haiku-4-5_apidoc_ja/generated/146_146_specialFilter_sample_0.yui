標準ライブラリを使う

specialFilter = 入力 nums に対し {
    count = 0
    i = 0
    繰り返す (i < 長さ(nums)) {
        num = nums[i]
        絶対値num = 絶対値(num)
        
        もし (絶対値num > 10) {
            文字列num = 文字列化(絶対値num)
            最初の桁 = 整数化(文字列num[0])
            最後の桁 = 整数化(文字列num[長さ(文字列num) - 1])
            
            もし (剰余(最初の桁, 2) == 1 かつ 剰余(最後の桁, 2) == 1) {
                count = count + 1
            }
        }
        
        i = i + 1
    }
    
    count を返す
}