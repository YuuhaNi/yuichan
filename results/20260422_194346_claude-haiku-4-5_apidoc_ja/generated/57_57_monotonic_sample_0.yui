標準ライブラリを使う

monotonic = 入力 l に対し {
  もし 配列判定(l) でなければ {
    偽を返す
  }
  
  もし 和([配列判定(l)]) = 0 ならば {
    真を返す
  }
  
  i = 0
  increasing = 真
  decreasing = 真
  
  繰り返す i を 0 から 差(配列長(l), 1) まで {
    もし l[i] > l[差(i, 1)] ならば {
      decreasing = 偽
    }
    もし l[i] < l[差(i, 1)] ならば {
      increasing = 偽
    }
  }
  
  もし 論理和(increasing, decreasing) ならば {
    真を返す
  } でなければ {
    偽を返す
  }
}