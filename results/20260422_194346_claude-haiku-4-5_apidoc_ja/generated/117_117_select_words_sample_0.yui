標準ライブラリを使う

select_words = 入力 s, n に対し {
    子音 = "bcdfghjklmnpqrstvwxyzBCDFGHJKLMNPQRSTVWXYZ"
    単語リスト = 文字列分割(s, " ")
    結果 = []
    
    繰り返し 単語 を 単語リスト で {
        子音数 = 0
        繰り返し 文字 を 配列化(単語) で {
            文字列 = 文字列化(文字)
            もし 文字列を含む(子音, 文字列) ならば {
                子音数 = 子音数 + 1
            }
        }
        もし 子音数 = n ならば {
            配列に追加(結果, 単語)
        }
    }
    
    結果を返す
}