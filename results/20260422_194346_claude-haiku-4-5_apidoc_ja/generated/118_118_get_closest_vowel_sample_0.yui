標準ライブラリを使う

get_closest_vowel = 入力 word に対し {
  母音 = "aeiouAEIOU"
  長さ = 文字列長(word)
  
  もし 長さ < 3 ならば {
    ""を返す
  }
  
  結果 = ""
  最小距離 = 長さ
  
  i = 1 から 長さ - 2 まで 1 ずつ {
    現在文字 = 文字列[word, i]
    
    もし 文字列に含まれるか(母音, 現在文字) ならば {
      左文字 = 文字列[word, i - 1]
      右文字 = 文字列[word, i + 1]
      
      左は子音か = 文字列に含まれるか(母音, 左文字) = 偽
      右は子音か = 文字列に含まれるか(母音, 右文字) = 偽
      
      もし 左は子音か かつ 右は子音か ならば {
        距離 = 最小値(i - 0, 長さ - 1 - i)
        
        もし 距離 < 最小距離 ならば {
          結果 = 現在文字
          最小距離 = 距離
        }
      }
    }
  }
  
  結果を返す
}