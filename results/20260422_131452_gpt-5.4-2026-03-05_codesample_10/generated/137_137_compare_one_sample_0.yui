標準ライブラリを使う

compare_one=入力a,bに対し{
   sa=""
   sb=""
   va=0.0
   vb=0.0

   もし文字列判定(a)ならば{
      sa=a
   }
   そうでなければ{
      sa=文字列化(a)
   }

   もし文字列判定(b)ならば{
      sb=b
   }
   そうでなければ{
      sb=文字列化(b)
   }

   va=小数化(sa)
   vb=小数化(sb)

   もしvaがvbより大きいならば{
      aが答え
   }
   そうでなければ{
      もしvbがvaより大きいならば{
         bが答え
      }
      そうでなければ{
         値なしが答え
      }
   }
}