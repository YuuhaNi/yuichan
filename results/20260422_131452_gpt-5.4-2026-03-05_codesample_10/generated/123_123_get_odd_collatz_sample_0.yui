標準ライブラリを使う

get_odd_collatz = 入力 n に対し {
   odds=[]
   x=n

   くり返す{
      # 奇数なら記録
      もし剰余(x,2)が1ならば{
         oddsにxを追加する
      }

      # 1 に到達したら終了
      もしxが1ならば{
         くり返しを抜ける
      }

      # 次のコラッツ項へ
      もし剰余(x,2)が0ならば{
         x=商(x,2)
      }
      そうでなければ{
         x=和(積(3,x),1)
      }
   }

   # 昇順ソート
   n2=oddsの大きさ
   i=0
   n2回くり返す{
      j=0
      lim=差(n2,1)
      lim回くり返す{
         a=odds[j]
         b=odds[和(j,1)]
         もしaがbより大きいならば{
            odds[j]=b
            odds[和(j,1)]=a
         }
         jを増やす
      }
      iを増やす
   }

   oddsが答え
}