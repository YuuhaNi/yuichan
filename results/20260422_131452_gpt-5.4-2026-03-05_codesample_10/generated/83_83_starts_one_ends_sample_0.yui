標準ライブラリを使う

starts_one_ends = 入力 n に対し {
   # n桁の正の整数は 10^(n-1) 個
   total=1
   i=1
   nより小さい間くり返す{
      total=積(total,10)
      iを増やす
   }

   # 先頭が1のもの: 10^(n-1) 個のうち下位 n-1 桁は自由
   starts=1
   i=1
   nより小さい間くり返す{
      starts=積(starts,10)
      iを増やす
   }

   # 末尾が1のもの: 10^(n-1) 個
   ends=starts

   # 両方満たすもの: n=1 でも 1 個、n>=2 でも中間桁が自由で 10^(n-2) 個
   both=1
   もしnが2以上ならば{
      i=2
      nより小さい間くり返す{
         both=積(both,10)
         iを増やす
      }
   }

   # 包除原理
   差(和(starts,ends),both)が答え
}