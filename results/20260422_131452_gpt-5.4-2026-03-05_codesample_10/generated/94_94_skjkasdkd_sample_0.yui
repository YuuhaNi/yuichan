標準ライブラリを使う

skjkasdkd = 入力 lst に対し {
   is_prime=入力nに対し{
      もしnが2より小さいならば{
         偽が答え
      }
      d=2
      1000000回くり返す{
         もし積(d,d)がnより大きいならば{
            くり返しを抜ける
         }
         もし剰余(n,d)が0ならば{
            偽が答え
         }
         dを増やす
      }
      真が答え
   }

   maxp=0
   n=lstの大きさ
   i=0
   n回くり返す{
      x=lst[i]
      もしis_prime(x)ならば{
         もしxがmaxpより大きいならば{
            maxp=x
         }
      }
      iを増やす
   }

   s=文字列化(maxp)
   total=0
   m=sの大きさ
   j=0
   m回くり返す{
      total=和(total,差(s[j],48))
      jを増やす
   }
   totalが答え
}