標準ライブラリを使う

solve = 入力 N に対し {
   sum=0
   x=N

   もしxが0ならば{
      sum=0
   }
   そうでなければ{
      100回くり返す{
         もしxが0ならば{
            くり返しを抜ける
         }
         sum=和(sum,剰余(x,10))
         x=商(x,10)
      }
   }

   もしsumが0ならば{
      "0"が答え
   }

   bits=""
   y=sum
   100回くり返す{
      もしyが0ならば{
         くり返しを抜ける
      }
      bit=剰余(y,2)
      bits="{文字列化(bit)}{bits}"
      y=商(y,2)
   }
   bitsが答え
}