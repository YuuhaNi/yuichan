標準ライブラリを使う

fix_spaces = 入力 text に対し {
   result=""
   n=textの大きさ
   i=0

   n回くり返す{
      c=text[i]
      もしcが32ならば{
         count=0
         n回くり返す{
            もしiがn以上ならば{
               くり返しを抜ける
            }
            もしtext[i]が32ならば{
               countを増やす
               iを増やす
            }
            そうでなければ{
               くり返しを抜ける
            }
         }
         もしcountが1ならば{
            resultに95を追加する
         }
         そうでなければ{
            resultに45を追加する
         }
      }
      そうでなければ{
         resultにcを追加する
         iを増やす
      }
   }

   resultが答え
}