標準ライブラリを使う

odd_count = 入力lstに対し{
   result=[]
   n=lstの大きさ
   i=0
   n回くり返す{
      s=lst[i]
      count=0
      m=sの大きさ
      j=0
      m回くり返す{
         c=s[j]
         もしcが49ならば{ countを増やす }
         もしcが51ならば{ countを増やす }
         もしcが53ならば{ countを増やす }
         もしcが55ならば{ countを増やす }
         もしcが57ならば{ countを増やす }
         jを増やす
      }
      msg="the number of odd elements {count}n the str{count}ng {count} of the {count}nput."
      resultにmsgを追加する
      iを増やす
   }
   resultが答え
}