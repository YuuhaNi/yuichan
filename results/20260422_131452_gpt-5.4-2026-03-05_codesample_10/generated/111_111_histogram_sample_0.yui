標準ライブラリを使う

histogram = 入力 test に対し {
   もしtestが""ならば{
      {}が答え
   }

   counts={}
   token=""
   n=testの大きさ
   i=0

   n回くり返す{
      c=test[i]
      もしcが" "ならば{
         もしtokenが""でないならば{
            もしcounts[token]が値なしならば{
               counts[token]=1
            }
            そうでなければ{
               counts[token]を増やす
            }
            token=""
         }
      }
      そうでなければ{
         token="{token}{c}"
      }
      iを増やす
   }

   もしtokenが""でないならば{
      もしcounts[token]が値なしならば{
         counts[token]=1
      }
      そうでなければ{
         counts[token]を増やす
      }
   }

   result={}
   max_count=0

   もしcounts["a"]が値なしでないならば{
      v=counts["a"]
      もしvがmax_countより大きいならば{
         max_count=v
         result={"a":v}
      }
      そうでなければ{
         もしvがmax_countならば{
            result["a"]=v
         }
      }
   }
