標準ライブラリを使う

exchange = 入力 lst1, lst2 に対し {
   odd1=0
   even2=0

   n1=lst1の大きさ
   i=0
   n1回くり返す{
      x=lst1[i]
      もし剰余(x,2)が1ならば{
         odd1を増やす
      }
      iを増やす
   }

   n2=lst2の大きさ
   j=0
   n2回くり返す{
      y=lst2[j]
      もし剰余(y,2)が0ならば{
         even2を増やす
      }
      jを増やす
   }

   もしeven2がodd1以上ならば{
      "YES"が答え
   }
   そうでなければ{
      "NO"が答え
   }
}