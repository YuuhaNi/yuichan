標準ライブラリを使う

triples_sum_to_zero = 入力 l に対し {
   n=lの大きさ
   もしnが3より小さいならば{
      偽が答え
   }

   i=0
   n回くり返す{
      j=和(i,1)
      残りj回数=差(n,j)
      残りj回数回くり返す{
         k=和(j,1)
         残りk回数=差(n,k)
         残りk回数回くり返す{
            s=和(l[i],l[j],l[k])
            もしsが0ならば{
               真が答え
            }
            kを増やす
         }
         jを増やす
      }
      iを増やす
   }

   偽が答え
}