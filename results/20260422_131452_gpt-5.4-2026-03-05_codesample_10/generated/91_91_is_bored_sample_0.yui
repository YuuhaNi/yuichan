標準ライブラリを使う

is_bored = 入力 S に対し {
   count=0
   at_start=真
   n=Sの大きさ
   i=0

   n回くり返す{
      c=S[i]

      もしat_startならば{
         もしcが32ならば{
            何もしない
         }
         そうでなければ{
            もしcが73ならば{
               ni=和(i,1)
               もしniがnより小さいならば{
                  もしS[ni]が32ならば{
                     countを増やす
                  }
               }
            }
            at_start=偽
         }
      }

      もしcが46ならば{
         at_start=真
      }
      もしcが63ならば{
         at_start=真
      }
      もしcが33ならば{
         at_start=真
      }

      iを増やす
   }

   countが答え
}