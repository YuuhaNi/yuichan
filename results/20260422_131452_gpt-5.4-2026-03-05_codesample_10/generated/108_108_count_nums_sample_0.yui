標準ライブラリを使う

count_nums = 入力 arr に対し {
   count=0
   n=arrの大きさ
   i=0

   n回くり返す{
      x=arr[i]
      s=0

      もしxが0より小さいならば{
         y=差(0,x)
         first=剰余(y,10)
         s=差(0,first)
         y=商(y,10)
         y回くり返す{
            s=和(s,剰余(y,10))
            y=商(y,10)
         }
      }
      そうでなければ{
         y=x
         もしyが0ならば{
            何もしない
         }
         そうでなければ{
            y回くり返す{
               s=和(s,剰余(y,10))
               y=商(y,10)
            }
         }
      }

      もしsが0より大きいならば{
         countを増やす
      }
      iを増やす
   }

   countが答え
}