標準ライブラリを使う

fizz_buzz = 入力 n に対し {
   count=0
   i=0
   n回くり返す{
      hit=偽
      もし剰余(i,11)が0ならば{
         hit=真
      }
      もし剰余(i,13)が0ならば{
         hit=真
      }
      もしhitならば{
         s=文字列化(i)
         j=0
         m=sの大きさ
         m回くり返す{
            もしs[j]が"7"ならば{
               countを増やす
            }
            jを増やす
         }
      }
      iを増やす
   }
   countが答え
}