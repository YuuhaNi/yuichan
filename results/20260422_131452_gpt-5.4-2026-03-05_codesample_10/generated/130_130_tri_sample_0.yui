標準ライブラリを使う

tri=入力nに対し{
   # tri(0)=1 として、0 から n までを配列で返す
   result=[1]
   もしnが0ならば{
      resultが答え
   }

   # 1..n を順に求める
   i=1
   n回くり返す{
      value=0

      # tri(1)=3
      もしiが1ならば{
         value=3
      }
      そうでなければ{
         # 偶数なら tri(i)=1+i/2
         もし剰余(i,2)が0ならば{
            value=和(1,商(i,2))
         }
         そうでなければ{
            # 奇数なら tri(i)=tri(i-1)+tri(i-2)+tri(i+1)
            # ただし i+1 は偶数なので 1+(i+1)/2 で直接求める
            a=result[差(i,1)]
            b=result[差(i,2)]
            next_even=和(1,商(和(i,1),2))
            value=和(a,b,next_even)
         }
      }

      resultにvalueを追加する
      iを増やす
   }
   resultが答え
}