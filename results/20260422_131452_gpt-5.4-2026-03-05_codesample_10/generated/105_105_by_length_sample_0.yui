標準ライブラリを使う

by_length = 入力 arr に対し {
   counts=[0,0,0,0,0,0,0,0,0]
   n=arrの大きさ
   i=0

   n回くり返す{
      x=arr[i]
      もしxが1以上ならば{
         もしxが9以下ならば{
            idx=差(x,1)
            counts[idx]を増やす
         }
      }
      iを増やす
   }

   result=[]
   d=9
   9回くり返す{
      idx=差(d,1)
      c=counts[idx]

      c回くり返す{
         name=""
         もしdが1ならば{
            name="One"
         }
         そうでなければ{
            もしdが2ならば{
               name="Two"
            }
            そうでなければ{
               もしdが3ならば{
                  name="Three"
               }
               そうでなければ{
                  もしdが4ならば{
                     name="Four"
                  }
                  そうでなければ{
                     もしdが5ならば{
                        name="Five"
                     }
                     そうでなければ{
                        もしdが6ならば{
                           name="Six"
                        }
                        そうでなければ{
                           もしdが7ならば{
                              name="Seven"
                           }
                           そうでなければ{
                              もしdが8ならば{
                                 name="Eight"
                              }
                              そうでなければ{
                                 もしdが9ならば{
                                    name="Nine"
                                 }
                              }
                           }
                        }
                     }
                  }
               }
            }
         }
         resultにnameを追加する
      }

      d=差(d,1)
   }

   resultが答え
}