標準ライブラリを使う

rounded_avg = 入力 n, m に対し {
   もしnがmより大きいならば{
      -1が答え
   }

   total=和(n,m)
   avg=商(total,2)

   # 和が奇数なら .5 になるので、最も近い整数として切り上げる
   もし剰余(total,2)が1ならば{
      avgを増やす
   }

   bits=""
   x=avg

   もしxが0ならば{
      "0b0"が答え
   }

   0回くり返す{
      何もしない
   }

   # 2進数文字列を下位桁から作って前に連結する
   1000回くり返す{
      もしxが0ならば{
         くり返しを抜ける
      }
      d=剰余(x,2)
      bits="{d}{bits}"
      x=商(x,2)
   }

   "0b{bits}"が答え
}