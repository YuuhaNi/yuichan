標準ライブラリを使う

match_parens = 入力 lst に対し {
   a=lst[0]
   b=lst[1]

   check=入力sに対し{
      bal=0
      n=sの大きさ
      i=0
      n回くり返す{
         c=s[i]
         もしcが40ならば{
            balを増やす
         }
         そうでなければ{
            balを減らす
         }
         もしbalが0より小さいならば{
            "No"が答え
         }
         iを増やす
      }
      もしbalが0ならば{
         "Yes"が答え
      }
      そうでなければ{
         "No"が答え
      }
   }

   s1="{a}{b}"
   もしcheck(s1)が"Yes"ならば{
      "Yes"が答え
   }

   s2="{b}{a}"
   check(s2)が答え
}