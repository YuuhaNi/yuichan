標準ライブラリを使う

solve = 入力 s に対し {
   result=""
   has_alpha=偽
   n=sの大きさ
   i=0

   n回くり返す{
      c=s[i]
      nc=c

      # 小文字 a..z → 大文字
      もしcが97以上ならば{
         もしcが122以下ならば{
            nc=差(c,32)
            has_alpha=真
         }
      }

      # 大文字 A..Z → 小文字
      もしcが65以上ならば{
         もしcが90以下ならば{
            nc=和(c,32)
            has_alpha=真
         }
      }

      resultにncを追加する
      iを増やす
   }

   もしhas_alphaならば{
      resultが答え
   }
   そうでなければ{
      rev=""
      i=差(n,1)
      n回くり返す{
         revにs[i]を追加する
         iを減らす
      }
      revが答え
   }
}