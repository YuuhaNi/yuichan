標準ライブラリを使う

count_distinct_characters = 入力 string に対し {
   seen=[]
   count=0
   n=stringの大きさ
   i=0

   n回くり返す{
      c=string[i]

      # 大文字なら小文字にそろえる
      もしcが65以上ならば{
         もしcが90以下ならば{
            c=和(c,32)
         }
      }

      found=偽
      m=seenの大きさ
      j=0
      m回くり返す{
         もしseen[j]がcならば{
            found=真
         }
         jを増やす
      }

      もしfoundが偽ならば{
         seenにcを追加する
         countを増やす
      }

      iを増やす
   }

   countが答え
}