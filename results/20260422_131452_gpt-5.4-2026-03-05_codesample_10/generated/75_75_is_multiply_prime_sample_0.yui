標準ライブラリを使う

is_multiply_prime = 入力 a に対し {
   # 3つの素数 p,q,r の積 a = p*q*r を満たすか調べる
   もしaが2より小さいならば{
      偽が答え
   }

   p=2
   100回くり返す{
      もし積(積(p,p),p)がaより大きいならば{
         くり返しを抜ける
      }

      # p が素数か判定
      p_prime=真
      d=2
      100回くり返す{
         もしdがpならば{
            くり返しを抜ける
         }
         もし剰余(p,d)が0ならば{
            p_prime=偽
            くり返しを抜ける
         }
         dを増やす
      }

      もしp_primeならば{
         q=2
         100回くり返す{
            もし積(積(p,q),q)がaより大きいならば{
               くり返しを抜ける
            }

            # q が素数か判定
            q_prime=真
            e=2
            100回くり返す{
               もしeがqならば{
                  くり返しを抜ける
               }
               もし剰余(q,e)が0ならば{
                  q_prime=偽
                  くり返しを抜ける
               }
               eを増やす
            }

            もしq_primeならば{
               pq=積(p,q)
               もし剰余(a,pq)が0ならば{
                  r=商(a,pq)
                  # r が素数か判定
                  もしrが2以上ならば{
                     r_prime=真
                     f=2
                     100回くり返す{
                        もしfがrならば{
                           くり返しを抜ける
                        }
                        もし剰余(r,f)が0ならば{
                           r_prime=偽
                           くり返しを抜ける
                        }
                        fを増やす
                     }
                     もしr_primeならば{
                        真が答え
                     }
                  }
               }
            }
            qを増やす
         }
      }
      pを増やす
   }

   偽が答え
}