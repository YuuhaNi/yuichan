標準ライブラリを使う

cycpattern_check = 入力 a, b に対し {
   na=aの大きさ
   nb=bの大きさ

   もしnbが0ならば{
      真が答え
   }

   bb=""
   i=0
   nb回くり返す{
      bbにb[i]を追加する
      iを増やす
   }
   i=0
   nb回くり返す{
      bbにb[i]を追加する
      iを増やす
   }

   limit=差(na,nb)
   もしlimitが0より小さいならば{
      偽が答え
   }

   start=0
   candidate_count=和(limit,1)
   candidate_count回くり返す{
      k=0
      nb回くり返す{
         もしa[和(start,k)]がbb[和(start,k)]以外ならば{
            くり返しを抜ける
         }
         kを増やす
      }
      もしkがnbならば{
         真が答え
      }
      startを増やす
   }

   偽が答え
}