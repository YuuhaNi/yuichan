標準ライブラリを使う

get_max_triples = 入力 n に対し {
   a=[]
   i=1
   n回くり返す{
      x=和(差(積(i,i),i),1)
      aにxを追加する
      iを増やす
   }

   c1=[]
   c0=[]
   c2=[]
   i=0
   n回くり返す{
      x=a[i]
      r=剰余(x,3)
      もしrが1ならば{
         c1にxを追加する
      }
      もしrが0ならば{
         c0にxを追加する
      }
      もしrが2ならば{
         c2にxを追加する
      }
      iを増やす
   }

   もしc1の大きさが3以上ならば{
      [c1[0],c1[1],c1[2]]が答え
   }
   そうでなければ{
      もしc0の大きさが1以上ならば{
         もしc1の大きさが1以上ならば{
            もしc2の大きさが1以上ならば{
               [c0[0],c1[0],c2[0]]が答え
            }
         }
      }
   }

   値なしが答え
}