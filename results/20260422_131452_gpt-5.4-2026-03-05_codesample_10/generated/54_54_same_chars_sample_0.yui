標準ライブラリを使う

same_chars = 入力 s0, s1 に対し {
   seen0={}
   seen1={}

   n0=s0の大きさ
   i=0
   n0回くり返す{
      c=s0[i]
      seen0[c]=真
      iを増やす
   }

   n1=s1の大きさ
   j=0
   n1回くり返す{
      c=s1[j]
      seen1[c]=真
      jを増やす
   }

   k0=seen0のキー列
   m0=k0の大きさ
   a=0
   m0回くり返す{
      key=k0[a]
      もしseen1[key]が真以外ならば{
         偽が答え
      }
      aを増やす
   }

   k1=seen1のキー列
   m1=k1の大きさ
   b=0
   m1回くり返す{
      key=k1[b]
      もしseen0[key]が真以外ならば{
         偽が答え
      }
      bを増やす
   }

   真が答え
}