標準ライブラリを使う

encode = 入力 message に対し {
   result=""
   n=messageの大きさ
   i=0
   n回くり返す{
      c=message[i]
      nc=c

      # まず大文字小文字を入れ替える
      もしcが65以上ならば{
         もしcが90以下ならば{
            nc=和(c,32)
         }
      }
      もしcが97以上ならば{
         もしcが122以下ならば{
            nc=差(c,32)
         }
      }

      # 入れ替え後の母音を 2 つ前の文字に置換
      もしncが"A"ならば{ nc="C" }
      もしncが"E"ならば{ nc="G" }
      もしncが"I"ならば{ nc="K" }
      もしncが"O"ならば{ nc="Q" }
      もしncが"U"ならば{ nc="W" }
      もしncが"a"ならば{ nc="c" }
      もしncが"e"ならば{ nc="g" }
      もしncが"i"ならば{ nc="k" }
      もしncが"o"ならば{ nc="q" }
      もしncが"u"ならば{ nc="w" }

      resultにncを追加する
      iを増やす
   }
   resultが答え
}