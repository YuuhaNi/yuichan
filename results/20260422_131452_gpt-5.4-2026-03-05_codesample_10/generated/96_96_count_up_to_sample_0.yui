標準ライブラリを使う

count_up_to = 入力 n に対し {
   primes=[]
   i=2
   もしnが2より小さいならば{
      primesが答え
   }

   差(n,2)回くり返す{
      is_prime=真
      d=2

      差(i,2)回くり返す{
         もし剰余(i,d)が0ならば{
            is_prime=偽
         }
         dを増やす
      }

      もしis_primeならば{
         primesにiを追加する
      }
      iを増やす
   }

   primesが答え
}