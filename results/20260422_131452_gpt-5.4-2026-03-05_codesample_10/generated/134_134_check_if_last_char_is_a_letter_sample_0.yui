標準ライブラリを使う

check_if_last_char_is_a_letter = 入力 txt に対し {
   n=txtの大きさ
   もしnが0ならば{
      偽が答え
   }

   last=txt[差(n,1)]

   # 最後の文字が英字かどうか
   is_letter=偽
   もしlastが65以上ならば{
      もしlastが90以下ならば{
         is_letter=真
      }
   }
   もしlastが97以上ならば{
      もしlastが122以下ならば{
         is_letter=真
      }
   }

   もしis_letterが偽ならば{
      偽が答え
   }

   # 最後の文字の直前がスペースなら、単独の1文字単語
   もしnが1ならば{
      真が答え
   }

   prev=txt[差(n,2)]
   もしprevが32ならば{
      真が答え
   }
   そうでなければ{
      偽が答え
   }
}