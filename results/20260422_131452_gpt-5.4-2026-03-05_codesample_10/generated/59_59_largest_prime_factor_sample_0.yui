標準ライブラリを使う

largest_prime_factor = 入力 n に対し {
   factor=2
   last=1

   # 2 で割れるだけ割る
   もし剰余(n,2)が0ならば{
      last=2
      くり返す{
         もし剰余(n,2)が0ならば{
            n=商(n,2)
         }
         そうでなければ{
            くり返しを抜ける
         }
      }
   }

   factor=3
   # 奇数の候補で割れるだけ割っていく
   くり返す{
      もし積(factor,factor)がnより大きいならば{
         くり返しを抜ける
      }

      もし剰余(n,factor)が0ならば{
         last=factor
         くり返す{
            もし剰余(n,factor)が0ならば{
               n=商(n,factor)
            }
            そうでなければ{
               くり返しを抜ける
            }
         }
      }

      factor=和(factor,2)
   }

   # まだ 1 より大きいものが残っていれば、それ自体が最大の素因数
   もしnが1より大きいならば{
      nが答え
   }
   そうでなければ{
      lastが答え
   }
}