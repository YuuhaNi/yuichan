標準ライブラリを使う

valid_date = 入力 date に対し {
   もしdateが""ならば{
      偽が答え
   }

   parts = dateを"-"で分割
   もしpartsの大きさが3以外ならば{
      偽が答え
   }

   mm_text = parts[0]
   dd_text = parts[1]
   yyyy_text = parts[2]

   もしmm_textの大きさが2以外ならば{
      偽が答え
   }
   もしdd_textの大きさが2以外ならば{
      偽が答え
   }
   もしyyyy_textの大きさが4以外ならば{
      偽が答え
   }

   m = 整数化(mm_text)
   d = 整数化(dd_text)

   もしmが1以下ならば{
      偽が答え
   }
   もしmが12より大きいならば{
      偽が答え
   }

   もしdが1より小さいならば{
      偽が答え
   }

   もしmが[1,3,5,7,8,10,12]のいずれかならば{
      もしdが31以下ならば{
         真が答え
      }
      そうでなければ{
         偽が答え
      }
   }

   もしmが[4,6,9,11]のいずれかならば{
      もしdが30以下ならば{
         真が答え
      }
      そうでなければ{
         偽が答え
      }
   }

   もしmが2ならば{
      もしdが29以下ならば{
         真が答え
      }
      そうでなければ{
         偽が答え
      }
   }

   偽が答え
}