標準ライブラリを使う

words_in_sentence = 入力 sentence に対し {
   result=""
   word=""
   n=sentenceの大きさ
   i=0

   is_prime=入力xに対し{
      もしxが2より小さいならば{
         偽が答え
      }
      d=2
      100回くり返す{
         もし積(d,d)がxより大きいならば{
            くり返しを抜ける
         }
         もし剰余(x,d)が0ならば{
            偽が答え
         }
         dを増やす
      }
      真が答え
   }

   n回くり返す{
      c=sentence[i]
      もしcが32ならば{
         もしis_prime(wordの大きさ)ならば{
            もしresultが""ならば{
               result=word
            }
            そうでなければ{
               result="{result} {word}"
            }
         }
         word=""
      }
      そうでなければ{
         wordにcを追加する
      }
      iを増やす
   }

   もしis_prime(wordの大きさ)ならば{
      もしresultが""ならば{
         result=word
      }
      そうでなければ{
         result="{result} {word}"
      }
   }

   resultが答え
}