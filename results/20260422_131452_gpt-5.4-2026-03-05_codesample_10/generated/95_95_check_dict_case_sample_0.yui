標準ライブラリを使う

check_dict_case = 入力dictに対し{
   keys=dict["keys"]
   もしkeysの大きさが0ならば{
      偽が答え
   }

   has_lower=偽
   has_upper=偽

   n=keysの大きさ
   i=0
   n回くり返す{
      k=keys[i]

      もし文字列判定(k)が偽ならば{
         偽が答え
      }

      is_lower=真
      is_upper=真

      m=kの大きさ
      j=0
      m回くり返す{
         c=k[j]

         もしcが97以上ならば{
            もしcが122以下ならば{
               何もしない
            }
            そうでなければ{
               is_upper=偽
               is_lower=偽
            }
         }
         そうでなければ{
            もしcが65以上ならば{
               もしcが90以下ならば{
                  何もしない
               }
               そうでなければ{
                  is_upper=偽
                  is_lower=偽
               }
            }
            そうでなければ{
               is_upper=偽
               is_lower=偽
            }
         }

         もしcが97以上ならば{
            もしcが122以下ならば{
               is_upper=偽
            }
         }

         もしcが65以上ならば{
            もしcが90以下ならば{
               is_lower=偽
            }
         }

         jを増やす
      }

      もしis_lowerならば{
         has_lower=真
      }
      そうでなければ{
         もしis_upperならば{
            has_upper=真
         }
         そうでなければ{
            偽が答え
         }
      }

      iを増やす
   }

   もしhas_lowerならば{
      真が答え
   }
   そうでなければ{
      偽が答え
   }
}