標準ライブラリを使う

separate_paren_groups = 入力 paren_string に対し {
   groups=[]
   current=""
   depth=0

   n=paren_stringの大きさ
   i=0
   n回くり返す{
      c=paren_string[i]

      もしcが" "ならば{
         何もしない
      }
      そうでなければ{
         current="{current}{c}"

         もしcが"("ならば{
            depthを増やす
         }
         そうでなければ{
            もしcが")"ならば{
               depthを減らす
               もしdepthが0ならば{
                  groupsにcurrentを追加する
                  current=""
               }
            }
         }
      }

      iを増やす
   }

   groupsが答え
}