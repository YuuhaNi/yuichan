標準ライブラリを使う

sort_array = 入力 arr に対し {
   n=arrの大きさ
   i=0
   n回くり返す{
      j=0
      limit=差(差(n,1),i)
      limit回くり返す{
         a=arr[j]
         b=arr[和(j,1)]

         ca=0
         cb=0

         ta=a
         tb=b

         もしtaが0より小さいならば{
            ta=差(0,ta)
         }
         もしtbが0より小さいならば{
            tb=差(0,tb)
         }

         もしtaが0ならば{
            何もしない
         }
         そうでなければ{
            100回くり返す{
               もしtaが0ならば{
                  くり返しを抜ける
               }
               ca=和(ca,剰余(ta,2))
               ta=商(ta,2)
            }
         }

         もしtbが0ならば{
            何もしない
         }
         そうでなければ{
            100回くり返す{
               もしtbが0ならば{
                  くり返しを抜ける
               }
               cb=和(cb,剰余(tb,2))
               tb=商(tb,2)
            }
         }

         swap=偽
         もしcaがcbより大きいならば{
            swap=真
         }
         そうでなければ{
            もしcaがcbならば{
               もしaがbより大きいならば{
                  swap=真
               }
            }
         }

         もしswapならば{
            tmp=arr[j]
            arr[j]=arr[和(j,1)]
            arr[和(j,1)]=tmp
         }

         jを増やす
      }
      iを増やす
   }
   arrが答え
}