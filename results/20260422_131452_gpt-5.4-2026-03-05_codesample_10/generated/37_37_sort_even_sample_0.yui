標準ライブラリを使う

sort_even = 入力 l に対し {
   evens=[]
   n=lの大きさ
   i=0

   # 偶数インデックスの要素を集める
   n回くり返す{
      もし剰余(i,2)が0ならば{
         evensにl[i]を追加する
      }
      iを増やす
   }

   # 偶数インデックス用の値だけをソート
   evens=ソート(evens)

   result=[]
   ei=0
   i=0

   # 元の奇数インデックスはそのまま、偶数インデックスだけソート済み値を入れる
   n回くり返す{
      もし剰余(i,2)が0ならば{
         resultにevens[ei]を追加する
         eiを増やす
      }
      そうでなければ{
         resultにl[i]を追加する
      }
      iを増やす
   }

   resultが答え
}