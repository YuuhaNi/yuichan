標準ライブラリを使う

fibfib=入力nに対し{
   もしnが0ならば{
      0が答え
   }
   そうでなければ{
      もしnが1ならば{
         0が答え
      }
      そうでなければ{
         もしnが2ならば{
            1が答え
         }
         そうでなければ{
            a=0
            b=0
            c=1
            i=3
            差(n,2)回くり返す{
               next=和(和(a,b),c)
               a=b
               b=c
               c=next
               iを増やす
            }
            cが答え
         }
      }
   }
}