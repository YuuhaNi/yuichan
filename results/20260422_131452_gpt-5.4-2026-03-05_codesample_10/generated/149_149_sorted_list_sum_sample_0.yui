標準ライブラリを使う

sorted_list_sum = 入力 lst に対し {
   evens=[]
   n=lstの大きさ
   i=0

   # 奇数長の文字列を除外して、偶数長の文字列だけ集める
   n回くり返す{
      s=lst[i]
      len=sの大きさ
      もし剰余(len,2)が0ならば{
         evensにsを追加する
      }
      iを増やす
   }

   # 長さ昇順、同じ長さならアルファベット順でバブルソート
   m=evensの大きさ
   もしmが1より大きいならば{
      pass=0
      差(m,1)回くり返す{
         j=0
         差(差(m,1),pass)回くり返す{
            a=evens[j]
            b=evens[和(j,1)]
            la=aの大きさ
            lb=bの大きさ

            swap=偽
            もしlaがlbより大きいならば{
               swap=真
            }
            そうでなければ{
               もしlaがlbならば{
                  もしaがbより大きいならば{
                     swap=真
                  }
               }
            }

            もしswapならば{
               temp=evens[j]
               evens[j]=evens[和(j,1)]
               evens[和(j,1)]=temp
            }
            jを増やす
         }
         passを増やす
      }
   }

   evensが答え
}