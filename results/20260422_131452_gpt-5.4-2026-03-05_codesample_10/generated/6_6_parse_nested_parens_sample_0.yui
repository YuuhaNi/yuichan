標準ライブラリを使う

parse_nested_parens = 入力 paren_string に対し {
   groups=[]
   current=""
   n=paren_stringの大きさ
   i=0

   n回くり返す{
      c=paren_string[i]
      もしcが32ならば{
         もしcurrentが""以外ならば{
            groupsにcurrentを追加する
            current=""
         }
      }
      そうでなければ{
         currentにcを追加する
      }
      iを増やす
   }

   もしcurrentが""以外ならば{
      groupsにcurrentを追加する
   }

   result=[]
   gsz=groupsの大きさ
   gi=0

   gsz回くり返す{
      g=groups[gi]
      depth=0
      best=0
      m=gの大きさ
      j=0

      m回くり返す{
         ch=g[j]
         もしchが40ならば{
            depthを増やす
            もしdepthがbestより大きいならば{
               best=depth
            }
         }
         もしchが41ならば{
            depthを減らす
         }
         jを増やす
      }

      resultにbestを追加する
      giを増やす
   }

   resultが答え
}