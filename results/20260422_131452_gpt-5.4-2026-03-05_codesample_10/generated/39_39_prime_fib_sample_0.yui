標準ライブラリを使う

prime_fib = 入力 n に対し {
   is_prime=入力xに対し{
      もしxが2より小さいならば{
         偽が答え
      }
      d=2
      100000回くり返す{
         もし積(d,d)がxより大きいならば{
            真が答え
         }
         もし剰余(x,d)が0ならば{
            偽が答え
         }
         dを増やす
      }
      真が答え
   }

   a=0
   b=1
   count=0

   100000回くり返す{
      c=和(a,b)
      a=b
      b=c

      もしis_prime(a)ならば{
         countを増やす
         もしcountがnならば{
            aが答え
         }
      }
   }
}