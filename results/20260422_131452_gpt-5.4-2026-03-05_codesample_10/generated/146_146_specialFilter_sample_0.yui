標準ライブラリを使う

specialFilter = 入力 nums に対し {
   count=0
   n=numsの大きさ
   i=0
   n回くり返す{
      x=nums[i]
      もしxが10より大きいならば{
         s=文字列化(x)
         first=s[0]
         last=s[差(sの大きさ,1)]
         もしfirstが["1","3","5","7","9"]のいずれかならば{
            もしlastが["1","3","5","7","9"]のいずれかならば{
               countを増やす
            }
         }
      }
      iを増やす
   }
   countが答え
}