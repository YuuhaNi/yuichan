標準ライブラリを使う

monotonic = 入力 l に対し {
   n = l の大きさ
   # 要素が 0 個または 1 個なら単調
   もし n が 2 より小さい なら ば {
      真 が 答え
   }
   
   # 最初の 2 要素で増加か減少かを判定
   increasing = 1
   decreasing = 1
   
   i = 0
   差(n, 1) 回 くり返す {
      curr = l[i]
      next = l[和(i, 1)]
      
      # 増加傾向をチェック
      もし next が curr より小さい なら ば {
         increasing = 0
      }
      
      # 減少傾向をチェック
      もし next が curr より大きい なら ば {
         decreasing = 0
      }
      
      i を増やす
   }
   
   # 増加または減少のどちらかが成り立つなら真
   もし increasing が 1 なら ば {
      真 が 答え
   }
   もし decreasing が 1 なら ば {
      真 が 答え
   }
   偽 が 答え
}