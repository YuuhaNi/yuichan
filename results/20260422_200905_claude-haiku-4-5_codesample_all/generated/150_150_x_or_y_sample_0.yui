標準ライブラリを使う

x_or_y = 入力 n, x, y に対し {
   # n が素数かどうかを判定する
   # 素数なら x を返し、そうでなければ y を返す
   
   # 1 以下は素数ではない
   もし n が 2 より小さい ならば {
      y が答え
   }
   
   # 2 は素数
   もし n が 2 ならば {
      x が答え
   }
   
   # 偶数は素数ではない
   r = 剰余(n, 2)
   もし r が 0 ならば {
      y が答え
   }
   
   # 3 から √n までの奇数で割り切れるかを調べる
   is_prime = 1
   i = 3
   limit = 整数化(平方根(小数化(n)))
   
   差(limit, 2)回くり返す {
      もし i が limit より大きい ならば {
         くり返しを抜ける
      }
      
      r = 剰余(n, i)
      もし r が 0 ならば {
         is_prime = 0
      }
      
      i = 和(i, 2)
   }
   
   もし is_prime が 1 ならば {
      x が答え
   }
   そうでなければ {
      y が答え
   }
}