標準ライブラリを使う

solve = 入力 s に対し {
   # ステップ 1: アルファベットが含まれているかを調べる
   has_alpha = 0
   i = 0
   s の大きさ 回 くり返す {
      c = s[i]
      # 大文字 A..Z (65..90)
      もし c が 65 以上 ならば {
         もし c が 90 以下 ならば {
            has_alpha = 1
         }
      }
      # 小文字 a..z (97..122)
      もし c が 97 以上 ならば {
         もし c が 122 以下 ならば {
            has_alpha = 1
         }
      }
      i を増やす
   }

   # ステップ 2: アルファベットがない場合は反転して返す
   もし has_alpha が 0 ならば {
      reverse(s) が答え
   }

   # ステップ 3: アルファベットがある場合は大文字小文字を反転
   result = ""
   i = 0
   s の大きさ 回 くり返す {
      c = s[i]
      nc = c
      # 大文字 A..Z を小文字に
      もし c が 65 以上 ならば {
         もし c が 90 以下 ならば {
            nc = 和(c, 32)
         }
      }
      # 小文字 a..z を大文字に
      もし c が 97 以上 ならば {
         もし c が 122 以下 ならば {
            nc = 差(c, 32)
         }
      }
      result に nc を追加する
      i を増やす
   }
   result が答え
}

# テスト