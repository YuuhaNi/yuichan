標準ライブラリを使う

match_parens = 入力 lst に対し {
   # 2つの文字列を取得
   s1 = lst[0]
   s2 = lst[1]
   
   # パターン1: s1 + s2 の順序で結合
   combined1 = ""
   i = 0
   s1の大きさ回くり返す {
      combined1に s1[i] を追加する
      i を増やす
   }
   i = 0
   s2の大きさ回くり返す {
      combined1に s2[i] を追加する
      i を増やす
   }
   
   # パターン2: s2 + s1 の順序で結合
   combined2 = ""
   i = 0
   s2の大きさ回くり返す {
      combined2に s2[i] を追加する
      i を増やす
   }
   i = 0
   s1の大きさ回くり返す {
      combined2に s1[i] を追加する
      i を増やす
   }
   
   # combined1 が良い括弧かチェック
   もし is_good(combined1) が 真 ならば {
      "Yes" が答え
   }
   
   # combined2 が良い括弧かチェック
   もし is_good(combined2) が 真 ならば {
      "Yes" が答え
   }
   
   "No" が答え
}

# 括弧がバランスしているかチェックする補助関数
is_good = 入力 s に対し {
   balance = 0
   i = 0
   s の大きさ回くり返す {
      c = s[i]
      # '(' のコードは 40、')' のコードは 41
      もし c が 40 ならば {
         balance を増やす
      }
      そうでなければ {
         balance を減らす
      }
      # balance が負になったら不正
      もし balance が 0 より小さい ならば {
         偽 が答え
      }
      i を増やす
   }
   # 最後に balance が 0 なら良い
   もし balance が 0 ならば {
      真 が答え
   }
   そうでなければ {
      偽 が答え
   }
}

# テスト