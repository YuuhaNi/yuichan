標準ライブラリを使う

is_multiply_prime=入力aに対し{
   # a を素因数分解して、素因数がちょうど 3 個かどうかを判定する
   # 素因数の個数をカウントする
   count=0
   n=a
   
   # 2 で割り切れるだけ割る
   2回くり返す{
      もしnが2で割り切れるならば{
         もしnが0ならば{
            何もしない
         }
         そうでなければ{
            r=剰余(n,2)
            もしrが0ならば{
               countを増やす
               n=商(n,2)
            }
         }
      }
   }
   
   # 3 以上の奇数で割り切れるだけ割る
   # 100 以下なので最大 10 まで調べれば十分
   d=3
   10回くり返す{
      もしdがnより大きいならば{
         くり返しを抜ける
      }
      もしnが1ならば{
         くり返しを抜ける
      }
      r=剰余(n,d)
      もしrが0ならば{
         countを増やす
         n=商(n,d)
      }
      そうでなければ{
         d=和(d,2)
      }
   }
   
   # 最後に n が 1 より大きければ、n 自体が素因数
   もしnが1より大きいならば{
      countを増やす
   }
   
   # 素因数がちょうど 3 個なら True
   もしcountが3ならば{
      真が答え
   }
   そうでなければ{
      偽が答え
   }
}