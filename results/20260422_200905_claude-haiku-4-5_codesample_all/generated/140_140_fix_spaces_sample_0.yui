標準ライブラリを使う

fix_spaces = 入力 text に対し {
   result = ""
   i = 0
   n = text の大きさ
   
   n 回くり返す {
      c = text[i]
      space_code = 32
      
      もし c が space_code ならば {
         # 空白を見つけた。連続した空白の個数を数える
         count = 0
         j = i
         n 回くり返す {
            もし j が n 以上 ならば {
               くり返しを抜ける
            }
            もし text[j] が space_code ならば {
               count を増やす
               j を増やす
            }
            そうでなければ {
               くり返しを抜ける
            }
         }
         
         # count 個の空白を処理した
         もし count が 2 以上 ならば {
            # 2 個以上の連続した空白は - に置換
            result に 45 を追加する
         }
         そうでなければ {
            # 1 個の空白は _ に置換
            result に 95 を追加する
         }
         
         # i を count だけ進める
         i = 和(i, count)
      }
      そうでなければ {
         # 空白以外はそのままコピー
         result に c を追加する
         i を増やす
      }
   }
   
   result が答え
}