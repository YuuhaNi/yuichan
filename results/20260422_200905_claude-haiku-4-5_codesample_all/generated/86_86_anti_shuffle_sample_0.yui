標準ライブラリを使う

anti_shuffle = 入力 s に対し {
   result = ""
   i = 0
   n = s の大きさ
   
   n 回くり返す {
      c = s[i]
      # スペース (32) はそのまま追加
      もし c が 32 ならば {
         result に c を追加する
      }
      そうでなければ {
         # スペースでない文字から単語を抽出
         word = ""
         j = i
         # 単語の終わり (スペースか文字列終端) まで進める
         n 回くり返す {
            もし j が n 以上 ならば {
               くり返しを抜ける
            }
            wc = s[j]
            もし wc が 32 ならば {
               くり返しを抜ける
            }
            word に wc を追加する
            j を増やす
         }
         
         # word をバブルソートで昇順に並べ替える
         wlen = word の大きさ
         wlen 回くり返す {
            wi = 0
            差(wlen, 1) 回くり返す {
               wj = 和(wi, 1)
               もし word[wi] が word[wj] より大きい ならば {
                  tmp = word[wi]
                  word[wi] = word[wj]
                  word[wj] = tmp
               }
               wi を増やす
            }
         }
         
         # ソート済みの単語を result に追加
         k = 0
         wlen 回くり返す {
            result に word[k] を追加する
            k を増やす
         }
         
         # i を単語の終わりまで進める
         i = 差(j, 1)
      }
      i を増やす
   }
   
   result が答え
}