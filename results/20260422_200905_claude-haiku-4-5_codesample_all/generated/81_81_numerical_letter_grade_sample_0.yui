標準ライブラリを使う

numerical_letter_grade = 入力 grades に対し {
   result = []
   n = grades の大きさ
   i = 0
   n 回くり返す {
      gpa = grades[i]
      letter = "E"
      
      もし gpa が 4.0 ならば {
         letter = "A+"
      }
      そうでなければ {
         もし gpa が 3.7 より大きい ならば {
            letter = "A"
         }
         そうでなければ {
            もし gpa が 3.3 より大きい ならば {
               letter = "A-"
            }
            そうでなければ {
               もし gpa が 3.0 より大きい ならば {
                  letter = "B+"
               }
               そうでなければ {
                  もし gpa が 2.7 より大きい ならば {
                     letter = "B"
                  }
                  そうでなければ {
                     もし gpa が 2.3 より大きい ならば {
                        letter = "B-"
                     }
                     そうでなければ {
                        もし gpa が 2.0 より大きい ならば {
                           letter = "C+"
                        }
                        そうでなければ {
                           もし gpa が 1.7 より大きい ならば {
                              letter = "C"
                           }
                           そうでなければ {
                              もし gpa が 1.3 より大きい ならば {
                                 letter = "C-"
                              }
                              そうでなければ {
                                 もし gpa が 1.0 より大きい ならば {
                                    letter = "D+"
                                 }
                                 そうでなければ {
                                    もし gpa が 0.7 より大きい ならば {
                                       letter = "D"
                                    }
                                    そうでなければ {
                                       もし gpa が 0.0 より大きい ならば {
                                          letter = "D-"
                                       }
                                    }
                                 }
                              }
                           }
                        }
                     }
                  }
               }
            }
         }
      }
      
      result に letter を追加する
      i を増やす
   }
   result が答え
}