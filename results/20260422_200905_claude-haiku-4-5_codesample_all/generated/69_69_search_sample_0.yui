標準ライブラリを使う

search = 入力 lst に対し {
   result = 差(0, 1)
   n = lst の大きさ
   
   # 各整数について、その頻度を数える
   i = 0
   n 回くり返す {
      num = lst[i]
      count = 0
      
      # num の頻度を数える
      j = 0
      n 回くり返す {
         もし lst[j] が num ならば {
            count を増やす
         }
         j を増やす
      }
      
      # 条件チェック: count >= num かつ num > result
      もし count が num 以上 ならば {
         もし num が result より大きい ならば {
            result = num
         }
      }
      
      i を増やす
   }
   
   result が答え
}