標準ライブラリを使う

strange_sort_list = 入力 lst に対し {
   # まず配列をソートする
   sorted = bubble_sort(lst)
   n = sorted の大きさ
   
   # ソート済み配列が空なら空配列を返す
   もし n が 0 ならば {
      []が答え
   }
   
   result = []
   left = 0
   right = 差(n, 1)
   turn = 0  # 0 なら左から取る (最小値)、1 なら右から取る (最大値)
   
   # left と right が交差するまでくり返す
   n 回くり返す {
      もし left が right より大きい ならば {
         くり返しを抜ける
      }
      
      もし turn が 0 ならば {
         # 左から最小値を取る
         result に sorted[left] を追加する
         left を増やす
      }
      そうでなければ {
         # 右から最大値を取る
         result に sorted[right] を追加する
         right を減らす
      }
      
      # ターンを切り替える
      turn = 差(1, turn)
   }
   
   result が答え
}

# bubble_sort 関数の定義 (コンテキストから)
bubble_sort = 入力 A に対し {
   n = A の大きさ
   n 回くり返す {
      i = 0
      差(n, 1) 回くり返す {
         j = 和(i, 1)
         もし A[i] が A[j] より大きい ならば {
            tmp = A[i]
            A[i] = A[j]
            A[j] = tmp
         }
         i を増やす
      }
   }
   A が答え
}