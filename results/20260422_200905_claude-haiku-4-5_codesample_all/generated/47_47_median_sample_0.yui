標準ライブラリを使う

median = 入力 l に対し {
   # リストをソートする
   sorted = bubble_sort(l)
   n = sorted の大きさ
   
   # 要素数が奇数の場合: 中央の要素を返す
   # 要素数が偶数の場合: 中央の 2 つの要素の平均を返す
   parity = 剰余(n, 2)
   
   もし parity が 1 ならば {
      # 奇数個: 中央のインデックスは (n-1)/2
      mid = 商(差(n, 1), 2)
      sorted[mid] が答え
   }
   そうでなければ {
      # 偶数個: 中央の 2 つの要素の平均
      mid1 = 差(商(n, 2), 1)
      mid2 = 商(n, 2)
      val1 = 小数化(sorted[mid1])
      val2 = 小数化(sorted[mid2])
      商(和(val1, val2), 小数化(2)) が答え
   }
}