標準ライブラリを使う

encode = 入力 message に対し {
   result = ""
   vowels = "aeiouAEIOU"
   vowel_map = {"a":"Y","e":"C","i":"G","o":"K","u":"S","A":"Y","E":"C","I":"G","O":"K","U":"S"}
   
   i = 0
   message の大きさ 回 くり返す {
      c = message[i]
      
      # 母音かどうかを判定
      もし c が vowels のいずれか ならば {
         # 母音を置き換える
         result に vowel_map[c] を追加する
      }
      そうでなければ {
         # 大文字と小文字を入れ替える
         code = c
         # 大文字 A..Z (65..90)
         もし code が 65 以上 ならば {
            もし code が 90 以下 ならば {
               # 大文字を小文字に
               result に 和(code,32) を追加する
            }
            そうでなければ {
               # 小文字 a..z (97..122)
               もし code が 97 以上 ならば {
                  もし code が 122 以下 ならば {
                     # 小文字を大文字に
                     result に 差(code,32) を追加する
                  }
                  そうでなければ {
                     # 文字以外はそのまま
                     result に c を追加する
                  }
               }
               そうでなければ {
                  # 文字以外はそのまま
                  result に c を追加する
               }
            }
         }
         そうでなければ {
            # 小文字 a..z (97..122)
            もし code が 97 以上 ならば {
               もし code が 122 以下 ならば {
                  # 小文字を大文字に
                  result に 差(code,32) を追加する
               }
               そうでなければ {
                  # 文字以外はそのまま
                  result に c を追加する
               }
            }
            そうでなければ {
               # 文字以外はそのまま
               result に c を追加する
            }
         }
      }
      
      i を増やす
   }
   
   result が答え
}