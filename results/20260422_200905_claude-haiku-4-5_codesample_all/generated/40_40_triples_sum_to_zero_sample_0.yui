標準ライブラリを使う

triples_sum_to_zero = 入力 l に対し {
   n = l の大きさ
   
   # 3つの要素を選ぶには最低3個必要
   もし n が 3 より小さい ならば {
      偽が答え
   }
   
   # 3重ループで全ての3つ組を調べる
   i = 0
   n 回 くり返す {
      j = 0
      n 回 くり返す {
         k = 0
         n 回 くり返す {
            # i, j, k が全て異なるかチェック
            もし i が j 以外 ならば {
               もし i が k 以外 ならば {
                  もし j が k 以外 ならば {
                     # 3つの要素の和が0かチェック
                     sum = 和(l[i], 和(l[j], l[k]))
                     もし sum が 0 ならば {
                        真が答え
                     }
                  }
               }
            }
            k を増やす
         }
         j を増やす
      }
      i を増やす
   }
   
   偽が答え
}