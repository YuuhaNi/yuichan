標準ライブラリを使う

check_dict_case = 入力 dict に対し {
   # 空の辞書は False を返す
   もし dict の大きさ が 0 ならば {
      偽が答え
   }

   # すべてのキーを調べる
   keys = dict の鍵
   key_count = keys の大きさ
   
   # 最初のキーで大文字/小文字を判定する基準を決める
   first_key = keys[0]
   
   # キーが文字列でない場合は False を返す
   もし 文字列判定(first_key) が 偽 ならば {
      偽が答え
   }
   
   # 最初のキーが小文字か大文字かを判定
   # 小文字キーを期待するかどうかを決める
   is_lowercase_mode = 0
   
   # 最初のキーの最初の文字を調べる
   first_char = first_key[0]
   
   # 小文字 a-z は 97-122
   # 大文字 A-Z は 65-90
   もし first_char が 97 以上 ならば {
      もし first_char が 122 以下 ならば {
         is_lowercase_mode = 1
      }
   }
   
   # すべてのキーをチェック
   i = 0
   key_count 回 くり返す {
      key = keys[i]
      
      # キーが文字列でない場合は False を返す
      もし 文字列判定(key) が 偽 ならば {
         偽が答え
      }
      
      # キーの長さが 0 でないことを確認
      もし key の大きさ が 0 より大きい ならば {
         first_char = key[0]
         
         もし is_lowercase_mode が 1 ならば {
            # 小文字モード: すべてのキーが小文字で始まるべき
            もし first_char が 97 未満 ならば {
               偽が答え
            }
            もし first_char が 122 より大きい ならば {
               偽が答え
            }
         }
         そうでなければ {
            # 大文字モード: すべてのキーが大文字で始まるべき
            もし first_char が 65 未満 ならば {
               偽が答え
            }
            もし first_char が 90 より大きい ならば {
               偽が答え
            }
         }
      }
      
      i を増やす
   }
   
   # すべてのキーが条件を満たした場合は True を返す
   真が答え
}