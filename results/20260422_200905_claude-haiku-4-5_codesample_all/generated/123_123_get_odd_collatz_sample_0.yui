標準ライブラリを使う

get_odd_collatz = 入力 n に対し {
   # コラッツ数列の奇数を集める
   odds = []
   current = n
   
   # 1 に到達するまでループ
   1000回くり返す {
      もし current が 1 ならば {
         くり返しを抜ける
      }
      
      # 現在の値が奇数なら odds に追加
      parity = 剰余(current, 2)
      もし parity が 1 ならば {
         odds に current を追加する
      }
      
      # 次の項を計算
      もし parity が 0 ならば {
         # 偶数: 2 で割る
         current = 商(current, 2)
      }
      そうでなければ {
         # 奇数: 3 倍して 1 を足す
         current = 和(積(current, 3), 1)
      }
   }
   
   # 最後に 1 を追加 (1 は常に奇数)
   odds に 1 を追加する
   
   # ソート
   bubble_sort(odds)が答え
}

# ヘルパー関数: バブルソート
bubble_sort = 入力 A に対し {
   n = A の大きさ
   n 回くり返す {
      i = 0
      差(n, 1) 回くり返す {
         j = 和(i, 1)
         もし A[i] が A[j] より大きい ならば {
            tmp = A[i]
            A[i] = A[j]
            A[j] = tmp
         }
         i を増やす
      }
   }
   A が答え
}