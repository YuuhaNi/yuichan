標準ライブラリを使う

fib4 = 入力 n に対し {
   # 初期値を設定
   もし n が 0 ならば {
      0 が答え
   }
   もし n が 1 ならば {
      0 が答え
   }
   もし n が 2 ならば {
      2 が答え
   }
   もし n が 3 ならば {
      0 が答え
   }

   # n >= 4 の場合、動的計画法で計算する
   # 最後の 4 つの値を保持する
   a = 0
   b = 0
   c = 2
   d = 0

   # i = 4 から n まで計算する
   i = 4
   差(n, 3) 回 くり返す {
      next = 和(a, 和(b, 和(c, d)))
      a = b
      b = c
      c = d
      d = next
      i を増やす
   }

   d が答え
}