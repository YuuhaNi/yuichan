標準ライブラリを使う

move_one_ball = 入力 arr に対し {
   n = arr の大きさ
   
   # 空配列は True
   もし n が 0 ならば {
      真が答え
   }
   
   # 配列が既にソート済みかチェック
   is_sorted = 入力 a に対し {
      sz = a の大きさ
      i = 0
      差(sz, 1) 回くり返す {
         j = 和(i, 1)
         もし a[i] が a[j] より大きい ならば {
            偽が答え
         }
         i を増やす
      }
      真が答え
   }
   
   # 最大 n 回の右シフトを試す
   current = []
   k = 0
   n 回くり返す {
      # 現在の配列をコピー
      もし k が 0 ならば {
         i = 0
         n 回くり返す {
            current に arr[i] を追加する
            i を増やす
         }
      }
      
      # ソート済みかチェック
      もし is_sorted(current) ならば {
         真が答え
      }
      
      # 右シフト操作を実行
      もし k が 差(n, 1) より小さい ならば {
         last = current[差(n, 1)]
         i = 差(n, 1)
         差(n, 1) 回くり返す {
            j = 差(i, 1)
            current[i] = current[j]
            i を減らす
         }
         current[0] = last
      }
      
      k を増やす
   }
   
   偽が答え
}