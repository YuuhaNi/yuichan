標準ライブラリを使う

largest_prime_factor = 入力 n に対し {
   largest = 1
   # 2 で割り切れる限り割り続ける
   もし n が 2 で割り切れるならば {
      largest = 2
      n回くり返す {
         もし n が 2 で割り切れるならば {
            n = 商(n, 2)
         }
         そうでなければ {
            くり返しを抜ける
         }
      }
   }
   # 3 以上の奇数で割り切れるかを調べる
   i = 3
   # i * i <= n の間、割り切れるかを試す
   n回くり返す {
      もし i が i より大きいならば {
         くり返しを抜ける
      }
      i2 = 積(i, i)
      もし i2 が n より大きいならば {
         くり返しを抜ける
      }
      もし n が i で割り切れるならば {
         largest = i
         n回くり返す {
            もし n が i で割り切れるならば {
               n = 商(n, i)
            }
            そうでなければ {
               くり返しを抜ける
            }
         }
      }
      i = 和(i, 2)
   }
   # n が 1 より大きければ、n 自体が素因数
   もし n が 1 より大きいならば {
      largest = n
   }
   largest が答え
}