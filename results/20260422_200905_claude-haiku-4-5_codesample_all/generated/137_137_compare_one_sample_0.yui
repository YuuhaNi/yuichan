標準ライブラリを使う

compare_one = 入力 a, b に対し {
   # a を数値に変換
   a_num = 0
   a_type = "int"
   もし整数判定(a)ならば {
      a_num = a
      a_type = "int"
   }
   そうでなければ {
      もし小数判定(a)ならば {
         a_num = a
         a_type = "float"
      }
      そうでなければ {
         もし文字列判定(a)ならば {
            # カンマをピリオドに置換
            a_str = 置換(a, ",", ".")
            a_num = 小数化(a_str)
            # 小数点を含むかで型を判定
            もし置換(a, ",", ".")が"."のいずれかならば {
               a_type = "float"
            }
            そうでなければ {
               a_type = "int"
            }
         }
      }
   }

   # b を数値に変換
   b_num = 0
   b_type = "int"
   もし整数判定(b)ならば {
      b_num = b
      b_type = "int"
   }
   そうでなければ {
      もし小数判定(b)ならば {
         b_num = b
         b_type = "float"
      }
      そうでなければ {
         もし文字列判定(b)ならば {
            # カンマをピリオドに置換
            b_str = 置換(b, ",", ".")
            b_num = 小数化(b_str)
            # 小数点を含むかで型を判定
            もし置換(b, ",", ".")が"."のいずれかならば {
               b_type = "float"
            }
            そうでなければ {
               b_type = "int"
            }
         }
      }
   }

   # 数値が同じなら値なしを返す
   もし a_num が b_num ならば {
      値なしが答え
   }

   # 大きい方を元の型で返す
   もし a_num が b_num より大きいならば {
      aが答え
   }
   そうでなければ {
      bが答え
   }
}