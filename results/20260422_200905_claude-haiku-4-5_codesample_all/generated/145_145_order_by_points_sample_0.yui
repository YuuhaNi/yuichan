標準ライブラリを使う

# 数字の各桁の合計を計算する
digit_sum = 入力 n に対し {
   # 負の数の場合は絶対値を使う
   abs_n = 絶対値(n)
   # 文字列化して各文字（桁）を処理
   s = 文字列化(abs_n)
   sum = 0
   i = 0
   s の大きさ 回 くり返す {
      c = s[i]
      # 文字コード '0' は 48
      digit = 差(c, 48)
      sum = 和(sum, digit)
      i を増やす
   }
   sum が答え
}

# バブルソート（安定ソート）で桁の合計でソート
order_by_points = 入力 nums に対し {
   n = nums の大きさ
   
   # 空配列の場合はそのまま返す
   もし n が 0 ならば {
      nums が答え
   }
   
   # 安定ソート：外側のループで n 回
   n 回 くり返す {
      i = 0
      # 内側のループで隣同士を比較
      差(n, 1) 回 くり返す {
         j = 和(i, 1)
         sum_i = digit_sum(nums[i])
         sum_j = digit_sum(nums[j])
         
         # 桁の合計が大きい場合は入れ替える
         もし sum_i が sum_j より大きい ならば {
            tmp = nums[i]
            nums[i] = nums[j]
            nums[j] = tmp
         }
         i を増やす
      }
   }
   
   nums が答え
}

# テスト