標準ライブラリを使う

bf = 入力 planet1, planet2 に対し {
   # 惑星のリスト（太陽に近い順）
   planets = ["Mercury", "Venus", "Earth", "Mars", "Jupiter", "Saturn", "Uranus", "Neptune"]
   
   # planet1 と planet2 のインデックスを探す
   idx1 = -1
   idx2 = -1
   
   i = 0
   planets の大きさ 回 くり返す {
      もし planets[i] が planet1 ならば {
         idx1 = i
      }
      もし planets[i] が planet2 ならば {
         idx2 = i
      }
      i を増やす
   }
   
   # どちらかが見つからなければ空配列を返す
   もし idx1 が -1 ならば {
      []が答え
   }
   もし idx2 が -1 ならば {
      []が答え
   }
   
   # idx1 と idx2 が同じなら空配列を返す
   もし idx1 が idx2 ならば {
      []が答え
   }
   
   # idx1 > idx2 なら入れ替える（小さい方を先にする）
   もし idx1 が idx2 より大きい ならば {
      tmp = idx1
      idx1 = idx2
      idx2 = tmp
   }
   
   # idx1 と idx2 の間の惑星を集める
   result = []
   i = 和(idx1, 1)
   差(idx2, idx1) 回 くり返す {
      result に planets[i] を追加する
      i を増やす
   }
   
   result が答え
}