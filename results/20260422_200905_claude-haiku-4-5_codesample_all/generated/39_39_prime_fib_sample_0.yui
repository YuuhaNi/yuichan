標準ライブラリを使う

# 素数判定: 2 以上の整数が素数かどうかを判定する
is_prime = 入力 num に対し {
   もし num が 2 より小さい ならば {
      偽が答え
   }
   もし num が 2 ならば {
      真が答え
   }
   もし 剰余(num, 2) が 0 ならば {
      偽が答え
   }
   # 3 以上の奇数で割り切れるかを調べる
   i = 3
   limit = 整数化(平方根(小数化(num)))
   差(limit, 2)回くり返す {
      もし 剰余(num, i) が 0 ならば {
         偽が答え
      }
      i = 和(i, 2)
   }
   真が答え
}

# フィボナッチ数で素数であるn番目の数を返す
prime_fib = 入力 n に対し {
   count = 0
   a = 1
   b = 1
   # フィボナッチ数を順に生成していく
   1000回くり返す {
      # 次のフィボナッチ数を計算
      c = 和(a, b)
      # c が素数かどうかを調べる
      もし is_prime(c) ならば {
         count を増やす
         # n 番目の素数フィボナッチ数が見つかった
         もし count が n ならば {
            c が答え
         }
      }
      a = b
      b = c
   }
}