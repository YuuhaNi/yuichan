標準ライブラリを使う

choose_num = 入力 x, y に対し {
   # x > y の場合は -1 を返す
   もし x が y より大きい ならば {
      差(0, 1) が答え
   }
   
   # y が偶数なら y を返す
   r = 剰余(y, 2)
   もし r が 0 ならば {
      y が答え
   }
   
   # y が奇数なら y - 1 を試す
   candidate = 差(y, 1)
   もし candidate が x 以上 ならば {
      candidate が答え
   }
   
   # 範囲内に偶数がない場合は -1 を返す
   差(0, 1) が答え
}