標準ライブラリを使う

flip_case = 入力 string に対し {
   result = ""
   i = 0
   string の大きさ 回くり返す {
      c = string[i]
      # 大文字 A..Z (65..90)
      もし c が 65 以上 ならば {
         もし c が 90 以下 ならば {
            # 大文字を小文字に変換 (c + 32)
            result に 和(c, 32) を追加する
            i を増やす
            くり返しを続ける
         }
      }
      # 小文字 a..z (97..122)
      もし c が 97 以上 ならば {
         もし c が 122 以下 ならば {
            # 小文字を大文字に変換 (c - 32)
            result に 差(c, 32) を追加する
            i を増やす
            くり返しを続ける
         }
      }
      # 英字以外はそのまま
      result に c を追加する
      i を増やす
   }
   result が答え
}