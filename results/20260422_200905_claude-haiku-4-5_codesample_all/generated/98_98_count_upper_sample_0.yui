標準ライブラリを使う

count_upper = 入力 s に対し {
   upper_vowels = "AEIOU"
   count = 0
   i = 0
   s の大きさ 回 くり返す {
      # 偶数インデックスかどうかを確認
      parity = 剰余(i, 2)
      もし parity が 0 ならば {
         c = s[i]
         # 大文字の母音かどうかを確認
         もし c が upper_vowels のいずれか ならば {
            count を増やす
         }
      }
      i を増やす
   }
   count が答え
}