標準ライブラリを使う

get_row = 入力 lst, x に対し {
   result = []
   row = 0
   lst の大きさ 回 くり返す {
      current_row = lst[row]
      col = 0
      current_row の大きさ 回 くり返す {
         もし current_row[col] が x ならば {
            result に [row, col] を追加する
         }
         col を増やす
      }
      row を増やす
   }
   
   # 結果を行の昇順、同じ行内では列の降順でソートする
   # バブルソートで実装
   n = result の大きさ
   n 回 くり返す {
      i = 0
      差(n, 1) 回 くり返す {
         j = 和(i, 1)
         current = result[i]
         next = result[j]
         current_row = current[0]
         next_row = next[0]
         current_col = current[1]
         next_col = next[1]
         
         # 行が異なる場合: 行の昇順
         もし current_row が next_row より大きい ならば {
            tmp = result[i]
            result[i] = result[j]
            result[j] = tmp
         }
         そうでなければ {
            # 同じ行の場合: 列の降順
            もし current_row が next_row ならば {
               もし current_col が next_col より小さい ならば {
                  tmp = result[i]
                  result[i] = result[j]
                  result[j] = tmp
               }
            }
         }
         i を増やす
      }
   }
   
   result が答え
}