標準ライブラリを使う

any_int = 入力 x, y, z に対し {
   # すべてが整数かチェック
   もし整数判定(x)が偽ならば {
      偽が答え
   }
   もし整数判定(y)が偽ならば {
      偽が答え
   }
   もし整数判定(z)が偽ならば {
      偽が答え
   }
   
   # 1つの数値が他の2つの和と等しいかチェック
   # x = y + z
   もし差(x, 和(y, z))が0ならば {
      真が答え
   }
   # y = x + z
   もし差(y, 和(x, z))が0ならば {
      真が答え
   }
   # z = x + y
   もし差(z, 和(x, y))が0ならば {
      真が答え
   }
   
   偽が答え
}

# テスト