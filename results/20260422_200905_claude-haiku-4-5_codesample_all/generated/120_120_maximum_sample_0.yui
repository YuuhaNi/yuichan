標準ライブラリを使う

maximum = 入力 arr, k に対し {
   # ステップ 1: 配列をソートする (昇順)
   sorted_arr = bubble_sort(arr)
   
   # ステップ 2: ソート済み配列の後ろから k 個を取り出す
   result = []
   n = sorted_arr の大きさ
   i = 0
   k 回くり返す {
      # 後ろから i 番目の要素を取り出す
      idx = 差(差(n, k), i)
      result に sorted_arr[idx] を追加する
      i を増やす
   }
   
   # ステップ 3: 結果を昇順でソートして返す
   bubble_sort(result) が答え
}

# ヘルパー関数: バブルソート
bubble_sort = 入力 A に対し {
   n = A の大きさ
   n 回くり返す {
      i = 0
      差(n, 1) 回くり返す {
         j = 和(i, 1)
         もし A[i] が A[j] より大きいならば {
            tmp = A[i]
            A[i] = A[j]
            A[j] = tmp
         }
         i を増やす
      }
   }
   A が答え
}

# テスト