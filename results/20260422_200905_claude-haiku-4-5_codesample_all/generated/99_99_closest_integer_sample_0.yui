標準ライブラリを使う

closest_integer = 入力 value に対し {
   # 文字列を小数に変換
   num = 小数化(value)
   
   # 小数部分を取り出す
   floor_num = 整数化(num)
   frac = 差(num, 小数化(floor_num))
   
   # 負の数の場合の処理
   もし num が 0 より小さい ならば {
      frac = 差(0, frac)
   }
   
   # 0.5 より小さい場合は切り捨て
   もし frac が 0.5 より小さい ならば {
      floor_num が答え
   }
   
   # 0.5 以上の場合はゼロから遠い方へ四捨五入
   もし num が 0 以上 ならば {
      和(floor_num, 1) が答え
   }
   そうでなければ {
      差(floor_num, 1) が答え
   }
}