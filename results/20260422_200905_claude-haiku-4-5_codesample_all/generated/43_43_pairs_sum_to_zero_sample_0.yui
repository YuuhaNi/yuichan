標準ライブラリを使う

pairs_sum_to_zero=入力lに対し{
   n=lの大きさ
   # 要素が 1 つ以下なら False
   もしnが2より小さいならば{
      偽が答え
   }
   # 外側のループ: i 番目の要素
   i=0
   n回くり返す{
      # 内側のループ: j 番目の要素 (i より後ろ)
      j=和(i,1)
      n回くり返す{
         もしjがn以上ならば{
            くり返しを抜ける
         }
         # l[i] + l[j] == 0 かどうかを調べる
         sum=和(l[i],l[j])
         もしsumが0ならば{
            真が答え
         }
         jを増やす
      }
      iを増やす
   }
   # どのペアも和がゼロにならなかった
   偽が答え
}