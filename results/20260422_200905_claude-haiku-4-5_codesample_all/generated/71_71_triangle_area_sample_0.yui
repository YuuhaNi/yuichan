標準ライブラリを使う

triangle_area = 入力 a, b, c に対し {
   # === ステップ 1: 三角不等式チェック ===
   # a+b > c, a+c > b, b+c > a がすべて成り立つかを ok フラグで集約
   ok = 1
   ab = 和(a, b)
   ac = 和(a, c)
   bc = 和(b, c)
   もし ab が c 以下 ならば { ok = 0 }
   もし ac が b 以下 ならば { ok = 0 }
   もし bc が a 以下 ならば { ok = 0 }
   もし ok が 0 ならば {
      差(0, 1) が答え
   }

   # === ステップ 2: ヘロンの公式で面積を計算 ===
   # s = (a + b + c) / 2
   # area = √(s(s-a)(s-b)(s-c))
   s = 商(和(a, b, c), 2)
   sa = 差(s, a)
   sb = 差(s, b)
   sc = 差(s, c)
   
   # 小数化して計算
   s_f = 小数化(s)
   sa_f = 小数化(sa)
   sb_f = 小数化(sb)
   sc_f = 小数化(sc)
   
   product = 積(s_f, 積(sa_f, 積(sb_f, sc_f)))
   area = 平方根(product)
   
   # === ステップ 3: 小数点以下2桁で四捨五入 ===
   # 100倍して四捨五入し、100で割る
   scaled = 積(area, 小数化(100))
   rounded = 整数化(和(scaled, 小数化(0.5)))
   result = 商(小数化(rounded), 小数化(100))
   
   result が答え
}