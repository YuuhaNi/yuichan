標準ライブラリを使う

valid_date = 入力 date に対し {
   # 空文字列チェック
   もし date の大きさ が 0 ならば {
      偽が答え
   }

   # フォーマットチェック: mm-dd-yyyy の形式
   # ハイフンの位置を確認
   もし date の大きさ が 10 以外 ならば {
      偽が答え
   }

   # 位置 2 と 5 がハイフンであることを確認
   もし date[2] が 45 以外 ならば {  # 45 は '-' のコード
      偽が答え
   }
   もし date[5] が 45 以外 ならば {
      偽が答え
   }

   # mm, dd, yyyy を抽出
   mm_str = ""
   dd_str = ""
   yyyy_str = ""
   
   # mm (位置 0-1)
   mm_str に date[0] を追加する
   mm_str に date[1] を追加する
   
   # dd (位置 3-4)
   dd_str に date[3] を追加する
   dd_str に date[4] を追加する
   
   # yyyy (位置 6-9)
   yyyy_str に date[6] を追加する
   yyyy_str に date[7] を追加する
   yyyy_str に date[8] を追加する
   yyyy_str に date[9] を追加する

   # 数値への変換を試みる
   mm = 整数化(mm_str)
   dd = 整数化(dd_str)
   yyyy = 整数化(yyyy_str)

   # 月の範囲チェック
   もし mm が 1 未満 ならば {
      偽が答え
   }
   もし mm が 12 より大きい ならば {
      偽が答え
   }

   # 日の範囲チェック（月ごと）
   max_day = 31
   
   もし mm が 4 ならば {
      max_day = 30
   }
   もし mm が 6 ならば {
      max_day = 30
   }
   もし mm が 9 ならば {
      max_day = 30
   }
   もし mm が 11 ならば {
      max_day = 30
   }
   もし mm が 2 ならば {
      max_day = 29
   }

   # 日の範囲チェック
   もし dd が 1 未満 ならば {
      偽が答え
   }
   もし dd が max_day より大きい ならば {
      偽が答え
   }

   # すべてのチェックに合格
   真が答え
}