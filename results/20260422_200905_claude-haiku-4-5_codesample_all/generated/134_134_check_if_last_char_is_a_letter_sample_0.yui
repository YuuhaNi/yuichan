標準ライブラリを使う

check_if_last_char_is_a_letter = 入力 txt に対し {
   n = txt の大きさ
   
   # 空文字列の場合は False
   もし n が 0 ならば {
      偽が答え
   }
   
   # 最後の文字を取得
   last_char = txt[差(n,1)]
   
   # 最後の文字がスペース (32) なら False
   もし last_char が 32 ならば {
      偽が答え
   }
   
   # 最後の文字がアルファベット (A-Z: 65-90, a-z: 97-122) かチェック
   is_letter = 0
   もし last_char が 65 以上 ならば {
      もし last_char が 90 以下 ならば {
         is_letter = 1
      }
   }
   もし last_char が 97 以上 ならば {
      もし last_char が 122 以下 ならば {
         is_letter = 1
      }
   }
   
   もし is_letter が 0 ならば {
      偽が答え
   }
   
   # 最後の文字の直前がスペース (32) かチェック
   # (最後の文字が単語の一部でない = 直前がスペース)
   もし n が 1 ならば {
      # 最後の文字が 1 文字だけで、かつアルファベットなら True
      真が答え
   }
   
   prev_char = txt[差(n,2)]
   もし prev_char が 32 ならば {
      真が答え
   }
   
   偽が答え
}