標準ライブラリを使う

is_sorted = 入力 lst に対し {
   n = lst の大きさ
   
   # 要素が 0 個または 1 個なら True
   もし n が 1 以下 ならば {
      真 が答え
   }
   
   # 連続する要素をチェック
   i = 0
   差(n, 1) 回 くり返す {
      current = lst[i]
      next = lst[和(i, 1)]
      
      # 次の要素が現在の要素より小さい場合は False
      もし next が current より小さい ならば {
         偽 が答え
      }
      
      # 同じ値が 2 回以上連続する場合は False
      もし next が current ならば {
         # さらに次の要素をチェック
         もし 和(i, 2) が n より小さい ならば {
            next_next = lst[和(i, 2)]
            もし next_next が next ならば {
               偽 が答え
            }
         }
      }
      
      i を増やす
   }
   
   真 が答え
}