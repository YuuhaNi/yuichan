標準ライブラリを使う

next_smallest = 入力 lst に対し {
   n = lst の大きさ
   もし n が 2 より小さい ならば {
      値なし が答え
   }
   
   # 最小値と2番目に小さい値を追跡する
   min1 = lst[0]
   min2 = 値なし
   
   i = 1
   n 回くり返す {
      x = lst[i]
      
      # x が min1 より小さい場合、min1 を min2 に降格
      もし x が min1 より小さい ならば {
         min2 = min1
         min1 = x
      }
      そうでなければ {
         # x が min1 と異なり、min2 より小さい (または min2 が未設定) 場合
         もし x が min1 以外 ならば {
            もし min2 が値なし ならば {
               min2 = x
            }
            そうでなければ {
               もし x が min2 より小さい ならば {
                  min2 = x
               }
            }
         }
      }
      
      i を増やす
   }
   
   min2 が答え
}