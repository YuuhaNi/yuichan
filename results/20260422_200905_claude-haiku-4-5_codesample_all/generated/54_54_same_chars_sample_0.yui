標準ライブラリを使う

same_chars = 入力 s0, s1 に対し {
   # s0 と s1 のユニークな文字セットが同じかどうかを判定する
   # 両方の文字列からユニークな文字を取り出して比較する
   
   u0 = unique_chars(s0)
   u1 = unique_chars(s1)
   
   # 長さが異なれば異なるセット
   もし u0 の大きさ が u1 の大きさ 以外 ならば {
      偽 が答え
   }
   
   # 同じ長さなら、u0 のすべての文字が u1 に含まれるかチェック
   i = 0
   u0 の大きさ 回 くり返す {
      c = u0[i]
      もし c が u1 のいずれでもない ならば {
         偽 が答え
      }
      i を増やす
   }
   
   真 が答え
}

# ユニークな文字を取り出すヘルパー関数
unique_chars = 入力 s に対し {
   result = ""
   i = 0
   s の大きさ 回 くり返す {
      c = s[i]
      もし c が result のいずれでもない ならば {
         result に c を追加する
      }
      i を増やす
   }
   result が答え
}