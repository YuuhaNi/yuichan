標準ライブラリを使う

parse_music = 入力 music_string に対し {
   result = []
   i = 0
   n = music_string の大きさ
   
   n 回くり返す {
      c = music_string[i]
      
      # スペース (32) はスキップ
      もし c が 32 ならば {
         何もしない
      }
      # 'o' (111) の場合
      そうでなければ {
         もし c が 111 ならば {
            # 次の文字を確認
            next_idx = 和(i, 1)
            もし next_idx が n より小さい ならば {
               next_c = music_string[next_idx]
               # '|' (124) がある場合は 2分音符 (2拍)
               もし next_c が 124 ならば {
                  result に 2 を追加する
                  i を増やす
               }
               # '|' がない場合は全音符 (4拍)
               そうでなければ {
                  result に 4 を追加する
               }
            }
            そうでなければ {
               # 末尾の 'o' は全音符 (4拍)
               result に 4 を追加する
            }
         }
         # '.' (46) の場合は 4分音符 (1拍)
         そうでなければ {
            もし c が 46 ならば {
               result に 1 を追加する
            }
         }
      }
      
      i を増やす
   }
   
   result が答え
}