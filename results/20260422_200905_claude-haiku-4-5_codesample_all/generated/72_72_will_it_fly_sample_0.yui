標準ライブラリを使う

will_it_fly = 入力 q, w に対し {
   # === ステップ 1: 配列の合計を計算 ===
   total = 0
   n = q の大きさ
   i = 0
   n 回くり返す {
      total = 和(total, q[i])
      i を増やす
   }
   
   # === ステップ 2: 合計が最大荷重を超えているかチェック ===
   もし total が w より大きい ならば {
      偽 が答え
   }
   
   # === ステップ 3: 配列が回文かチェック ===
   # 先頭と末尾から中央へ向かって比較する
   half = 商(n, 2)
   j = 0
   half 回くり返す {
      # j 番目と (n-1-j) 番目を比較
      k = 差(差(n, 1), j)
      もし q[j] が q[k] 以外 ならば {
         偽 が答え
      }
      j を増やす
   }
   
   # === すべての条件を満たした ===
   真 が答え
}