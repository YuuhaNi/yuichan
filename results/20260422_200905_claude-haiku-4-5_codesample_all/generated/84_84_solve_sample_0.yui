標準ライブラリを使う

solve = 入力 N に対し {
   # ステップ 1: N を文字列化して各桁の総和を求める
   s = 文字列化(N)
   digit_sum = 0
   i = 0
   s の大きさ 回 くり返す {
      c = s[i]
      # 文字コード '0' は 48 なので、c - 48 で数値に変換
      digit = 差(c, 48)
      digit_sum = 和(digit_sum, digit)
      i を増やす
   }
   
   # ステップ 2: digit_sum を 2 進数文字列に変換する
   # 0 の場合は特別に "0" を返す
   もし digit_sum が 0 ならば {
      "0" が答え
   }
   
   # digit_sum を 2 進数に変換
   binary = ""
   n = digit_sum
   # 上限 20 回でガード (2^20 > 10000 の桁和の最大値)
   20 回 くり返す {
      もし n が 0 ならば {
         くり返しを抜ける
      }
      bit = 剰余(n, 2)
      bit_char = 和(bit, 48)
      binary に bit_char を追加する
      n = 商(n, 2)
   }
   
   # ステップ 3: 逆順にする (LSB ファーストで構築したため)
   reverse(binary) が答え
}