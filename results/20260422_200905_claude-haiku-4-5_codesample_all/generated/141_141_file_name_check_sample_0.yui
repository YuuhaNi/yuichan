標準ライブラリを使う

file_name_check = 入力 file_name に対し {
   # === ステップ 1: ドットの個数をチェック ===
   dot_count = 0
   dot_pos = -1
   i = 0
   file_name の大きさ 回 くり返す {
      c = file_name[i]
      もし c が 46 ならば {  # 46 は '.' のコード
         dot_count を増やす
         dot_pos = i
      }
      i を増やす
   }
   
   # ドットがちょうど 1 つでなければ No
   もし dot_count が 1 以外 ならば {
      "No" が答え
   }
   
   # === ステップ 2: ドットの前後を分割 ===
   name_part = ""
   ext_part = ""
   i = 0
   file_name の大きさ 回 くり返す {
      c = file_name[i]
      もし i が dot_pos より小さい ならば {
         name_part に c を追加する
      }
      そうでなければ {
         もし i が dot_pos より大きい ならば {
            ext_part に c を追加する
         }
      }
      i を増やす
   }
   
   # === ステップ 3: name_part が空でないかチェック ===
   もし name_part の大きさ が 0 ならば {
      "No" が答え
   }
   
   # === ステップ 4: name_part の最初の文字が英文字かチェック ===
   first_char = name_part[0]
   is_alpha = 0
   # 大文字 A-Z: 65-90
   もし first_char が 65 以上 ならば {
      もし first_char が 90 以下 ならば {
         is_alpha = 1
      }
   }
   # 小文字 a-z: 97-122
   もし first_char が 97 以上 ならば {
      もし first_char が 122 以下 ならば {
         is_alpha = 1
      }
   }
   
   もし is_alpha が 0 ならば {
      "No" が答え
   }
   
   # === ステップ 5: name_part に 3 桁以上の連続した数字がないかチェック ===
   consecutive_digits = 0
   i = 0
   name_part の大きさ 回 くり返す {
      c = name_part[i]
      # 数字 0-9: 48-57
      もし c が 48 以上 ならば {
         もし c が 57 以下 ならば {
            consecutive_digits を増やす
            もし consecutive_digits が 3 以上 ならば {
               "No" が答え
            }
         }
         そうでなければ {
            consecutive_digits = 0
         }
      }
      そうでなければ {
         consecutive_digits = 0
      }
      i を増やす
   }
   
   # === ステップ 6: ext_part が有効な拡張子かチェック ===
   valid_exts = ["txt", "exe", "dll"]
   is_valid_ext = 0
   j = 0
   3 回 くり返す {
      もし ext_part が valid_exts[j] ならば {
         is_valid_ext = 1
      }
      j を増やす
   }
   
   もし is_valid_ext が 0 ならば {
      "No" が答え
   }
   
   # すべての条件を満たした
   "Yes" が答え
}