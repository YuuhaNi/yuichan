標準ライブラリを使う

solution = 入力 lst に対し {
   total = 0
   i = 0
   lst の大きさ 回 くり返す {
      # 偶数の位置 (0, 2, 4, ...) をチェック
      parity = 剰余(i, 2)
      もし parity が 0 ならば {
         # 位置 i の要素を取得
         x = lst[i]
         # その要素が奇数かチェック
         x_parity = 剰余(x, 2)
         もし x_parity が 0 以外 ならば {
            # 奇数なら合計に加える
            total = 和(total, x)
         }
      }
      i を増やす
   }
   total が答え
}