標準ライブラリを使う

fibfib = 入力 n に対し {
   もし n が 0 ならば {
      0 が答え
   }
   もし n が 1 ならば {
      0 が答え
   }
   もし n が 2 ならば {
      1 が答え
   }
   
   # n >= 3 の場合、動的計画法で計算する
   # dp[i] は fibfib(i) の値を保持する
   dp = [0, 0, 1]
   i = 3
   n 回くり返す {
      もし i が n より大きい ならば {
         くり返しを抜ける
      }
      # fibfib(i) = fibfib(i-1) + fibfib(i-2) + fibfib(i-3)
      # dp の最後の 3 要素を使って計算
      idx1 = 差(i, 1)
      idx2 = 差(i, 2)
      idx3 = 差(i, 3)
      val1 = dp[差(dp の大きさ, 1)]
      val2 = dp[差(dp の大きさ, 2)]
      val3 = dp[差(dp の大きさ, 3)]
      next_val = 和(和(val1, val2), val3)
      dp に next_val を追加する
      i を増やす
   }
   
   dp[差(dp の大きさ, 1)] が答え
}