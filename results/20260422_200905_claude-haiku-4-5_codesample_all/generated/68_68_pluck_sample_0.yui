標準ライブラリを使う

pluck = 入力 arr に対し {
   n = arr の大きさ
   もし n が 0 ならば {
      []が答え
   }
   
   # 最小偶数値と、その最初のインデックスを探す
   min_even = 値なし
   min_index = 値なし
   
   i = 0
   n 回くり返す {
      x = arr[i]
      # x が偶数かどうかを調べる (剰余が 0)
      remainder = 剰余(x, 2)
      もし remainder が 0 ならば {
         # x は偶数
         もし min_even が値なし ならば {
            # 最初の偶数を見つけた
            min_even = x
            min_index = i
         }
         そうでなければ {
            # 既に偶数を見つけている場合、より小さい値があるか確認
            もし x が min_even より小さい ならば {
               min_even = x
               min_index = i
            }
         }
      }
      i を増やす
   }
   
   # 偶数が見つかったかどうかを確認
   もし min_even が値なし ならば {
      []が答え
   }
   
   [min_even, min_index]が答え
}

# テスト