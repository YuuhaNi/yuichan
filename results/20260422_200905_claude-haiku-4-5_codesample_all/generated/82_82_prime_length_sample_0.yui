標準ライブラリを使う

prime_length = 入力 string に対し {
   n = string の大きさ
   
   # n が 2 未満なら素数ではない
   もし n が 2 より小さい ならば {
      偽 が答え
   }
   
   # n が 2 なら素数
   もし n が 2 ならば {
      真 が答え
   }
   
   # n が偶数なら素数ではない
   remainder = 剰余(n, 2)
   もし remainder が 0 ならば {
      偽 が答え
   }
   
   # 3 以上の奇数で割り切れるかを調べる
   # i*i <= n の範囲で調べれば十分
   i = 3
   limit = 整数化(平方根(小数化(n)))
   
   差(limit, 2) 回 くり返す {
      もし 剰余(n, i) が 0 ならば {
         偽 が答え
      }
      i = 和(i, 2)
   }
   
   # どの数でも割り切れなかったら素数
   真 が答え
}