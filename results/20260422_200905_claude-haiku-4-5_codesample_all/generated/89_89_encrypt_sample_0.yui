標準ライブラリを使う

encrypt = 入力 s に対し {
   result = ""
   n = s の大きさ
   i = 0
   n 回くり返す {
      c = s[i]
      nc = c
      
      # 大文字 A..Z (65..90)
      もし c が 65 以上ならば {
         もし c が 90 以下ならば {
            # 位置を計算: 0..25 に正規化
            pos = 差(c, 65)
            # 位置を 2 倍して 2 を足す
            new_pos = 和(積(pos, 2), 2)
            # 26 で割った余りで循環させる
            new_pos = 剰余(new_pos, 26)
            # 文字コードに戻す
            nc = 和(new_pos, 65)
         }
      }
      
      # 小文字 a..z (97..122)
      もし c が 97 以上ならば {
         もし c が 122 以下ならば {
            # 位置を計算: 0..25 に正規化
            pos = 差(c, 97)
            # 位置を 2 倍して 2 を足す
            new_pos = 和(積(pos, 2), 2)
            # 26 で割った余りで循環させる
            new_pos = 剰余(new_pos, 26)
            # 文字コードに戻す
            nc = 和(new_pos, 97)
         }
      }
      
      result に nc を追加する
      i を増やす
   }
   result が答え
}

# テスト