標準ライブラリを使う

is_happy = 入力 s に対し {
   # 文字列の長さが 3 未満なら False
   n = s の大きさ
   もし n が 3 より小さい ならば {
      偽 が答え
   }
   
   # 連続する 3 文字をチェック
   # 走査範囲は 0 から n-3 まで
   limit = 差(n, 2)
   i = 0
   limit 回 くり返す {
      c1 = s[i]
      c2 = s[和(i, 1)]
      c3 = s[和(i, 2)]
      
      # 3 文字が全て異なるかチェック
      # c1 == c2 または c1 == c3 または c2 == c3 なら unhappy
      もし c1 が c2 ならば {
         偽 が答え
      }
      もし c1 が c3 ならば {
         偽 が答え
      }
      もし c2 が c3 ならば {
         偽 が答え
      }
      
      i を増やす
   }
   
   # すべての連続 3 文字が異なれば True
   真 が答え
}