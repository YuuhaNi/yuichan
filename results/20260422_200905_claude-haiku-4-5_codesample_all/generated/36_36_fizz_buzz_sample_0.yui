標準ライブラリを使う

fizz_buzz = 入力 n に対し {
   count = 0
   i = 0
   n 回くり返す {
      # 11 または 13 で割り切れるかを調べる
      r11 = 剰余(i, 11)
      r13 = 剰余(i, 13)
      divisible = 0
      もし r11 が 0 ならば {
         divisible = 1
      }
      もし r13 が 0 ならば {
         divisible = 1
      }
      
      # 割り切れる場合、文字列化して "7" が含まれるか調べる
      もし divisible が 1 ならば {
         s = 文字列化(i)
         もし "7" が s のいずれか ならば {
            count を増やす
         }
      }
      i を増やす
   }
   count が答え
}