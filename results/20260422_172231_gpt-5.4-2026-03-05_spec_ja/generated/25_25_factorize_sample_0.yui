標準ライブラリを使う

factorize = 入力 n に対し {
  result = []
  d = 2

  もしnが1以下ならば {
    result が答え
  }

  もしnが0より大きいならば {
    くり返し = 1
    n回くり返す {
      もし剰余(n, d)が0ならば {
        resultにdを追加する
        n = 商(n, d)
      }
      そうでなければ {
        dを増やす
      }

      もしnが1ならば {
        result が答え
      }
    }
  }

  result が答え
}