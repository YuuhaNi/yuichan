標準ライブラリを使う

will_it_fly = 入力 q, w に対し {
   合計 = 0
   回文 = 真
   i = 0

   qの大きさ回くり返す {
      合計 = 和(合計, q[i])

      もし q[i] が q[差(qの大きさ, 1, i)] 以外ならば {
         回文 = 偽
      }

      iを増やす
   }

   もし 回文 が 真 ならば {
      もし 合計 が w 以下ならば {
         真 が答え
      }
      そうでなければ {
         偽 が答え
      }
   }
   そうでなければ {
      偽 が答え
   }
}