標準ライブラリを使う

minPath = 入力 grid, k に対し {
   n = gridの大きさ
   pos = {}
   i = 0
   n回くり返す {
      j = 0
      n回くり返す {
         v = grid[i][j]
         pos[文字列化(v)] = [i, j]
         jを増やす
      }
      iを増やす
   }

   答え = []
   start = 1
   k回くり返す {
      もし start が 積(n, n) 以下 ならば {
         答えにstartを追加する
      }

      もし 答えの大きさ が k より小さい ならば {
         cur = start
         もし cur が 積(n, n) 以外 ならば {
            p1 = pos[文字列化(cur)]
            p2 = pos[文字列化(和(cur, 1))]
            dist = 和(絶対値(差(p1[0], p2[0])), 絶対値(差(p1[1], p2[1])))

            もし dist が 1 ならば {
               start = 和(start, 1)
            }
            そうでなければ {
               くり返しを抜ける
            }
         }
         そうでなければ {
            くり返しを抜ける
         }
      }
      そうでなければ {
         くり返しを抜ける
      }
   }

   もし 答えの大きさ が k より小さい ならば {
      もし 答えの大きさ が 0 ならば {
         cur = 1
      }
      そうでなければ {
         cur = 答え[差(答えの大きさ, 1)]
      }

      残り = 差(k, 答えの大きさ)
      t = 0
      残り回くり返す {
         もし 剰余(t, 2) が 0 ならば {
            答えに差(cur, 1)を追加する
         }
         そうでなければ {
            答えにcurを追加する
         }
         tを増やす
      }
   }

   答え が答え
}