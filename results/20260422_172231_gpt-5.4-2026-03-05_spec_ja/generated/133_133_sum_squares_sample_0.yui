標準ライブラリを使う

sum_squares = 入力 lst に対し {
  合計 = 0
  i = 0
  lstの大きさ回くり返す {
    x = lst[i]
    整数部 = 整数化(x)
    もしxが整数部ならば {
      切り上げ値 = 整数部
    }
    そうでなければ {
      もしxが0より大きいならば {
        切り上げ値 = 和(整数部, 1)
      }
      そうでなければ {
        切り上げ値 = 整数部
      }
    }
    合計 = 和(合計, 積(切り上げ値, 切り上げ値))
    iを増やす
  }
  合計が答え
}