標準ライブラリを使う

solve = 入力 s に対し {
   result = []
   has_alpha = 偽
   i = 0

   sの大きさ回くり返す {
      c = s[i]

      もしcが65以上ならば {
         もしcが90以下ならば {
            resultに和(c, 32)を追加する
            has_alpha = 真
         }
         そうでなければ {
            もしcが97以上ならば {
               もしcが122以下ならば {
                  resultに差(c, 32)を追加する
                  has_alpha = 真
               }
               そうでなければ {
                  resultにcを追加する
               }
            }
            そうでなければ {
               resultにcを追加する
            }
         }
      }
      そうでなければ {
         もしcが97以上ならば {
            もしcが122以下ならば {
               resultに差(c, 32)を追加する
               has_alpha = 真
            }
            そうでなければ {
               resultにcを追加する
            }
         }
         そうでなければ {
            resultにcを追加する
         }
      }

      iを増やす
   }

   もしhas_alphaが真ならば {
      result が答え
   }
   そうでなければ {
      rev = []
      j = sの大きさ
      jを減らす

      sの大きさ回くり返す {
         revにs[j]を追加する
         jを減らす
      }

      rev が答え
   }
}