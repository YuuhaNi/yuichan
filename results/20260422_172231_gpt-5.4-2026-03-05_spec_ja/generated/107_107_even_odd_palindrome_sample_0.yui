標準ライブラリを使う

even_odd_palindrome = 入力 n に対し {
    偶数回数 = 0
    奇数回数 = 0
    i = 1
    n回くり返す {
        もし i が 10 より小さいならば {
            もし 剰余(i, 2) が 0 ならば {
                偶数回数を増やす
            }
            そうでなければ {
                奇数回数を増やす
            }
        }
        そうでなければ {
            もし i が 100 より小さいならば {
                もし i[0] が i[1] ならば {
                    もし 剰余(i, 2) が 0 ならば {
                        偶数回数を増やす
                    }
                    そうでなければ {
                        奇数回数を増やす
                    }
                }
            }
            そうでなければ {
                もし i[0] が i[2] ならば {
                    もし 剰余(i, 2) が 0 ならば {
                        偶数回数を増やす
                    }
                    そうでなければ {
                        奇数回数を増やす
                    }
                }
            }
        }
        iを増やす
    }
    [偶数回数, 奇数回数] が答え
}