標準ライブラリを使う

longest = 入力 strings に対し {
   もし stringsの大きさ が 0 ならば {
      値なし が答え
   }

   best = strings[0]
   i = 1
   stringsの大きさ回くり返す {
      もし i が stringsの大きさ より小さい ならば {
         もし bestの大きさ が strings[i]の大きさ より小さい ならば {
            best = strings[i]
         }
         iを増やす
      }
   }
   best が答え
}