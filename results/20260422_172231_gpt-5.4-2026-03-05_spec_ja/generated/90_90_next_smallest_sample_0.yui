標準ライブラリを使う

next_smallest = 入力 lst に対し {
    もし lstの大きさ が 2より小さい ならば {
        値なし が答え
    }

    最小 = lst[0]
    次最小 = 値なし
    i = 1

    lstの大きさ回くり返す {
        もし i が lstの大きさ 以下 ならば {
            くり返しを抜ける
        }

        x = lst[i]

        もし x が 最小より小さい ならば {
            次最小 = 最小
            最小 = x
        }
        そうでなければ {
            もし x が 最小以外 ならば {
                もし 次最小 が 値なし ならば {
                    次最小 = x
                }
                そうでなければ {
                    もし x が 次最小より小さい ならば {
                        次最小 = x
                    }
                }
            }
        }

        iを増やす
    }

    次最小 が答え
}