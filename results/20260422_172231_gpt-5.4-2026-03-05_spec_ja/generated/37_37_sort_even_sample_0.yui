標準ライブラリを使う

sort_even = 入力 l に対し {
   偶数要素 = []
   i = 0
   lの大きさ回くり返す {
      もし剰余(i, 2)が0ならば {
         偶数要素にl[i]を追加する
      }
      iを増やす
   }

   a = 0
   偶数要素の大きさ回くり返す {
      b = 0
      もしaが差(偶数要素の大きさ, 1)より小さいならば {
         差(差(偶数要素の大きさ, 1), a)回くり返す {
            もし偶数要素[b]が偶数要素[和(b, 1)]より大きいならば {
               一時 = 偶数要素[b]
               偶数要素[b] = 偶数要素[和(b, 1)]
               偶数要素[和(b, 1)] = 一時
            }
            bを増やす
         }
      }
      aを増やす
   }

   結果 = []
   i = 0
   偶数位置 = 0
   lの大きさ回くり返す {
      もし剰余(i, 2)が0ならば {
         結果に偶数要素[偶数位置]を追加する
         偶数位置を増やす
      }
      そうでなければ {
         結果にl[i]を追加する
      }
      iを増やす
   }

   結果 が答え
}