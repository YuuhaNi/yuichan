標準ライブラリを使う

valid_date = 入力 date に対し {
   もしdateの大きさが0ならば {
      偽が答え
   }

   parts = []
   current = ""
   i = 0
   もしdateの大きさが10以外ならば {
      偽が答え
   }
   10回くり返す {
      ch = date[i]
      もしiが2ならば {
         もしchが45以外ならば {
            偽が答え
         }
         partsにcurrentを追加する
         current = ""
      }
      そうでなければ {
         もしiが5ならば {
            もしchが45以外ならば {
               偽が答え
            }
            partsにcurrentを追加する
            current = ""
         }
         そうでなければ {
            もしchが48より小さいならば {
               偽が答え
            }
            もしchが57より大きいならば {
               偽が答え
            }
            current = "{current}{文字列化(ch)}"
         }
      }
      iを増やす
   }
   partsにcurrentを追加する

   もしpartsの大きさが3以外ならば {
      偽が答え
   }

   もしparts[0]の大きさが2以外ならば {
      偽が答え
   }
   もしparts[1]の大きさが2以外ならば {
      偽が答え
   }
   もしparts[2]の大きさが4以外ならば {
      偽が答え
   }

   month = 整数化(parts[0])
   day = 整数化(parts[1])

   もしmonthが1より小さいならば {
      偽が答え
   }
   もしmonthが12より大きいならば {
      偽が答え
   }

   もしdayが1より小さいならば {
      偽が答え
   }

   もしmonthが2ならば {
      もしdayが29より大きいならば {
         偽が答え
      }
      真が答え
   }

   もしmonthが4ならば {
      もしdayが30より大きいならば {
         偽が答え
      }
      真が答え
   }
   そうでなければ {
      もしmonthが6ならば {
         もしdayが30より大きいならば {
            偽が答え
         }
         真が答え
      }
      そうでなければ {
         もしmonthが9ならば {
            もしdayが30より大きいならば {
               偽が答え
            }
            真が答え
         }
         そうでなければ {
            もしmonthが11ならば {
               もしdayが30より大きいならば {
                  偽が答え
               }
               真が答え
            }
            そうでなければ {
               もしdayが31より大きいならば {
                  偽が答え
               }
               真が答え
            }
         }
      }
   }
}