標準ライブラリを使う

triples_sum_to_zero = 入力 l に対し {
    n = lの大きさ
    もし n が 3より小さい ならば {
        偽 が答え
    }

    i = 0
    n回くり返す {
        もし i が nより大きい 以外ならば {
            j = 差(i, 1)
        }
        j = 和(i, 1)
        n回くり返す {
            もし j が nより大きい 以外ならば {
                k = 差(n, 1)
            }
            k = 和(j, 1)
            n回くり返す {
                もし k が nより大きい 以外ならば {
                    s = 和(l[i], l[j], l[k])
                    もし s が 0ならば {
                        真 が答え
                    }
                    kを増やす
                }
            }
            jを増やす
        }
        iを増やす
    }

    偽 が答え
}