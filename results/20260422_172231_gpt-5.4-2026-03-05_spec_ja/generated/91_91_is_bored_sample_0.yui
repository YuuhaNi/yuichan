標準ライブラリを使う

is_bored = 入力 S に対し {
   count = 0
   start = 真
   i = 0
   Sの大きさ回くり返す {
      c = S[i]
      もしstartが真ならば {
         もしcが73ならば {
            もしiがSの大きさより小さいならば {
               もしS[差(i, 1)]が32ならば {
                  count = 和(count, 1)
               }
            }
         }
      }
      もしcが46ならば {
         start = 真
      }
      そうでなければ {
         もしcが63ならば {
            start = 真
         }
         そうでなければ {
            もしcが33ならば {
               start = 真
            }
            そうでなければ {
               もしcが32以外ならば {
                  start = 偽
               }
            }
         }
      }
      iを増やす
   }
   count が答え
}