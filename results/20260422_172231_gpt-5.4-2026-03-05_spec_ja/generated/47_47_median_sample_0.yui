標準ライブラリを使う

median = 入力 l に対し {
    a = 配列化(l)
    n = aの大きさ

    i = 0
    n回くり返す {
        j = 0
        差(n, 1)回くり返す {
            もし a[j] が a[差(n, 2)] より大きいならば {
                temp = a[j]
                a[j] = a[差(j, -1)]
                a[差(j, -1)] = temp
            }
            jを増やす
        }
        iを増やす
    }

    もし 剰余(n, 2) が 1 ならば {
        a[商(n, 2)] が答え
    }
    そうでなければ {
        商(和(a[差(商(n, 2), 1)], a[商(n, 2)]), 2) が答え
    }
}