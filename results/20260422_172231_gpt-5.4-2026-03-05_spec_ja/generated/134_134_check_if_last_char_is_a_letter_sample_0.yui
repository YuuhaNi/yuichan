標準ライブラリを使う

check_if_last_char_is_a_letter = 入力 txt に対し {
    もしtxtの大きさが0ならば {
        偽が答え
    }

    last = txt[差(txtの大きさ, 1)]

    もしlastが32ならば {
        偽が答え
    }

    もしtxtの大きさが1ならば {
        もしlastが65以上ならば {
            もしlastが90以下ならば {
                真が答え
            }
        }
        もしlastが97以上ならば {
            もしlastが122以下ならば {
                真が答え
            }
        }
        偽が答え
    }

    prev = txt[差(txtの大きさ, 2)]

    もしprevが32以外ならば {
        偽が答え
    }

    もしlastが65以上ならば {
        もしlastが90以下ならば {
            真が答え
        }
    }

    もしlastが97以上ならば {
        もしlastが122以下ならば {
            真が答え
        }
    }

    偽が答え
}