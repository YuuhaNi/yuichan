標準ライブラリを使う

remove_vowels = 入力 text に対し {
   result = []
   i = 0
   textの大きさ回くり返す {
      c = text[i]
      もしcが97ならば {
         何もしない
      }
      そうでなければ {
         もしcが101ならば {
            何もしない
         }
         そうでなければ {
            もしcが105ならば {
               何もしない
            }
            そうでなければ {
               もしcが111ならば {
                  何もしない
               }
               そうでなければ {
                  もしcが117ならば {
                     何もしない
                  }
                  そうでなければ {
                     もしcが65ならば {
                        何もしない
                     }
                     そうでなければ {
                        もしcが69ならば {
                           何もしない
                        }
                        そうでなければ {
                           もしcが73ならば {
                              何もしない
                           }
                           そうでなければ {
                              もしcが79ならば {
                                 何もしない
                              }
                              そうでなければ {
                                 もしcが85ならば {
                                    何もしない
                                 }
                                 そうでなければ {
                                    resultにcを追加する
                                 }
                              }
                           }
                        }
                     }
                  }
               }
            }
         }
      }
      iを増やす
   }
   result が答え
}