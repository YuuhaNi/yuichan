標準ライブラリを使う

any_int = 入力 x, y, z に対し {
   もし整数判定(x)が真ならば {
      もし整数判定(y)が真ならば {
         もし整数判定(z)が真ならば {
            もしxが和(y, z)ならば {
               真が答え
            }
            そうでなければ {
               もしyが和(x, z)ならば {
                  真が答え
               }
               そうでなければ {
                  もしzが和(x, y)ならば {
                     真が答え
                  }
                  そうでなければ {
                     偽が答え
                  }
               }
            }
         }
         そうでなければ {
            偽が答え
         }
      }
      そうでなければ {
         偽が答え
      }
   }
   そうでなければ {
      偽が答え
   }
}