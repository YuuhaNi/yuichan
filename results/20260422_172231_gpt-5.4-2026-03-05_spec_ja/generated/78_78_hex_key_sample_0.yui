標準ライブラリを使う

hex_key = 入力 num に対し {
  count = 0
  i = 0
  numの大きさ回くり返す {
    ch = num[i]
    もし ch が "2" ならば {
      countを増やす
    }
    そうでなければ {
      もし ch が "3" ならば {
        countを増やす
      }
      そうでなければ {
        もし ch が "5" ならば {
          countを増やす
        }
        そうでなければ {
          もし ch が "7" ならば {
            countを増やす
          }
          そうでなければ {
            もし ch が "B" ならば {
              countを増やす
            }
            そうでなければ {
              もし ch が "D" ならば {
                countを増やす
              }
            }
          }
        }
      }
    }
    iを増やす
  }
  count が答え
}