標準ライブラリを使う

is_happy = 入力 s に対し {
   もしsの大きさが3より小さいならば {
      偽が答え
   }

   i = 0
   回数 = 差(sの大きさ, 2)

   回数回くり返す {
      もしs[i]がs[差(i, -1)]ならば {
         偽が答え
      }
      もしs[差(i, -1)]がs[差(i, -2)]ならば {
         偽が答え
      }
      もしs[i]がs[差(i, -2)]ならば {
         偽が答え
      }
      iを増やす
   }

   真が答え
}