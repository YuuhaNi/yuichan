標準ライブラリを使う

count_up_to = 入力 n に対し {
  result = []
  i = 2

  n回くり返す {
    もし i が n より大きいならば {
      くり返しを抜ける
    }

    is_prime = 真
    j = 2

    i回くり返す {
      もし j が i より小さいならば {
        もし 剰余(i, j) が 0 ならば {
          is_prime = 偽
        }
        jを増やす
      }
    }

    もし is_prime が 真 ならば {
      resultにiを追加する
    }

    iを増やす
  }

  result が答え
}