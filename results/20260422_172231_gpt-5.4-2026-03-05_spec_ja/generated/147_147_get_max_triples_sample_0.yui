標準ライブラリを使う

get_max_triples = 入力 n に対し {
   a = []
   i = 1
   n回くり返す {
      aに差(積(i, i), i, -1)を追加する
      iを増やす
   }

   triples = []
   i = 0
   aの大きさ回くり返す {
      j = 和(i, 1)
      rest1 = 差(aの大きさ, j)
      rest1回くり返す {
         k = 和(j, 1)
         rest2 = 差(aの大きさ, k)
         rest2回くり返す {
            s = 和(a[i], a[j], a[k])
            もし剰余(s, 3)が0ならば {
               triplesに[a[i], a[j], a[k]]を追加する
            }
            kを増やす
         }
         jを増やす
      }
      iを増やす
   }

   triples が答え
}