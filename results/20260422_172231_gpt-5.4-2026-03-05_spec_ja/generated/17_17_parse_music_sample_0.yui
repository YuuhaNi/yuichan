標準ライブラリを使う

parse_music = 入力 music_string に対し {
   結果 = []
   現在 = ""
   i = 0

   music_stringの大きさ回くり返す {
      文字 = music_string[i]

      もし文字が32ならば {
         もし現在が""以外ならば {
            もし現在が"o"ならば {
               結果に4を追加する
            }
            そうでなければ {
               もし現在が"o|"ならば {
                  結果に2を追加する
               }
               そうでなければ {
                  もし現在が".|"ならば {
                     結果に1を追加する
                  }
               }
            }
            現在 = ""
         }
      }
      そうでなければ {
         現在 = "{現在}{文字列化(文字)}"
      }

      iを増やす
   }

   もし現在が""以外ならば {
      もし現在が"o"ならば {
         結果に4を追加する
      }
      そうでなければ {
         もし現在が"o|"ならば {
            結果に2を追加する
         }
         そうでなければ {
            もし現在が".|"ならば {
               結果に1を追加する
            }
         }
      }
   }

   結果 が答え
}