標準ライブラリを使う

pairs_sum_to_zero = 入力 l に対し {
    i = 0
    lの大きさ回くり返す {
        j = i
        jを増やす
        lの大きさ回くり返す {
            もし j が lの大きさより小さいならば {
                もし 和(l[i], l[j]) が 0 ならば {
                    真 が答え
                }
                jを増やす
            }
        }
        iを増やす
    }
    偽 が答え
}