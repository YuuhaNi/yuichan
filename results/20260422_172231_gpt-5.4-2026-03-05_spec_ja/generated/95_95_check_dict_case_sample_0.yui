標準ライブラリを使う

check_dict_case = 入力 dict に対し {
   keys = []
   もし配列判定(dict["keys"])ならば {
      keys = dict["keys"]
   }
   そうでなければ {
      dictの大きさが0ならば {
         偽が答え
      }
      偽が答え
   }

   keysの大きさが0ならば {
      偽が答え
   }

   lower_count = 0
   upper_count = 0

   keysの大きさ回くり返す {
      i = lower_count
      i = 和(i, upper_count)
      key = keys[i]

      もし文字列判定(key)が偽ならば {
         偽が答え
      }

      もしkeyが小文字化(key)ならば {
         lower_countを増やす
      }
      そうでなければ {
         もしkeyが大文字化(key)ならば {
            upper_countを増やす
         }
         そうでなければ {
            偽が答え
         }
      }
   }

   もしlower_countがkeysの大きさならば {
      真が答え
   }
   そうでなければ {
      偽が答え
   }
}