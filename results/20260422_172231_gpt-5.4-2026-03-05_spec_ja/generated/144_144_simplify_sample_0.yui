標準ライブラリを使う

simplify = 入力 x, n に対し {
   i=0
   x_num=""
   x_den=""
   2回くり返す {
      もしx[i]が47ならば {
         iを増やす
         くり返しを抜ける
      }
      x_numにx[i]を追加する
      iを増やす
   }
   もしx[1]が47以外ならば {
      x_num=""
      i=0
      xの大きさ回くり返す {
         もしx[i]が47ならば {
            iを増やす
            くり返しを抜ける
         }
         x_numにx[i]を追加する
         iを増やす
      }
   }
   xの大きさ回くり返す {
      x_denにx[i]を追加する
      iを増やす
      もしiがxの大きさ以上ならば {
         くり返しを抜ける
      }
   }

   i=0
   n_num=""
   n_den=""
   2回くり返す {
      もしn[i]が47ならば {
         iを増やす
         くり返しを抜ける
      }
      n_numにn[i]を追加する
      iを増やす
   }
   もしn[1]が47以外ならば {
      n_num=""
      i=0
      nの大きさ回くり返す {
         もしn[i]が47ならば {
            iを増やす
            くり返しを抜ける
         }
         n_numにn[i]を追加する
         iを増やす
      }
   }
   nの大きさ回くり返す {
      n_denにn[i]を追加する
      iを増やす
      もしiがnの大きさ以上ならば {
         くり返しを抜ける
      }
   }

   a=整数化(x_num)
   b=整数化(x_den)
   c=整数化(n_num)
   d=整数化(n_den)

   num=積(a,c)
   den=積(b,d)

   もし剰余(num, den)が0ならば {
      真が答え
   }
   そうでなければ {
      偽が答え
   }
}