標準ライブラリを使う

flip_case = 入力 string に対し {
  result = []
  i = 0
  stringの大きさ回くり返す {
    c = string[i]
    もしcが97以上ならば {
      もしcが122以下ならば {
        resultに差(c, 32)を追加する
      }
      そうでなければ {
        もしcが65以上ならば {
          もしcが90以下ならば {
            resultに和(c, 32)を追加する
          }
          そうでなければ {
            resultにcを追加する
          }
        }
        そうでなければ {
          resultにcを追加する
        }
      }
    }
    そうでなければ {
      もしcが65以上ならば {
        もしcが90以下ならば {
          resultに和(c, 32)を追加する
        }
        そうでなければ {
          resultにcを追加する
        }
      }
      そうでなければ {
        resultにcを追加する
      }
    }
    iを増やす
  }
  result が答え
}