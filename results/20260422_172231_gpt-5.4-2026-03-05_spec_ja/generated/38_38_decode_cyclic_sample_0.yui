標準ライブラリを使う

decode_cyclic = 入力 s に対し {
    result = []
    i = 0
    sの大きさ回くり返す {
        c = s[i]
        もしcが65以上ならば {
            もしcが90以下ならば {
                n = 差(c, 65)
                m = 剰余(差(和(n, 23), 0), 26)
                resultに和(m, 65)を追加する
            }
            そうでなければ {
                もしcが97以上ならば {
                    もしcが122以下ならば {
                        n = 差(c, 97)
                        m = 剰余(差(和(n, 23), 0), 26)
                        resultに和(m, 97)を追加する
                    }
                    そうでなければ {
                        resultにcを追加する
                    }
                }
                そうでなければ {
                    resultにcを追加する
                }
            }
        }
        そうでなければ {
            もしcが97以上ならば {
                もしcが122以下ならば {
                    n = 差(c, 97)
                    m = 剰余(差(和(n, 23), 0), 26)
                    resultに和(m, 97)を追加する
                }
                そうでなければ {
                    resultにcを追加する
                }
            }
            そうでなければ {
                resultにcを追加する
            }
        }
        iを増やす
    }
    result が答え
}