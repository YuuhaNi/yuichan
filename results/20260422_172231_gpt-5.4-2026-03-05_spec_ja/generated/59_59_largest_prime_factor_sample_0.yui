標準ライブラリを使う

largest_prime_factor = 入力 n に対し {
  最大 = 1
  d = 2
  1回くり返す {
    もし積(d, d)がnより大きいならば {
      くり返しを抜ける
    }
    もし剰余(n, d)が0ならば {
      最大 = d
      1回くり返す {
        もし剰余(n, d)が0以外ならば {
          くり返しを抜ける
        }
        n = 商(n, d)
      }
    }
    dを増やす
  }
  もしnが1より大きいならば {
    n が答え
  }
  そうでなければ {
    最大 が答え
  }
}