標準ライブラリを使う

tri = 入力 n に対し {
   result = [1]

   もしnが0ならば {
      result が答え
   }

   resultに3を追加する

   もしnが1ならば {
      result が答え
   }

   i = 2
   n回くり返す {
      もしiがnより大きいならば {
         くり返しを抜ける
      }

      もし剰余(i, 2)が0ならば {
         resultに和(1, 商(i, 2))を追加する
      }
      そうでなければ {
         resultに和(result[差(i, 1)], result[差(i, 2)], 和(1, 商(和(i, 1), 2)))を追加する
      }

      iを増やす
   }

   result が答え
}