標準ライブラリを使う

decode_shift = 入力 s に対し {
  result = []
  i = 0
  sの大きさ回くり返す {
    c = s[i]
    もしcが65以上ならば {
      もしcが90以下ならば {
        c = 和(剰余(和(差(c, 65), 5), 26), 65)
      }
      そうでなければ {
        もしcが97以上ならば {
          もしcが122以下ならば {
            c = 和(剰余(和(差(c, 97), 5), 26), 97)
          }
        }
      }
    }
    resultにcを追加する
    iを増やす
  }
  文字列化(result) が答え
}