標準ライブラリを使う

digits = 入力 n に対し {
  result = 1
  found = 偽
  もし剰余(n, 10)が0以外ならば {
    d = 剰余(n, 10)
    もし剰余(d, 2)が0以外ならば {
      result = 積(result, d)
      found = 真
    }
  }
  そうでなければ {
    d = 0
    もし剰余(d, 2)が0以外ならば {
      result = 積(result, d)
      found = 真
    }
  }

  n = 商(n, 10)
  n回くり返す {
    もしnが0ならば {
      くり返しを抜ける
    }
    d = 剰余(n, 10)
    もし剰余(d, 2)が0以外ならば {
      result = 積(result, d)
      found = 真
    }
    n = 商(n, 10)
  }

  もしfoundが真ならば {
    result が答え
  }
  そうでなければ {
    0 が答え
  }
}