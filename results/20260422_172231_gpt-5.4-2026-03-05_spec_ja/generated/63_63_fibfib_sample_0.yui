標準ライブラリを使う

fibfib = 入力 n に対し {
   もしnが0ならば {
      0 が答え
   }
   そうでなければ {
      もしnが1ならば {
         0 が答え
      }
      そうでなければ {
         もしnが2ならば {
            1 が答え
         }
         そうでなければ {
            a = 0
            b = 0
            c = 1
            i = 3
            差(n, 2)回くり返す {
               t = 和(a, b, c)
               a = b
               b = c
               c = t
            }
            c が答え
         }
      }
   }
}