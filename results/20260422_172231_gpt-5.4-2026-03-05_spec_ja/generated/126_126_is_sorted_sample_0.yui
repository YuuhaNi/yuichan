標準ライブラリを使う

is_sorted = 入力 lst に対し {
    もしlstの大きさが1以下ならば {
        真 が答え
    }

    i = 1
    同じ数 = 1

    差(lstの大きさ, 1)回くり返す {
        もしlst[i]がlst[差(i, 1)]より小さいならば {
            偽 が答え
        }

        もしlst[i]がlst[差(i, 1)]ならば {
            同じ数を増やす
            もし同じ数が3以上ならば {
                偽 が答え
            }
        }
        そうでなければ {
            同じ数 = 1
        }

        iを増やす
    }

    真 が答え
}