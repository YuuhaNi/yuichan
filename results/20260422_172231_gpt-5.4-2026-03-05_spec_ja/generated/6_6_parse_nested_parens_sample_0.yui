標準ライブラリを使う

parse_nested_parens = 入力 paren_string に対し {
   結果 = []
   現在グループ最大 = 0
   現在深さ = 0
   位置 = 0

   paren_stringの大きさ回くり返す {
      文字 = paren_string[位置]

      もし文字が40ならば {
         現在深さ = 和(現在深さ, 1)
         もし現在深さが現在グループ最大より大きいならば {
            現在グループ最大 = 現在深さ
         }
      }
      そうでなければ {
         もし文字が41ならば {
            現在深さ = 差(現在深さ, 1)
         }
         そうでなければ {
            もし文字が32ならば {
               もし現在グループ最大が0より大きいならば {
                  結果に現在グループ最大を追加する
                  現在グループ最大 = 0
                  現在深さ = 0
               }
            }
         }
      }

      位置を増やす
   }

   もし現在グループ最大が0より大きいならば {
      結果に現在グループ最大を追加する
   }

   結果 が答え
}