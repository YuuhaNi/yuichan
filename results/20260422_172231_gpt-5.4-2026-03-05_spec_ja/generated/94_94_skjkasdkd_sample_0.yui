標準ライブラリを使う

skjkasdkd = 入力 lst に対し {
   素数判定 = 入力 n に対し {
      もしnが2より小さいならば {
         偽 が答え
      }
      i = 2
      くり返し回数 = n
      くり返し回数回くり返す {
         もし積(i, i)がnより大きいならば {
            真 が答え
         }
         もし剰余(n, i)が0ならば {
            偽 が答え
         }
         iを増やす
      }
      真 が答え
   }

   最大素数 = 0
   i = 0
   lstの大きさ回くり返す {
      値 = lst[i]
      もし素数判定(値)が真ならば {
         もし値が最大素数より大きいならば {
            最大素数 = 値
         }
      }
      iを増やす
   }

   文字 = 文字列化(最大素数)
   合計 = 0
   i = 0
   文字の大きさ回くり返す {
      合計 = 和(合計, 差(文字[i], 48))
      iを増やす
   }
   合計 が答え
}