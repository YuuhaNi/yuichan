標準ライブラリを使う

fix_spaces = 入力 text に対し {
   result = []
   i = 0

   textの大きさ回くり返す {
      もしiがtextの大きさより小さいならば {
         もしtext[i]が32ならば {
            count = 0

            textの大きさ回くり返す {
               もしiがtextの大きさより小さいならば {
                  もしtext[i]が32ならば {
                     countを増やす
                     iを増やす
                  }
                  そうでなければ {
                     くり返しを抜ける
                  }
               }
               そうでなければ {
                  くり返しを抜ける
               }
            }

            もしcountが1ならば {
               resultに95を追加する
            }
            そうでなければ {
               resultに45を追加する
            }
         }
         そうでなければ {
            resultにtext[i]を追加する
            iを増やす
         }
      }
      そうでなければ {
         くり返しを抜ける
      }
   }

   result が答え
}