標準ライブラリを使う

count_upper = 入力 s に対し {
  i = 0
  count = 0
  sの大きさ回くり返す {
    もし剰余(i, 2)が0ならば {
      ch = s[i]
      もしchが65ならば {
        countを増やす
      }
      そうでなければ {
        もしchが69ならば {
          countを増やす
        }
        そうでなければ {
          もしchが73ならば {
            countを増やす
          }
          そうでなければ {
            もしchが79ならば {
              countを増やす
            }
            そうでなければ {
              もしchが85ならば {
                countを増やす
              }
            }
          }
        }
      }
    }
    iを増やす
  }
  count が答え
}