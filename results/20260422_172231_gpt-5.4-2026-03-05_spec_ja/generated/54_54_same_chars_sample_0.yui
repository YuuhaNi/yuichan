標準ライブラリを使う

same_chars = 入力 s0, s1 に対し {
   chars0 = []
   chars1 = []

   i = 0
   s0の大きさ回くり返す {
      c = s0[i]
      もしcがchars0のいずれでもないならば {
         chars0にcを追加する
      }
      iを増やす
   }

   i = 0
   s1の大きさ回くり返す {
      c = s1[i]
      もしcがchars1のいずれでもないならば {
         chars1にcを追加する
      }
      iを増やす
   }

   もしchars0の大きさがchars1の大きさ以外ならば {
      偽が答え
   }

   i = 0
   chars0の大きさ回くり返す {
      もしchars0[i]がchars1のいずれでもないならば {
         偽が答え
      }
      iを増やす
   }

   真が答え
}