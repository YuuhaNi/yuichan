標準ライブラリを使う

is_multiply_prime = 入力 a に対し {
   count = 0
   n = a
   i = 2

   100回くり返す {
      もし積(i, i)がnより大きいならば {
         くり返しを抜ける
      }

      もし剰余(n, i)が0ならば {
         prime = 真
         j = 2

         100回くり返す {
            もし積(j, j)がiより大きいならば {
               くり返しを抜ける
            }
            もし剰余(i, j)が0ならば {
               prime = 偽
               くり返しを抜ける
            }
            jを増やす
         }

         もしprimeが真ならば {
            countを増やす
            n = 商(n, i)
            i = 1
         }
      }

      iを増やす
   }

   もしnが1より大きいならば {
      prime = 真
      j = 2

      100回くり返す {
         もし積(j, j)がnより大きいならば {
            くり返しを抜ける
         }
         もし剰余(n, j)が0ならば {
            prime = 偽
            くり返しを抜ける
         }
         jを増やす
      }

      もしprimeが真ならば {
         countを増やす
      }
   }

   もしcountが3ならば {
      真 が答え
   }
   そうでなければ {
      偽 が答え
   }
}