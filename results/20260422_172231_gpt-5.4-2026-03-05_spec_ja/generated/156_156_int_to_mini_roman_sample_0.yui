標準ライブラリを使う

int_to_mini_roman = 入力 number に対し {
   values = [1000, 900, 500, 400, 100, 90, 50, 40, 10, 9, 5, 4, 1]
   symbols = ["m", "cm", "d", "cd", "c", "xc", "l", "xl", "x", "ix", "v", "iv", "i"]
   result = ""
   i = 0

   valuesの大きさ回くり返す {
      もしnumberがvalues[i]以上ならば {
         商(number, values[i])回くり返す {
            result = "{result}{symbols[i]}"
         }
         number = 剰余(number, values[i])
      }
      iを増やす
   }

   result が答え
}