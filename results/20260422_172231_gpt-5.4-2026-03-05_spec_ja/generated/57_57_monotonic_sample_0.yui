標準ライブラリを使う

monotonic = 入力 l に対し {
   もしlの大きさが2以下ならば {
      真が答え
   }

   inc = 真
   dec = 真
   i = 1

   差(lの大きさ, 1)回くり返す {
      もしl[i]がl[差(i, 1)]より小さいならば {
         inc = 偽
      }
      もしl[i]がl[差(i, 1)]より大きいならば {
         dec = 偽
      }
      iを増やす
   }

   もしincが真ならば {
      真が答え
   }
   そうでなければ {
      decが答え
   }
}