標準ライブラリを使う

match_parens = 入力 lst に対し {
  a = lst[0]
  b = lst[1]

  check = 入力 s に対し {
    bal = 0
    i = 0
    sの大きさ回くり返す {
      ch = s[i]
      もし ch が 40 ならば {
        bal = 和(bal, 1)
      }
      そうでなければ {
        bal = 差(bal, 1)
      }
      もし bal が 0 より小さいならば {
        偽 が答え
      }
      iを増やす
    }
    もし bal が 0 ならば {
      真 が答え
    }
    そうでなければ {
      偽 が答え
    }
  }

  first = "{a}{b}"
  もし check(first) が 真 ならば {
    "Yes" が答え
  }
  そうでなければ {
    second = "{b}{a}"
    もし check(second) が 真 ならば {
      "Yes" が答え
    }
    そうでなければ {
      "No" が答え
    }
  }
}