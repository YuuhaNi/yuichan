標準ライブラリを使う

anti_shuffle = 入力 s に対し {
   結果 = []
   単語 = []
   長さ = sの大きさ
   i = 0

   並べ替え単語を追加 = 入力なしに対し {
      もし単語の大きさが0ならば {
         関数から抜ける
      }

      j = 0
      単語の大きさ回くり返す {
         k = 0
         単語の大きさ回くり返す {
            もし k が 差(単語の大きさ, j, 1) より小さいならば {
               もし 単語[k] が 単語[和(k, 1)] より大きいならば {
                  一時 = 単語[k]
                  単語[k] = 単語[和(k, 1)]
                  単語[和(k, 1)] = 一時
               }
            }
            kを増やす
         }
         jを増やす
      }

      j = 0
      単語の大きさ回くり返す {
         結果に単語[j]を追加する
         jを増やす
      }

      単語 = []
   }

   長さ回くり返す {
      もし s[i] が 32 ならば {
         並べ替え単語を追加()
         結果に32を追加する
      }
      そうでなければ {
         単語にs[i]を追加する
      }
      iを増やす
   }

   並べ替え単語を追加()
   結果 が答え
}