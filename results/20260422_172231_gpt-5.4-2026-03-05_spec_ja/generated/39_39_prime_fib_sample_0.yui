標準ライブラリを使う

prime_fib = 入力 n に対し {
   is_prime = 入力 x に対し {
      もしxが2より小さいならば {
         偽 が答え
      }
      i = 2
      くり返す = 真
      1000000回くり返す {
         もしくり返すが偽ならば {
            くり返しを抜ける
         }
         もし積(i, i)がxより大きいならば {
            真 が答え
         }
         もし剰余(x, i)が0ならば {
            偽 が答え
         }
         iを増やす
      }
      偽 が答え
   }

   a = 1
   b = 1
   count = 0

   1000000回くり返す {
      c = 和(a, b)
      a = b
      b = c
      もしis_prime(a)が真ならば {
         countを増やす
         もしcountがnならば {
            a が答え
         }
      }
   }
}