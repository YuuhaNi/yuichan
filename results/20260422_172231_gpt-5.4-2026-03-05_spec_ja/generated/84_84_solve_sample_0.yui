標準ライブラリを使う

solve = 入力 N に対し {
  s = 0
  もしNが0ならば {
    s = 0
  }
  そうでなければ {
    くり返し = 真
    10000回くり返す {
      もしNが0ならば {
        くり返しを抜ける
      }
      d = 剰余(N, 10)
      s = 和(s, d)
      N = 商(N, 10)
    }
  }

  もしsが0ならば {
    "0" が答え
  }

  bits = []
  100回くり返す {
    もしsが0ならば {
      くり返しを抜ける
    }
    b = 剰余(s, 2)
    もしbが0ならば {
      bitsに"0"を追加する
    }
    そうでなければ {
      bitsに"1"を追加する
    }
    s = 商(s, 2)
  }

  result = []
  i = 差(bitsの大きさ, 1)
  100回くり返す {
    もしiが0より小さいならば {
      くり返しを抜ける
    }
    resultにbits[i]を追加する
    i = 差(i, 1)
  }

  文字列化(result) が答え
}