標準ライブラリを使う

get_odd_collatz = 入力 n に対し {
  odds = []
  x = n

  10000回くり返す {
    もし剰余(x, 2)が1ならば {
      oddsにxを追加する
    }

    もしxが1ならば {
      くり返しを抜ける
    }
    そうでなければ {
      もし剰余(x, 2)が0ならば {
        x = 商(x, 2)
      }
      そうでなければ {
        x = 和(積(3, x), 1)
      }
    }
  }

  sorted = []

  oddsの大きさ回くり返す {
    m = odds[0]
    idx = 0
    i = 0

    oddsの大きさ回くり返す {
      もしodds[i]がmより小さいならば {
        m = odds[i]
        idx = i
      }
      iを増やす
    }

    sortedにmを追加する

    rest = []
    i = 0
    removed = 偽

    oddsの大きさ回くり返す {
      もしiがidxならば {
        もしremovedが偽ならば {
          removed = 真
        }
        そうでなければ {
          restにodds[i]を追加する
        }
      }
      そうでなければ {
        restにodds[i]を追加する
      }
      iを増やす
    }

    odds = rest
  }

  sorted が答え
}