標準ライブラリを使う

prod_signs = 入力 arr に対し {
   もしarrの大きさが0ならば {
      値なし が答え
   }

   sum = 0
   sign = 1
   i = 0

   arrの大きさ回くり返す {
      x = arr[i]
      sum = 和(sum, 絶対値(x))

      もしxが0ならば {
         sign = 0
      }
      そうでなければ {
         もしxが0より小さいならば {
            sign = 差(0, sign)
         }
      }

      iを増やす
   }

   積(sum, sign) が答え
}