標準ライブラリを使う

odd_count = 入力 lst に対し {
   結果 = []
   i = 0
   lstの大きさ回くり返す {
      文字列 = lst[i]
      奇数数 = 0
      j = 0
      文字列の大きさ回くり返す {
         文字 = 文字列[j]
         もし文字が49ならば {
            奇数数を増やす
         }
         そうでなければ {
            もし文字が51ならば {
               奇数数を増やす
            }
            そうでなければ {
               もし文字が53ならば {
                  奇数数を増やす
               }
               そうでなければ {
                  もし文字が55ならば {
                     奇数数を増やす
                  }
                  そうでなければ {
                     もし文字が57ならば {
                        奇数数を増やす
                     }
                  }
               }
            }
         }
         jを増やす
      }
      結果に"the number of odd elements {奇数数}n the str{奇数数}ng {奇数数} of the {奇数数}nput."を追加する
      iを増やす
   }
   結果が答え
}