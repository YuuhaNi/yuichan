標準ライブラリを使う

fib4 = 入力 n に対し {
   もしnが0ならば {
      0が答え
   }
   そうでなければ {
      もしnが1ならば {
         0が答え
      }
      そうでなければ {
         もしnが2ならば {
            2が答え
         }
         そうでなければ {
            もしnが3ならば {
               0が答え
            }
            そうでなければ {
               a=0
               b=0
               c=2
               d=0
               i=4
               繰り返し回数=差(n, 3)
               繰り返し回数回くり返す {
                  次=和(a, b, c, d)
                  a=b
                  b=c
                  c=d
                  d=次
               }
               dが答え
            }
         }
      }
   }
}