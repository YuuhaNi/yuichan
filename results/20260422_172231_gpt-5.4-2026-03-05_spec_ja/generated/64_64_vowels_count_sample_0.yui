標準ライブラリを使う

vowels_count = 入力 s に対し {
  count = 0
  i = 0
  sの大きさ回くり返す {
    ch = s[i]
    もし ch が "a" ならば {
      countを増やす
    }
    そうでなければ {
      もし ch が "e" ならば {
        countを増やす
      }
      そうでなければ {
        もし ch が "i" ならば {
          countを増やす
        }
        そうでなければ {
          もし ch が "o" ならば {
            countを増やす
          }
          そうでなければ {
            もし ch が "u" ならば {
              countを増やす
            }
          }
        }
      }
    }
    iを増やす
  }
  count が答え
}