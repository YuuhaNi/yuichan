標準ライブラリを使う

encrypt = 入力 s に対し {
  result = []
  i = 0
  sの大きさ回くり返す {
    c = s[i]
    もしcが97以上ならば {
      もしcが122以下ならば {
        pos = 差(c, 97)
        shifted = 剰余(和(pos, 4), 26)
        resultに和(shifted, 97)を追加する
      }
      そうでなければ {
        resultにcを追加する
      }
    }
    そうでなければ {
      もしcが65以上ならば {
        もしcが90以下ならば {
          pos = 差(c, 65)
          shifted = 剰余(和(pos, 4), 26)
          resultに和(shifted, 65)を追加する
        }
        そうでなければ {
          resultにcを追加する
        }
      }
      そうでなければ {
        resultにcを追加する
      }
    }
    iを増やす
  }
  result が答え
}