標準ライブラリを使う

largest_smallest_integers = 入力 lst に対し {
   最大の負 = 値なし
   最小の正 = 値なし
   i = 0

   lstの大きさ回くり返す {
      値 = lst[i]

      もし 値が0より小さいならば {
         もし 最大の負が値なしならば {
            最大の負 = 値
         }
         そうでなければ {
            もし 値が最大の負より大きいならば {
               最大の負 = 値
            }
         }
      }
      そうでなければ {
         もし 値が0より大きいならば {
            もし 最小の正が値なしならば {
               最小の正 = 値
            }
            そうでなければ {
               もし 値が最小の正より小さいならば {
                  最小の正 = 値
               }
            }
         }
      }

      iを増やす
   }

   [最大の負, 最小の正] が答え
}