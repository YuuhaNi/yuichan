標準ライブラリを使う

cycpattern_check = 入力 a, b に対し {
   n = bの大きさ
   m = aの大きさ

   i = 0
   n回くり返す {
      j = 0
      見つかった = 偽

      m回くり返す {
         k = 0
         一致 = 真

         n回くり返す {
            ai = 和(j, k)
            bi = 剰余(和(i, k), n)

            もしaiがm以上ならば {
               一致 = 偽
               くり返しを抜ける
            }

            もしa[ai]がb[bi]以外ならば {
               一致 = 偽
               くり返しを抜ける
            }

            kを増やす
         }

         もし一致が真ならば {
            見つかった = 真
            くり返しを抜ける
         }

         jを増やす
      }

      もし見つかったが真ならば {
         真 が答え
      }

      iを増やす
   }

   偽 が答え
}