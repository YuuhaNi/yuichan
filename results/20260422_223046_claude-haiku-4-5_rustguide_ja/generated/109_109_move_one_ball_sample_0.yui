標準ライブラリを使う

move_one_ball = 入力 arr に対し {
   # 配列が空の場合はTrue
   もしarrの大きさが0ならば{
      真が答え
   }

   # 配列の大きさを取得
   n = arrの大きさ

   # n回まで右シフトを試す
   n回くり返す{
      # ソート済みかチェック
      is_sorted = 真
      差(n, 1)回くり返す{
         i = 0
         差(n, 1)回くり返す{
            もしarr[i]がarr[和(i, 1)]より大きいならば{
               is_sorted = 偽
               くり返しを抜ける
            }
            iを増やす
         }
         もしis_sortedが偽ならば{
            くり返しを抜ける
         }
      }

      # ソート済みならTrue
      もしis_sortedが真ならば{
         真が答え
      }

      # 右シフト操作を実行
      last = arr[差(n, 1)]
      i = 差(n, 1)
      n回くり返す{
         もしiが0ならば{
            くり返しを抜ける
         }
         arr[i] = arr[差(i, 1)]
         iを減らす
      }
      arr[0] = last
   }

   # どの右シフトでもソートできなかった
   偽が答え
}