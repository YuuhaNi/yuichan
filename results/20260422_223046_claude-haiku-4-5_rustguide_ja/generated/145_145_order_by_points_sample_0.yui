標準ライブラリを使う

order_by_points = 入力 nums に対し {
   # 桁の合計を計算する関数
   digit_sum = 入力 n に対し {
      もし n が 0 より小さいならば {
         n = 積(n, -1)
      }
      sum = 0
      n が 0 より大きいならば {
         sum = 和(sum, 剰余(n, 10))
         n = 商(n, 10)
      }
      sum が答え
   }

   # インデックス付きで処理するための配列を作成
   indexed = []
   i = 0
   nums の大きさ 回くり返す {
      item = {"value": nums[i], "index": i, "digit_sum": digit_sum(nums[i])}
      indexed に item を追加する
      i を増やす
   }

   # バブルソートで昇順に並べる（桁の合計で比較、同じなら元のインデックスで比較）
   n = indexed の大きさ
   n 回くり返す {
      j = 0
      差(n, 1) 回くり返す {
         current_sum = indexed[j]["digit_sum"]
         next_sum = indexed[差(j, 1)]["digit_sum"]
         current_index = indexed[j]["index"]
         next_index = indexed[差(j, 1)]["index"]

         もし current_sum が next_sum より大きいならば {
            temp = indexed[j]
            indexed[j] = indexed[差(j, 1)]
            indexed[差(j, 1)] = temp
         } そうでなければ {
            もし current_sum が next_sum ならば {
               もし current_index が next_index より大きいならば {
                  temp = indexed[j]
                  indexed[j] = indexed[差(j, 1)]
                  indexed[差(j, 1)] = temp
               }
            }
         }
         j を増やす
      }
   }

   # 値だけを抽出して返す
   result = []
   i = 0
   indexed の大きさ 回くり返す {
      result に indexed[i]["value"] を追加する
      i を増やす
   }
   result が答え
}