標準ライブラリを使う

pluck = 入力 arr に対し {
   もし arr の大きさ が 0 ならば {
      []が答え
   }
   
   min_even = 値なし
   min_index = 値なし
   
   i = 0
   arr の大きさ 回くり返す {
      value = arr[i]
      remainder = 剰余(value, 2)
      
      もし remainder が 0 ならば {
         もし min_even が 値なし ならば {
            min_even = value
            min_index = i
         } そうでなければ {
            もし value が min_even より小さい ならば {
               min_even = value
               min_index = i
            }
         }
      }
      
      i を増やす
   }
   
   もし min_even が 値なし ならば {
      []が答え
   } そうでなければ {
      [min_even, min_index]が答え
   }
}