標準ライブラリを使う

rounded_avg = 入力 n, m に対し {
   もし n が m より大きいならば {
      -1が答え
   }
   
   # n から m までの合計を計算
   合計 = 0
   i = n
   ループ回数 = 差(m, n)
   ループ回数を増やす
   
   ループ回数回くり返す {
      合計 = 和(合計, i)
      i を増やす
   }
   
   # 平均を計算
   個数 = 差(m, n)
   個数 を増やす
   平均 = 商(合計, 個数)
   
   # 余りで四捨五入判定
   余り = 剰余(合計, 個数)
   余り2倍 = 積(余り, 2)
   
   もし 余り2倍 が 個数 以上ならば {
      平均 を増やす
   }
   
   # 2進数に変換
   result = ""
   num = 平均
   
   もし num が 0 ならば {
      result = "0b0"
   } そうでなければ {
      binary = ""
      num回くり返す {
         余 = 剰余(num, 2)
         binary = 文字列化(余) + binary
         num = 商(num, 2)
         もし num が 0 ならば {
            くり返しを抜ける
         }
      }
      result = "0b" + binary
   }
   
   result が答え
}