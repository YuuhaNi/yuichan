標準ライブラリを使う

will_it_fly = 入力 q, w に対し {
   # 配列の合計を計算
   total = 0
   qの大きさ回くり返す {
      i = 0
      qの大きさ回くり返す {
         iを増やす
         total = 和(total, q[差(i, 1)])
      }
   }
   
   # 合計が最大荷重を超えているかチェック
   もしtotalがwより大きいならば {
      偽が答え
   }
   
   # バランス（回文）をチェック
   balanced = 真
   n = qの大きさ
   商(n, 2)回くり返す {
      i = 0
      商(n, 2)回くり返す {
         iを増やす
         idx = 差(i, 1)
         もしq[idx]がq[差(n, 和(idx, 1))]以外ならば {
            balanced = 偽
            くり返しを抜ける
         }
      }
   }
   
   もしbalancedが真ならば {
      真が答え
   }
   そうでなければ {
      偽が答え
   }
}