標準ライブラリを使う

is_happy = 入力 s に対し {
   # 文字列の長さが3未満なら偽
   もし s の大きさ が 3 より小さいならば {
      偽が答え
   }
   
   # 連続する3文字をチェック
   i = 0
   差(s の大きさ, 2)回くり返す {
      c1 = s[i]
      c2 = s[i + 1]
      c3 = s[i + 2]
      
      # 3文字がすべて異なるかチェック
      もし c1 が c2 ならば {
         偽が答え
      }
      もし c2 が c3 ならば {
         偽が答え
      }
      もし c1 が c3 ならば {
         偽が答え
      }
      
      i を増やす
   }
   
   # すべてのチェックを通過したら真
   真が答え
}