標準ライブラリを使う

below_threshold = 入力 l, t に対し {
   result = 真
   lの大きさ回くり返す{
      i = 0
      lの大きさ回くり返す{
         もしl[i]がtより大きいならば{
            result = 偽
         }
         iを増やす
      }
   }
   resultが答え
}
標準ライブラリを使う

below_threshold = 入力 l, t に対し {
   i = 0
   lの大きさ回くり返す{
      もしl[i]がtより大きいならば{
         偽が答え
      }
      iを増やす
   }
   真が答え
}