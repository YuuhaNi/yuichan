標準ライブラリを使う

is_bored = 入力 S に対し {
   count = 0
   i = 0
   Sの大きさ回くり返す{
      もし i が Sの大きさより小さいならば{
         もし S[i] が "I"[0] ならば{
            もし i が 0 ならば{
               もし差(Sの大きさ, i) が 1より大きいならば{
                  もし S[足(i, 1)] が " "[0] ならば{
                     countを増やす
                  }
               }
            }そうでなければ{
               もし S[差(i, 1)] が "."[0] ならば{
                  もし S[足(i, 1)] が " "[0] ならば{
                     countを増やす
                  }
               }そうでなければ{
                  もし S[差(i, 1)] が "?"[0] ならば{
                     もし S[足(i, 1)] が " "[0] ならば{
                        countを増やす
                     }
                  }そうでなければ{
                     もし S[差(i, 1)] が "!"[0] ならば{
                        もし S[足(i, 1)] が " "[0] ならば{
                           countを増やす
                        }
                     }
                  }
               }
            }
         }
      }
      iを増やす
   }
   countが答え
}