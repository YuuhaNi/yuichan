標準ライブラリを使う

triples_sum_to_zero = 入力 l に対し {
   n = lの大きさ
   もしnが3より小さいならば{
      偽が答え
   }
   
   i = 0
   n回くり返す{
      もしiがn以上ならば{
         くり返しを抜ける
      }
      j = 0
      n回くり返す{
         もしjがn以上ならば{
            くり返しを抜ける
         }
         もしjがiならば{
            jを増やす
         }そうでなければ{
            k = 0
            n回くり返す{
               もしkがn以上ならば{
                  くり返しを抜ける
               }
               もしkがiならば{
                  kを増やす
               }そうでなければ{
                  もしkがjならば{
                     kを増やす
                  }そうでなければ{
                     sum = 和(l[i], l[j], l[k])
                     もしsumが0ならば{
                        真が答え
                     }
                     kを増やす
                  }
               }
            }
            jを増やす
         }
      }
      iを増やす
   }
   
   偽が答え
}