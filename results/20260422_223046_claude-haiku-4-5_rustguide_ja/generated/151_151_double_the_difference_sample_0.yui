標準ライブラリを使う

double_the_difference = 入力 lst に対し {
   sum = 0
   i = 0
   lstの大きさ回くり返す {
      num = lst[i]
      # 整数判定と0以上の判定
      もし整数判定(num)が真ならば {
         もしnumが0以上ならば {
            # 奇数判定：剰余が1なら奇数
            もし剰余(num, 2)が1ならば {
               sum = 和(sum, 積(num, num))
            }
         }
      }
      iを増やす
   }
   sumが答え
}