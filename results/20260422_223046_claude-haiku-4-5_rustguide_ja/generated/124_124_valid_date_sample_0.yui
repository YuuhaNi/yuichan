標準ライブラリを使う

valid_date = 入力 date に対し {
   # 日付文字列が空でないかチェック
   もし date が値なし ならば {
      偽が答え
   }
   
   # "-" で分割するため、配列化して処理
   parts = []
   current = ""
   i = 0
   date の大きさ 回くり返す {
      char = date[i]
      もし char が 45 ならば {
         # 45 は "-" の文字コード
         parts に current を追加する
         current = ""
      } そうでなければ {
         current = 文字列化(char)
      }
      i を増やす
   }
   parts に current を追加する
   
   # mm-dd-yyyy 形式でなければならない（3つの部分に分割される）
   もし parts の大きさ が 3 以外 ならば {
      偽が答え
   }
   
   # 月、日、年を取得
   month_str = parts[0]
   day_str = parts[1]
   year_str = parts[2]
   
   # 各部分が数字のみで構成されているかチェック
   month = 整数化(month_str)
   day = 整数化(day_str)
   year = 整数化(year_str)
   
   # 月のチェック（1以上12以下）
   もし month が 1 より小さい ならば {
      偽が答え
   }
   もし month が 12 より大きい ならば {
      偽が答え
   }
   
   # 日のチェック（月によって異なる）
   max_day = 31
   もし month が 4 ならば {
      max_day = 30
   } そうでなければ {
      もし month が 6 ならば {
         max_day = 30
      } そうでなければ {
         もし month が 9 ならば {
            max_day = 30
         } そうでなければ {
            もし month が 11 ならば {
               max_day = 30
            } そうでなければ {
               もし month が 2 ならば {
                  max_day = 29
               }
            }
         }
      }
   }
   
   # 日が有効な範囲内か確認
   もし day が 1 より小さい ならば {
      偽が答え
   }
   もし day が max_day より大きい ならば {
      偽が答え
   }
   
   # すべてのチェックに合格
   真が答え
}