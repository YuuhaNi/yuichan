標準ライブラリを使う

is_equal_to_sum_even = 入力 n に対し {
   count = 0
   i = 2
   n回くり返す {
      もし i が n より大きいならば {
         くり返しを抜ける
      }
      j = 2
      n回くり返す {
         もし j が n より大きいならば {
            くり返しを抜ける
         }
         k = 2
         n回くり返す {
            もし k が n より大きいならば {
               くり返しを抜ける
            }
            l = 2
            n回くり返す {
               もし l が n より大きいならば {
                  くり返しを抜ける
               }
               もし和(i, j, k, l)が n ならば {
                  count を増やす
               }
               l を増やす
            }
            k を増やす
         }
         j を増やす
      }
      i を増やす
   }
   もし count が 0 より大きいならば {
      真が答え
   }
   そうでなければ {
      偽が答え
   }
}