標準ライブラリを使う

is_prime = 入力 n に対し {
   もしnが2より小さいならば{
      偽が答え
   }
   もしnが2ならば{
      真が答え
   }
   i = 2
   n回くり返す{
      もしiがnより大きいならば{
         くり返しを抜ける
      }
      もし剰余(n, i)が0ならば{
         偽が答え
      }
      iを増やす
   }
   真が答え
}

prime_length = 入力 string に対し {
   len = stringの大きさ
   is_prime(len)が答え
}