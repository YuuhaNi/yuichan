標準ライブラリを使う

sorted_list_sum = 入力 lst に対し {
   # 奇数の長さを持つ文字列を削除
   filtered = []
   i = 0
   lstの大きさ回くり返す {
      length = lstの大きさ
      もし i が length より小さいならば {
         word = lst[i]
         word_length = word の大きさ
         remainder = 剰余(word_length, 2)
         もし remainder が 0 ならば {
            filteredに word を追加する
         }
         i を増やす
      }
   }

   # バブルソート：長さで昇順、同じ長さならアルファベット順
   n = filtered の大きさ
   n 回くり返す {
      j = 0
      差(n, 1) 回くり返す {
         もし j が 差(n, 1) より小さいならば {
            word1 = filtered[j]
            word2 = filtered[差(j, 1)]
            len1 = word1 の大きさ
            len2 = word2 の大きさ
            
            もし len1 が len2 より大きいならば {
               # スワップ
               temp = filtered[j]
               filtered[j] = filtered[差(j, 1)]
               filtered[差(j, 1)] = temp
            } そうでなければ {
               もし len1 が len2 ならば {
                  # 同じ長さの場合、アルファベット順で比較
                  もし word1 が word2 より大きいならば {
                     temp = filtered[j]
                     filtered[j] = filtered[差(j, 1)]
                     filtered[差(j, 1)] = temp
                  }
               }
            }
            j を増やす
         }
      }
   }

   filtered が答え
}