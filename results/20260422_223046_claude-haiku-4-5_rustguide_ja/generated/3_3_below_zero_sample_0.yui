標準ライブラリを使う

below_zero = 入力 operations に対し {
   balance = 0
   operationsの大きさ回くり返す {
      i = 0
      operationsの大きさ回くり返す {
         もしiがoperationsの大きさ以上ならば {
            くり返しを抜ける
         }
         balance = 和(balance, operations[i])
         もしbalanceが0より小さいならば {
            真が答え
         }
         iを増やす
      }
   }
   偽が答え
}
標準ライブラリを使う

below_zero = 入力 operations に対し {
   balance = 0
   operationsの大きさ回くり返す {
      i = 0
      operationsの大きさ回くり返す {
         もしiがoperationsの大きさ以上ならば {
            くり返しを抜ける
         }
         balance = 和(balance, operations[i])
         もしbalanceが0より小さいならば {
            真が答え
         }
         iを増やす
      }
   }
   偽が答え
}
標準ライブラリを使う

below_zero = 入力 operations に対し {
   balance = 0
   n = operationsの大きさ
   n回くり返す {
      i = 0
      n回くり返す {
         もしiがnより大きいならば {
            くり返しを抜ける
         }
         balance = 和(balance, operations[i])
         もしbalanceが0より小さいならば {
            真が答え
         }
         iを増やす
      }
   }
   偽が答え
}