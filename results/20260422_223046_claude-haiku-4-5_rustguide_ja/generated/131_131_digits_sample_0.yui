標準ライブラリを使う

digits = 入力 n に対し {
   s = 文字列化(n)
   result = 1
   found = 偽
   sの大きさ回くり返す {
      i = 0
      sの大きさ回くり返す {
         digit = 整数化(s[i])
         もしdigitが2で割り切れるならば {
            # 偶数の場合はスキップ
         } そうでなければ {
            # 奇数の場合
            resultを積(result, digit)に設定する
            found = 真
         }
         iを増やす
      }
   }
   もしfoundが偽ならば {
      0が答え
   } そうでなければ {
      resultが答え
   }
}
