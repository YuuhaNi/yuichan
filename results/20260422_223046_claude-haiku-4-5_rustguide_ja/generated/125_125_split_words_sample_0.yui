標準ライブラリを使う

split_words = 入力 txt に対し {
   # 空白で分割できるか確認
   もし" "がtxtのいずれかならば{
      # 空白で分割して返す
      result = []
      word = ""
      i = 0
      txtの大きさ回くり返す{
         char = txt[i]
         もしcharが32ならば{
            # 32は空白の文字コード
            もしwordの大きさが0以外ならば{
               resultにwordを追加する
               word = ""
            }
         }そうでなければ{
            wordにcharを追加する
         }
         iを増やす
      }
      もしwordの大きさが0以外ならば{
         resultにwordを追加する
      }
      resultが答え
   }
   
   # カンマで分割できるか確認
   もし","がtxtのいずれかならば{
      # カンマで分割して返す
      result = []
      word = ""
      i = 0
      txtの大きさ回くり返す{
         char = txt[i]
         もしcharが44ならば{
            # 44はカンマの文字コード
            もしwordの大きさが0以外ならば{
               resultにwordを追加する
               word = ""
            }
         }そうでなければ{
            wordにcharを追加する
         }
         iを増やす
      }
      もしwordの大きさが0以外ならば{
         resultにwordを追加する
      }
      resultが答え
   }
   
   # 奇数順の小文字の数を数える
   count = 0
   i = 0
   txtの大きさ回くり返す{
      char = txt[i]
      # 小文字 a-z の文字コードは 97-122
      もしcharが97以上ならば{
         もしcharが122以下ならば{
            # ord('a') = 97 なので、97を引いて 0-25 に正規化
            code = 差(char, 97)
            # 奇数順（0-indexed で奇数）かチェック
            もし剰余(code, 2)が1ならば{
               countを増やす
            }
         }
      }
      iを増やす
   }
   countが答え
}