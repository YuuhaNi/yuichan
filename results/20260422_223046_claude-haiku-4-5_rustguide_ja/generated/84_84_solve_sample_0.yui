標準ライブラリを使う

solve = 入力 N に対し {
   # N を文字列化して各桁を取得
   s = 文字列化(N)
   
   # 各桁の総和を計算
   digit_sum = 0
   sの大きさ回くり返す {
      i = 0
      sの大きさ回くり返す {
         digit_sum = 和(digit_sum, s[i])
         iを増やす
         もしiがsの大きさならば {
            くり返しを抜ける
         }
      }
      くり返しを抜ける
   }
   
   # digit_sum を2進数に変換
   binary = ""
   もしdigit_sumが0ならば {
      binary = "0"
   }
   そうでなければ {
      temp = digit_sum
      100回くり返す {
         もしtempが0ならば {
            くり返しを抜ける
         }
         remainder = 剰余(temp, 2)
         binary = 和(文字列化(remainder), binary)
         temp = 商(temp, 2)
      }
   }
   
   binaryが答え
}