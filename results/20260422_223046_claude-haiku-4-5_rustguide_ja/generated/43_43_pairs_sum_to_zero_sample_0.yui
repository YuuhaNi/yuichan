標準ライブラリを使う

pairs_sum_to_zero = 入力 l に対し {
   n = lの大きさ
   i = 0
   n回くり返す {
      もし i が n 以上ならば {
         くり返しを抜ける
      }
      j = 0
      n回くり返す {
         もし j が n 以上ならば {
            くり返しを抜ける
         }
         もし i が j 以外ならば {
            もし 和(l[i], l[j]) が 0 ならば {
               真が答え
            }
         }
         j を増やす
      }
      i を増やす
   }
   偽が答え
}