標準ライブラリを使う

get_max_triples = 入力 n に対し {
   # 配列 a を作成: a[i] = i * i - i + 1
   a = []
   i = 1
   n回くり返す {
      value = 差(和(積(i, i), -i), -1)
      aに value を追加する
      iを増やす
   }

   # 三つ組の個数をカウント
   count = 0
   i = 0
   n回くり返す {
      もし i が n 以上ならば {
         くり返しを抜ける
      }
      j = 0
      n回くり返す {
         もし j が n 以上ならば {
            くり返しを抜ける
         }
         もし j が i 以下ならば {
            jを増やす
            くり返しを抜ける
         }
         k = 0
         n回くり返す {
            もし k が n 以上ならば {
               くり返しを抜ける
            }
            もし k が j 以下ならば {
               kを増やす
               くり返しを抜ける
            }
            # a[i] + a[j] + a[k] が3の倍数か判定
            sum = 和(a[i], a[j], a[k])
            remainder = 剰余(sum, 3)
            もし remainder が 0 ならば {
               countを増やす
            }
            kを増やす
         }
         jを増やす
      }
      iを増やす
   }

   count が答え
}