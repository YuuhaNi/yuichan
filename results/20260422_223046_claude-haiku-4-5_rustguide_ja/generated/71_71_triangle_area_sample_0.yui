標準ライブラリを使う

triangle_area = 入力 a, b, c に対し {
   # 三角形の有効性を確認
   もしaがbとcの和より小さいならば{
      もしbがaとcの和より小さいならば{
         もしcがaとbの和より小さいならば{
            # 有効な三角形 → ヘロンの公式で面積を計算
            s = 商(和(a, b, c), 2)
            s_a = 差(s, a)
            s_b = 差(s, b)
            s_c = 差(s, c)
            area = 平方根(積(s, s_a, s_b, s_c))
            # 小数点以下2桁で四捨五入
            area_rounded = 商(整数化(和(積(area, 100), 0.5)), 100)
            area_roundedが答え
         }
      }
   }
   # 無効な三角形
   -1が答え
}