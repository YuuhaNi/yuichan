標準ライブラリを使う

is_prime = 入力 x に対し {
   もし x が 2 より小さい ならば {
      偽が答え
   }
   もし x が 2 ならば {
      真が答え
   }
   i = 2
   差(x, 1)回くり返す {
      もし 剰余(x, i) が 0 ならば {
         偽が答え
      }
      i を増やす
      もし 積(i, i) が x より大きい ならば {
         くり返しを抜ける
      }
   }
   真が答え
}

prime_fib = 入力 n に対し {
   count = 0
   a = 1
   b = 1
   10000回くり返す {
      c = 和(a, b)
      a = b
      b = c
      もし c が素数判定 ならば {
         count を増やす
         もし count が n ならば {
            c が答え
         }
      }
   }
}