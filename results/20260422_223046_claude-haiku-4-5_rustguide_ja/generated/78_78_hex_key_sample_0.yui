標準ライブラリを使う

hex_key = 入力 num に対し {
   # 素数である16進数の桁: 2, 3, 5, 7, B(11), D(13)
   primes = ["2", "3", "5", "7", "B", "D"]
   count = 0
   
   # 文字列の各文字をチェック
   i = 0
   numの大きさ回くり返す {
      char = num[i]
      
      # charが素数リストに含まれているかチェック
      もしcharがprimesのいずれかならば {
         countを増やす
      }
      
      iを増やす
   }
   
   countが答え
}