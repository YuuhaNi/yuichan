標準ライブラリを使う

largest_prime_factor = 入力 n に対し {
   largest = 1
   
   # 2で割り切れる限り割る
   n回くり返す {
      もし剰余(n, 2)が0ならば {
         largest = 2
         n = 商(n, 2)
      } そうでなければ {
         くり返しを抜ける
      }
   }
   
   # 3以上の奇数で割り切れるかチェック
   i = 3
   n回くり返す {
      もしiが積(i, i)より大きいならば {
         くり返しを抜ける
      }
      
      n回くり返す {
         もし剰余(n, i)が0ならば {
            largest = i
            n = 商(n, i)
         } そうでなければ {
            くり返しを抜ける
         }
      }
      
      i = 和(i, 2)
   }
   
   # nが1より大きければ、nそのものが素因数
   もしnが1より大きいならば {
      largest = n
   }
   
   largestが答え
}