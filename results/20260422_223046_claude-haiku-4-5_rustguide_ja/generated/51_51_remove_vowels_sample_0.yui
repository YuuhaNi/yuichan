標準ライブラリを使う

remove_vowels = 入力 text に対し {
   result = ""
   i = 0
   text の大きさ 回くり返す {
      char = text[i]
      もし char が "a"[0] ならば {
         i を増やす
      } そうでなければ {
         もし char が "e"[0] ならば {
            i を増やす
         } そうでなければ {
            もし char が "i"[0] ならば {
               i を増やす
            } そうでなければ {
               もし char が "o"[0] ならば {
                  i を増やす
               } そうでなければ {
                  もし char が "u"[0] ならば {
                     i を増やす
                  } そうでなければ {
                     もし char が "A"[0] ならば {
                        i を増やす
                     } そうでなければ {
                        もし char が "E"[0] ならば {
                           i を増やす
                        } そうでなければ {
                           もし char が "I"[0] ならば {
                              i を増やす
                           } そうでなければ {
                              もし char が "O"[0] ならば {
                                 i を増やす
                              } そうでなければ {
                                 もし char が "U"[0] ならば {
                                    i を増やす
                                 } そうでなければ {
                                    result に char を追加する
                                    i を増やす
                                 }
                              }
                           }
                        }
                     }
                  }
               }
            }
         }
      }
   }
   result が答え
}