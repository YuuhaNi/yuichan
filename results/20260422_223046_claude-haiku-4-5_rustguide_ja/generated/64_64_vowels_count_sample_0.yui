標準ライブラリを使う

vowels_count = 入力 s に対し {
   count = 0
   i = 0
   sの大きさ回くり返す {
      c = s[i]
      もし c が "a"[0] ならば {
         countを増やす
      } そうでなければ {
         もし c が "e"[0] ならば {
            countを増やす
         } そうでなければ {
            もし c が "i"[0] ならば {
               countを増やす
            } そうでなければ {
               もし c が "o"[0] ならば {
                  countを増やす
               } そうでなければ {
                  もし c が "u"[0] ならば {
                     countを増やす
                  }
               }
            }
         }
      }
      iを増やす
   }
   countが答え
}