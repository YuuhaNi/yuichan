標準ライブラリを使う

common = 入力 l1, l2 に対し {
   result = []
   
   # l1の各要素をチェック
   i = 0
   l1の大きさ回くり返す {
      elem = l1[i]
      
      # l2に含まれているか確認
      もしelemがl2のいずれかならば {
         # resultに既に含まれていないか確認
         もしelemがresultのいずれでもないならば {
            resultにelemを追加する
         }
      }
      
      iを増やす
   }
   
   # resultをソート（バブルソート）
   n = resultの大きさ
   n回くり返す {
      j = 0
      差(n, 1)回くり返す {
         もしresult[j]がresult[和(j, 1)]より大きいならば {
            # スワップ
            temp = result[j]
            result[j] = result[和(j, 1)]
            result[和(j, 1)] = temp
         }
         jを増やす
      }
   }
}