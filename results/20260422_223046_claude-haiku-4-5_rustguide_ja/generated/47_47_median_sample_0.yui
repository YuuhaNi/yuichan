標準ライブラリを使う

median = 入力 l に対し {
   n = l の大きさ
   
   # バブルソートで昇順に並べる
   n回くり返す {
      i = 0
      差(n, 1)回くり返す {
         もし l[i] が l[差(i, 1)]より大きいならば {
            temp = l[i]
            l[i] = l[差(i, 1)]
            l[差(i, 1)] = temp
         }
         i を増やす
      }
   }
   
   # 中央値を計算
   もし 剰余(n, 2) が 1 ならば {
      # 奇数個の場合：中央の要素
      l[商(n, 2)]が答え
   }
   そうでなければ {
      # 偶数個の場合：中央2つの平均
      mid1 = l[差(商(n, 2), 1)]
      mid2 = l[商(n, 2)]
      商(和(mid1, mid2), 2)が答え
   }
}