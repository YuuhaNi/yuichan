標準ライブラリを使う

fizz_buzz = 入力 n に対し {
   count = 0
   i = 0
   n回くり返す {
      もし i が n より小さいならば {
         もし 剰余(i, 11) が 0 ならば {
            s = 文字列化(i)
            j = 0
            s の大きさ 回くり返す {
               もし s[j] が "7"[0] ならば {
                  count を増やす
               }
               j を増やす
            }
         }
         そうでなければ {
            もし 剰余(i, 13) が 0 ならば {
               s = 文字列化(i)
               j = 0
               s の大きさ 回くり返す {
                  もし s[j] が "7"[0] ならば {
                     count を増やす
                  }
                  j を増やす
               }
            }
         }
      }
      i を増やす
   }
   count が答え
}