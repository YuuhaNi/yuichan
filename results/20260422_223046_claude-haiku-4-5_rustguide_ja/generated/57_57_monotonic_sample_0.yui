標準ライブラリを使う

monotonic = 入力 l に対し {
   n = lの大きさ
   もしnが2より小さいならば{
      真が答え
   }
   
   # 単調増加をチェック
   increasing = 真
   i = 0
   差(n, 1)回くり返す{
      もしl[i]がl[差(i, 1)]より大きいならば{
         increasing = 偽
         くり返しを抜ける
      }
      iを増やす
   }
   
   もしincreasingが真ならば{
      真が答え
   }
   
   # 単調減少をチェック
   decreasing = 真
   i = 0
   差(n, 1)回くり返す{
      もしl[i]がl[差(i, 1)]より小さいならば{
         decreasing = 偽
         くり返しを抜ける
      }
      iを増やす
   }
   
   もしdecreasingが真ならば{
      真が答え
   }
   
   偽が答え
}