標準ライブラリを使う

even_odd_count = 入力 num に対し {
   s = 文字列化(num)
   even = 0
   odd = 0
   i = 0
   sの大きさ回くり返す{
      digit = s[i]
      もしdigitが45ならば{
         # マイナス記号（文字コード45）はスキップ
         iを増やす
      }そうでなければ{
         # 文字コードを数値に変換（'0'は48）
         d = 差(digit, 48)
         もしdが0ならば{
            evenを増やす
         }そうでなければ{
            もしdが2ならば{
               evenを増やす
            }そうでなければ{
               もしdが4ならば{
                  evenを増やす
               }そうでなければ{
                  もしdが6ならば{
                     evenを増やす
                  }そうでなければ{
                     もしdが8ならば{
                        evenを増やす
                     }そうでなければ{
                        oddを増やす
                     }
                  }
               }
            }
         }
         iを増やす
      }
   }
   even_count = even
   odd_count = odd
}