標準ライブラリを使う

encode = 入力 message に対し {
   result = ""
   i = 0
   messageの大きさ回くり返す {
      char = message[i]
      
      # 母音判定と置き換え
      もし char が 97 ならば {
         # 'a' -> 'U' (97 -> 85)
         char = 85
      } そうでなければ {
         もし char が 101 ならば {
            # 'e' -> 'C' (101 -> 67)
            char = 67
         } そうでなければ {
            もし char が 105 ならば {
               # 'i' -> 'G' (105 -> 71)
               char = 71
            } そうでなければ {
               もし char が 111 ならば {
                  # 'o' -> 'M' (111 -> 77)
                  char = 77
               } そうでなければ {
                  もし char が 117 ならば {
                     # 'u' -> 'S' (117 -> 83)
                     char = 83
                  } そうでなければ {
                     もし char が 65 ならば {
                        # 'A' -> 'u' (65 -> 117)
                        char = 117
                     } そうでなければ {
                        もし char が 69 ならば {
                           # 'E' -> 'c' (69 -> 99)
                           char = 99
                        } そうでなければ {
                           もし char が 73 ならば {
                              # 'I' -> 'g' (73 -> 103)
                              char = 103
                           } そうでなければ {
                              もし char が 79 ならば {
                                 # 'O' -> 'm' (79 -> 109)
                                 char = 109
                              } そうでなければ {
                                 もし char が 85 ならば {
                                    # 'U' -> 's' (85 -> 115)
                                    char = 115
                                 }
                              }
                           }
                        }
                     }
                  }
               }
            }
         }
      }
      
      # 大文字と小文字を入れ替え
      もし char が 97以上ならば {
         もし char が 122以下ならば {
            # 小文字 -> 大文字に変換
            char = 差(char, 32)
         }
      } そうでなければ {
         もし char が 65以上ならば {
            もし char が 90以下ならば {
               # 大文字 -> 小文字に変換
               char = 和(char, 32)
            }
         }
      }
      
      resultに char を追加する
      iを増やす
   }
   
   resultが答え
}