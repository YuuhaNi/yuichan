標準ライブラリを使う

is_nested = 入力 string に対し {
   depth = 0
   max_depth = 0
   i = 0
   stringの大きさ回くり返す {
      char = string[i]
      もし char が "[" の文字コード ならば {
         depth を増やす
         もし depth が max_depth より大きい ならば {
            max_depth = depth
         }
      }
      もし char が "]" の文字コード ならば {
         depth を減らす
      }
      i を増やす
   }
   もし max_depth が 1 より大きい ならば {
      真が答え
   }
   そうでなければ {
      偽が答え
   }
}