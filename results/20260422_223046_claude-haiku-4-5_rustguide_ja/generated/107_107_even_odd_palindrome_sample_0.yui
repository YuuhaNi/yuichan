標準ライブラリを使う

even_odd_palindrome = 入力 n に対し {
   even_count = 0
   odd_count = 0
   
   i = 1
   n回くり返す {
      # iが回文数かどうかを判定
      s = 文字列化(i)
      s_len = sの大きさ
      is_palindrome = 真
      
      # 前半と後半を比較
      j = 0
      商(s_len, 2)回くり返す {
         もし s[j] が s[差(差(s_len, 1), j)] 以外ならば {
            is_palindrome = 偽
            くり返しを抜ける
         }
         jを増やす
      }
      
      # 回文数なら偶数/奇数をカウント
      もし is_palindrome が 真 ならば {
         もし 剰余(i, 2) が 0 ならば {
            even_countを増やす
         } そうでなければ {
            odd_countを増やす
         }
      }
      
      iを増やす
   }
   
   # 結果をオブジェクトとして返す（戻り値を明示しないため自動的にタプル化）
}