標準ライブラリを使う

is_sorted = 入力 lst に対し {
   n=lstの大きさ
   もしnが1以下ならば{
      真が答え
   }

   i=1
   dup=0

   差(n,1)回くり返す{
      prev=lst[差(i,1)]
      cur=lst[i]

      もしcurがprev以下ならば{
         もしcurがprevならば{
            dupを増やす
            もしdupが2以上ならば{
               偽が答え
            }
         }
         そうでなければ{
            偽が答え
         }
      }

      iを増やす
   }

   真が答え
}