標準ライブラリを使う

get_closest_vowel = 入力 word に対し {
   n=wordの長さ
   もしnが3より小さいならば{
      ""が答え
   }

   i=差(n,2)
   i回くり返す{
      c=word[i]
      left=word[差(i,1)]
      right=word[和(i,1)]

      isVowel=0
      もしcが"a"のいずれか["a","e","i","o","u"]ならば{ isVowel=1 }
      もしcが"A"のいずれか["A","E","I","O","U"]ならば{ isVowel=1 }

      leftIsVowel=0
      もしleftが"a"のいずれか["a","e","i","o","u"]ならば{ leftIsVowel=1 }
      もしleftが"A"のいずれか["A","E","I","O","U"]ならば{ leftIsVowel=1 }

      rightIsVowel=0
      もしrightが"a"のいずれか["a","e","i","o","u"]ならば{ rightIsVowel=1 }
      もしrightが"A"のいずれか["A","E","I","O","U"]ならば{ rightIsVowel=1 }

      もしisVowelが1ならば{
         もしleftIsVowelが0ならば{
            もしrightIsVowelが0ならば{
               cが答え
            }
         }
      }

      iを減らす
   }

   ""が答え
}