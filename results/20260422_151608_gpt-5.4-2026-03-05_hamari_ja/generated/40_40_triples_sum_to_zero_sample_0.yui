標準ライブラリを使う

triples_sum_to_zero = 入力 l に対し {
    n=lの大きさ
    もしnが3より小さいならば{
        Falseが答え
    }

    i=0
    n回くり返す{
        j=和(i,1)
        n回くり返す{
            k=和(j,1)
            n回くり返す{
                もしkがnより小さいならば{
                    s=和(和(l[i],l[j]),l[k])
                    もしsが0ならば{
                        Trueが答え
                    }
                }
                kを増やす
            }
            jを増やす
        }
        iを増やす
    }

    Falseが答え
}