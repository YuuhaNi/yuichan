標準ライブラリを使う

same_chars = 入力 s0, s1 に対し {
    seen0={}
    seen1={}

    i=0
    n0=s0の長さ
    n0回くり返す{
        ch=s0[i]
        seen0[ch]=1
        iを増やす
    }

    j=0
    n1=s1の長さ
    n1回くり返す{
        ch=s1[j]
        seen1[ch]=1
        jを増やす
    }

    k=0
    keys0=seen0のキー列
    m0=keys0の長さ
    m0回くり返す{
        ch=keys0[k]
        もしseen1がchをキーに含む以外ならば{
            偽が答え
        }
        kを増やす
    }

    l=0
    keys1=seen1のキー列
    m1=keys1の長さ
    m1回くり返す{
        ch=keys1[l]
        もしseen0がchをキーに含む以外ならば{
            偽が答え
        }
        lを増やす
    }

    真が答え
}