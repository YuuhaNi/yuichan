標準ライブラリを使う

iscube = 入力 a に対し {
    もしaが0ならば{
        真が答え
    }

    もしaが0より大きいならば{
        i=0
        ずっとくり返す{
            cube=積(積(i,i),i)
            もしcubeがaならば{
                真が答え
            }
            もしcubeがaより大きいならば{
                偽が答え
            }
            iを増やす
        }
    }

    i=0
    ずっとくり返す{
        cube=積(積(i,i),i)
        もしcubeがaならば{
            真が答え
        }
        もしcubeがaより小さいならば{
            偽が答え
        }
        iを減らす
    }
}