標準ライブラリを使う

by_length = 入力 arr に対し {
   n=arrの大きさ
   counts=[0,0,0,0,0,0,0,0,0]
   i=0
   n回くり返す{
      x=arr[i]
      もしxが1以上ならば{
         もしxが9以下ならば{
            idx=差(x,1)
            counts[idx]=和(counts[idx],1)
         }
      }
      iを増やす
   }

   result=[]
   d=9
   9回くり返す{
      idx=差(d,1)
      c=counts[idx]
      c回くり返す{
         もしdが1ならば{
            resultに"One"を追加する
         }
         そうでなければ{
            もしdが2ならば{
               resultに"Two"を追加する
            }
            そうでなければ{
               もしdが3ならば{
                  resultに"Three"を追加する
               }
               そうでなければ{
                  もしdが4ならば{
                     resultに"Four"を追加する
                  }
                  そうでなければ{
                     もしdが5ならば{
                        resultに"Five"を追加する
                     }
                     そうでなければ{
                        もしdが6ならば{
                           resultに"Six"を追加する
                        }
                        そうでなければ{
                           もしdが7ならば{
                              resultに"Seven"を追加する
                           }
                           そうでなければ{
                              もしdが8ならば{
                                 resultに"Eight"を追加する
                              }
                              そうでなければ{
                                 resultに"Nine"を追加する
                              }
                           }
                        }
                     }
                  }
               }
            }
         }
      }
      dを減らす
   }

   resultが答え
}