標準ライブラリを使う

is_bored = 入力 S に対し {
   count=0
   start=1
   n=Sの長さ
   i=0

   n回くり返す{
      c=S[i]

      endmark=0
      もしcが"."ならば{
         endmark=1
      }
      もしcが"?"ならば{
         endmark=1
      }
      もしcが"!"ならば{
         endmark=1
      }

      もしstartが1ならば{
         もしcが"I"ならば{
            ni=和(i,1)
            もしniがnより小さいならば{
               もしS[ni]が" "ならば{
                  countを増やす
               }
            }
         }
      }

      もしendmarkが1ならば{
         start=1
      }
      そうでなければ{
         もしcが" "以外ならば{
            start=0
         }
      }

      iを増やす
   }

   countが答え
}