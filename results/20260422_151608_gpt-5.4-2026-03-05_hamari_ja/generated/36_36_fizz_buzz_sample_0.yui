標準ライブラリを使う

fizz_buzz = 入力 n に対し {
    i=0
    count=0
    n回くり返す{
        hit=0
        r11=剰余(i,11)
        もしr11が0ならば{
            hit=1
        }
        そうでなければ{
            r13=剰余(i,13)
            もしr13が0ならば{
                hit=1
            }
        }

        もしhitが1ならば{
            x=i
            もしxが0ならば{
            }
            そうでなければ{
                xを表示する
                s=表示結果
                j=0
                len=sの大きさ
                len回くり返す{
                    もしs[j]が"7"ならば{
                        countを増やす
                    }
                    jを増やす
                }
            }
        }
        iを増やす
    }
    countが答え
}