標準ライブラリを使う

x_or_y = 入力 n, x, y に対し {
   もしnが2以下ならば{
      もしnが2ならば{
         xが答え
      }
      そうでなければ{
         yが答え
      }
   }

   d=2
   prime=1
   続ける=1
   もしnが2より大きいならば{
      続ける=1
   }
   そうでなければ{
      続ける=0
   }

   続けるの間くり返す{
      もし積(d,d)がnより大きいならば{
         くり返しを抜ける
      }
      もし剰余(n,d)が0ならば{
         prime=0
         くり返しを抜ける
      }
      d=和(d,1)
   }

   もしprimeが1ならば{
      xが答え
   }
   そうでなければ{
      yが答え
   }
}