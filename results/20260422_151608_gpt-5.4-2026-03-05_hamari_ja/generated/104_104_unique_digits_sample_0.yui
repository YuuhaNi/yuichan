標準ライブラリを使う

unique_digits = 入力 x に対し {
   res=[]
   i=0
   n=xの大きさ
   n回くり返す{
      v=x[i]
      s=文字列化(v)
      j=0
      m=sの大きさ
      ok=1
      m回くり返す{
         ch=s[j]
         k=和(j,1)
         もしkがmより小さいならば{
            t=k
            差(m,k)回くり返す{
               もしchがs[t]ならば{
                  ok=0
               }
               tを増やす
            }
         }
         jを増やす
      }
      もしokが1ならば{
         resにvを追加する
      }
      iを増やす
   }
   resをソートする
   resが答え
}