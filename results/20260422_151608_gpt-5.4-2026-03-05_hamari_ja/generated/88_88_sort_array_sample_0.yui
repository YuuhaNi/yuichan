標準ライブラリを使う

sort_array = 入力 array に対し {
   n=arrayの大きさ
   result=[]
   i=0
   n回くり返す{
      resultにarray[i]を追加する
      iを増やす
   }

   もしnが1以下ならば{
      resultが答え
   }

   lastIndex=差(n,1)
   edgeSum=和(array[0],array[lastIndex])
   parity=剰余(edgeSum,2)

   i=0
   差(n,1)回くり返す{
      j=0
      limit=差(差(n,1),i)
      limit回くり返す{
         next=和(j,1)
         a=result[j]
         b=result[next]

         もしparityが1ならば{
            もしaがbより大きいならば{
               result[j]=b
               result[next]=a
            }
         }
         そうでなければ{
            もしaがbより小さいならば{
               result[j]=b
               result[next]=a
            }
         }

         jを増やす
      }
      iを増やす
   }

   resultが答え
}