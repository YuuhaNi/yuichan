標準ライブラリを使う

sort_array = 入力 arr に対し {
   n=arrの大きさ
   i=0
   n回くり返す{
      j=0
      limit=差(n,i)
      limitを減らす
      limit回くり返す{
         a=arr[j]
         b=arr[和(j,1)]

         ca=0
         ta=a
         もしtaが0より小さいならば{
            ta=差(0,ta)
         }
         もしtaが0ならば{
         }
         そうでなければ{
            もしtaが0より大きいならば{
               くり返す{
                  bit=剰余(ta,2)
                  もしbitが1ならば{
                     caを増やす
                  }
                  ta=商(ta,2)
                  もしtaが0以下ならば{
                     くり返しを抜ける
                  }
               }
            }
         }

         cb=0
         tb=b
         もしtbが0より小さいならば{
            tb=差(0,tb)
         }
         もしtbが0ならば{
         }
         そうでなければ{
            もしtbが0より大きいならば{
               くり返す{
                  bit=剰余(tb,2)
                  もしbitが1ならば{
                     cbを増やす
                  }
                  tb=商(tb,2)
                  もしtbが0以下ならば{
                     くり返しを抜ける
                  }
               }
            }
         }

         swap=0
         もしcaがcbより大きいならば{
            swap=1
         }
         もしcaがcbならば{
            もしaがbより大きいならば{
               swap=1
            }
         }

         もしswapが1ならば{
            tmp=arr[j]
            arr[j]=arr[和(j,1)]
            arr[和(j,1)]=tmp
         }

         jを増やす
      }
      iを増やす
   }
   arrが答え
}