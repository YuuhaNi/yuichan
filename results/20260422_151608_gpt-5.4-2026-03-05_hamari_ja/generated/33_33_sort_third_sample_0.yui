標準ライブラリを使う

sort_third = 入力 l に対し {
   n=lの大きさ
   thirds=[]
   i=0
   n回くり返す{
      rem=剰余(i,3)
      もしremが0ならば{
         thirdsにl[i]を追加する
      }
      iを増やす
   }

   thirdsをソートする

   ans=[]
   ti=0
   i=0
   n回くり返す{
      rem=剰余(i,3)
      もしremが0ならば{
         ansにthirds[ti]を追加する
         tiを増やす
      }
      そうでなければ{
         ansにl[i]を追加する
      }
      iを増やす
   }

   ansが答え
}