標準ライブラリを使う

vowels_count = 入力 s に対し {
   count=0
   i=0
   n=sの大きさ
   n回くり返す{
      ch=s[i]
      もしchが"a"のいずれかならば{
         countを増やす
      }
      そうでなければ{
         もしchが"e"のいずれかならば{
            countを増やす
         }
         そうでなければ{
            もしchが"i"のいずれかならば{
               countを増やす
            }
            そうでなければ{
               もしchが"o"のいずれかならば{
                  countを増やす
               }
               そうでなければ{
                  もしchが"u"のいずれかならば{
                     countを増やす
                  }
               }
            }
         }
      }
      iを増やす
   }
   countが答え
}