標準ライブラリを使う

tri = 入力 n に対し {
   もしnが0ならば{
      [1]が答え
   }

   ans=[]
   ansに1を追加する

   もしnが1以上ならば{
      ansに3を追加する
   }

   i=2
   n回くり返す{
      もしiがn以下ならば{
         もし剰余(i,2)が0ならば{
            ansに和(1,商(i,2))を追加する
         }
         そうでなければ{
            a=ans[差(i,1)]
            b=ans[差(i,2)]
            c=ans[和(i,1)]
            ansに和(和(a,b),c)を追加する
         }
         iを増やす
      }
   }

   ansが答え
}