標準ライブラリを使う

solve = 入力 N に対し {
   sum=0
   x=N

   もしxが0ならば{
      sum=0
   }
   そうでなければ{
      くり返し{
         digit=剰余(x,10)
         sum=和(sum,digit)
         x=商(x,10)
         もしxが0ならば{
            くり返しを抜ける
         }
      }
   }

   もしsumが0ならば{
      "0"が答え
   }

   bits=""
   y=sum

   くり返し{
      bit=剰余(y,2)
      もしbitが0ならば{
         bits=連結("0",bits)
      }
      そうでなければ{
         bits=連結("1",bits)
      }
      y=商(y,2)
      もしyが0ならば{
         くり返しを抜ける
      }
   }

   bitsが答え
}