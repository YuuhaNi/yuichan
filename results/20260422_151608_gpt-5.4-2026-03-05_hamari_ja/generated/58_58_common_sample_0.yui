標準ライブラリを使う

common = 入力 l1, l2 に対し {
   a=l1をソートしたもの
   b=l2をソートしたもの
   i=0
   j=0
   res=[]

   n=aの大きさ
   m=bの大きさ

   前条件が成り立つ間くり返す 条件 iがnより小さい {
      前条件が成り立つ間くり返す 条件 jがmより小さい {
         もしb[j]がa[i]より小さいならば{
            jを増やす
         }
         そうでなければ{
            くり返しを抜ける
         }
      }

      もしjがmより小さいならば{
         もしa[i]がb[j]ならば{
            sz=resの大きさ
            もしszが0ならば{
               resにa[i]を追加する
            }
            そうでなければ{
               last=差(sz,1)
               もしres[last]がa[i]以外ならば{
                  resにa[i]を追加する
               }
            }
         }
      }

      iを増やす
   }

   resが答え
}