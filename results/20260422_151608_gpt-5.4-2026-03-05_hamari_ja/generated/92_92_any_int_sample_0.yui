標準ライブラリを使う

any_int = 入力 x, y, z に対し {
   もしxが整数ならば{
      もしyが整数ならば{
         もしzが整数ならば{
            s1=和(x,y)
            s2=和(x,z)
            s3=和(y,z)
            もしzがs1ならば{
               True
            }
            そうでなければ{
               もしyがs2ならば{
                  True
               }
               そうでなければ{
                  もしxがs3ならば{
                     True
                  }
                  そうでなければ{
                     False
                  }
               }
            }
         }
         そうでなければ{
            False
         }
      }
      そうでなければ{
         False
      }
   }
   そうでなければ{
      False
   }
}