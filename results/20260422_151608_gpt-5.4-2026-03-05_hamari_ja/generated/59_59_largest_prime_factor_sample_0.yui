標準ライブラリを使う

largest_prime_factor = 入力 n に対し {
   largest=1

   もし剰余(n,2)が0ならば{
      largest=2
      もし剰余(n,2)が0ならば{
         n=商(n,2)
         n回くり返す{
            もし剰余(n,2)が0ならば{
               n=商(n,2)
            }
            そうでなければ{
               くり返しを抜ける
            }
         }
      }
   }

   f=3
   もしfの二乗がn以下ならば{
      n回くり返す{
         もしfの二乗がn以下ならば{
            もし剰余(n,f)が0ならば{
               largest=f
               n=商(n,f)
               n回くり返す{
                  もし剰余(n,f)が0ならば{
                     n=商(n,f)
                  }
                  そうでなければ{
                     くり返しを抜ける
                  }
               }
            }
            f=和(f,2)
         }
         そうでなければ{
            くり返しを抜ける
         }
      }
   }

   もしnが1より大きいならば{
      largest=n
   }

   largestが答え
}