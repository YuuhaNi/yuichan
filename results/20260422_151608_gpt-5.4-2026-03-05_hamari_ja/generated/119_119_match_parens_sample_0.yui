標準ライブラリを使う

match_parens = 入力 lst に対し {
    a=lst[0]
    b=lst[1]

    ab=文字列連結(a,b)
    ba=文字列連結(b,a)

    もし良い括弧列か(ab)が1ならば{
        "Yes"が答え
    }

    もし良い括弧列か(ba)が1ならば{
        "Yes"が答え
    }

    "No"が答え
}

良い括弧列か = 入力 s に対し {
    bal=0
    i=0
    n=sの長さ

    n回くり返す{
        ch=s[i]
        もしchが"("ならば{
            balを増やす
        }
        そうでなければ{
            balを減らす
        }

        もしbalが0より小さいならば{
            0が答え
        }
        iを増やす
    }

    もしbalが0ならば{
        1が答え
    }
    そうでなければ{
        0が答え
    }
}