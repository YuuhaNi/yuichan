標準ライブラリを使う

triangle_area = 入力 a, b, c に対し {
   ab=和(a,b)
   ac=和(a,c)
   bc=和(b,c)

   もしabがcより大きいならば{
      もしacがbより大きいならば{
         もしbcがaより大きいならば{
            s=商(小数化(和(和(a,b),c)),2)
            area=平方根(積(積(s,差(s,a)),積(差(s,b),差(s,c))))
            rounded=商(四捨五入(積(area,100)),100)
            roundedが答え
         }
      }
   }

   -1が答え
}