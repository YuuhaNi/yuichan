標準ライブラリを使う

count_up_to = 入力 n に対し {
   primes=[]
   i=2
   n回くり返す{
      もしiがnより小さいならば{
         is_prime=1
         j=2
         j回くり返す{
            もしjがiより小さいならば{
               r=剰余(i,j)
               もしrが0ならば{
                  is_prime=0
               }
               jを増やす
            }
         }
         もしis_primeが1ならば{
            primesにiを追加する
         }
         iを増やす
      }
   }
   primesが答え
}