標準ライブラリを使う

skjkasdkd = 入力 lst に対し {
   最大素数=0
   i=0
   n=lstの大きさ

   n回くり返す{
      x=lst[i]
      素数=0

      もしxが2以上ならば{
         もしxが2ならば{
            素数=1
         }
         そうでなければ{
            もし剰余(x,2)が0ならば{
            }
            そうでなければ{
               素数=1
               d=3
               続ける=1
               続ける回くり返す{
                  もし積(d,d)がxより大きいならば{
                     続ける=0
                  }
                  そうでなければ{
                     もし剰余(x,d)が0ならば{
                        素数=0
                        続ける=0
                     }
                     そうでなければ{
                        d=和(d,2)
                     }
                  }
               }
            }
         }
      }

      もし素数が1ならば{
         もしxが最大素数より大きいならば{
            最大素数=x
         }
      }

      iを増やす
   }

   和計=0
   もし最大素数が0ならば{
      0が答え
   }

   続ける2=1
   続ける2回くり返す{
      もし最大素数が0より大きいならば{
         桁=剰余(最大素数,10)
         和計=和(和計,桁)
         最大素数=商(最大素数,10)
      }
      そうでなければ{
         続ける2=0
      }
   }

   和計が答え
}