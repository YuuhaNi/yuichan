標準ライブラリを使う

compare_one = 入力 a, b に対し {
   sa=文字列化(a)
   sb=文字列化(b)

   na=sa
   nb=sb

   もしsaの中に","があるならば{
      na=saの","を"."に置換したもの
   }
   もしsbの中に","があるならば{
      nb=sbの","を"."に置換したもの
   }

   va=小数化(na)
   vb=小数化(nb)

   もしvaがvbならば{
      Noneが答え
   }
   もしvaがvbより大きいならば{
      aが答え
   }
   そうでなければ{
      bが答え
   }
}