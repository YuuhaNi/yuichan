標準ライブラリを使う

numerical_letter_grade = 入力 grades に対し {
    result=[]
    i=0
    n=gradesの大きさ

    n回くり返す{
        g=grades[i]

        もしgが4.0ならば{
            resultに"A+"を追加する
        }
        そうでなければ{
            もしgが3.7より大きいならば{
                resultに"A"を追加する
            }
            そうでなければ{
                もしgが3.3より大きいならば{
                    resultに"A-"を追加する
                }
                そうでなければ{
                    もしgが3.0より大きいならば{
                        resultに"B+"を追加する
                    }
                    そうでなければ{
                        もしgが2.7より大きいならば{
                            resultに"B"を追加する
                        }
                        そうでなければ{
                            もしgが2.3より大きいならば{
                                resultに"B-"を追加する
                            }
                            そうでなければ{
                                もしgが2.0より大きいならば{
                                    resultに"C+"を追加する
                                }
                                そうでなければ{
                                    もしgが1.7より大きいならば{
                                        resultに"C"を追加する
                                    }
                                    そうでなければ{
                                        もしgが1.3より大きいならば{
                                            resultに"C-"を追加する
                                        }
                                        そうでなければ{
                                            もしgが1.0より大きいならば{
                                                resultに"D+"を追加する
                                            }
                                            そうでなければ{
                                                もしgが0.7より大きいならば{
                                                    resultに"D"を追加する
                                                }
                                                そうでなければ{
                                                    もしgが0.0より大きいならば{
                                                        resultに"D-"を追加する
                                                    }
                                                    そうでなければ{
                                                        resultに"E"を追加する
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        iを増やす
    }

    resultが答え
}