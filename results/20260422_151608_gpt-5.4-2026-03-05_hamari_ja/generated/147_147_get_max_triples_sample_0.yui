標準ライブラリを使う

get_max_triples = 入力 n に対し {
   a=[]
   i=1
   n回くり返す{
      v=和(差(積(i,i),i),1)
      aにvを追加する
      iを増やす
   }

   triples=[]
   i=0
   n回くり返す{
      j=和(i,1)
      rem_j=差(n,j)
      rem_j回くり返す{
         k=和(j,1)
         rem_k=差(n,k)
         rem_k回くり返す{
            s=和(和(a[i],a[j]),a[k])
            r=剰余(s,3)
            もしrが0ならば{
               triplesに[a[i],a[j],a[k]]を追加する
            }
            kを増やす
         }
         jを増やす
      }
      iを増やす
   }

   triplesが答え
}