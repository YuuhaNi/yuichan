標準ライブラリを使う

words_in_sentence = 入力 sentence に対し {
   words=sentenceを" "で分割する
   result=[]
   i=0
   n=wordsの大きさ

   n回くり返す{
      w=words[i]
      len=wの長さ
      is_prime=1

      もしlenが2より小さいならば{
         is_prime=0
      }
      そうでなければ{
         d=2
         もし積(d,d)がlen以下ならば{
            while_flag=1
         }
         そうでなければ{
            while_flag=0
         }

         while_flag回くり返す{
            rem=剰余(len,d)
            もしremが0ならば{
               is_prime=0
            }

            d=和(d,1)
            もしis_primeが0ならば{
               while_flag=0
            }
            そうでなければ{
               もし積(d,d)がlen以下ならば{
                  while_flag=1
               }
               そうでなければ{
                  while_flag=0
               }
            }
         }
      }

      もしis_primeが1ならば{
         resultにwを追加する
      }
      i=和(i,1)
   }

   resultを" "で連結したものが答え
}