標準ライブラリを使う

has_close_elements = 入力 numbers, threshold に対し {
    n = numbersの大きさ
    i = 0
    n回くり返す{
        j = 和(i,1)
        残り = 差(n,j)
        残り回くり返す{
            a = numbers[i]
            b = numbers[j]
            diff1 = 差(a,b)
            diff2 = 差(b,a)
            もしdiff1がthresholdより小さいならば{
                もしdiff1が0より大きいならば{
                    真が答え
                }
            }
            もしdiff2がthresholdより小さいならば{
                もしdiff2が0より大きいならば{
                    真が答え
                }
            }
            jを増やす
        }
        iを増やす
    }
    偽が答え
}