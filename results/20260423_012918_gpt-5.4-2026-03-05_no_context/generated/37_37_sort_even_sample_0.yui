標準ライブラリを使う

sort_even = 入力 l に対し {
  偶数要素 = []
  i = 0
  (i < l の長さ) の間 {
    もし (i % 2 == 0) なら {
      偶数要素 = 偶数要素 に (l[i]) を追加
    }
    i = i + 1
  }

  偶数要素 = 偶数要素 をソート

  結果 = []
  偶数番号 = 0
  i = 0
  (i < l の長さ) の間 {
    もし (i % 2 == 0) なら {
      結果 = 結果 に (偶数要素[偶数番号]) を追加
      偶数番号 = 偶数番号 + 1
    } 違えば {
      結果 = 結果 に (l[i]) を追加
    }
    i = i + 1
  }

  結果
}