標準ライブラリを使う

specialFilter = 入力 nums に対し {
  nums を絞り込み、各要素 x について {
    x > 10 かつ {
      文字列 = x を文字列に変換
      最初 = 文字列[0]
      最後 = 文字列[文字列の長さ - 1]
      ((最初 == "1" または 最初 == "3" または 最初 == "5" または 最初 == "7" または 最初 == "9")
      かつ
      (最後 == "1" または 最後 == "3" または 最後 == "5" または 最後 == "7" または 最後 == "9"))
    }
  } の長さ
}