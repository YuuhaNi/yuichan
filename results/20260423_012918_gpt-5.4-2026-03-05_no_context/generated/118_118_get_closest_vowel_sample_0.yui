標準ライブラリを使う

get_closest_vowel = 入力 word に対し {
    母音たち = "aeiouAEIOU"
    長さ = word の長さ

    もし 長さ < 3 なら {
        ""
    } 違えば {
        i = 長さ - 2
        見つかった = ""

        繰り返し i >= 1 の間 {
            文字 = word[i]
            左 = word[i - 1]
            右 = word[i + 1]

            もし 母音たち が 文字 を含む かつ
               母音たち が 左 を含む でない かつ
               母音たち が 右 を含む でない なら {
                見つかった = 文字
                i = -1
            } 違えば {
                i = i - 1
            }
        }

        見つかった
    }
}