標準ライブラリを使う

decode_shift = 入力 s に対し {
    結果 = ""
    s の各文字を c として繰り返す {
        もし c が "a" 以上 かつ c が "z" 以下 なら {
            結果 = 結果 + 文字((コード(c) - コード("a") + 5) % 26 + コード("a"))
        } 違えば もし c が "A" 以上 かつ c が "Z" 以下 なら {
            結果 = 結果 + 文字((コード(c) - コード("A") + 5) % 26 + コード("A"))
        } 違えば {
            結果 = 結果 + c
        }
    }
    結果 を返す
}