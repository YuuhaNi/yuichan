標準ライブラリを使う

numerical_letter_grade = 入力 grades に対し {
    grades の各要素を g として {
        もし g == 4.0 なら "A+"
        でなければ もし g > 3.7 なら "A"
        でなければ もし g > 3.3 なら "A-"
        でなければ もし g > 3.0 なら "B+"
        でなければ もし g > 2.7 なら "B"
        でなければ もし g > 2.3 なら "B-"
        でなければ もし g > 2.0 なら "C+"
        でなければ もし g > 1.7 なら "C"
        でなければ もし g > 1.3 なら "C-"
        でなければ もし g > 1.0 なら "D+"
        でなければ もし g > 0.7 なら "D"
        でなければ もし g > 0.0 なら "D-"
        でなければ "E"
    }
}