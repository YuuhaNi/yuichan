標準ライブラリを使う

tri = 入力 n に対し {
  もし n == 0 なら {
    [1]
  } 違えば {
    tri値 = 関数 i に対し {
      もし i == 0 なら {
        1
      } でなければ もし i == 1 なら {
        3
      } でなければ もし i % 2 == 0 なら {
        1 + i / 2
      } 違えば {
        tri値(i - 1) + tri値(i - 2) + tri値(i + 1)
      }
    }

    範囲(0, n) を写像 tri値
  }
}