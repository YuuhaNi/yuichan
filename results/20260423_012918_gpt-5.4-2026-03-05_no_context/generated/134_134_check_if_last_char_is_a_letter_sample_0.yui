標準ライブラリを使う

check_if_last_char_is_a_letter = 入力 txt に対し {
  もし txt の長さ == 0 なら {
    偽
  } でなければ {
    最後 = txt の (txt の長さ - 1) 文字目
    もし 最後 == " " なら {
      偽
    } でなければ {
      もし 最後 が "/[A-Za-z]/" に一致 かつ (txt の長さ == 1 または txt の (txt の長さ - 2) 文字目 == " ") なら {
        真
      } でなければ {
        偽
      }
    }
  }
}