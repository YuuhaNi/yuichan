標準ライブラリを使う

select_words = 入力 s, n に対し {
  母音たち = 「aeiouAEIOU」
  単語一覧 = s を 「 」 で 分割
  結果 = []

  単語一覧 の各要素を単語として繰り返す {
    子音数 = 0

    単語 の各文字を文字として繰り返す {
      もし ((文字 >= 「a」 かつ 文字 <= 「z」) または (文字 >= 「A」 かつ 文字 <= 「Z」)) なら {
        もし (母音たち が 文字 を含まない) なら {
          子音数 = 子音数 + 1
        }
      }
    }

    もし 子音数 == n なら {
      結果 に 単語 を追加
    }
  }

  結果 を返す
}