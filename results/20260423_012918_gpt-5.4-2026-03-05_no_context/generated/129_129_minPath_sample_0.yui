標準ライブラリを使う

minPath = 入力 grid, k に対し {
    N = gridの長さ

    値から行列位置 = 空辞書
    i = 0
    ながら i < N {
        j = 0
        ながら j < N {
            値から行列位置[grid[i][j]] = [i, j]
            j = j + 1
        }
        i = i + 1
    }

    dp = 空配列
    次 = 空配列

    v = 1
    ながら v <= N * N {
        dpに追加(空配列)
        次に追加(-1)
        v = v + 1
    }

    v = 1
    ながら v <= N * N {
        dp[v - 1] = 空配列
        dp[v - 1]に追加(v)
        v = v + 1
    }

    残り長さ = 2
    ながら 残り長さ <= k {
        新dp = 空配列

        v = 1
        ながら v <= N * N {
            [r, c] = 値から行列位置[v]

            候補値 = 空配列

            もし r > 0 なら {
                候補値に追加(grid[r - 1][c])
            }
            もし r + 1 < N なら {
                候補値に追加(grid[r + 1][c])
            }
            もし c > 0 なら {
                候補値に追加(grid[r][c - 1])
            }
            もし c + 1 < N なら {
                候補値に追加(grid[r][c + 1])
            }

            最良隣接 = 候補値[0]
            idx = 1
            ながら idx < 候補値の長さ {
                u = 候補値[idx]
                もし dp[u - 1] < dp[最良隣接 - 1] なら {
                    最良隣接 = u
                }
                idx = idx + 1
            }

            次[v - 1] = 最良隣接

            経路 = 空配列
            経路に追加(v)

            idx = 0
            ながら idx < dp[最良隣接 - 1]の長さ {
                経路に追加(dp[最良隣接 - 1][idx])
                idx = idx + 1
            }

            新dpに追加(経路)
            v = v + 1
        }

        dp = 新dp
        残り長さ = 残り長さ + 1
    }

    答え = dp[0]
    v = 2
    ながら v <= N * N {
        もし dp[v - 1] < 答え なら {
            答え = dp[v - 1]
        }
        v = v + 1
    }

    答え
}