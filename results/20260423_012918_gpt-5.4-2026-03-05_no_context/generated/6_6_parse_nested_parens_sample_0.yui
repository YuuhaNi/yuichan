標準ライブラリを使う

parse_nested_parens = 入力 paren_string に対し {
    グループ一覧 = paren_string を " " で分割する
    結果 = []

    グループ一覧 の各要素について |グループ| {
        現在深さ = 0
        最大深さ = 0

        グループ の各文字について |文字| {
            もし 文字 == "(" なら {
                現在深さ = 現在深さ + 1
                もし 現在深さ > 最大深さ なら {
                    最大深さ = 現在深さ
                }
            } 違えば もし 文字 == ")" なら {
                現在深さ = 現在深さ - 1
            }
        }

        結果 に 最大深さ を追加する
    }

    結果 を返す
}