標準ライブラリを使う

is_multiply_prime = 入力 a に対し {
    もし a < 8 なら {
        戻る False
    }

    i = 2
    a の平方根まで i を 1 ずつ増やしながら {
        もし a % i == 0 かつ 素数(i) なら {
            b = a / i
            j = 2
            b の平方根まで j を 1 ずつ増やしながら {
                もし b % j == 0 かつ 素数(j) かつ 素数(b / j) なら {
                    戻る True
                }
            }
        }
    }

    戻る False
}