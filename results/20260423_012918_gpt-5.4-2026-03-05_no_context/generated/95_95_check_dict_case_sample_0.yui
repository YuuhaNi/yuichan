標準ライブラリを使う

check_dict_case = 入力 dict に対し {
    もし 長さ(dict) == 0 なら {
        False
    } でなければ {
        keys = dictのキー列挙()
        すべて小文字 = keysのすべてに対し(k => 型(k) == "文字列" かつ k == 小文字化(k))
        すべて大文字 = keysのすべてに対し(k => 型(k) == "文字列" かつ k == 大文字化(k))
        もし すべて小文字 なら {
            True
        } でなければ {
            もし すべて大文字 なら {
                False
            } でなければ {
                False
            }
        }
    }
}