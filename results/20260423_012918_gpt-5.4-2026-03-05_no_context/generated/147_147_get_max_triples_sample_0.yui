標準ライブラリを使う

get_max_triples = 入力 n に対し {
    a = 空配列
    i = 1
    反復 i <= n の間 {
        a に (i * i - i + 1) を追加
        i = i + 1
    }

    result = 空配列

    x = 0
    反復 x < n の間 {
        y = x + 1
        反復 y < n の間 {
            z = y + 1
            反復 z < n の間 {
                もし ((a[x] + a[y] + a[z]) % 3 == 0) なら {
                    result に [a[x], a[y], a[z]] を追加
                }
                z = z + 1
            }
            y = y + 1
        }
        x = x + 1
    }

    result を返す
}