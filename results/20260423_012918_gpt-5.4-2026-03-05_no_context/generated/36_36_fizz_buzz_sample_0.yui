標準ライブラリを使う

fizz_buzz = 入力 n に対し {
    count = 0
    i = 0
    反復 (i < n) の間 {
        もし ((i % 11 == 0) または (i % 13 == 0)) なら {
            s = 文字列(i)
            j = 0
            反復 (j < 長さ(s)) の間 {
                もし (s[j] == "7") なら {
                    count = count + 1
                }
                j = j + 1
            }
        }
        i = i + 1
    }
    count
}