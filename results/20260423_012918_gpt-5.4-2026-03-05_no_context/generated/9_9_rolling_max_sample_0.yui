標準ライブラリを使う

rolling_max = 入力 numbers に対し {
    もし numbers が [] なら []
    そうでなければ {
        初期値 = numbers[0]
        numbers を たたみこみ({結果, current に対し
            前最大 = もし 結果 が [] なら 初期値 そうでなければ 結果[-1]
            次最大 = もし current > 前最大 なら current そうでなければ 前最大
            結果 に 次最大 を追加
        }, [])
    }
}