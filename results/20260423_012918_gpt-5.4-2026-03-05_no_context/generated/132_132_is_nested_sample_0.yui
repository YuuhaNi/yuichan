標準ライブラリを使う

is_nested = 入力 string に対し {
    深さ = 0
    最大深さ = 0

    string の各文字を文字 として繰り返す {
        もし 文字 == "[" なら {
            深さ = 深さ + 1
            もし 深さ > 最大深さ なら {
                最大深さ = 深さ
            }
        } でなければ もし 文字 == "]" なら {
            もし 深さ > 0 なら {
                深さ = 深さ - 1
            }
        }
    }

    最大深さ > 1
}