標準ライブラリを使う

vowels_count = 入力 s に対し {
  count = 0
  i = 0
  sの大きさ回くり返す {
    ch = s[i]
    もし chが"a"のいずれかならば {
      countを増やす
    } そうでなければ {
      もし chが"e"のいずれかならば {
        countを増やす
      } そうでなければ {
        もし chが"i"のいずれかならば {
          countを増やす
        } そうでなければ {
          もし chが"o"のいずれかならば {
            countを増やす
          } そうでなければ {
            もし chが"u"のいずれかならば {
              countを増やす
            }
          }
        }
      }
    }
    iを増やす
  }
  countが答え
}