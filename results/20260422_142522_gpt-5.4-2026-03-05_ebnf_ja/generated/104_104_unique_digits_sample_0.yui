標準ライブラリを使う

unique_digits = 入力 x に対し {
    結果 = []
    長さ = xの大きさ
    長さ回くり返す {
        長さを減らす
        値 = x[長さ]
        文字列 = 文字列変換(値)
        桁数 = 文字列の大きさ
        使った = {}
        重複あり = 偽

        桁数回くり返す {
            桁数を減らす
            桁 = 文字列[桁数]
            もし 使った[桁] が 値なし ならば {
                使った[桁] = 真
            } そうでなければ {
                重複あり = 真
            }
        }

        もし 重複あり が 偽 ならば {
            結果に値を追加する
        }
    }

    整列済み = 並べ替え(結果)
    整列済みが答え
}