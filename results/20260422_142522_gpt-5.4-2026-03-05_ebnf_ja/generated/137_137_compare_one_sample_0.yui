標準ライブラリを使う

compare_one = 入力 a, b に対し {
    sa = 文字列化(a)
    sb = 文字列化(b)

    na = sa
    nb = sb

    もし sa の大きさ が 0 より大きい ならば {
        もし sa[0] が "-" ならば {
            signa = -1
            starta = 1
        } そうでなければ {
            signa = 1
            starta = 0
        }

        vala = 0
        fraca = 0
        scalea = 1
        pointa = 偽
        i = starta
        (saの大きさ)回 くり返す {
            もし i が saの大きさ より小さい ならば {
                ch = sa[i]
                もし ch が "." のいずれか ならば {
                    pointa = 真
                } そうでなければ {
                    もし ch が "," のいずれか ならば {
                        pointa = 真
                    } そうでなければ {
                        もし ch が "0" のいずれか ならば {
                            d = 0
                        } そうでなければ {
                            もし ch が "1" のいずれか ならば {
                                d = 1
                            } そうでなければ {
                                もし ch が "2" のいずれか ならば {
                                    d = 2
                                } そうでなければ {
                                    もし ch が "3" のいずれか ならば {
                                        d = 3
                                    } そうでなければ {
                                        もし ch が "4" のいずれか ならば {
                                            d = 4
                                        } そうでなければ {
                                            もし ch が "5" のいずれか ならば {
                                                d = 5
                                            } そうでなければ {
                                                もし ch が "6" のいずれか ならば {
                                                    d = 6
                                                } そうでなければ {
                                                    もし ch が "7" のいずれか ならば {
                                                        d = 7
                                                    } そうでなければ {
                                                        もし ch が "8" のいずれか ならば {
                                                            d = 8
                                                        } そうでなければ {
                                                            d = 9
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                            もし pointa が 偽 ならば {
                                vala = 和(積(vala, 10), d)
                            } そうでなければ {
                                fraca = 和(積(fraca, 10), d)
                                scalea = 積(scalea, 10)
                            }
                        }
                    }
                }
            }
            i を増やす
        }
        na = 積(signa, 和(vala, 商(fraca, scalea)))
    }

    もし sb の大きさ が 0 より大きい ならば {
        もし sb[0] が "-" ならば {
            signb = -1
            startb = 1
        } そうでなければ {
            signb = 1
            startb = 0
        }

        valb = 0
        fracb = 0
        scaleb = 1
        pointb = 偽
        j = startb
        (sbの大きさ)回 くり返す {
            もし j が sbの大きさ より小さい ならば {
                ch = sb[j]
                もし ch が "." のいずれか ならば {
                    pointb = 真
                } そうでなければ {
                    もし ch が "," のいずれか ならば {
                        pointb = 真
                    } そうでなければ {
                        もし ch が "0" のいずれか ならば {
                            d = 0
                        } そうでなければ {
                            もし ch が "1" のいずれか ならば {
                                d = 1
                            } そうでなければ {
                                もし ch が "2" のいずれか ならば {
                                    d = 2
                                } そうでなければ {
                                    もし ch が "3" のいずれか ならば {
                                        d = 3
                                    } そう