標準ライブラリを使う

skjkasdkd = 入力 lst に対し {
    最大素数 = 0
    i = 0
    lstの大きさ回 くり返す {
        値 = lst[i]
        もし 値 が 1 より大きい ならば {
            素数 = 真
            d = 2
            値回 くり返す {
                もし d が 値 以下 ならば {
                    もし 値 が d ならば {
                        何もしない
                    }
                    そうでなければ {
                        もし 剰余(値, d) が 0 ならば {
                            素数 = 偽
                        }
                    }
                    dを増やす
                }
            }
            もし 素数 が 真 ならば {
                もし 値 が 最大素数 より大きい ならば {
                    最大素数 = 値
                }
            }
        }
        iを増やす
    }

    合計 = 0
    もし 最大素数 が 0 より大きい ならば {
        10回 くり返す {
            もし 最大素数 が 0 より大きい ならば {
                合計 = 和(合計, 剰余(最大素数, 10))
                最大素数 = 商(最大素数, 10)
            }
        }
    }
    合計 が 答え
}