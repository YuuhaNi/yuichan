標準ライブラリを使う

factorize = 入力 n に対し {
  factors = []
  d = 2
  もし n が 1 ならば {
    factors が 答え
  }
  くり返し = 入力なし に対し {
    もし 積(d, d) が n より大きい ならば {
      くり返しを抜ける
    }
    もし 剰余(n, d) が 0 ならば {
      factors に d を追加する
      n = 商(n, d)
    } そうでなければ {
      d を増やす
    }
  }
  1000000 回 くり返す {
    くり返し()
  }
  もし n が 1 以外 ならば {
    factors に n を追加する
  }
  factors が 答え
}