標準ライブラリを使う

is_sorted = 入力 lst に対し {
    もし lstの大きさ が 1 以下 ならば {
        真 が 答え
    }
    i = 1
    重複数 = 0
    (lstの大きさ)回 くり返す {
        もし i が lstの大きさ より大きい ならば {
            くり返しを抜ける
        }
        もし lst[i] が lst[差(i, 1)] 以下 ならば {
            もし lst[i] が lst[差(i, 1)] ならば {
                重複数を増やす
                もし 重複数 が 2 以上 ならば {
                    偽 が 答え
                }
            } そうでなければ {
                偽 が 答え
            }
        }
        iを増やす
    }
    真 が 答え
}