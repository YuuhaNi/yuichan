標準ライブラリを使う

largest_smallest_integers = 入力 lst に対し {
  最大負 = 値なし
  最小正 = 値なし
  i = 0
  lstの大きさ回 くり返す {
    値 = lst[i]
    もし 値 が 0 より小さい ならば {
      もし 最大負 が 値なし ならば {
        最大負 = 値
      }
      そうでなければ {
        もし 値 が 最大負 より大きい ならば {
          最大負 = 値
        }
      }
    }
    そうでなければ {
      もし 値 が 0 より大きい ならば {
        もし 最小正 が 値なし ならば {
          最小正 = 値
        }
        そうでなければ {
          もし 値 が 最小正 より小さい ならば {
            最小正 = 値
          }
        }
      }
    }
    iを増やす
  }
  {"a": 最大負, "b": 最小正} が 答え
}