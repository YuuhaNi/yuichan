標準ライブラリを使う

check_if_last_char_is_a_letter = 入力 txt に対し {
    もし txtの大きさ が 0 ならば {
        偽 が 答え
    }

    最後 = txt[差(txtの大きさ, 1)]
    もし 最後 が " " ならば {
        偽 が 答え
    }

    もし txtの大きさ が 1 ならば {
        真 が 答え
    }

    前 = txt[差(txtの大きさ, 2)]
    もし 前 が " " ならば {
        真 が 答え
    } そうでなければ {
        偽 が 答え
    }
}