標準ライブラリを使う

select_words = 入力 s, n に対し {
  words = sを" "で分割する()
  result = []
  i = 0
  wordsの大きさ回 くり返す {
    word = words[i]
    count = 0
    j = 0
    wordの大きさ回 くり返す {
      ch = word[j]
      もし chが"a"のいずれか ならば {
        何もしない
      } そうでなければ {
        もし chが"e"のいずれか ならば {
          何もしない
        } そうでなければ {
          もし chが"i"のいずれか ならば {
            何もしない
          } そうでなければ {
            もし chが"o"のいずれか ならば {
              何もしない
            } そうでなければ {
              もし chが"u"のいずれか ならば {
                何もしない
              } そうでなければ {
                もし chが"A"のいずれか ならば {
                  何もしない
                } そうでなければ {
                  もし chが"E"のいずれか ならば {
                    何もしない
                  } そうでなければ {
                    もし chが"I"のいずれか ならば {
                      何もしない
                    } そうでなければ {
                      もし chが"O"のいずれか ならば {
                        何もしない
                      } そうでなければ {
                        もし chが"U"のいずれか ならば {
                          何もしない
                        } そうでなければ {
                          countを増やす
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
      jを増やす
    }
    もし countがn ならば {
      resultにwordを追加する
    } そうでなければ {
      何もしない
    }
    iを増やす
  }
  resultが答え
}