標準ライブラリを使う

count_upper = 入力 s に対し {
    count = 0
    i = 0
    sの大きさ回 くり返す {
        ch = s[i]
        もし i が 2の倍数ならば {
            もし ch が "A" のいずれかならば {
                countを増やす
            }
            もし ch が "E" のいずれかならば {
                countを増やす
            }
            もし ch が "I" のいずれかならば {
                countを増やす
            }
            もし ch が "O" のいずれかならば {
                countを増やす
            }
            もし ch が "U" のいずれかならば {
                countを増やす
            }
        }
        iを増やす
    }
    countが答え
}