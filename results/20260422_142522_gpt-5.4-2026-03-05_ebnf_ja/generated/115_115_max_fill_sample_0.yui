標準ライブラリを使う

max_fill = 入力 grid, capacity に対し {
    回数 = 0
    行数 = gridの大きさ
    i = 0

    行数回 くり返す {
        行 = grid[i]
        列数 = 行の大きさ
        j = 0
        水量 = 0

        列数回 くり返す {
            もし 行[j] が 1 ならば {
                水量を増やす
            }
            jを増やす
        }

        もし 水量 が 0 ならば {
            何もしない
        } そうでなければ {
            商 = 切り上げ(水量, capacity)
            回数 = 和(回数, 商)
        }

        iを増やす
    }

    回数が答え
}