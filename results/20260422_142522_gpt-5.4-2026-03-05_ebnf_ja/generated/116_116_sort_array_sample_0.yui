標準ライブラリを使う

sort_array = 入力 arr に対し {
    n = arrの大きさ
    i = 0
    n回 くり返す {
        j = 0
        n回 くり返す {
            a = arr[j]
            b = arr[j + 1]

            ca = 0
            ta = a
            32回 くり返す {
                もし 剰余(ta, 2) が 1 ならば {
                    caを増やす
                }
                ta = 商(ta, 2)
            }

            cb = 0
            tb = b
            32回 くり返す {
                もし 剰余(tb, 2) が 1 ならば {
                    cbを増やす
                }
                tb = 商(tb, 2)
            }

            swap = 偽
            もし ca が cb より大きい ならば {
                swap = 真
            } そうでなければ {
                もし ca が cb ならば {
                    もし a が b より大きい ならば {
                        swap = 真
                    }
                }
            }

            もし swap が 真 ならば {
                temp = arr[j]
                arr[j] = arr[j + 1]
                arr[j + 1] = temp
            }

            jを増やす
            もし j が 差(n, 1) 以上 ならば {
                くり返しを抜ける
            }
        }
        iを増やす
    }
    arrが答え
}