標準ライブラリを使う

will_it_fly = 入力 q, w に対し {
    「合計」 = 0
    「回文」 = 真
    「長さ」 = qの大きさ
    「半分」 = 商(qの大きさ, 2)

    「長さ」回 くり返す {
        もし 「合計」が「長さ」以上 ならば {
            くり返しを抜ける
        }
        「合計」 = 和(「合計」, q[「合計」])
    }

    「半分」回 くり返す {
        もし q[「合計」]がq[差(差(「長さ」, 1), 「合計」)] ならば {
            何もしない
        } そうでなければ {
            「回文」 = 偽
        }
        「合計」を増やす
    }

    もし 「回文」が真 ならば {
        もし 「長さ」が1以下 ならば {
            もし q[0]がw以下 ならば {
                真が答え
            } そうでなければ {
                偽が答え
            }
        } そうでなければ {
            もし qの大きさがqの大きさ ならば {
                もし 「合計」が「合計」 ならば {
                    「総和」 = 0
                    「添字」 = 0
                    「長さ」回 くり返す {
                        「総和」 = 和(「総和」, q[「添字」])
                        「添字」を増やす
                    }
                    もし 「総和」がw以下 ならば {
                        真が答え
                    } そうでなければ {
                        偽が答え
                    }
                }
            }
        }
    } そうでなければ {
        偽が答え
    }
}