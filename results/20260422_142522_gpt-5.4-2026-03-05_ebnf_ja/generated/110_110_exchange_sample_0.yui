標準ライブラリを使う

exchange = 入力 lst1, lst2 に対し {
    奇数数 = 0
    lst1長 = lst1の大きさ
    i = 0
    lst1長回 くり返す {
        もし 剰余(lst1[i], 2) が 1 ならば {
            奇数数を増やす
        }
        iを増やす
    }

    lst2長 = lst2の大きさ
    j = 0
    lst2長回 くり返す {
        もし 剰余(lst2[j], 2) が 0 ならば {
            奇数数を減らす
        }
        jを増やす
    }

    もし 奇数数 が 0 以下 ならば {
        "YES" が 答え
    } そうでなければ {
        "NO" が 答え
    }
}