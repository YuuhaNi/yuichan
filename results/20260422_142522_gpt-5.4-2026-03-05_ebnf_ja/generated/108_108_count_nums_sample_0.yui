標準ライブラリを使う

count_nums = 入力 arr に対し {
    count = 0
    i = 0
    arrの大きさ回 くり返す {
        n = arr[i]
        s = 0
        もし n が 0 より小さい ならば {
            m = -n
            first = m[0]
            s = 0 - first
            j = 1
            mの大きさ回 くり返す {
                もし j が mの大きさ より小さい ならば {
                    s = 和(s, m[j])
                }
                jを増やす
            }
        } そうでなければ {
            m = n
            j = 0
            mの大きさ回 くり返す {
                s = 和(s, m[j])
                jを増やす
            }
        }
        もし s が 0 より大きい ならば {
            countを増やす
        }
        iを増やす
    }
    count が 答え
}