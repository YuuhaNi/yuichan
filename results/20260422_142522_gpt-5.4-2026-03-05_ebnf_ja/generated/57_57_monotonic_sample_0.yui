標準ライブラリを使う

monotonic = 入力 l に対し {
    もし lの大きさ が 2 以下 ならば {
        真 が 答え
    }

    inc = 真
    dec = 真
    i = 1

    差(l[1], l[0]) が 0 より小さい ならば {
        inc = 偽
    }
    差(l[1], l[0]) が 0 より大きい ならば {
        dec = 偽
    }

    差(lの大きさ, 1) 回 くり返す {
        もし i が 差(lの大きさ, 1) 以上 ならば {
            くり返しを抜ける
        }

        d = 差(l[i], l[差(i, 1)])

        もし d が 0 より小さい ならば {
            inc = 偽
        }
        もし d が 0 より大きい ならば {
            dec = 偽
        }

        もし inc が 偽 ならば {
            もし dec が 偽 ならば {
                偽 が 答え
            }
        }

        iを増やす
    }

    真 が 答え
}