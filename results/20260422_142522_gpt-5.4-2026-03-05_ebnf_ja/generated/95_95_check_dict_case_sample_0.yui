標準ライブラリを使う

check_dict_case = 入力 dict に対し {
    keys = キー列(dict)
    もし keysの大きさ が 0 ならば {
        偽 が 答え
    }
    has_lower = 偽
    has_upper = 偽
    i = 0
    keysの大きさ 回 くり返す {
        key = keys[i]
        もし 小文字列(key) が key ならば {
            has_lower = 真
        } そうでなければ {
            もし 大文字列(key) が key ならば {
                has_upper = 真
            } そうでなければ {
                偽 が 答え
            }
        }
        iを増やす
    }
    もし has_lower が 真 ならば {
        真 が 答え
    } そうでなければ {
        偽 が 答え
    }
}