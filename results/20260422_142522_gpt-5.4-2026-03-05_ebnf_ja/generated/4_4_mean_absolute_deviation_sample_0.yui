標準ライブラリを使う

mean_absolute_deviation = 入力 numbers に対し {
    total = 0.0
    count = numbersの大きさ
    i = 0
    count回 くり返す {
        total = 和(total, numbers[i])
        iを増やす
    }
    mean = 商(total, count)

    deviation_sum = 0.0
    i = 0
    count回 くり返す {
        diff = 差(numbers[i], mean)
        abs_diff = 絶対値(diff)
        deviation_sum = 和(deviation_sum, abs_diff)
        iを増やす
    }

    mad = 商(deviation_sum, count)
    madが答え
}