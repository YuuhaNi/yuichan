標準ライブラリを使う

digits = 入力 n に対し {
  もし n が 0 ならば {
    0 が 答え
  }

  結果 = 1
  見つけた = 偽

  くり返し = 入力なし に対し {
    もし n が 0 ならば {
      関数から抜ける
    }

    桁 = 剰余(n, 10)
    もし 剰余(桁, 2) が 1 ならば {
      結果 = 積(結果, 桁)
      見つけた = 真
    }

    n = 商(n, 10)
  }

  1000 回 くり返す {
    くり返し()
    もし n が 0 ならば {
      くり返しを抜ける
    }
  }

  もし 見つけた が 真 ならば {
    結果 が 答え
  } そうでなければ {
    0 が 答え
  }
}