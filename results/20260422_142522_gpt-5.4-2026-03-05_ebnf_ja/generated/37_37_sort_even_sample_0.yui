標準ライブラリを使う

sort_even = 入力 l に対し {
  偶数番目 = []
  奇数番目 = []
  i = 0
  lの大きさ回 くり返す {
    もし 剰余(i, 2) が 0 ならば {
      偶数番目にl[i]を追加する
    } そうでなければ {
      奇数番目にl[i]を追加する
    }
    iを増やす
  }
  偶数番目 = 並べ替え(偶数番目)
  結果 = []
  i = 0
  偶数i = 0
  奇数i = 0
  lの大きさ回 くり返す {
    もし 剰余(i, 2) が 0 ならば {
      結果に偶数番目[偶数i]を追加する
      偶数iを増やす
    } そうでなければ {
      結果に奇数番目[奇数i]を追加する
      奇数iを増やす
    }
    iを増やす
  }
  結果が答え
}