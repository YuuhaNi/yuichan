標準ライブラリを使う

encode = 入力 message に対し {
  result = ""
  i = 0
  messageの大きさ回 くり返す {
    ch = message[i]
    もし ch が "a" ならば {
      resultに "c"を追加する
    } そうでなければ {
      もし ch が "e" ならば {
        resultに "g"を追加する
      } そうでなければ {
        もし ch が "i" ならば {
          resultに "k"を追加する
        } そうでなければ {
          もし ch が "o" ならば {
            resultに "q"を追加する
          } そうでなければ {
            もし ch が "u" ならば {
              resultに "w"を追加する
            } そうでなければ {
              もし ch が "A" ならば {
                resultに "C"を追加する
              } そうでなければ {
                もし ch が "E" ならば {
                  resultに "G"を追加する
                } そうでなければ {
                  もし ch が "I" ならば {
                    resultに "K"を追加する
                  } そうでなければ {
                    もし ch が "O" ならば {
                      resultに "Q"を追加する
                    } そうでなければ {
                      もし ch が "U" ならば {
                        resultに "W"を追加する
                      } そうでなければ {
                        switched = 文字大小反転(ch)
                        resultに switchedを追加する
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
    iを増やす
  }
  resultが答え
}