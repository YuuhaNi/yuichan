標準ライブラリを使う

rescale_to_unit = 入力 numbers に対し {
    最小値 = numbers[0]
    最大値 = numbers[0]
    結果 = []

    i = 1
    numbersの大きさ回 くり返す {
        もし i が numbersの大きさ より小さい ならば {
            値 = numbers[i]
            もし 値 が 最小値 より小さい ならば {
                最小値 = 値
            }
            もし 値 が 最大値 より大きい ならば {
                最大値 = 値
            }
            iを増やす
        }
    }

    範囲 = 差(最大値, 最小値)

    i = 0
    numbersの大きさ回 くり返す {
        値 = numbers[i]
        正規化値 = 商(差(値, 最小値), 範囲)
        結果に正規化値を追加する
        iを増やす
    }

    結果が答え
}