標準ライブラリを使う

next_smallest = 入力 lst に対し {
    もし lstの大きさ が 2 より小さい ならば {
        値なし が 答え
    }
    最小 = lst[0]
    次最小 = 値なし
    i = 1
    lstの大きさ 回 くり返す {
        もし i が lstの大きさ より小さい ならば {
            値 = lst[i]
            もし 値 が 最小 より小さい ならば {
                次最小 = 最小
                最小 = 値
            }
            そうでなければ {
                もし 値 が 最小 より大きい ならば {
                    もし 次最小 が 値なし ならば {
                        次最小 = 値
                    }
                    そうでなければ {
                        もし 値 が 次最小 より小さい ならば {
                            次最小 = 値
                        }
                    }
                }
            }
            iを増やす
        }
    }
    次最小 が 答え
}