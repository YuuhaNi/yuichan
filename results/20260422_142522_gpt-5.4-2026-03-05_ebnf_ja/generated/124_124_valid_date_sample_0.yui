標準ライブラリを使う

valid_date = 入力 date に対し {
  もし date の大きさ が 0 ならば {
    偽 が 答え
  }

  parts = 分割(date, "-")
  もし parts の大きさ が 3 以外 ならば {
    偽 が 答え
  }

  month_s = parts[0]
  day_s = parts[1]
  year_s = parts[2]

  もし month_s の大きさ が 2 以外 ならば {
    偽 が 答え
  }
  もし day_s の大きさ が 2 以外 ならば {
    偽 が 答え
  }
  もし year_s の大きさ が 4 以外 ならば {
    偽 が 答え
  }

  month = 整数変換(month_s)
  day = 整数変換(day_s)

  もし month が 1 より小さい ならば {
    偽 が 答え
  }
  もし month が 12 より大きい ならば {
    偽 が 答え
  }
  もし day が 1 より小さい ならば {
    偽 が 答え
  }

  もし month が 2 ならば {
    もし day が 29 より大きい ならば {
      偽 が 答え
    }
    真 が 答え
  }

  もし month が 4 ならば {
    もし day が 30 より大きい ならば {
      偽 が 答え
    }
    真 が 答え
  }

  もし month が 6 ならば {
    もし day が 30 より大きい ならば {
      偽 が 答え
    }
    真 が 答え
  }

  もし month が 9 ならば {
    もし day が 30 より大きい ならば {
      偽 が 答え
    }
    真 が 答え
  }

  もし month が 11 ならば {
    もし day が 30 より大きい ならば {
      偽 が 答え
    }
    真 が 答え
  }

  もし day が 31 より大きい ならば {
    偽 が 答え
  }

  真 が 答え
}