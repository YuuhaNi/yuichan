標準ライブラリを使う

pairs_sum_to_zero = 入力 l に対し {
    i = 0
    lの大きさ回 くり返す {
        a = l[i]
        j = 0
        lの大きさ回 くり返す {
            もし i が j 以外 ならば {
                b = l[j]
                もし 和(a, b) が 0 ならば {
                    真 が 答え
                }
            }
            jを増やす
        }
        iを増やす
    }
    偽 が 答え
}