標準ライブラリを使う

triples_sum_to_zero = 入力 l に対し {
    n = lの大きさ
    もし n が 3 より小さい ならば {
        偽 が 答え
    }
    i = 0
    n回 くり返す {
        j = i
        jを増やす
        n回 くり返す {
            k = j
            kを増やす
            n回 くり返す {
                もし k が n より小さい ならば {
                    a = l[i]
                    b = l[j]
                    c = l[k]
                    s1 = 和(a, b)
                    s2 = 和(s1, c)
                    もし s2 が 0 ならば {
                        真 が 答え
                    }
                }
                kを増やす
            }
            jを増やす
        }
        iを増やす
    }
    偽 が 答え
}