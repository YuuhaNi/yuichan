標準ライブラリを使う

count_up_to = 入力 n に対し {
  primes = []
  i = 2
  n回 くり返す {
    もし i が n より小さい ならば {
      is_prime = 真
      j = 2
      n回 くり返す {
        もし j が i より小さい ならば {
          もし 剰余(i, j) が 0 ならば {
            is_prime = 偽
          }
          jを増やす
        }
      }
      もし is_prime が 真 ならば {
        primesに iを追加する
      }
      iを増やす
    }
  }
  primesが答え
}