標準ライブラリを使う

pluck = 入力 arr に対し {
    もし arrの大きさ が 0 ならば {
        [] が 答え
    }

    best = []
    i = 0
    arrの大きさ 回 くり返す {
        v = arr[i]
        もし 剰余(v, 2) が 0 ならば {
            もし bestの大きさ が 0 ならば {
                best = [v, i]
            } そうでなければ {
                もし v が best[0] より小さい ならば {
                    best = [v, i]
                }
            }
        }
        iを増やす
    }
    best が 答え
}