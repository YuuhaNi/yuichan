標準ライブラリを使う

remove_duplicates = 入力 numbers に対し {
    counts = {}
    result = []
    i = 0
    numbersの大きさ回 くり返す {
        x = numbers[i]
        もし x が counts のいずれか ならば {
            counts[x]を増やす
        } そうでなければ {
            counts[x] = 1
        }
        iを増やす
    }
    i = 0
    numbersの大きさ回 くり返す {
        x = numbers[i]
        もし counts[x] が 1 ならば {
            resultに xを追加する
        }
        iを増やす
    }
    resultが答え
}