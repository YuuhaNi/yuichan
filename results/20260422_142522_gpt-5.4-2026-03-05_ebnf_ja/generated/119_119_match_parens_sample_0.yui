標準ライブラリを使う

match_parens = 入力 lst に対し {
  a = lst[0]
  b = lst[1]
  ab = a
  abの末尾にbを追加する
  ba = b
  baの末尾にaを追加する

  もし 良い括弧列(ab) が 真 ならば {
    "Yes" が 答え
  } そうでなければ {
    もし 良い括弧列(ba) が 真 ならば {
      "Yes" が 答え
    } そうでなければ {
      "No" が 答え
    }
  }
}

良い括弧列 = 入力 s に対し {
  残高 = 0
  長さ = sの大きさ
  i = 0
  長さ回 くり返す {
    文字 = s[i]
    もし 文字 が "(" ならば {
      残高 = 和(残高, 1)
    } そうでなければ {
      残高 = 差(残高, 1)
    }

    もし 残高 が 0 より小さい ならば {
      偽 が 答え
    } そうでなければ {
      何もしない
    }
    iを増やす
  }

  もし 残高 が 0 ならば {
    真 が 答え
  } そうでなければ {
    偽 が 答え
  }
}