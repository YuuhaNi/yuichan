標準ライブラリを使う

reverse_delete = 入力 s, c に対し {
    結果 = ""
    i = 0
    sの大きさ回 くり返す {
        文字 = s[i]
        含む = 偽
        j = 0
        cの大きさ回 くり返す {
            もし 文字 が c[j] ならば {
                含む = 真
            }
            jを増やす
        }
        もし 含む が 偽 ならば {
            結果 = 結果 + 文字
        }
        iを増やす
    }

    回文 = 真
    左 = 0
    右 = 結果の大きさ
    右を減らす

    結果の大きさ回 くり返す {
        もし 左 が 右 より大きい ならば {
            くり返しを抜ける
        }
        もし 結果[左] が 結果[右] 以外 ならば {
            回文 = 偽
        }
        左を増やす
        右を減らす
    }

    {"result": 結果, "is_palindrome": 回文} が 答え
}