標準ライブラリを使う

get_closest_vowel = 入力 word に対し {
    長さ = wordの大きさ
    もし 長さ が 3 より小さい ならば {
        "" が 答え
    }

    母音たち = ["a", "e", "i", "o", "u", "A", "E", "I", "O", "U"]
    結果 = ""

    i = 長さ
    iを減らす
    iを減らす

    i回 くり返す {
        前 = word[i]
        左 = word[差(i, 1)]
        右 = word[和(i, 1)]

        もし 前 が 母音たち のいずれか ならば {
            もし 左 が 母音たち のいずれでもない ならば {
                もし 右 が 母音たち のいずれでもない ならば {
                    前 が 答え
                }
            }
        }

        iを減らす
    }

    結果 が 答え
}