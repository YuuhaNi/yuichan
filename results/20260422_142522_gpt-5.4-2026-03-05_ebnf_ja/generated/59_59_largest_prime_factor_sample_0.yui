標準ライブラリを使う

largest_prime_factor = 入力 n に対し {
    最大 = 1
    d = 2
    もし 剰余(n, d) が 0 ならば {
        最大 = d
        くり返し中 = 真
        もし 剰余(n, d) が 0 ならば {
            n = 商(n, d)
        }
        そうでなければ {
            何もしない
        }
        もし 剰余(n, d) が 0 ならば {
            くり返し中 = 真
        }
        そうでなければ {
            くり返し中 = 偽
        }
        くり返し中回 くり返す {
            もし 剰余(n, d) が 0 ならば {
                n = 商(n, d)
                もし 剰余(n, d) が 0 ならば {
                    くり返し中 = 真
                }
                そうでなければ {
                    くり返し中 = 偽
                }
            }
            そうでなければ {
                くり返し中 = 偽
            }
        }
    }
    d = 3
    続ける = 真
    もし n が 1 ならば {
        続ける = 偽
    }
    そうでなければ {
        何もしない
    }
    もし 積(d, d) が n 以下 ならば {
        何もしない
    }
    そうでなければ {
        続ける = 偽
    }
    100000回 くり返す {
        もし 続ける が 真 ならば {
            もし 剰余(n, d) が 0 ならば {
                最大 = d
                割れる = 真
                もし 剰余(n, d) が 0 ならば {
                    n = 商(n, d)
                }
                そうでなければ {
                    何もしない
                }
                もし 剰余(n, d) が 0 ならば {
                    割れる = 真
                }
                そうでなければ {
                    割れる = 偽
                }
                割れる回 くり返す {
                    もし 剰余(n, d) が 0 ならば {
                        n = 商(n, d)
                        もし 剰余(n, d) が 0 ならば {
                            割れる = 真
                        }
                        そうでなければ {
                            割れる = 偽
                        }
                    }
                    そうでなければ {
                        割れる = 偽
                    }
                }
            }
            そうでなければ {
                何もしない
            }
            d = 和(d, 2)
            もし n が 1 ならば {
                続ける = 偽
            }
            そうでなければ {
                何もしない
            }
            もし 積(d, d) が n 以下 ならば {
                何もしない
            }
            そうでなければ {
                続ける = 偽
            }
        }
        そうでなければ {
            何もしない
        }
    }
    もし n が 1 より大きい ならば {
        最大 = n
    }
    そうでなければ {
        何もしない
    }
    最大 が 答え
}