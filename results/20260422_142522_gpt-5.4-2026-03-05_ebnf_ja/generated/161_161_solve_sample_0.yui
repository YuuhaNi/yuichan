標準ライブラリを使う

solve = 入力 s に対し {
    結果 = ""
    英字あり = 偽
    i = 0
    sの大きさ 回 くり返す {
        c = s[i]
        もし c が "a" 以上 ならば {
            もし c が "z" 以下 ならば {
                英字あり = 真
                結果の末尾に 大文字化(c) を追加する
            } そうでなければ {
                もし c が "A" 以上 ならば {
                    もし c が "Z" 以下 ならば {
                        英字あり = 真
                        結果の末尾に 小文字化(c) を追加する
                    } そうでなければ {
                        結果の末尾に c を追加する
                    }
                } そうでなければ {
                    結果の末尾に c を追加する
                }
            }
        } そうでなければ {
            もし c が "A" 以上 ならば {
                もし c が "Z" 以下 ならば {
                    英字あり = 真
                    結果の末尾に 小文字化(c) を追加する
                } そうでなければ {
                    結果の末尾に c を追加する
                }
            } そうでなければ {
                結果の末尾に c を追加する
            }
        }
        iを増やす
    }
    もし 英字あり が 真 ならば {
        結果 が 答え
    } そうでなければ {
        逆順(s) が 答え
    }
}