標準ライブラリを使う

change_base = 入力 x, base に対し {
    もし x が 0 ならば {
        "0" が 答え
    }
    result = ""
    n = x
    もし n が 0 より大きい ならば {
        くり返し = 真
        1000回 くり返す {
            もし くり返し が 偽 ならば {
                くり返しを抜ける
            }
            r = 剰余(n, base)
            result = 文字列(r) + result
            n = 商(n, base)
            もし n が 0 ならば {
                くり返し = 偽
            }
        }
    }
    result が 答え
}