標準ライブラリを使う

decimal_to_binary = 入力 decimal に対し {
    もし decimal が 0 ならば {
        "db0db" が 答え
    }
    bits = []
    n = decimal
    もし n が 0 より大きい ならば {
        くり返し = 真
        1000000回 くり返す {
            もし くり返し が 偽 ならば {
                くり返しを抜ける
            }
            余り = 剰余(n, 2)
            もし 余り が 0 ならば {
                bits の末尾に "0" を追加する
            } そうでなければ {
                bits の末尾に "1" を追加する
            }
            n = 商(n, 2)
            もし n が 0 ならば {
                くり返し = 偽
            }
        }
    }
    result = "db"
    i = 差(bitsの大きさ, 1)
    1000000回 くり返す {
        もし i が 0 より小さい ならば {
            くり返しを抜ける
        }
        result = 連結(result, bits[i])
        i = 差(i, 1)
    }
    result = 連結(result, "db")
    result が 答え
}