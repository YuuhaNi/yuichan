標準ライブラリを使う

sort_third = 入力 l に対し {
    対象 = []
    結果 = []
    i = 0
    lの大きさ回 くり返す {
        もし 剰余(i, 3) が 0 ならば {
            対象に l[i] を追加する
        }
        iを増やす
    }
    対象 = ソート(対象)

    j = 0
    k = 0
    lの大きさ回 くり返す {
        もし 剰余(j, 3) が 0 ならば {
            結果に 対象[k] を追加する
            kを増やす
        } そうでなければ {
            結果に l[j] を追加する
        }
        jを増やす
    }
    結果 が 答え
}