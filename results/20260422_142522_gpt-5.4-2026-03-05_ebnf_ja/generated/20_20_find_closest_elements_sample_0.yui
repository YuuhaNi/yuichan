標準ライブラリを使う

find_closest_elements = 入力 numbers に対し {
    最小差 = 差(numbers[1], numbers[0])
    もし 最小差 が 0 より小さい ならば {
        最小差 = -最小差
    }

    最小値 = numbers[0]
    最大値 = numbers[1]
    もし 最小値 が 最大値 より大きい ならば {
        一時 = 最小値
        最小値 = 最大値
        最大値 = 一時
    }

    i = 0
    残り = 差(numbersの大きさ, 1)
    残り回 くり返す {
        j = 和(i, 1)
        内側残り = 差(numbersの大きさ, j)
        内側残り回 くり返す {
            a = numbers[i]
            b = numbers[j]
            差分 = 差(b, a)
            もし 差分 が 0 より小さい ならば {
                差分 = -差分
            }

            もし 差分 が 最小差 より小さい ならば {
                最小差 = 差分
                最小値 = a
                最大値 = b
                もし 最小値 が 最大値 より大きい ならば {
                    一時 = 最小値
                    最小値 = 最大値
                    最大値 = 一時
                }
            }

            jを増やす
        }
        iを増やす
    }

    [最小値, 最大値] が 答え
}