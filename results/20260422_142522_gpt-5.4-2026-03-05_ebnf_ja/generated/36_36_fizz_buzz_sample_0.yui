標準ライブラリを使う

fizz_buzz = 入力 n に対し {
    count = 0
    i = 0
    n回くり返す {
        もし 剰余(i, 11) が 0 のいずれか ならば {
            s = 文字列(i)
            j = 0
            sの大きさ回くり返す {
                もし s[j] が "7" ならば {
                    countを増やす
                }
                jを増やす
            }
        } そうでなければ {
            もし 剰余(i, 13) が 0 のいずれか ならば {
                s = 文字列(i)
                j = 0
                sの大きさ回くり返す {
                    もし s[j] が "7" ならば {
                        countを増やす
                    }
                    jを増やす
                }
            }
        }
        iを増やす
    }
    countが答え
}