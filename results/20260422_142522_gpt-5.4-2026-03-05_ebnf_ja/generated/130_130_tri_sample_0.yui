標準ライブラリを使う

tri = 入力 n に対し {
    結果 = [1]
    もし n が 1 以上 ならば {
        結果に 3 を追加する
    }
    もし n が 2 以上 ならば {
        結果に 2 を追加する
    }
    i = 3
    もし n が 3 以上 ならば {
        m = 差(n, 2)
        m 回 くり返す {
            次 = 和(和(結果[差(i, 1)], 結果[差(i, 2)]), 結果[和(i, 1)])
            結果に 次 を追加する
            iを増やす
        }
    }
    結果 が 答え
}