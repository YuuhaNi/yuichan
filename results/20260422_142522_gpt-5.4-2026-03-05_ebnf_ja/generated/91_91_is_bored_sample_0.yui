標準ライブラリを使う

is_bored = 入力 S に対し {
    区切り文字 = [".", "?", "!"]
    文一覧 = [S]
    i = 0
    3回 くり返す {
        新しい文一覧 = []
        j = 0
        文一覧の大きさ回 くり返す {
            分割結果 = 分割(文一覧[j], 区切り文字[i])
            k = 0
            分割結果の大きさ回 くり返す {
                新しい文一覧に 分割結果[k] を追加する
                kを増やす
            }
            jを増やす
        }
        文一覧 = 新しい文一覧
        iを増やす
    }

    数 = 0
    j = 0
    文一覧の大きさ回 くり返す {
        文 = トリム(文一覧[j])
        もし 文の大きさ が 2 以上 ならば {
            もし 文[0] が "I" ならば {
                もし 文[1] が " " ならば {
                    数を増やす
                }
            }
        }
        jを増やす
    }
    数が答え
}