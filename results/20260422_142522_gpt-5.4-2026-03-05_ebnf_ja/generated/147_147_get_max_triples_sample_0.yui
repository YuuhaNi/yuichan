標準ライブラリを使う

get_max_triples = 入力 n に対し {
  a = []
  i = 1
  n 回 くり返す {
    x = 差(積(i, i), i)
    x = 和(x, 1)
    a に x を追加する
    i を増やす
  }

  もし n が 3 より小さい ならば {
    [] が 答え
  }

  r1 = []
  r2 = []
  idx = 0
  n 回 くり返す {
    v = a[idx]
    m = 剰余(v, 3)
    もし m が 1 ならば {
      r1 に v を追加する
    } そうでなければ {
      もし m が 2 ならば {
        r2 に v を追加する
      }
    }
    idx を増やす
  }

  もし r1の大きさ が 2 以下 ならば {
    [] が 答え
  }

  ans = []
  ans に r1[0] を追加する
  ans に r1[1] を追加する
  ans に r1[2] を追加する
  ans が 答え
}