標準ライブラリを使う

numerical_letter_grade = 入力 grades に対し {
    result = []

    i = 0
    gradesの大きさ 回 くり返す {
        g = grades[i]

        もし g が 4.0 ならば {
            resultに"A+"を追加する
        } そうでなければ {
            もし g が 3.7 より大きい ならば {
                resultに"A"を追加する
            } そうでなければ {
                もし g が 3.3 より大きい ならば {
                    resultに"A-"を追加する
                } そうでなければ {
                    もし g が 3.0 より大きい ならば {
                        resultに"B+"を追加する
                    } そうでなければ {
                        もし g が 2.7 より大きい ならば {
                            resultに"B"を追加する
                        } そうでなければ {
                            もし g が 2.3 より大きい ならば {
                                resultに"B-"を追加する
                            } そうでなければ {
                                もし g が 2.0 より大きい ならば {
                                    resultに"C+"を追加する
                                } そうでなければ {
                                    もし g が 1.7 より大きい ならば {
                                        resultに"C"を追加する
                                    } そうでなければ {
                                        もし g が 1.3 より大きい ならば {
                                            resultに"C-"を追加する
                                        } そうでなければ {
                                            もし g が 1.0 より大きい ならば {
                                                resultに"D+"を追加する
                                            } そうでなければ {
                                                もし g が 0.7 より大きい ならば {
                                                    resultに"D"を追加する
                                                } そうでなければ {
                                                    もし g が 0.0 より大きい ならば {
                                                        resultに"D-"を追加する
                                                    } そうでなければ {
                                                        resultに"E"を追加する
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        iを増やす
    }

    result が 答え
}