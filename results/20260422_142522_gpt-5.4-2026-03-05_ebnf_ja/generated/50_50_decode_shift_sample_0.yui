標準ライブラリを使う

decode_shift = 入力 s に対し {
    結果 = ""
    i = 0
    sの大きさ回 くり返す {
        c = s[i]
        文字コード = 文字コード取得(c)
        もし 文字コード が 65 以上 ならば {
            もし 文字コード が 90 以下 ならば {
                文字コード = 剰余(差(和(差(文字コード, 65), 5), 26), 26)
                文字コード = 和(文字コード, 65)
                結果に 文字列化(文字コードから文字へ(文字コード))を追加する
            } そうでなければ {
                もし 文字コード が 97 以上 ならば {
                    もし 文字コード が 122 以下 ならば {
                        文字コード = 剰余(差(和(差(文字コード, 97), 5), 26), 26)
                        文字コード = 和(文字コード, 97)
                        結果に 文字列化(文字コードから文字へ(文字コード))を追加する
                    } そうでなければ {
                        結果に cを追加する
                    }
                } そうでなければ {
                    結果に cを追加する
                }
            }
        } そうでなければ {
            結果に cを追加する
        }
        iを増やす
    }
    結果が答え
}