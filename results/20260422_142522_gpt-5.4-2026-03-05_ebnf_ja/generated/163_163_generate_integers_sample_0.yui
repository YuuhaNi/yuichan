標準ライブラリを使う

generate_integers = 入力 a, b に対し {
    結果 = []
    小さい方 = 最小(a, b)
    大きい方 = 最大(a, b)

    もし 小さい方 が 10 以下 ならば {
        結果 が 答え
    }

    現在 = 10
    もし 現在 が 小さい方 より小さい ならば {
        差 = 差(小さい方, 10)
        半分 = 商(差, 2)
        現在 = 和(10, 積(半分, 2))
        もし 現在 が 小さい方 より小さい ならば {
            現在を増やす
            現在を増やす
        }
    }

    くり返し回数 = 和(商(差(大きい方, 現在), 2), 1)
    もし 現在 が 大きい方 より大きい ならば {
        くり返し回数 = 0
    }

    くり返し回数 回 くり返す {
        結果に現在を追加する
        現在を増やす
        現在を増やす
    }

    結果 が 答え
}