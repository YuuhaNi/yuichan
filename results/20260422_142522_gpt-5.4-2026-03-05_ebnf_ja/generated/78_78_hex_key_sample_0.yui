標準ライブラリを使う

hex_key = 入力 num に対し {
    count = 0
    i = 0
    numの大きさ回 くり返す {
        ch = num[i]
        もし ch が "2" のいずれか ならば {
            countを増やす
        } そうでなければ {
            もし ch が "3" のいずれか ならば {
                countを増やす
            } そうでなければ {
                もし ch が "5" のいずれか ならば {
                    countを増やす
                } そうでなければ {
                    もし ch が "7" のいずれか ならば {
                        countを増やす
                    } そうでなければ {
                        もし ch が "B" のいずれか ならば {
                            countを増やす
                        } そうでなければ {
                            もし ch が "D" のいずれか ならば {
                                countを増やす
                            }
                        }
                    }
                }
            }
        }
        iを増やす
    }
    countが答え
}