標準ライブラリを使う

split_words = 入力 txt に対し {
    もし txt が " " のいずれか ならば {
        txt(" ") が答え
    } そうでなければ {
        もし txt が "," のいずれか ならば {
            txt(",") が答え
        } そうでなければ {
            count = 0
            i = 0
            txtの大きさ 回 くり返す {
                ch = txt[i]
                もし ch が "b" のいずれか ならば {
                    countを増やす
                }
                もし ch が "d" のいずれか ならば {
                    countを増やす
                }
                もし ch が "f" のいずれか ならば {
                    countを増やす
                }
                もし ch が "h" のいずれか ならば {
                    countを増やす
                }
                もし ch が "j" のいずれか ならば {
                    countを増やす
                }
                もし ch が "l" のいずれか ならば {
                    countを増やす
                }
                もし ch が "n" のいずれか ならば {
                    countを増やす
                }
                もし ch が "p" のいずれか ならば {
                    countを増やす
                }
                もし ch が "r" のいずれか ならば {
                    countを増やす
                }
                もし ch が "t" のいずれか ならば {
                    countを増やす
                }
                もし ch が "v" のいずれか ならば {
                    countを増やす
                }
                もし ch が "x" のいずれか ならば {
                    countを増やす
                }
                もし ch が "z" のいずれか ならば {
                    countを増やす
                }
                iを増やす
            }
            count が答え
        }
    }
}