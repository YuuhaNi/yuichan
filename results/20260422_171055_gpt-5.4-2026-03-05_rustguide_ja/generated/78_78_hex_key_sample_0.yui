標準ライブラリを使う

hex_key = 入力 num に対し {
   count = 0
   i = 0

   numの大きさ回くり返す{
      c = num[i]

      もしcが"2"[0]ならば{
         countを増やす
      }そうでなければ{
         もしcが"3"[0]ならば{
            countを増やす
         }そうでなければ{
            もしcが"5"[0]ならば{
               countを増やす
            }そうでなければ{
               もしcが"7"[0]ならば{
                  countを増やす
               }そうでなければ{
                  もしcが"B"[0]ならば{
                     countを増やす
                  }そうでなければ{
                     もしcが"D"[0]ならば{
                        countを増やす
                     }
                  }
               }
            }
         }
      }

      iを増やす
   }

   countが答え
}