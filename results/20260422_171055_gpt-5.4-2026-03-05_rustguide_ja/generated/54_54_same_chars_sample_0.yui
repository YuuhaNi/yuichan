標準ライブラリを使う

same_chars = 入力 s0, s1 に対し {
   chars0 = []
   i = 0
   s0の大きさ回くり返す{
      c = s0[i]
      もしcがchars0のいずれでもないならば{
         chars0にcを追加する
      }
      iを増やす
   }

   chars1 = []
   j = 0
   s1の大きさ回くり返す{
      c = s1[j]
      もしcがchars1のいずれでもないならば{
         chars1にcを追加する
      }
      jを増やす
   }

   k = 0
   chars0の大きさ回くり返す{
      c = chars0[k]
      もしcがchars1のいずれでもないならば{
         偽が答え
      }
      kを増やす
   }

   l = 0
   chars1の大きさ回くり返す{
      c = chars1[l]
      もしcがchars0のいずれでもないならば{
         偽が答え
      }
      lを増やす
   }

   真が答え
}