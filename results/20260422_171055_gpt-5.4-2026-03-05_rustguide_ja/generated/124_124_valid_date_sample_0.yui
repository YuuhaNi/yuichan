標準ライブラリを使う

valid_date = 入力 date に対し {
   もしdateが""ならば{
      偽が答え
   }

   parts = []
   cur = ""
   i = 0

   dateの大きさ回くり返す{
      ch = date[i]

      もしchが"-"[0]ならば{
         partsにcurを追加する
         cur = ""
      }
      そうでなければ{
         curにchを追加する
      }
      iを増やす
   }
   partsにcurを追加する

   もしpartsの大きさが3以外ならば{
      偽が答え
   }

   mm = parts[0]
   dd = parts[1]
   yyyy = parts[2]

   もしmmの大きさが2以外ならば{
      偽が答え
   }
   もしddの大きさが2以外ならば{
      偽が答え
   }
   もしyyyyの大きさが4以外ならば{
      偽が答え
   }

   nums = "0123456789"

   j = 0
   mmの大きさ回くり返す{
      もしmm[j]がnumsのいずれでもないならば{
         偽が答え
      }
      jを増やす
   }

   j = 0
   ddの大きさ回くり返す{
      もしdd[j]がnumsのいずれでもないならば{
         偽が答え
      }
      jを増やす
   }

   j = 0
   yyyyの大きさ回くり返す{
      もしyyyy[j]がnumsのいずれでもないならば{
         偽が答え
      }
      jを増やす
   }

   m = 整数化(mm)
   d = 整数化(dd)

   もしmが1より小さいならば{
      偽が答え
   }
   もしmが12より大きいならば{
      偽が答え
   }

   もしdが1より小さいならば{
      偽が答え
   }

   もしmが2ならば{
      もしdが29より大きいならば{
         偽が答え
      }
      真が答え
   }

   months31 = [1, 3, 5, 7, 8, 10, 12]
   もしmがmonths31のいずれかならば{
      もしdが31より大きいならば{
         偽が答え
      }
      真が答え
   }

   months30 = [4, 6, 9, 11]
   もしmがmonths30のいずれかならば{
      もしdが30より大きいならば{
         偽が答え
      }
      真が答え
   }

   偽が答え
}