標準ライブラリを使う

select_words = 入力 s, n に対し {
   result = []
   word = ""
   count = 0
   i = 0

   vowels = ["a", "e", "i", "o", "u", "A", "E", "I", "O", "U"]

   sの大きさ回くり返す{
      ch = s[i]

      もしchが" "[0]ならば{
         もしwordの大きさが0より大きいならば{
            もしcountがnならば{
               resultにwordを追加する
            }
         }
         word = ""
         count = 0
      }そうでなければ{
         wordにchを追加する
         もしchがvowelsのいずれでもないならば{
            countを増やす
         }
      }

      iを増やす
   }

   もしwordの大きさが0より大きいならば{
      もしcountがnならば{
         resultにwordを追加する
      }
   }

   resultが答え
}