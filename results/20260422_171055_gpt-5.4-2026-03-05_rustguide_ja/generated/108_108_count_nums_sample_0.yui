標準ライブラリを使う

count_nums = 入力 arr に対し {
   count = 0
   i = 0

   arrの大きさ回くり返す{
      n = arr[i]
      s = 文字列化(n)
      j = 0
      total = 0

      sの大きさ回くり返す{
         c = s[j]
         もしcが"-"[0]ならば{
            jを増やす
            c = s[j]
            total = 差(total, 整数化(文字列化(c)))
         }そうでなければ{
            total = 和(total, 整数化(文字列化(c)))
         }
         jを増やす
      }

      もしtotalが0より大きいならば{
         countを増やす
      }
      iを増やす
   }

   countが答え
}