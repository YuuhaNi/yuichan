標準ライブラリを使う

sort_even = 入力 l に対し {
   evens = []
   i = 0
   lの大きさ回くり返す{
      もし剰余(i, 2)が0ならば{
         evensにl[i]を追加する
      }
      iを増やす
   }

   n = evensの大きさ
   n回くり返す{
      j = 0
      もしnが1以下ならば{
         くり返しを抜ける
      }
      差(n, 1)回くり返す{
         もしevens[j]がevens[和(j, 1)]より大きいならば{
            tmp = evens[j]
            evens[j] = evens[和(j, 1)]
            evens[和(j, 1)] = tmp
         }
         jを増やす
      }
      n = 差(n, 1)
   }

   result = []
   i = 0
   e = 0
   lの大きさ回くり返す{
      もし剰余(i, 2)が0ならば{
         resultにevens[e]を追加する
         eを増やす
      }
      そうでなければ{
         resultにl[i]を追加する
      }
      iを増やす
   }

   resultが答え
}