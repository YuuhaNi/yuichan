標準ライブラリを使う

check_dict_case = 入力 dict に対し {
   keys = 配列化(dict)
   もしkeysの大きさが0ならば{
      偽が答え
   }

   i = 0
   has_lower = 偽
   has_upper = 偽

   keysの大きさ回くり返す{
      pair = keys[i]
      key = pair[0]

      もし文字列判定(key)が偽ならば{
         偽が答え
      }

      もしkeyが文字列化(小文字化(key))ならば{
         has_lower = 真
      }そうでなければ{
         もしkeyが文字列化(大文字化(key))ならば{
            has_upper = 真
         }そうでなければ{
            偽が答え
         }
      }

      iを増やす
   }

   もしhas_lowerが真ならば{
      もしhas_upperが偽ならば{
         真が答え
      }
   }

   偽が答え
}