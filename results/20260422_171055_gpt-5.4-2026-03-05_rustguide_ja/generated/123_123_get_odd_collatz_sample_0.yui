標準ライブラリを使う

get_odd_collatz = 入力 n に対し {
   odds = []
   x = n

   もし剰余(x, 2)が1ならば{
      oddsにxを追加する
   }

   n回くり返す{
      もしxが1ならば{
         くり返しを抜ける
      }

      もし剰余(x, 2)が0ならば{
         x = 商(x, 2)
      }
      そうでなければ{
         x = 和(積(x, 3), 1)
      }

      もし剰余(x, 2)が1ならば{
         もしxがoddsのいずれでもないならば{
            oddsにxを追加する
         }
      }
   }

   i = 0
   oddsの大きさ回くり返す{
      j = 0
      oddsの大きさ回くり返す{
         もしjが差(oddsの大きさ, 1)以上ならば{
            くり返しを抜ける
         }
         もしodds[j]がodds[和(j, 1)]より大きいならば{
            temp = odds[j]
            odds[j] = odds[和(j, 1)]
            odds[和(j, 1)] = temp
         }
         jを増やす
      }
      iを増やす
   }

   oddsが答え
}