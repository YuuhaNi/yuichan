標準ライブラリを使う

fix_spaces = 入力 text に対し {
   result = ""
   i = 0

   textの大きさ回くり返す{
      もしtext[i]が" "[0]ならば{
         count = 0
         j = i

         textの大きさ回くり返す{
            もしjがtextの大きさ以上ならば{
               くり返しを抜ける
            }
            もしtext[j]が" "[0]ならば{
               countを増やす
               jを増やす
            }そうでなければ{
               くり返しを抜ける
            }
         }

         もしcountが1ならば{
            resultに"_"[0]を追加する
         }そうでなければ{
            resultに"-"[0]を追加する
         }
         i = j
      }そうでなければ{
         resultにtext[i]を追加する
         iを増やす
      }

      もしiがtextの大きさ以上ならば{
         くり返しを抜ける
      }
   }

   resultが答え
}