標準ライブラリを使う

do_algebra = 入力 operator, operand に対し {
   values = [operand[0]]
   i = 0

   operatorの大きさ回くり返す{
      op = operator[i]
      right = operand[和(i, 1)]

      もしopが"**"ならば{
         left = values[差(valuesの大きさ, 1)]
         values[差(valuesの大きさ, 1)] = leftのright乗
      }そうでなければ{
         もしopが"*"ならば{
            left = values[差(valuesの大きさ, 1)]
            values[差(valuesの大きさ, 1)] = 積(left, right)
         }そうでなければ{
            もしopが"//"ならば{
               left = values[差(valuesの大きさ, 1)]
               values[差(valuesの大きさ, 1)] = 商(left, right)
            }そうでなければ{
               valuesにopを追加する
               valuesにrightを追加する
            }
         }
      }
      iを増やす
   }

   result = values[0]
   i = 1
   商(差(valuesの大きさ, 1), 2)回くり返す{
      op = values[i]
      right = values[和(i, 1)]

      もしopが"+"ならば{
         result = 和(result, right)
      }そうでなければ{
         result = 差(result, right)
      }

      i = 和(i, 2)
   }

   resultが答え
}