標準ライブラリを使う

rounded_avg = 入力 n, m に対し {
   もしnがmより大きいならば{
      -1が答え
   }

   total = 0
   x = n
   和(差(m, n), 1)回くり返す{
      total = 和(total, x)
      xを増やす
   }

   count = 和(差(m, n), 1)
   avg = 商(total, count)
   rem = 剰余(total, count)

   もし積(rem, 2)がcount以上ならば{
      avgを増やす
   }

   bits = []
   value = avg

   もしvalueが0ならば{
      bitsに"0"を追加する
   }そうでなければ{
      digits = []
      value回くり返す{
         もしvalueが0ならば{
            くり返しを抜ける
         }
         もし剰余(value, 2)が0ならば{
            digitsに"0"を追加する
         }そうでなければ{
            digitsに"1"を追加する
         }
         value = 商(value, 2)
      }

      i = 差(digitsの大きさ, 1)
      digitsの大きさ回くり返す{
         bitsにdigits[i]を追加する
         もしiが0ならば{
            くり返しを抜ける
         }
         i = 差(i, 1)
      }
   }

   result = "0b"
   i = 0
   bitsの大きさ回くり返す{
      resultにbits[i]を追加する
      iを増やす
   }

   resultが答え
}