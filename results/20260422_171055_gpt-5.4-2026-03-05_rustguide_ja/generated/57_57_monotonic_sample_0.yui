標準ライブラリを使う

monotonic = 入力 l に対し {
   もしlの大きさが1以下ならば{
      真が答え
   }

   inc = 真
   dec = 真
   i = 1

   差(lの大きさ, 1)回くり返す{
      prev = l[差(i,1)]
      curr = l[i]

      もしcurrがprevより小さいならば{
         inc = 偽
      }
      もしcurrがprevより大きいならば{
         dec = 偽
      }

      iを増やす
   }

   もしincが真ならば{
      真が答え
   }
   そうでなければ{
      decが答え
   }
}