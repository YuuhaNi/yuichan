標準ライブラリを使う

specialFilter = 入力 nums に対し {
   count = 0
   i = 0

   numsの大きさ回くり返す{
      n = nums[i]

      もしnが10より大きいならば{
         last = 剰余(n, 10)

         m = n
         m回くり返す{
            もしmが10より小さいならば{
               くり返しを抜ける
            }
            m = 商(m, 10)
         }

         first = m

         odds = [1, 3, 5, 7, 9]
         もしlastがoddsのいずれかならば{
            もしfirstがoddsのいずれかならば{
               countを増やす
            }
         }
      }

      iを増やす
   }

   countが答え
}