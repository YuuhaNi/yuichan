標準ライブラリを使う

sort_third = 入力 l に対し {
   pos = []
   vals = []
   i = 0

   lの大きさ回くり返す{
      もし剰余(i, 3)が0ならば{
         posにiを追加する
         valsにl[i]を追加する
      }
      iを増やす
   }

   valsの大きさ回くり返す{
      j = 0
      valsの大きさ回くり返す{
         もしjが差(valsの大きさ, 1)以上ならば{
            くり返しを抜ける
         }
         もしvals[j]がvals[和(j, 1)]より大きいならば{
            tmp = vals[j]
            vals[j] = vals[和(j, 1)]
            vals[和(j, 1)] = tmp
         }
         jを増やす
      }
   }

   k = 0
   valsの大きさ回くり返す{
      l[pos[k]] = vals[k]
      kを増やす
   }

   lが答え
}