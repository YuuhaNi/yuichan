標準ライブラリを使う

check_if_last_char_is_a_letter = 入力 txt に対し {
   もしtxtの大きさが0ならば{
      偽が答え
   }

   last = txt[差(txtの大きさ, 1)]

   # 英字かどうか
   lower = "abcdefghijklmnopqrstuvwxyz"
   upper = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
   is_letter = 偽

   もしlastがlowerのいずれかならば{
      is_letter = 真
   }
   もしlastがupperのいずれかならば{
      is_letter = 真
   }

   もしis_letterが偽ならば{
      偽が答え
   }

   # 最後の文字が単語の一部でない <=> 直前がスペース
   もしtxtの大きさが1ならば{
      真が答え
   }

   prev = txt[差(txtの大きさ, 2)]
   もしprevが" "[0]ならば{
      真が答え
   }
   そうでなければ{
      偽が答え
   }
}