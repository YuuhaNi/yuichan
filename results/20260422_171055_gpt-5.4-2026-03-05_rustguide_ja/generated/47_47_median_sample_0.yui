標準ライブラリを使う

median = 入力 l に対し {
   a = l
   n = aの大きさ

   i = 0
   n回くり返す{
      j = 0
      差(n, 1)回くり返す{
         もしa[j]がa[和(j,1)]より大きいならば{
            t = a[j]
            a[j] = a[和(j,1)]
            a[和(j,1)] = t
         }
         jを増やす
      }
      iを増やす
   }

   もし剰余(n, 2)が1ならば{
      a[商(n, 2)]が答え
   }
   そうでなければ{
      和(a[差(商(n, 2), 1)], a[商(n, 2)])が答え
      小数化(商(和(a[差(商(n, 2), 1)], a[商(n, 2)]), 2))が答え
   }
}