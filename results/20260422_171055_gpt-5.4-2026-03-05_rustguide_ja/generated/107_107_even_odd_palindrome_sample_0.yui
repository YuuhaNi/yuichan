標準ライブラリを使う

even_odd_palindrome = 入力 n に対し {
   even = 0
   odd = 0
   i = 0

   n回くり返す{
      iを増やす
      s = 文字列化(i)
      len = sの大きさ
      is_pal = 真
      j = 0

      商(len, 2)回くり返す{
         もしs[j]がs[差(差(len, 1), j)]以外ならば{
            is_pal = 偽
            くり返しを抜ける
         }
         jを増やす
      }

      もしis_palが真ならば{
         もし剰余(i, 2)が0ならば{
            evenを増やす
         }
         そうでなければ{
            oddを増やす
         }
      }
   }

   [even, odd]が答え
}