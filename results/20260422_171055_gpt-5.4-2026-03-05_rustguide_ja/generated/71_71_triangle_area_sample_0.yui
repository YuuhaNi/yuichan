標準ライブラリを使う

triangle_area = 入力 a, b, c に対し {
   もし和(a,b)がcより大きいならば{
      もし和(a,c)がbより大きいならば{
         もし和(b,c)がaより大きいならば{
            s = 商(和(小数化(a), 小数化(b), 小数化(c)), 2)
            area = 平方根(積(s, 差(s,a), 差(s,b), 差(s,c)))
            rounded = 商(整数化(和(積(area, 100), 0.5)), 100)
            roundedが答え
         }
      }
   }
   -1が答え
}