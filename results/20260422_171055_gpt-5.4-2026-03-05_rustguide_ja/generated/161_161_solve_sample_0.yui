標準ライブラリを使う

solve = 入力 s に対し {
   has_alpha = 偽
   i = 0

   sの大きさ回くり返す{
      c = s[i]
      もしcが65以上ならば{
         もしcが90以下ならば{
            has_alpha = 真
            s[i] = 和(c, 32)
         }
      }
      そうでなければ{
         もしcが97以上ならば{
            もしcが122以下ならば{
               has_alpha = 真
               s[i] = 差(c, 32)
            }
         }
      }
      iを増やす
   }

   もしhas_alphaが偽ならば{
      n = sの大きさ
      r = []
      i = 0
      n回くり返す{
         rにs[差(差(n,1),i)]を追加する
         iを増やす
      }
      rが答え
   }

   sが答え
}