標準ライブラリを使う

skjkasdkd = 入力 lst に対し {
   is_prime = 入力 n に対し {
      もしnが2より小さいならば{
         偽が答え
      }
      d = 2
      n回くり返す{
         もし積(d,d)がnより大きいならば{
            くり返しを抜ける
         }
         もし剰余(n,d)が0ならば{
            偽が答え
         }
         dを増やす
      }
      真が答え
   }

   sum_digits = 入力 n に対し {
      total = 0
      もしnが0ならば{
         0が答え
      }
      n回くり返す{
         もしnが0ならば{
            くり返しを抜ける
         }
         total = 和(total, 剰余(n,10))
         n = 商(n,10)
      }
      totalが答え
   }

   max_prime = 0
   i = 0
   lstの大きさ回くり返す{
      x = lst[i]
      もしis_prime(x)が真ならば{
         もしxがmax_primeより大きいならば{
            max_prime = x
         }
      }
      iを増やす
   }

   sum_digits(max_prime)が答え
}