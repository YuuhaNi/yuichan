標準ライブラリを使う

unique = 入力 l に対し {
   result = []
   i = 0

   lの大きさ回くり返す{
      x = l[i]
      もしxがresultのいずれでもないならば{
         resultにxを追加する
      }
      iを増やす
   }

   n = resultの大きさ
   n回くり返す{
      j = 0
      差(n,1)回くり返す{
         もしresult[j]がresult[和(j,1)]より大きいならば{
            tmp = result[j]
            result[j] = result[和(j,1)]
            result[和(j,1)] = tmp
         }
         jを増やす
      }
   }

   resultが答え
}