標準ライブラリを使う

solve = 入力 N に対し {
   s = 文字列化(N)
   i = 0
   sum = 0

   sの大きさ回くり返す{
      sum = 和(sum, 差(s[i], "0"[0]))
      iを増やす
   }

   もしsumが0ならば{
      "0"が答え
   }

   bits = []
   20回くり返す{
      もしsumが0ならば{
         くり返しを抜ける
      }
      bitsに文字列化(剰余(sum, 2))を追加する
      sum = 商(sum, 2)
   }

   ans = ""
   i = 差(bitsの大きさ, 1)
   bitsの大きさ回くり返す{
      ans = "{ans}{bits[i]}"
      もしiが0ならば{
         くり返しを抜ける
      }
      i = 差(i, 1)
   }

   ansが答え
}