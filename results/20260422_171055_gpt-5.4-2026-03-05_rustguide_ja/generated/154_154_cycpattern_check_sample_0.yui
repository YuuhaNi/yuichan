標準ライブラリを使う

cycpattern_check = 入力 a, b に対し {
   n = bの大きさ
   i = 0

   n回くり返す{
      ok = 偽
      j = 0

      aの大きさ回くり返す{
         もし和(j, n)がaの大きさより大きいならば{
            くり返しを抜ける
         }

         same = 真
         k = 0
         n回くり返す{
            もしa[和(j, k)]がb[k]以外ならば{
               same = 偽
               くり返しを抜ける
            }
            kを増やす
         }

         もしsameが真ならば{
            ok = 真
            くり返しを抜ける
         }
         jを増やす
      }

      もしokが真ならば{
         真が答え
      }

      first = b[0]
      j = 0
      差(n,1)回くり返す{
         b[j] = b[和(j,1)]
         jを増やす
      }
      b[差(n,1)] = first

      iを増やす
   }

   偽が答え
}