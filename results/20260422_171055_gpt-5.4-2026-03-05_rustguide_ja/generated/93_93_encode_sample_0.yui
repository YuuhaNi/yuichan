標準ライブラリを使う

encode = 入力 message に対し {
   result = ""
   i = 0

   messageの大きさ回くり返す{
      c = message[i]

      もしcが"a"[0]ならば{
         resultに"c"[0]を追加する
      }そうでなければ{
         もしcが"e"[0]ならば{
            resultに"g"[0]を追加する
         }そうでなければ{
            もしcが"i"[0]ならば{
               resultに"k"[0]を追加する
            }そうでなければ{
               もしcが"o"[0]ならば{
                  resultに"q"[0]を追加する
               }そうでなければ{
                  もしcが"u"[0]ならば{
                     resultに"w"[0]を追加する
                  }そうでなければ{
                     もしcが"A"[0]ならば{
                        resultに"C"[0]を追加する
                     }そうでなければ{
                        もしcが"E"[0]ならば{
                           resultに"G"[0]を追加する
                        }そうでなければ{
                           もしcが"I"[0]ならば{
                              resultに"K"[0]を追加する
                           }そうでなければ{
                              もしcが"O"[0]ならば{
                                 resultに"Q"[0]を追加する
                              }そうでなければ{
                                 もしcが"U"[0]ならば{
                                    resultに"W"[0]を追加する
                                 }そうでなければ{
                                    もしcが"a"[0]より小さいならば{
                                       resultに和(c, 32)を追加する
                                    }そうでなければ{
                                       resultに差(c, 32)を追加する
                                    }
                                 }
                              }
                           }
                        }
                     }
                  }
               }
            }
         }
      }

      iを増やす
   }

   resultが答え
}