標準ライブラリを使う

is_sorted = 入力 lst に対し {
   もしlstの大きさが1以下ならば{
      真が答え
   }

   i = 1
   prev = lst[0]
   dup = 1

   差(lstの大きさ, 1)回くり返す{
      cur = lst[i]

      もしcurがprevより小さいならば{
         偽が答え
      }

      もしcurがprevならば{
         dupを増やす
         もしdupが3以上ならば{
            偽が答え
         }
      }そうでなければ{
         dup = 1
      }

      prev = cur
      iを増やす
   }

   真が答え
}