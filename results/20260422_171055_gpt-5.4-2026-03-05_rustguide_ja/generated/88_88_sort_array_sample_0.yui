標準ライブラリを使う

sort_array = 入力 array に対し {
   result = []
   i = 0
   arrayの大きさ回くり返す{
      resultにarray[i]を追加する
      iを増やす
   }

   n = resultの大きさ
   もしnが0ならば{
      resultが答え
   }

   first = result[0]
   last = result[差(n,1)]
   sum = 和(first, last)

   ascending = 偽
   もし剰余(sum, 2)が1ならば{
      ascending = 真
   }

   i = 0
   n回くり返す{
      j = 0
      差(n, 1)回くり返す{
         left = result[j]
         right = result[和(j,1)]

         もしascendingが真ならば{
            もしleftがrightより大きいならば{
               temp = result[j]
               result[j] = result[和(j,1)]
               result[和(j,1)] = temp
            }
         }そうでなければ{
            もしleftがrightより小さいならば{
               temp = result[j]
               result[j] = result[和(j,1)]
               result[和(j,1)] = temp
            }
         }

         jを増やす
      }
      iを増やす
   }

   resultが答え
}