標準ライブラリを使う

count_up_to = 入力 n に対し {
   result = []
   i = 2

   n回くり返す{
      もしiがn以上ならば{
         くり返しを抜ける
      }

      prime = 真
      d = 2

      i回くり返す{
         もしdがi以上ならば{
            くり返しを抜ける
         }
         もし剰余(i, d)が0ならば{
            prime = 偽
            くり返しを抜ける
         }
         dを増やす
      }

      もしprimeが真ならば{
         resultにiを追加する
      }
      iを増やす
   }

   resultが答え
}