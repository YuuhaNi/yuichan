標準ライブラリを使う

is_multiply_prime = 入力 a に対し {
   もしaが8より小さいならば{
      偽が答え
   }

   p = 2
   100回くり返す{
      もし積(p,p)がaより大きいならば{
         くり返しを抜ける
      }

      もし剰余(a,p)が0ならば{
         q = 商(a,p)

         qが素数か = 真
         もしqが2より小さいならば{
            qが素数か = 偽
         }そうでなければ{
            d = 2
            100回くり返す{
               もし積(d,d)がqより大きいならば{
                  くり返しを抜ける
               }
               もし剰余(q,d)が0ならば{
                  qが素数か = 偽
                  くり返しを抜ける
               }
               dを増やす
            }
         }

         もしqが素数かならば{
            r = p

            rが素数か = 真
            もしrが2より小さいならば{
               rが素数か = 偽
            }そうでなければ{
               e = 2
               100回くり返す{
                  もし積(e,e)がrより大きいならば{
                     くり返しを抜ける
                  }
                  もし剰余(r,e)が0ならば{
                     rが素数か = 偽
                     くり返しを抜ける
                  }
                  eを増やす
               }
            }

            もしrが素数かならば{
               真が答え
            }
         }
      }

      pを増やす
   }

   偽が答え
}