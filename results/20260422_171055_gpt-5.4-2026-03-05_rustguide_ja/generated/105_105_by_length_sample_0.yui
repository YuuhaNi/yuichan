標準ライブラリを使う

by_length = 入力 arr に対し {
   nums = []
   i = 0

   arrの大きさ回くり返す{
      x = arr[i]
      もしxが1以上ならば{
         もしxが9以下ならば{
            numsにxを追加する
         }
      }
      iを増やす
   }

   sorted = []
   n = 9
   9回くり返す{
      i = 0
      numsの大きさ回くり返す{
         もしnums[i]がnならば{
            sortedにnums[i]を追加する
         }
         iを増やす
      }
      nを減らす
   }

   result = []
   i = 0
   sortedの大きさ回くり返す{
      x = sorted[i]
      もしxが1ならば{
         resultに"One"を追加する
      }そうでなければ{
         もしxが2ならば{
            resultに"Two"を追加する
         }そうでなければ{
            もしxが3ならば{
               resultに"Three"を追加する
            }そうでなければ{
               もしxが4ならば{
                  resultに"Four"を追加する
               }そうでなければ{
                  もしxが5ならば{
                     resultに"Five"を追加する
                  }そうでなければ{
                     もしxが6ならば{
                        resultに"Six"を追加する
                     }そうでなければ{
                        もしxが7ならば{
                           resultに"Seven"を追加する
                        }そうでなければ{
                           もしxが8ならば{
                              resultに"Eight"を追加する
                           }そうでなければ{
                              もしxが9ならば{
                                 resultに"Nine"を追加する
                              }
                           }
                        }
                     }
                  }
               }
            }
         }
      }
      iを増やす
   }

   resultが答え
}