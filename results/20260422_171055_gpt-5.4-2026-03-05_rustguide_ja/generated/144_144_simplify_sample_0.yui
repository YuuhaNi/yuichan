標準ライブラリを使う

simplify = 入力 x, n に対し {
   xa = 配列化(x)
   na = 配列化(n)

   xi = 0
   xn = 0
   xd = 0
   part = 0
   xaの大きさ回くり返す{
      もしxa[xi]が47ならば{
         part = 1
      }そうでなければ{
         もしpartが0ならば{
            xn = 和(積(xn, 10), 差(xa[xi], 48))
         }そうでなければ{
            xd = 和(積(xd, 10), 差(xa[xi], 48))
         }
      }
      xiを増やす
   }

   ni = 0
   nn = 0
   nd = 0
   part = 0
   naの大きさ回くり返す{
      もしna[ni]が47ならば{
         part = 1
      }そうでなければ{
         もしpartが0ならば{
            nn = 和(積(nn, 10), 差(na[ni], 48))
         }そうでなければ{
            nd = 和(積(nd, 10), 差(na[ni], 48))
         }
      }
      niを増やす
   }

   num = 積(xn, nn)
   den = 積(xd, nd)

   もし剰余(num, den)が0ならば{
      真が答え
   }
   そうでなければ{
      偽が答え
   }
}