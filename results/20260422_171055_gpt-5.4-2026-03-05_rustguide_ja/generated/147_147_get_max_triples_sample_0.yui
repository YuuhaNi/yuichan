標準ライブラリを使う

get_max_triples = 入力 n に対し {
   A = []
   i = 1
   n回くり返す{
      v = 和(差(積(i,i), i), 1)
      Aにvを追加する
      iを増やす
   }

   R = []
   i = 0
   Aの大きさ回くり返す{
      j = 和(i, 1)
      Aの大きさ回くり返す{
         もしjがAの大きさ以上ならば{
            くり返しを抜ける
         }
         k = 和(j, 1)
         Aの大きさ回くり返す{
            もしkがAの大きさ以上ならば{
               くり返しを抜ける
            }
            s = 和(A[i], A[j], A[k])
            もし剰余(s, 3)が0ならば{
               Rに[A[i], A[j], A[k]]を追加する
            }
            kを増やす
         }
         jを増やす
      }
      iを増やす
   }

   Rが答え
}