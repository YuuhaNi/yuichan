標準ライブラリを使う

separate_paren_groups = 入力 paren_string に対し {
   result = []
   current = ""
   depth = 0
   n = paren_string の大きさ
   i = 0
   n 回くり返す {
      c = paren_string[i]
      
      # 空白は無視
      もし c が " " ならば {
         何もしない
      }
      そうでなければ {
         # 開き括弧
         もし c が "(" ならば {
            current に c を追加する
            depth を増やす
         }
         # 閉じ括弧
         もし c が ")" ならば {
            current に c を追加する
            depth を減らす
            
            # depth が 0 になったら 1 つのグループが完成
            もし depth が 0 ならば {
               result に current を追加する
               current = ""
            }
         }
      }
      
      i を増やす
   }
   
   result が答え
}