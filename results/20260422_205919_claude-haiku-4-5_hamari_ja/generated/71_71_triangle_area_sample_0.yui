標準ライブラリを使う

triangle_area = 入力 a, b, c に対し {
   # 三角形の有効性を確認
   # a + b > c かつ b + c > a かつ c + a > b
   ab_sum = 和(a, b)
   bc_sum = 和(b, c)
   ca_sum = 和(c, a)
   
   valid = 0
   もしab_sumがcより大きいならば {
      もしbc_sumがaより大きいならば {
         もしca_sumがbより大きいならば {
            valid = 1
         }
      }
   }
   
   もしvalidが0ならば {
      -1
   } そうでなければ {
      # ヘロンの公式を使用
      # s = (a + b + c) / 2
      # area = sqrt(s * (s - a) * (s - b) * (s - c))
      
      perimeter = 和(ab_sum, c)
      s = 商(小数化(perimeter), 小数化(2))
      
      s_a = 差(s, 小数化(a))
      s_b = 差(s, 小数化(b))
      s_c = 差(s, 小数化(c))
      
      product = 積(s, 積(s_a, 積(s_b, s_c)))
      area = 平方根(product)
      
      # 小数点以下2桁で四捨五入
      rounded = 四捨五入(積(area, 小数化(100)))
      結果 = 商(rounded, 小数化(100))
      
      結果
   }
}