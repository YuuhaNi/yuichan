標準ライブラリを使う

is_happy = 入力 s に対し {
   len = sの大きさ
   
   もし len が 3 より小さい ならば {
      偽
   }
   
   i = 0
   len_minus_2 = 差(len, 2)
   
   len_minus_2 回くり返す {
      c1 = s[i]
      c2 = s[和(i, 1)]
      c3 = s[和(i, 2)]
      
      もし c1 が c2 ならば {
         偽
      }
      
      もし c2 が c3 ならば {
         偽
      }
      
      もし c1 が c3 ならば {
         偽
      }
      
      i = 和(i, 1)
   }
   
   真
}