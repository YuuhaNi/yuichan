標準ライブラリを使う

change_base = 入力 x, base に対し {
   もしxが0ならば {
      "0"
   }
   そうでなければ {
      result = ""
      もしxが0より大きいならば {
         n = x
         n回くり返す {
            余り = 剰余(n, base)
            result = 文字列(余り) + result
            n = 商(n, base)
            もしnが0ならば {
               くり返しを抜ける
            }
         }
      }
      result
   }
}