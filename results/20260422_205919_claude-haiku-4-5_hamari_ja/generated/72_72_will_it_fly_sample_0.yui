標準ライブラリを使う

will_it_fly = 入力 q, w に対し {
   # バランスが取れているか確認（回文判定）
   balanced = 1
   len = qの大きさ
   half = 商(len, 2)
   
   half回くり返す {
      もしq[i]がq[差(len, 和(i, 1))]ならば {
         # バランスが取れている
      }
      そうでなければ {
         balanced = 0
         くり返しを抜ける
      }
      iを増やす
   }
   
   # 要素の和を計算
   sum = 0
   lenの大きさ回くり返す {
      sum = 和(sum, q[i])
      iを増やす
   }
   
   # バランスが取れていて、かつ合計が最大荷重以下なら True
   もしbalancedが1ならば {
      もしsumがw以下ならば {
         1
      }
      そうでなければ {
         0
      }
   }
   そうでなければ {
      0
   }
}