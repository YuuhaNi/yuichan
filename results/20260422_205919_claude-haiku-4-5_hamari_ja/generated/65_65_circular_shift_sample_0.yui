標準ライブラリを使う

circular_shift = 入力 x, shift に対し {
   s = 文字列化(x)
   len = sの大きさ
   
   もし shift が len より大きい ならば {
      反転s = ""
      i = 差(len, 1)
      もし i が 0 以上 ならば {
         i回くり返す {
            反転s = 文字列連結(反転s, s[i])
            i を減らす
         }
      }
      反転s
   }
   そうでなければ {
      実shift = 剰余(shift, len)
      もし 実shift が 0 ならば {
         s
      }
      そうでなければ {
         開始位置 = 差(len, 実shift)
         後部 = ""
         前部 = ""
         j = 開始位置
         もし j が len より小さい ならば {
            差(len, 開始位置)回くり返す {
               後部 = 文字列連結(後部, s[j])
               j を増やす
            }
         }
         k = 0
         開始位置回くり返す {
            前部 = 文字列連結(前部, s[k])
            k を増やす
         }
         文字列連結(後部, 前部)
      }
   }
}