標準ライブラリを使う

largest_prime_factor = 入力 n に対し {
   largest = 1
   
   # 2で割り切れなくなるまで割る
   もしnが2で割り切れるならば {
      largest = 2
      nを2で割り続ける {
         もしnが2で割り切れるならば {
            n = 商(n, 2)
         } そうでなければ {
            くり返しを抜ける
         }
      }
   }
   
   # 3以上の奇数で試す
   i = 3
   もしiの二乗がnより大きいならば {
      くり返しを抜ける
   }
   
   nより大きくなるまでくり返す {
      もしnがiで割り切れるならば {
         largest = i
         nを割り続ける {
            もしnがiで割り切れるならば {
               n = 商(n, i)
            } そうでなければ {
               くり返しを抜ける
            }
         }
      }
      i = 和(i, 2)
      もしiの二乗がnより大きいならば {
         くり返しを抜ける
      }
   }
   
   # nが1より大きければ、nそのものが素因数
   もしnが1より大きいならば {
      largest = n
   }
   
   largest
}