標準ライブラリを使う

sort_array = 入力 arr に対し {
   # ヘルパー関数：整数の2進数表現における"1"の個数を数える
   count_ones = 入力 n に対し {
      # 負の数の場合は0を返す
      もし n が 0 より小さい ならば {
         0
      } そうでなければ {
         count = 0
         もし n が 0 ならば {
            0
         } そうでなければ {
            n回くり返す {
               もし 剰余(n, 2) が 1 ならば {
                  count を増やす
               }
               n = 商(n, 2)
            }
            count
         }
      }
   }

   # ソート用の比較関数
   # a と b を比較し、ソート順序を決める
   compare = 入力 a, b に対し {
      ones_a = count_ones(a)
      ones_b = count_ones(b)
      
      もし ones_a が ones_b ならば {
         # "1"の個数が同じ場合は10進数で比較
         もし a が b より小さい ならば {
            -1
         } そうでなければ {
            もし a が b より大きい ならば {
               1
            } そうでなければ {
               0
            }
         }
      } そうでなければ {
         # "1"の個数で比較
         もし ones_a が ones_b より小さい ならば {
            -1
         } そうでなければ {
            1
         }
      }
   }

   # バブルソートで配列をソート
   n = arr の大きさ
   n回くり返す {
      i = 0
      差(n, 1)回くり返す {
         もし compare(arr[i], arr[和(i, 1)]) が 1 ならば {
            # スワップ
            temp = arr[i]
            arr[i] = arr[和(i, 1)]
            arr[和(i, 1)] = temp
         }
         i を増やす
      }
   }

   arr
}