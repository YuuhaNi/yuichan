標準ライブラリを使う

count_upper = 入力 s に対し {
   count = 0
   i = 0
   sの大きさ回くり返す {
      もし剰余(i, 2)が0ならば {
         char = s[i]
         もしcharが'A'のいずれかならば {
            countを増やす
         }
         そうでなければ {
            もしcharが'E'のいずれかならば {
               countを増やす
            }
            そうでなければ {
               もしcharが'I'のいずれかならば {
                  countを増やす
               }
               そうでなければ {
                  もしcharが'O'のいずれかならば {
                     countを増やす
                  }
                  そうでなければ {
                     もしcharが'U'のいずれかならば {
                        countを増やす
                     }
                  }
               }
            }
         }
      }
      iを増やす
   }
   count
}