標準ライブラリを使う

make_palindrome = 入力 string に対し {
   length = string の大きさ
   i = 0
   もし length が 0 ならば {
      "はい" が答え
   }
   そうでなければ {
      is_palindrome = 1
      half = 商(length, 2)
      
      half 回くり返す {
         left = string[i]
         right = string[差(length, 和(i, 1))]
         
         もし left が right 以外 ならば {
            is_palindrome = 0
         }
         
         i を増やす
      }
      
      もし is_palindrome が 1 ならば {
         "はい" が答え
      }
      そうでなければ {
         "いいえ" が答え
      }
   }
}