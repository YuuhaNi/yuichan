標準ライブラリを使う

iscube = 入力 a に対し {
   もし a が 0 ならば {
      真
   }
   
   # a の絶対値を取得
   abs_a = a
   もし a が 0 より小さい ならば {
      abs_a = 差(0, a)
   }
   
   # 立方根の整数部を計算（二分探索）
   low = 0
   high = abs_a
   
   # high を調整（大きすぎる場合の最適化）
   もし abs_a が 1000 より大きい ならば {
      high = 1000
   }
   
   result = 偽
   
   高 = 積(high, 2)
   高回くり返す {
      mid = 商(和(low, high), 2)
      cube = 積(積(mid, mid), mid)
      
      もし cube が a ならば {
         result = 真
         くり返しを抜ける
      }
      
      もし cube が a より小さい ならば {
         low = 和(mid, 1)
      }
      そうでなければ {
         もし high が 0 ならば {
            くり返しを抜ける
         }
         high = 差(mid, 1)
      }
   }
   
   result
}