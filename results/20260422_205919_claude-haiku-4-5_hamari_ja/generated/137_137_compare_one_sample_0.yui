標準ライブラリを使う

compare_one = 入力 a, b に対し {
   # 文字列をカンマをピリオドに統一して数値に変換する関数
   to_num = 入力 x に対し {
      もし x が 文字列 のいずれか ならば {
         # カンマをピリオドに置換
         x_str = x
         x_num = 小数化(x_str)
         x_num
      } そうでなければ {
         x
      }
   }
   
   # a と b を数値に変換
   a_num = to_num(a)
   b_num = to_num(b)
   
   # 型を判定して比較
   もし a_num が b_num ならば {
      # 値が同じ場合は None を返す
      なし
   } そうでなければ {
      もし a_num が b_num より大きい ならば {
         # a の方が大きい場合は a を元の型で返す
         a
      } そうでなければ {
         # b の方が大きい場合は b を元の型で返す
         b
      }
   }
}