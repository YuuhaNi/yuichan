標準ライブラリを使う

is_prime = 入力 n に対し {
   もし n が 2 より小さい ならば {
      偽
   }
   もし n が 2 ならば {
      真
   }
   もし 剰余(n, 2) が 0 ならば {
      偽
   }
   
   i = 3
   limit = 商(小数化(n), 小数化(2))
   limit = 積(商(整数化(limit), 1), 1)
   
   くり返す {
      もし 積(i, i) が n より大きい ならば {
         くり返しを抜ける
      }
      もし 剰余(n, i) が 0 ならば {
         偽を返す
      }
      i = 和(i, 2)
   }
   
   真
}