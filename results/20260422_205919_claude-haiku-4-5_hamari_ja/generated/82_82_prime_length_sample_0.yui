標準ライブラリを使う

prime_length = 入力 string に対し {
   len = string の大きさ
   
   もし len が 2 より小さい ならば {
      偽
   }
   
   もし len が 2 ならば {
      真
   }
   
   i = 2
   もし len が 2 より大きい ならば {
      差(len, 1) 回くり返す {
         もし i が i より大きい ならば {
            くり返しを抜ける
         }
         
         もし 剰余(len, i) が 0 ならば {
            偽
         }
         
         i を増やす
      }
      
      真
   }
}