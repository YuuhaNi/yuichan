標準ライブラリを使う

double_the_difference = 入力 lst に対し {
   合計 = 0
   lstの大きさを n とする
   n回くり返す {
      i = 0
      もし i が n より小さい ならば {
         要素 = lst[i]
         
         もし要素 が 0 以上 ならば {
            余り = 剰余(要素, 2)
            もし余り が 1 ならば {
               二乗 = 積(要素, 要素)
               合計 = 和(合計, 二乗)
            }
         }
         
         i = 和(i, 1)
      }
   }
   合計が答え
}