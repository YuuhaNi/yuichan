標準ライブラリを使う

is_nested = 入力 string に対し {
   depth = 0
   max_depth = 0
   
   string の大きさ 回くり返す {
      char = string[i]
      
      もし char が "[" ならば {
         depth を増やす
         もし depth が max_depth より大きい ならば {
            max_depth = depth
         }
      }
      
      もし char が "]" ならば {
         depth を減らす
      }
      
      i を増やす
   }
   
   max_depth が 2 以上 ならば {
      真
   }
   そうでなければ {
      偽
   }
}