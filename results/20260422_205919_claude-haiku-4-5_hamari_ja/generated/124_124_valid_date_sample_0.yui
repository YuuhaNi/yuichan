標準ライブラリを使う

valid_date = 入力 date に対し {
   # 空文字列チェック
   もし date が "" ならば {
      0
   }
   
   # ハイフンの個数をチェック (ハイフンが正確に2個必要)
   hyphen_count = 0
   i = 0
   date_len = date の大きさ
   
   i 回くり返す {
      もし i が date_len より小さい ならば {
         char = date[i]
         もし char が "-" ならば {
            hyphen_count を増やす
         }
         i を増やす
      }
   }
   
   もし hyphen_count が 2 以外 ならば {
      0
   }
   
   # mm-dd-yyyy形式で分割
   parts = date を "-" で分割する
   
   もし parts の大きさ が 3 以外 ならば {
      0
   }
   
   month_str = parts[0]
   day_str = parts[1]
   year_str = parts[2]
   
   # 各部分が数字のみで構成されているかチェック
   month = 0
   day = 0
   year = 0
   
   # 月の検証
   もし month_str の大きさ が 2 ならば {
      month = 数値化(month_str)
   }
   そうでなければ {
      0
   }
   
   # 日の検証
   もし day_str の大きさ が 2 ならば {
      day = 数値化(day_str)
   }
   そうでなければ {
      0
   }
   
   # 年の検証
   もし year_str の大きさ が 4 ならば {
      year = 数値化(year_str)
   }
   そうでなければ {
      0
   }
   
   # 月の範囲チェック (1-12)
   もし month が 1 より小さい ならば {
      0
   }
   もし month が 12 より大きい ならば {
      0
   }
   
   # 日の範囲チェック
   max_day = 31
   
   もし month が 4 ならば {
      max_day = 30
   }
   もし month が 6 ならば {
      max_day = 30
   }
   もし month が 9 ならば {
      max_day = 30
   }
   もし month が 11 ならば {
      max_day = 30
   }
   もし month が 2 ならば {
      max_day = 29
   }
   
   # 日が有効な範囲内か確認
   もし day が 1 より小さい ならば {
      0
   }
   もし day が max_day より大きい ならば {
      0
   }
   
   # すべてのチェックに合格
   1
}