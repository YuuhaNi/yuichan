標準ライブラリを使う

total_match = 入力 lst1, lst2 に対し {
   # lst1 の全文字数を計算
   sum1 = 0
   lst1の大きさ回くり返す {
      i = 反復変数
      s = lst1[i]
      sum1 = 和(sum1, sの大きさ)
   }
   
   # lst2 の全文字数を計算
   sum2 = 0
   lst2の大きさ回くり返す {
      i = 反復変数
      s = lst2[i]
      sum2 = 和(sum2, sの大きさ)
   }
   
   # 文字数が少ないリストを返す
   # 同じ場合は lst1 を返す
   もし sum1 が sum2 以下ならば {
      lst1 が答え
   }
   そうでなければ {
      lst2 が答え
   }
}