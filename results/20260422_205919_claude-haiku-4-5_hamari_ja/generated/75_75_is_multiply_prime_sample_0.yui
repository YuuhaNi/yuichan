標準ライブラリを使う

is_multiply_prime = 入力 a に対し {
   # 素因数分解して、素因数がちょうど3個かチェック
   count = 0
   n = a
   
   # 2で割り切れる限り割る
   もし剰余(n, 2)が0ならば {
      n = 商(n, 2)
      count = 和(count, 1)
      もし剰余(n, 2)が0ならば {
         n = 商(n, 2)
         count = 和(count, 1)
         もし剰余(n, 2)が0ならば {
            n = 商(n, 2)
            count = 和(count, 1)
         }
      }
   }
   
   # 3で割り切れる限り割る
   もし剰余(n, 3)が0ならば {
      n = 商(n, 3)
      count = 和(count, 1)
      もし剰余(n, 3)が0ならば {
         n = 商(n, 3)
         count = 和(count, 1)
         もし剰余(n, 3)が0ならば {
            n = 商(n, 3)
            count = 和(count, 1)
         }
      }
   }
   
   # 5以上の奇数で割り切れる限り割る
   i = 5
   10回くり返す {
      もしiがnより大きいならば {
         くり返しを抜ける
      }
      もし剰余(n, i)が0ならば {
         n = 商(n, i)
         count = 和(count, 1)
         もし剰余(n, i)が0ならば {
            n = 商(n, i)
            count = 和(count, 1)
            もし剰余(n, i)が0ならば {
               n = 商(n, i)
               count = 和(count, 1)
            }
         }
      }
      i = 和(i, 2)
   }
   
   # 最後にnが1なら、素因数がちょうど3個
   もしcountが3ならば {
      nが1
   }
   そうでなければ {
      0
   }
}