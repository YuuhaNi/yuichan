標準ライブラリを使う

any_int = 入力 x, y, z に対し {
   # すべてが整数かチェック
   xが整数か = (xと小数化(x)が等しい)
   yが整数か = (yと小数化(y)が等しい)
   zが整数か = (zと小数化(z)が等しい)
   
   もしxが整数かが0ならば{
      「偽」
   }
   そうでなければ{
      もしyが整数かが0ならば{
         「偽」
      }
      そうでなければ{
         もしzが整数かが0ならば{
            「偽」
         }
         そうでなければ{
            # 3つの条件をチェック: x+y=z または x+z=y または y+z=x
            条件1 = (xと和(y,z)が等しい)
            条件2 = (yと和(x,z)が等しい)
            条件3 = (zと和(x,y)が等しい)
            
            もし条件1が0以外ならば{
               「真」
            }
            そうでなければ{
               もし条件2が0以外ならば{
                  「真」
               }
               そうでなければ{
                  もし条件3が0以外ならば{
                     「真」
                  }
                  そうでなければ{
                     「偽」
                  }
               }
            }
         }
      }
   }
}