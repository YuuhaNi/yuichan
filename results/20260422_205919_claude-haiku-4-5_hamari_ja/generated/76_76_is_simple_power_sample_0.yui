標準ライブラリを使う

is_simple_power = 入力 x, n に対し {
   もし x が 1 ならば {
      1
   }
   そうでなければ {
      もし n が 1 ならば {
         0
      }
      そうでなければ {
         power = 1
         found = 0
         100回くり返す {
            power = 積(power, n)
            もし power が x ならば {
               found = 1
               くり返しを抜ける
            }
            もし power が x より大きい ならば {
               くり返しを抜ける
            }
         }
         found
      }
   }
}