標準ライブラリを使う

same_chars = 入力 s0, s1 に対し {
   # s0 と s1 の文字セットが同じかどうかを判定
   # 各文字列をソートして比較する
   
   s0_len = s0の大きさ
   s1_len = s1の大きさ
   
   # 文字列を配列に変換してソート
   arr0 = []
   i = 0
   s0_lenくり返す {
      arr0に s0[i] を追加する
      i = 和(i, 1)
   }
   
   arr1 = []
   i = 0
   s1_lenくり返す {
      arr1に s1[i] を追加する
      i = 和(i, 1)
   }
   
   # 配列をソート（昇順）
   arr0_sorted = 配列をソートする(arr0)
   arr1_sorted = 配列をソートする(arr1)
   
   # ソート後の文字列を比較
   もし arr0_sorted が arr1_sorted ならば {
      真
   }
   そうでなければ {
      偽
   }
}