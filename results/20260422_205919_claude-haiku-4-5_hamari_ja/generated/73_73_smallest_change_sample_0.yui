標準ライブラリを使う

smallest_change = 入力 arr に対し {
   n = arr の大きさ
   changes = 0
   left = 0
   right = 差(n, 1)
   
   もし n が 0 ならば {
      0 が答え
   }
   
   もし n が 1 ならば {
      0 が答え
   }
   
   そうでなければ {
      n 回くり返す {
         もし left が right 以上 ならば {
            くり返しを抜ける
         }
         
         もし arr[left] が arr[right] 以外 ならば {
            changes を増やす
         }
         
         left を増やす
         right を減らす
      }
      
      changes が答え
   }
}