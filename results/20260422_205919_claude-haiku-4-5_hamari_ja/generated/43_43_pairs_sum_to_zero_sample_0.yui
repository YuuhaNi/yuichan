標準ライブラリを使う

pairs_sum_to_zero = 入力 l に対し {
   n = lの大きさ
   
   もし n が 1 以下 ならば {
      偽
   }
   
   i = 0
   n 回くり返す {
      もし i が n より小さい ならば {
         j = 和(i, 1)
         もし j が n より小さい ならば {
            j 回くり返す {
               もし j が n より小さい ならば {
                  a = l[i]
                  b = l[j]
                  sum = 和(a, b)
                  もし sum が 0 ならば {
                     真
                  }
                  j を増やす
               }
            }
         }
      }
      i を増やす
   }
   
   偽
}