標準ライブラリを使う

triples_sum_to_zero = 入力 l に対し {
   n = lの大きさ
   
   もしnが3より小さいならば{
      偽
   }
   
   i = 0
   n回くり返す{
      もしiがnより小さいならば{
         j = 和(i, 1)
         n回くり返す{
            もしjがnより小さいならば{
               k = 和(j, 1)
               n回くり返す{
                  もしkがnより小さいならば{
                     sum = 和(和(l[i], l[j]), l[k])
                     もしsumが0ならば{
                        真
                     }
                     kを増やす
                  }
               }
               jを増やす
            }
         }
         iを増やす
      }
   }
   
   偽
}