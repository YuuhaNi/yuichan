標準ライブラリを使う

fib4 = 入力 n に対し {
   もし n が 0 ならば {
      0
   }
   もし n が 1 ならば {
      0
   }
   もし n が 2 ならば {
      2
   }
   もし n が 3 ならば {
      0
   }
   
   # n >= 4 の場合、動的計画法で計算
   a = 0
   b = 0
   c = 2
   d = 0
   
   i = 4
   差(n, 3)回くり返す {
      next = 和(和(和(d, c), b), a)
      a = b
      b = c
      c = d
      d = next
      i を増やす
   }
   
   d
}