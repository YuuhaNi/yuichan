標準ライブラリを使う

is_sorted = 入力 lst に対し {
   sz = lst の大きさ
   
   もし sz が 1 以下ならば {
      真
   }
   
   i = 0
   sz回くり返す {
      もし i が 0 ならば {
         i を増やす
         くり返しを続ける
      }
      
      prev = lst[差(i,1)]
      curr = lst[i]
      
      skip = 0
      
      # 昇順チェック: curr > prev であるべき
      もし curr が prev より大きいならば {
         # OK、次へ
      } そうでなければ {
         skip = 1
      }
      
      # 重複チェック: curr = prev なら False
      もし skip が 0 ならば {
         もし curr が prev ならば {
            偽
         }
      }
      
      もし skip が 0 でないならば {
         偽
      }
      
      i を増やす
   }
   
   真
}