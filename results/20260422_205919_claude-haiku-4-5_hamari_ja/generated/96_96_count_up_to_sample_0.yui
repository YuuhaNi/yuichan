標準ライブラリを使う

count_up_to = 入力 n に対し {
   primes = []
   candidate = 2
   
   もし n が 2 より小さい ならば {
      primes
   }
   そうでなければ {
      candidate が n より小さい の間 {
         is_prime = 1
         divisor = 2
         
         divisor が candidate より小さい の間 {
            remainder = 剰余(candidate, divisor)
            もし remainder が 0 ならば {
               is_prime = 0
               くり返しを抜ける
            }
            divisor を増やす
         }
         
         もし is_prime が 1 ならば {
            primes に candidate を追加する
         }
         
         candidate を増やす
      }
      primes
   }
}