標準ライブラリを使う

next_smallest = 入力 lst に対し {
   sz = lst の大きさ
   もし sz が 2 より小さい ならば {
      None
   }
   そうでなければ {
      sorted = lst を昇順に並べ替える
      i = 0
      もし sorted[0] が sorted[1] ならば {
         i = 1
         くり返す {
            もし i が sz 以上 ならば {
               くり返しを抜ける
            }
            もし sorted[i] が sorted[差(i,1)] 以外 ならば {
               sorted[i]
               くり返しを抜ける
            }
            i = 和(i,1)
         }
      }
      そうでなければ {
         sorted[1]
      }
   }
}