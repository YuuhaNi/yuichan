標準ライブラリを使う

right_angle_triangle = 入力 a, b, c に対し {
   # 3辺を昇順にソート
   sides = [a, b, c]
   
   # ピタゴラスの定理を確認: 最小の2辺の二乗の和 = 最大辺の二乗
   # a^2 + b^2 = c^2 かどうかを判定
   
   sq_a = 積(a, a)
   sq_b = 積(b, b)
   sq_c = 積(c, c)
   
   # 3つの組み合わせを確認
   # パターン1: a^2 + b^2 = c^2
   sum1 = 和(sq_a, sq_b)
   もしsum1がsq_cならば {
      真
   }
   
   # パターン2: a^2 + c^2 = b^2
   sum2 = 和(sq_a, sq_c)
   もしsum2がsq_bならば {
      真
   }
   
   # パターン3: b^2 + c^2 = a^2
   sum3 = 和(sq_b, sq_c)
   もしsum3がsq_aならば {
      真
   }
   
   # どれにも当てはまらない
   偽
}