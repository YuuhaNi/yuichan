標準ライブラリを使う

x_or_y = 入力 n, x, y に対し {
   is_prime = 1
   
   もしnが2より小さいならば {
      is_prime = 0
   }
   
   i = 2
   もしnが2より大きいならば {
      商(n, 2)回くり返す {
         もし剰余(n, i)が0ならば {
            is_prime = 0
            くり返しを抜ける
         }
         i = 和(i, 1)
      }
   }
   
   もしis_primeが1ならば {
      x
   }
   そうでなければ {
      y
   }
}