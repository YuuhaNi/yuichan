標準ライブラリを使う

hex_key = 入力 num に対し {
   素数リスト = ["2", "3", "5", "7", "B", "D"]
   カウント = 0
   i = 0
   numの大きさを長さとする
   
   長さ回くり返す {
      現在の文字 = num[i]
      skip = 0
      
      もし現在の文字が"2"のいずれかならば { skip = 1 }
      もし現在の文字が"3"のいずれかならば { skip = 1 }
      もし現在の文字が"5"のいずれかならば { skip = 1 }
      もし現在の文字が"7"のいずれかならば { skip = 1 }
      もし現在の文字が"B"のいずれかならば { skip = 1 }
      もし現在の文字が"D"のいずれかならば { skip = 1 }
      
      もしskipが1ならば {
         カウントを増やす
      }
      
      i = 和(i, 1)
   }
   
   カウント
}