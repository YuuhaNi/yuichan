標準ライブラリを使う

match_parens = 入力 lst に対し {
   a = lst[0]
   b = lst[1]

   check = 入力 s に対し{
      bal = 0
      i = 0
      sの大きさ回くり返す{
         もしs[i]が"("ならば{
            balを増やす
         }そうでなければ{
            balを減らす
         }
         もしbalが0より小さいならば{
            "No"が答え
         }
         iを増やす
      }
      もしbalが0ならば{
         "Yes"が答え
      }そうでなければ{
         "No"が答え
      }
   }

   s1 = ""
   i = 0
   aの大きさ回くり返す{
      s1にa[i]を追加する
      iを増やす
   }
   i = 0
   bの大きさ回くり返す{
      s1にb[i]を追加する
      iを増やす
   }

   もしcheck(s1)が"Yes"ならば{
      "Yes"が答え
   }

   s2 = ""
   i = 0
   bの大きさ回くり返す{
      s2にb[i]を追加する
      iを増やす
   }
   i = 0
   aの大きさ回くり返す{
      s2にa[i]を追加する
      iを増やす
   }

   check(s2)が答え
}