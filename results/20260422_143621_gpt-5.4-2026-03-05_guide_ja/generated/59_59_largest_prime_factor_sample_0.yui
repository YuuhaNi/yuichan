標準ライブラリを使う

largest_prime_factor = 入力 n に対し {
   largest = 1
   d = 2

   n回くり返す{
      もし積(d, d)がnより大きいならば{
         くり返しを抜ける
      }

      もし剰余(n, d)が0ならば{
         largest = d
         n = 商(n, d)
         もし剰余(n, d)が0ならば{
            dを減らす
         }
      }

      dを増やす
   }

   もしnが1より大きいならば{
      largest = n
   }

   largestが答え
}