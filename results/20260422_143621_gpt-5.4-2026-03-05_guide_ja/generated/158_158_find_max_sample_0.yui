標準ライブラリを使う

find_max = 入力 words に対し {
   best = ""
   best_count = -1

   i = 0
   wordsの大きさ回くり返す{
      word = words[i]
      used = []
      count = 0

      j = 0
      wordの大きさ回くり返す{
         ch = word[j]
         もしchがusedのいずれでもないならば{
            usedにchを追加する
            countを増やす
         }
         jを増やす
      }

      もしcountがbest_countより大きいならば{
         best = word
         best_count = count
      }そうでなければ{
         もしcountがbest_countならば{
            もしwordがbestより小さいならば{
               best = word
               best_count = count
            }
         }
      }

      iを増やす
   }

   bestが答え
}