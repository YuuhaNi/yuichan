標準ライブラリを使う

do_algebra = 入力 operator, operand に対し {
   result = operand[0]
   i = 0
   operatorの大きさ回くり返す{
      op = operator[i]
      value = operand[和(i,1)]

      もしopが"+"ならば{
         result = 和(result, value)
      }そうでなければ{
         もしopが"-"ならば{
            result = 差(result, value)
         }そうでなければ{
            もしopが"*"ならば{
               result = 積(result, value)
            }そうでなければ{
               もしopが"//"ならば{
                  result = 商(result, value)
               }そうでなければ{
                  power = 1
                  j = 0
                  value回くり返す{
                     power = 積(power, result)
                     jを増やす
                  }
                  result = power
               }
            }
         }
      }

      iを増やす
   }
   resultが答え
}