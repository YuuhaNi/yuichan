標準ライブラリを使う

count_upper = 入力 s に対し {
   i = 0
   count = 0
   sの大きさ回くり返す{
      もしiがsの大きさ以上ならば{
         くり返しを抜ける
      }
      もしs[i]が"A"[0]のいずれかならば{
         countを増やす
      }
      もしs[i]が"E"[0]のいずれかならば{
         countを増やす
      }
      もしs[i]が"I"[0]のいずれかならば{
         countを増やす
      }
      もしs[i]が"O"[0]のいずれかならば{
         countを増やす
      }
      もしs[i]が"U"[0]のいずれかならば{
         countを増やす
      }
      i = 和(i, 2)
   }
   countが答え
}