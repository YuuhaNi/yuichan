標準ライブラリを使う

valid_date = 入力 date に対し {
   もしdateが""ならば{
      偽が答え
   }

   もしdateの大きさが10以外ならば{
      偽が答え
   }

   もしdate[2]が"-"[0]以外ならば{
      偽が答え
   }

   もしdate[5]が"-"[0]以外ならば{
      偽が答え
   }

   month_text = ""
   month_textにdate[0]を追加する
   month_textにdate[1]を追加する

   day_text = ""
   day_textにdate[3]を追加する
   day_textにdate[4]を追加する

   year_text = ""
   year_textにdate[6]を追加する
   year_textにdate[7]を追加する
   year_textにdate[8]を追加する
   year_textにdate[9]を追加する

   month = 整数化(month_text)
   day = 整数化(day_text)
   year = 整数化(year_text)

   もしmonthが1より小さいならば{
      偽が答え
   }

   もしmonthが12より大きいならば{
      偽が答え
   }

   もしdayが1より小さいならば{
      偽が答え
   }

   もしmonthが2ならば{
      もしdayが29より大きいならば{
         偽が答え
      }
      真が答え
   }

   もしmonthが4ならば{
      もしdayが30より大きいならば{
         偽が答え
      }
      真が答え
   }

   もしmonthが6ならば{
      もしdayが30より大きいならば{
         偽が答え
      }
      真が答え
   }

   もしmonthが9ならば{
      もしdayが30より大きいならば{
         偽が答え
      }
      真が答え
   }

   もしmonthが11ならば{
      もしdayが30より大きいならば{
         偽が答え
      }
      真が答え
   }

   もしdayが31より大きいならば{
      偽が答え
   }

   真が答え
}