標準ライブラリを使う

prod_signs = 入力 arr に対し {
   もしarrの大きさが0ならば{
      値なしが答え
   }

   合計 = 0
   符号積 = 1
   i = 0

   arrの大きさ回くり返す{
      値 = arr[i]
      合計 = 和(合計, 絶対値(値))

      もし値が0ならば{
         符号積 = 0
      }そうでなければ{
         もし値が0より小さいならば{
            符号積 = 積(符号積, -1)
         }
      }

      iを増やす
   }

   積(合計, 符号積)が答え
}