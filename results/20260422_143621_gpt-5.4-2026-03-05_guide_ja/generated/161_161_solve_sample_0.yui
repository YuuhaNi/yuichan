標準ライブラリを使う

solve = 入力 s に対し {
   result = ""
   found = 偽
   i = 0

   sの大きさ回くり返す{
      c = s[i]

      もしcが"a"以上ならば{
         もしcが"z"以下ならば{
            code = 差(c[0], 32)
            resultにcodeを追加する
            found = 真
         }そうでなければ{
            もしcが"A"以上ならば{
               もしcが"Z"以下ならば{
                  code = 和(c[0], 32)
                  resultにcodeを追加する
                  found = 真
               }そうでなければ{
                  resultにc[0]を追加する
               }
            }そうでなければ{
               resultにc[0]を追加する
            }
         }
      }そうでなければ{
         もしcが"A"以上ならば{
            もしcが"Z"以下ならば{
               code = 和(c[0], 32)
               resultにcodeを追加する
               found = 真
            }そうでなければ{
               resultにc[0]を追加する
            }
         }そうでなければ{
            resultにc[0]を追加する
         }
      }

      iを増やす
   }

   もしfoundが偽ならば{
      rev = ""
      i = 差(sの大きさ, 1)
      sの大きさ回くり返す{
         もしiが0より小さいならば{
            くり返しを抜ける
         }
         revにs[i][0]を追加する
         i = 差(i, 1)
      }
      revが答え
   }

   resultが答え
}