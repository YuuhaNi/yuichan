標準ライブラリを使う

vowels_count = 入力 s に対し {
   count = 0
   i = 0
   sの大きさ回くり返す{
      c = s[i]
      もしcが"a"[0]のいずれかならば{
         countを増やす
      }
      もしcが"e"[0]のいずれかならば{
         countを増やす
      }
      もしcが"i"[0]のいずれかならば{
         countを増やす
      }
      もしcが"o"[0]のいずれかならば{
         countを増やす
      }
      もしcが"u"[0]のいずれかならば{
         countを増やす
      }
      iを増やす
   }
   countが答え
}