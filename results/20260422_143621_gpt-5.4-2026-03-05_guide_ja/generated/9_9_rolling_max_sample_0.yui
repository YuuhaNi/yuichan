標準ライブラリを使う

rolling_max = 入力 numbers に対し {
   result = []
   もしnumbersの大きさが0ならば{
      resultが答え
   }

   current = numbers[0]
   resultにcurrentを追加する

   i = 1
   numbersの大きさ回くり返す{
      もしiがnumbersの大きさ以上ならば{
         くり返しを抜ける
      }
      もしnumbers[i]がcurrentより大きいならば{
         current = numbers[i]
      }
      resultにcurrentを追加する
      iを増やす
   }

   resultが答え
}