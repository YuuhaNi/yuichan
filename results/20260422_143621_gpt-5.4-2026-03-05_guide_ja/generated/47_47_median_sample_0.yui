標準ライブラリを使う

median = 入力 l に対し {
   a = []
   i = 0
   lの大きさ回くり返す{
      aにl[i]を追加する
      iを増やす
   }

   i = 0
   aの大きさ回くり返す{
      j = 0
      aの大きさ回くり返す{
         もしjが差(aの大きさ, 1)以上ならば{
            くり返しを抜ける
         }
         もしa[j]がa[和(j, 1)]より大きいならば{
            t = a[j]
            a[j] = a[和(j, 1)]
            a[和(j, 1)] = t
         }
         jを増やす
      }
      iを増やす
   }

   n = aの大きさ
   m = 商(n, 2)

   もし剰余(n, 2)が1ならば{
      a[m]が答え
   }
   そうでなければ{
      商(和(a[差(m, 1)], a[m]), 2.0)が答え
   }
}