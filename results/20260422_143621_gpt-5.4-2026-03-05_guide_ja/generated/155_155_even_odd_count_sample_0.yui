標準ライブラリを使う

even_odd_count = 入力 num に対し {
   s = 文字列化(num)
   even = 0
   odd = 0
   i = 0

   もしs[0]が45ならば{
      iを増やす
   }

   sの大きさ回くり返す{
      もしiがsの大きさ以上ならば{
         くり返しを抜ける
      }

      d = 差(s[i], 48)
      r = 剰余(d, 2)

      もしrが0ならば{
         evenを増やす
      }
      そうでなければ{
         oddを増やす
      }

      iを増やす
   }

   [even, odd]が答え
}