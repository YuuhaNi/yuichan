標準ライブラリを使う

search = 入力 lst に対し {
   counts = {}
   i = 0

   lstの大きさ回くり返す{
      x = lst[i]
      もしxがcountsのいずれかならば{
         counts[x]を増やす
      }
      そうでなければ{
         counts[x] = 1
      }
      iを増やす
   }

   answer = -1
   i = 0
   lstの大きさ回くり返す{
      x = lst[i]
      もしcounts[x]がx以上ならば{
         もしxがanswerより大きいならば{
            answer = x
         }
      }
      iを増やす
   }

   answerが答え
}