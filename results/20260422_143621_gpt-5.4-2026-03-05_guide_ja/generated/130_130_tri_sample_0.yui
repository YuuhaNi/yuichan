標準ライブラリを使う

tri = 入力 n に対し {
   result = [1]
   もしnが0ならば{
      resultが答え
   }

   i = 1
   n回くり返す{
      もし剰余(i, 2)が0ならば{
         resultに和(1, 商(i, 2))を追加する
      }
      そうでなければ{
         もしiが1ならば{
            resultに3を追加する
         }
         そうでなければ{
            x = 和(result[差(i,1)], result[差(i,2)], result[和(i,1)])
            resultにxを追加する
         }
      }
      iを増やす
   }
   resultが答え
}