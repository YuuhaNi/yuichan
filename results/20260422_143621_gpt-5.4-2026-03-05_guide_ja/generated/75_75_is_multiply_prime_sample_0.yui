標準ライブラリを使う

is_multiply_prime = 入力 a に対し {
   もしaが8より小さいならば{
      偽が答え
   }

   p = 2
   a回くり返す{
      もしpがaより大きいならば{
         くり返しを抜ける
      }

      p_is_prime = 真
      もしpが2より大きいならば{
         d = 2
         p回くり返す{
            もしdがp以上ならば{
               くり返しを抜ける
            }
            もし剰余(p, d)が0ならば{
               p_is_prime = 偽
               くり返しを抜ける
            }
            dを増やす
         }
      }

      もしp_is_primeが真ならば{
         q = 2
         a回くり返す{
            もしqがaより大きいならば{
               くり返しを抜ける
            }

            q_is_prime = 真
            もしqが2より大きいならば{
               d = 2
               q回くり返す{
                  もしdがq以上ならば{
                     くり返しを抜ける
                  }
                  もし剰余(q, d)が0ならば{
                     q_is_prime = 偽
                     くり返しを抜ける
                  }
                  dを増やす
               }
            }

            もしq_is_primeが真ならば{
               r = 2
               a回くり返す{
                  もしrがaより大きいならば{
                     くり返しを抜ける
                  }

                  r_is_prime = 真
                  もしrが2より大きいならば{
                     d = 2
                     r回くり返す{
                        もしdがr以上ならば{
                           くり返しを抜ける
                        }
                        もし剰余(r, d)が0ならば{
                           r_is_prime = 偽
                           くり返しを抜ける
                        }
                        dを増やす
                     }
                  }

                  もしr_is_primeが真ならば{
                     もし積(p, q, r)がaならば{
                        真が答え
                     }
                  }
                  rを増やす
               }
            }
            qを増やす
         }
      }
      pを増やす
   }

   偽が答え
}