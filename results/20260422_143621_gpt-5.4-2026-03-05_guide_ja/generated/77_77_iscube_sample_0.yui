標準ライブラリを使う

iscube = 入力 a に対し {
   もしaが0ならば{
      真が答え
   }

   n = 0
   もしaが0より大きいならば{
      n = 0
      a回くり返す{
         v = 積(n, n, n)
         もしvがaならば{
            真が答え
         }
         もしvがaより大きいならば{
            くり返しを抜ける
         }
         nを増やす
      }
      偽が答え
   }

   b = 絶対値(a)
   b回くり返す{
      v = 積(n, n, n)
      もしvがbならば{
         真が答え
      }
      もしvがbより大きいならば{
         くり返しを抜ける
      }
      nを増やす
   }
   偽が答え
}