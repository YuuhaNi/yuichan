標準ライブラリを使う

select_words = 入力 s, n に対し {
   result = []
   word = ""
   count = 0
   i = 0

   sの大きさ回くり返す{
      ch = s[i]

      もしchが" "[0]ならば{
         もしwordの大きさが0より大きいならば{
            もしcountがnならば{
               resultにwordを追加する
            }
         }
         word = ""
         count = 0
      }
      そうでなければ{
         wordにchを追加する

         もしchが"a"[0]ならば{
         }
         そうでなければ{
            もしchが"e"[0]ならば{
            }
            そうでなければ{
               もしchが"i"[0]ならば{
               }
               そうでなければ{
                  もしchが"o"[0]ならば{
                  }
                  そうでなければ{
                     もしchが"u"[0]ならば{
                     }
                     そうでなければ{
                        もしchが"A"[0]ならば{
                        }
                        そうでなければ{
                           もしchが"E"[0]ならば{
                           }
                           そうでなければ{
                              もしchが"I"[0]ならば{
                              }
                              そうでなければ{
                                 もしchが"O"[0]ならば{
                                 }
                                 そうでなければ{
                                    もしchが"U"[0]ならば{
                                    }
                                    そうでなければ{
                                       countを増やす
                                    }
                                 }
                              }
                           }
                        }
                     }
                  }
               }
            }
         }
      }

      iを増やす
   }

   もしwordの大きさが0より大きいならば{
      もしcountがnならば{
         resultにwordを追加する
      }
   }

   resultが答え
}