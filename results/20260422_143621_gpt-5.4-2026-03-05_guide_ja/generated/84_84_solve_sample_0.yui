標準ライブラリを使う

solve = 入力 N に対し {
   n = N
   合計 = 0

   もしnが0ならば{
      合計 = 0
   }
   そうでなければ{
      n回くり返す{
         もしnが0ならば{
            くり返しを抜ける
         }
         合計 = 和(合計, 剰余(n, 10))
         n = 商(n, 10)
      }
   }

   もし合計が0ならば{
      "0"が答え
   }

   bits = []
   x = 合計
   x回くり返す{
      もしxが0ならば{
         くり返しを抜ける
      }
      bitsに文字列化(剰余(x, 2))を追加する
      x = 商(x, 2)
   }

   結果 = ""
   i = 差(bitsの大きさ, 1)
   bitsの大きさ回くり返す{
      もしiが0より小さいならば{
         くり返しを抜ける
      }
      結果 = "{結果}{bits[i]}"
      i = 差(i, 1)
   }

   結果が答え
}