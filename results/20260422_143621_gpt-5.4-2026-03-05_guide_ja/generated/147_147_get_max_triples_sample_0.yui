標準ライブラリを使う

get_max_triples = 入力nに対し{
   a = []
   i = 1
   n回くり返す{
      x = 和(差(積(i, i), i), 1)
      aにxを追加する
      iを増やす
   }

   triples = []
   i = 0
   aの大きさ回くり返す{
      もしiが差(aの大きさ, 2)以上ならば{
         くり返しを抜ける
      }
      j = 和(i, 1)
      aの大きさ回くり返す{
         もしjが差(aの大きさ, 1)以上ならば{
            くり返しを抜ける
         }
         k = 和(j, 1)
         aの大きさ回くり返す{
            もしkがaの大きさ以上ならば{
               くり返しを抜ける
            }
            s = 和(a[i], a[j], a[k])
            もし剰余(s, 3)が0ならば{
               triplesに[a[i], a[j], a[k]]を追加する
            }
            kを増やす
         }
         jを増やす
      }
      iを増やす
   }

   triplesが答え
}