標準ライブラリを使う

triples_sum_to_zero = 入力 l に対し {
   n = lの大きさ

   もしnが3より小さいならば{
      偽が答え
   }

   i = 0
   n回くり返す{
      もしiがn以上ならば{
         くり返しを抜ける
      }

      j = 差(i, -1)
      n回くり返す{
         もしjがn以上ならば{
            くり返しを抜ける
         }

         k = 差(j, -1)
         n回くり返す{
            もしkがn以上ならば{
               くり返しを抜ける
            }

            s = 和(l[i], l[j], l[k])
            もしsが0ならば{
               真が答え
            }

            kを増やす
         }

         jを増やす
      }

      iを増やす
   }

   偽が答え
}