標準ライブラリを使う

count_nums = 入力 arr に対し {
   count = 0
   i = 0

   arrの大きさ回くり返す{
      n = arr[i]
      s = 0

      もしnが0より小さいならば{
         n = 絶対値(n)
         first = 真
         nの大きさ回くり返す{
            d = n[差(nの大きさ, 1)]
            もしfirstが真ならば{
               s = 差(s, d)
               first = 偽
            }そうでなければ{
               s = 和(s, d)
            }
            bits = 0
            j = 0
            nの大きさ回くり返す{
               もしjが0ならば{
               }そうでなければ{
                  bitsにn[j]を追加する
               }
               jを増やす
            }
            n = bits
            もしnが0ならば{
               くり返しを抜ける
            }
         }
      }そうでなければ{
         nの大きさ回くり返す{
            d = n[差(nの大きさ, 1)]
            s = 和(s, d)

            bits = 0
            j = 0
            nの大きさ回くり返す{
               もしjが0ならば{
               }そうでなければ{
                  bitsにn[j]を追加する
               }
               jを増やす
            }
            n = bits
            もしnが0ならば{
               くり返しを抜ける
            }
         }
      }

      もしsが0より大きいならば{
         countを増やす
      }
      iを増やす
   }

   countが答え
}