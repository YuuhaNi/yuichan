標準ライブラリを使う

cycpattern_check = 入力 a, b に対し {
   n = bの大きさ
   i = 0

   n回くり返す{
      ok = 真
      j = 0

      aの大きさ回くり返す{
         もし和(j, n)がaの大きさより大きいならば{
            くり返しを抜ける
         }

         k = 0
         j回くり返す{
            kを増やす
         }

         m = 0
         n回くり返す{
            もしa[和(j, m)]がb[剰余(和(i, m), n)]以外ならば{
               ok = 偽
               くり返しを抜ける
            }
            mを増やす
         }

         もしokが真ならば{
            真が答え
         }

         jを増やす
      }

      iを増やす
   }

   偽が答え
}