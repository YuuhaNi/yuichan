標準ライブラリを使う

same_chars = 入力 s0, s1 に対し {
   seen0 = {}
   seen1 = {}

   i = 0
   s0の大きさ回くり返す{
      ch = s0[i]
      seen0[文字列化(ch)] = 真
      iを増やす
   }

   i = 0
   s1の大きさ回くり返す{
      ch = s1[i]
      seen1[文字列化(ch)] = 真
      iを増やす
   }

   i = 0
   s0の大きさ回くり返す{
      key = 文字列化(s0[i])
      もしseen1[key]が真以外ならば{
         偽が答え
      }
      iを増やす
   }

   i = 0
   s1の大きさ回くり返す{
      key = 文字列化(s1[i])
      もしseen0[key]が真以外ならば{
         偽が答え
      }
      iを増やす
   }

   真が答え
}