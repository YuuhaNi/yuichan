標準ライブラリを使う

words_string = 入力 s に対し {
   結果 = []
   現在 = ""
   i = 0

   sの大きさ回くり返す{
      文字 = s[i]

      もし文字が","[0]ならば{
         もし現在の大きさが0より大きいならば{
            結果に現在を追加する
            現在 = ""
         }
      }そうでなければ{
         もし文字が" "[0]ならば{
            もし現在の大きさが0より大きいならば{
               結果に現在を追加する
               現在 = ""
            }
         }そうでなければ{
            現在に文字を追加する
         }
      }

      iを増やす
   }

   もし現在の大きさが0より大きいならば{
      結果に現在を追加する
   }

   結果が答え
}