標準ライブラリを使う

hex_key = 入力numに対し{
   count = 0
   i = 0
   numの大きさ回くり返す{
      ch = num[i]
      もしchが"2"[0]ならば{
         countを増やす
      }そうでなければ{
         もしchが"3"[0]ならば{
            countを増やす
         }そうでなければ{
            もしchが"5"[0]ならば{
               countを増やす
            }そうでなければ{
               もしchが"7"[0]ならば{
                  countを増やす
               }そうでなければ{
                  もしchが"B"[0]ならば{
                     countを増やす
                  }そうでなければ{
                     もしchが"D"[0]ならば{
                        countを増やす
                     }
                  }
               }
            }
         }
      }
      iを増やす
   }
   countが答え
}