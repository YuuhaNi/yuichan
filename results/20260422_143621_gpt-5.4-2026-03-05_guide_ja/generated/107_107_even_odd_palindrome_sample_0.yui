標準ライブラリを使う

even_odd_palindrome = 入力nに対し{
   偶数 = 0
   奇数 = 0
   i = 1

   n回くり返す{
      s = 文字列化(i)
      左 = 0
      右 = 差(sの大きさ, 1)
      回文 = 真

      sの大きさ回くり返す{
         もし左が右以上ならば{
            くり返しを抜ける
         }
         もしs[左]がs[右]以外ならば{
            回文 = 偽
            くり返しを抜ける
         }
         左を増やす
         右を減らす
      }

      もし回文が真ならば{
         もし剰余(i, 2)が0ならば{
            偶数を増やす
         }
         そうでなければ{
            奇数を増やす
         }
      }

      iを増やす
   }

   [偶数, 奇数]が答え
}