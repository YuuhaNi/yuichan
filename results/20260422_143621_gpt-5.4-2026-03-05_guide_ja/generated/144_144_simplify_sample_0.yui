標準ライブラリを使う

simplify = 入力 x, n に対し {
   i = 0
   xs = ""
   xの大きさ回くり返す{
      もしx[i]が"/"[0]ならば{
         くり返しを抜ける
      }
      xsにx[i]を追加する
      iを増やす
   }
   iを増やす
   xt = ""
   xの大きさ回くり返す{
      もしiがxの大きさ以上ならば{
         くり返しを抜ける
      }
      xtにx[i]を追加する
      iを増やす
   }

   i = 0
   ns = ""
   nの大きさ回くり返す{
      もしn[i]が"/"[0]ならば{
         くり返しを抜ける
      }
      nsにn[i]を追加する
      iを増やす
   }
   iを増やす
   nt = ""
   nの大きさ回くり返す{
      もしiがnの大きさ以上ならば{
         くり返しを抜ける
      }
      ntにn[i]を追加する
      iを増やす
   }

   a = 整数化(xs)
   b = 整数化(xt)
   c = 整数化(ns)
   d = 整数化(nt)

   num = 積(a, c)
   den = 積(b, d)

   もし剰余(num, den)が0ならば{
      真が答え
   }
   そうでなければ{
      偽が答え
   }
}