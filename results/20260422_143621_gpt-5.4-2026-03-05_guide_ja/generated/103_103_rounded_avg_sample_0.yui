標準ライブラリを使う

rounded_avg = 入力 n, m に対し {
   もしnがmより大きいならば{
      -1が答え
   }

   avg = 商(和(n, m), 2)
   もし剰余(和(n, m), 2)が0以外ならば{
      avgを増やす
   }

   bits = ""
   もしavgが0ならば{
      "0b0"が答え
   }

   avg回くり返す{
      もしavgが0ならば{
         くり返しを抜ける
      }
      d = 剰余(avg, 2)
      bits = "{文字列化(d)}{bits}"
      avg = 商(avg, 2)
   }

   "0b{bits}"が答え
}