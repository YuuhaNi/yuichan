標準ライブラリを使う

common = 入力 l1, l2 に対し {
   result = []
   i = 0

   l1の大きさ回くり返す{
      x = l1[i]
      もしxがl2のいずれかならば{
         もしxがresultのいずれでもないならば{
            resultにxを追加する
         }
      }
      iを増やす
   }

   n = resultの大きさ
   i = 0
   n回くり返す{
      j = 0
      差(n, i, 1)回くり返す{
         もしresult[j]がresult[和(j,1)]より大きいならば{
            tmp = result[j]
            result[j] = result[和(j,1)]
            result[和(j,1)] = tmp
         }
         jを増やす
      }
      iを増やす
   }

   resultが答え
}