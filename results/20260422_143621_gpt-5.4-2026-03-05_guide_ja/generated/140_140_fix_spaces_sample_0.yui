標準ライブラリを使う

fix_spaces = 入力 text に対し {
   result = ""
   i = 0

   textの大きさ回くり返す{
      c = text[i]

      もしcが" "[0]ならば{
         count = 0

         textの大きさ回くり返す{
            もしiがtextの大きさ以上ならば{
               くり返しを抜ける
            }
            もしtext[i]が" "[0]以外ならば{
               くり返しを抜ける
            }
            countを増やす
            iを増やす
         }

         もしcountが1ならば{
            resultに"_"[0]を追加する
         }
         そうでなければ{
            resultに"-"[0]を追加する
         }
      }
      そうでなければ{
         resultにcを追加する
         iを増やす
      }
   }

   resultが答え
}