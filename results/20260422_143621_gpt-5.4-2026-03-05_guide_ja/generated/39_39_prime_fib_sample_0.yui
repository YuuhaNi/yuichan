標準ライブラリを使う

prime_fib = 入力 n に対し {
   is_prime = 入力xに対し{
      もしxが2より小さいならば{
         偽が答え
      }
      d = 2
      x回くり返す{
         もしdがx以上ならば{
            くり返しを抜ける
         }
         もし剰余(x, d)が0ならば{
            偽が答え
         }
         dを増やす
      }
      真が答え
   }

   a = 0
   b = 1
   count = 0

   n回くり返す{
   }

   100000回くり返す{
      c = 和(a, b)
      a = b
      b = c

      もしis_prime(b)が真ならば{
         countを増やす
         もしcountがnならば{
            bが答え
         }
      }
   }
}