標準ライブラリを使う

sort_even = 入力 l に対し {
   偶数要素 = []
   i = 0

   lの大きさ回くり返す{
      もし剰余(i, 2)が0ならば{
         偶数要素にl[i]を追加する
      }
      iを増やす
   }

   n = 偶数要素の大きさ
   i = 0
   n回くり返す{
      j = 0
      差(n, i, 1)回くり返す{
         もし偶数要素[j]が偶数要素[和(j,1)]より大きいならば{
            一時 = 偶数要素[j]
            偶数要素[j] = 偶数要素[和(j,1)]
            偶数要素[和(j,1)] = 一時
         }
         jを増やす
      }
      iを増やす
   }

   結果 = []
   偶数位置 = 0
   i = 0
   lの大きさ回くり返す{
      もし剰余(i, 2)が0ならば{
         結果に偶数要素[偶数位置]を追加する
         偶数位置を増やす
      }
      そうでなければ{
         結果にl[i]を追加する
      }
      iを増やす
   }

   結果が答え
}