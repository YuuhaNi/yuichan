標準ライブラリを使う

compare_one = 入力 a, b に対し {
   sa = 文字列化(a)
   sb = 文字列化(b)

   na = sa
   nb = sb

   もし文字列判定(a)が真ならば{
      na = ""
      i = 0
      saの大きさ回くり返す{
         c = sa[i]
         もしcが","ならば{
            naに"."[0]を追加する
         }
         そうでなければ{
            naにcを追加する
         }
         iを増やす
      }
   }

   もし文字列判定(b)が真ならば{
      nb = ""
      i = 0
      sbの大きさ回くり返す{
         c = sb[i]
         もしcが","ならば{
            nbに"."[0]を追加する
         }
         そうでなければ{
            nbにcを追加する
         }
         iを増やす
      }
   }

   va = 小数化(na)
   vb = 小数化(nb)

   もしvaがvbならば{
      値なしが答え
   }
   もしvaがvbより大きいならば{
      aが答え
   }
   bが答え
}