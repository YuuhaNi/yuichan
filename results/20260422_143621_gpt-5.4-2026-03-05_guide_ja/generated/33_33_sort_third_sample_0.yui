標準ライブラリを使う

sort_third = 入力 l に対し {
   thirds = []
   i = 0
   lの大きさ回くり返す{
      もし剰余(i, 3)が0ならば{
         thirdsにl[i]を追加する
      }
      iを増やす
   }

   n = thirdsの大きさ
   i = 0
   n回くり返す{
      j = 0
      差(n, i, 1)回くり返す{
         もしthirds[差(j, -1)]がthirds[j]より小さいならば{
         }
         jを増やす
      }
      iを増やす
   }

   i = 0
   k = 0
   lの大きさ回くり返す{
      もし剰余(i, 3)が0ならば{
         l[i] = thirds[k]
         kを増やす
      }
      iを増やす
   }

   lが答え
}