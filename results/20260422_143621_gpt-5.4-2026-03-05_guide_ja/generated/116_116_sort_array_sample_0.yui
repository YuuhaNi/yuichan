標準ライブラリを使う

sort_array = 入力 arr に対し {
   n = arrの大きさ
   result = []
   i = 0
   n回くり返す{
      resultにarr[i]を追加する
      iを増やす
   }

   count_bits = 入力xに対し{
      y = x
      もしyが0より小さいならば{
         y = 絶対値(y)
      }
      c = 0
      もしyが0ならば{
         0が答え
      }
      yの大きさ回くり返す{
         もしy[c]が1ならば{
            cを増やす
         }
      }
      cが答え
   }

   i = 0
   n回くり返す{
      j = 0
      差(n, i, 1)回くり返す{
         a = result[j]
         b = result[和(j, 1)]
         ca = count_bits(a)
         cb = count_bits(b)

         swap = 偽
         もしcaがcbより大きいならば{
            swap = 真
         }
         そうでなければ{
            もしcaがcbならば{
               もしaがbより大きいならば{
                  swap = 真
               }
            }
         }

         もしswapが真ならば{
            temp = result[j]
            result[j] = result[和(j, 1)]
            result[和(j, 1)] = temp
         }
         jを増やす
      }
      iを増やす
   }

   resultが答え
}