標準ライブラリを使う

encode = 入力 message に対し {
   result = ""
   i = 0

   messageの大きさ回くり返す{
      ch = message[i]
      code = 整数化(ch)

      # 小文字 a-z
      もしcodeが97以上ならば{
         もしcodeが122以下ならば{
            # 母音を2つ前の文字へ
            もしchが"a"ならば{
               ch = "y"
            }
            もしchが"e"ならば{
               ch = "c"
            }
            もしchが"i"ならば{
               ch = "g"
            }
            もしchが"o"ならば{
               ch = "m"
            }
            もしchが"u"ならば{
               ch = "s"
            }

            # 大文字化
            ch = 文字列化(差(整数化(ch), 32))
         }
      }

      # 大文字 A-Z
      もしcodeが65以上ならば{
         もしcodeが90以下ならば{
            # 母音を2つ前の文字へ
            もしchが"A"ならば{
               ch = "Y"
            }
            もしchが"E"ならば{
               ch = "C"
            }
            もしchが"I"ならば{
               ch = "G"
            }
            もしchが"O"ならば{
               ch = "M"
            }
            もしchが"U"ならば{
               ch = "S"
            }

            # 小文字化
            ch = 文字列化(和(整数化(ch), 32))
         }
      }

      resultにch[0]を追加する
      iを増やす
   }

   resultが答え
}