標準ライブラリを使う

fibfib = 入力 n に対し {
   もし n が 0 ならば {
      0 が答え
   }
   そうでなければ {
      もし n が 1 ならば {
         0 が答え
      }
      そうでなければ {
         もし n が 2 ならば {
            1 が答え
         }
         そうでなければ {
            # n >= 3 の場合、動的計画法で計算
            a = 0
            b = 0
            c = 1
            i = 3
            n 回くり返す {
               もし i が n より大きい ならば {
                  くり返しを抜ける
               }
               next = 和(和(a, b), c)
               a = b
               b = c
               c = next
               i を増やす
            }
            c が答え
         }
      }
   }
}