標準ライブラリを使う

prime_fib = 入力 n に対し {
   # 素数判定関数
   is_prime = 入力 num に対し {
      もし num が 2 未満ならば {
         偽が答え
      }
      もし num が 2 ならば {
         真が答え
      }
      もし 剰余(num, 2) が 0 ならば {
         偽が答え
      }
      i = 3
      limit = 整数化(積(小数化(num), 0.5)) を超えない最大整数
      limit より大きい値を limit に設定する
      くり返す {
         もし i が limit より大きいならば {
            くり返しを抜ける
         }
         もし 剰余(num, i) が 0 ならば {
            偽が答え
         }
         i = 和(i, 2)
      }
      真が答え
   }
   
   # フィボナッチ数列を生成しながら素数をカウント
   count = 0
   a = 0
   b = 1
   
   くり返す {
      c = 和(a, b)
      もし is_prime(c) ならば {
         count を増やす
         もし count が n ならば {
            c が答え
         }
      }
      a = b
      b = c
   }
}