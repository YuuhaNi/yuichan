標準ライブラリを使う

generate_integers = 入力 a, b に対し {
   result = []
   
   # a と b の大小を判定して、小さい方を start、大きい方を end にする
   start = a
   end = b
   もし a が b より大きいならば {
      start = b
      end = a
   }
   
   # start から end までループして、偶数を result に追加する
   i = start
   もし i が 剰余(i, 2) と等しいならば {
      何もしない
   }
   そうでなければ {
      i を増やす
   }
   
   # i が偶数になるまで増やす
   もし 剰余(start, 2) が 0 でないならば {
      i = 和(start, 1)
   }
   そうでなければ {
      i = start
   }
   
   # i が end 以下の間、偶数を追加していく
   くり返す {
      もし i が end より大きいならば {
         くり返しを抜ける
      }
      result に i を追加する
      i = 和(i, 2)
   }
   
   result が答え
}