標準ライブラリを使う

triangle_area = 入力 a, b, c に対し {
   # 三角形の有効性を判定: 任意の2辺の和が3辺より大きい
   もし和(a, b)がcより大きいならば {
      もし和(b, c)がaより大きいならば {
         もし和(c, a)がbより大きいならば {
            # 有効な三角形: ヘロンの公式で面積を計算
            s = 積(和(a, b, c), 0.5)
            area = 平方根(積(積(積(差(s, a), 差(s, b)), 差(s, c)), s))
            # 小数点以下2桁で四捨五入
            rounded = 整数化(和(積(area, 100), 0.5))
            結果 = 積(小数化(rounded), 0.01)
            結果が答え
         }
         そうでなければ {
            -1が答え
         }
      }
      そうでなければ {
         -1が答え
      }
   }
   そうでなければ {
      -1が答え
   }
}