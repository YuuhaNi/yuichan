標準ライブラリを使う

triples_sum_to_zero = 入力 l に対し {
   n = lの大きさ
   i = 0
   n回くり返す {
      j = 和(i, 1)
      n回くり返す {
         もし j が n 以上 ならば {
            くり返しを抜ける
         }
         k = 和(j, 1)
         n回くり返す {
            もし k が n 以上 ならば {
               くり返しを抜ける
            }
            sum = 和(l[i], l[j], l[k])
            もし sum が 0 ならば {
               真が答え
            }
            k を増やす
         }
         j を増やす
      }
      i を増やす
   }
   偽が答え
}