標準ライブラリを使う

pairs_sum_to_zero = 入力 l に対し {
   n = lの大きさ
   i = 0
   n回くり返す {
      j = 和(i, 1)
      n回くり返す {
         もし j が n より小さいならば {
            a = l[i]
            b = l[j]
            もし 和(a, b) が 0 ならば {
               真が答え
            }
            j を増やす
         }
         そうでなければ {
            くり返しを抜ける
         }
      }
      i を増やす
   }
   偽が答え
}