標準ライブラリを使う

get_closest_vowel = 入力 word に対し {
   vowels = "aeiouAEIOU"
   n = word の大きさ
   
   # 最後から 2 番目の位置から逆向きに探索
   i = 差(n, 2)
   
   # i が 0 以上 1 以下の間、ループを続ける
   # (最初と最後は除外するため)
   {
      もし i が 0 より小さい ならば {
         くり返しを抜ける
      }
      
      c = word[i]
      left = word[差(i, 1)]
      right = word[和(i, 1)]
      
      # c が母音で、左右が子音かを確認
      もし c が vowels のいずれか ならば {
         # left が子音か確認（母音でない）
         もし left が vowels のいずれでもない ならば {
            # right が子音か確認（母音でない）
            もし right が vowels のいずれでもない ならば {
               c が答え
            }
         }
      }
      
      i を減らす
   }
   
   "" が答え
}