標準ライブラリを使う

same_chars = 入力 s0, s1 に対し {
   # 両方の文字列をソートして比較する
   # 同じ文字セットから構成されていれば、ソート後は同じ文字列になる
   
   # s0 を文字配列に変換してソート
   arr0 = []
   n0 = s0 の大きさ
   i = 0
   n0 回くり返す {
      arr0 に s0[i] を追加する
      i を増やす
   }
   
   # s1 を文字配列に変換してソート
   arr1 = []
   n1 = s1 の大きさ
   i = 0
   n1 回くり返す {
      arr1 に s1[i] を追加する
      i を増やす
   }
   
   # 配列の大きさが異なれば False
   もし n0 が n1 でないならば {
      偽 が答え
   }
   
   # バブルソート (arr0)
   i = 0
   n0 回くり返す {
      j = 0
      差(n0, 1) 回くり返す {
         もし arr0[j] が arr0[和(j, 1)] より大きいならば {
            # スワップ
            tmp = arr0[j]
            arr0[j] = arr0[和(j, 1)]
            arr0[和(j, 1)] = tmp
         }
         j を増やす
      }
      i を増やす
   }
   
   # バブルソート (arr1)
   i = 0
   n1 回くり返す {
      j = 0
      差(n1, 1) 回くり返す {
         もし arr1[j] が arr1[和(j, 1)] より大きいならば {
            # スワップ
            tmp = arr1[j]
            arr1[j] = arr1[和(j, 1)]
            arr1[和(j, 1)] = tmp
         }
         j を増やす
      }
      i を増やす
   }
   
   # ソート後の配列を比較
   i = 0
   n0 回くり返す {
      もし arr0[i] が arr1[i] でないならば {
         偽 が答え
      }
      i を増やす
   }
   
   真 が答え
}