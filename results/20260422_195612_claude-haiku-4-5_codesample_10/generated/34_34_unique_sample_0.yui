標準ライブラリを使う

unique = 入力 l に対し {
   # ユニークな要素を集める
   unique_list = []
   n = lの大きさ
   i = 0
   n回くり返す {
      x = l[i]
      # x が unique_list に含まれていなければ追加
      もし x が unique_list のいずれでもないならば {
         unique_listに x を追加する
      }
      i を増やす
   }
   
   # ソート（バブルソート）
   m = unique_listの大きさ
   i = 0
   m回くり返す {
      j = 0
      差(m, 1)回くり返す {
         a = unique_list[j]
         b = unique_list[差(j, 1)]
         もし a が b より大きいならば {
            # スワップ
            temp = unique_list[j]
            unique_list[j] = unique_list[差(j, 1)]
            unique_list[差(j, 1)] = temp
         }
         j を増やす
      }
      i を増やす
   }
   
   unique_list が答え
}