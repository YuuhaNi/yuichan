標準ライブラリを使う

pluck = 入力 arr に対し {
   # 配列が空の場合は [] を返す
   もし arr の大きさ が 0 ならば {
      []が答え
   }
   
   # 最小偶数値と そのインデックスを探す
   min_even = 値なし
   min_index = 値なし
   n = arr の大きさ
   i = 0
   n 回くり返す {
      val = arr[i]
      # 偶数かどうかを判定 (剰余が 0)
      もし 剰余(val, 2) が 0 ならば {
         # 最初の偶数か、より小さい偶数か、同じ値でより小さいインデックスか
         もし min_even が 値なし ならば {
            min_even = val
            min_index = i
         }
         そうでなければ {
            もし val が min_even より小さい ならば {
               min_even = val
               min_index = i
            }
         }
      }
      i を増やす
   }
   
   # 偶数が見つからなかった場合は [] を返す
   もし min_even が 値なし ならば {
      []が答え
   }
   そうでなければ {
      [min_even, min_index]が答え
   }
}