標準ライブラリを使う

right_angle_triangle = 入力 a, b, c に対し {
   # ピタゴラスの定理: a² + b² = c² を満たすかチェック
   # 3辺のうちどれが斜辺かわからないので、すべての組み合わせをチェック
   
   a2 = 積(a, a)
   b2 = 積(b, b)
   c2 = 積(c, c)
   
   # c が斜辺の場合
   もし和(a2, b2)がc2と等しいならば {
      真が答え
   }
   
   # b が斜辺の場合
   そうでなければ {
      もし和(a2, c2)がb2と等しいならば {
         真が答え
      }
      
      # a が斜辺の場合
      そうでなければ {
         もし和(b2, c2)がa2と等しいならば {
            真が答え
         }
         
         そうでなければ {
            偽が答え
         }
      }
   }
}