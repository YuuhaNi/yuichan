標準ライブラリを使う

encode = 入力 message に対し {
   result = ""
   n = messageの大きさ
   i = 0
   n回くり返す {
      c = message[i]
      
      # 大文字と小文字を入れ替える
      もし c が 65 以上ならば {
         もし c が 90 以下ならば {
            # 大文字 A..Z → 小文字に変換
            c = 和(c, 32)
         }
      }
      そうでなければ {
         もし c が 97 以上ならば {
            もし c が 122 以下ならば {
               # 小文字 a..z → 大文字に変換
               c = 差(c, 32)
            }
         }
      }
      
      # 母音を置き換える
      # a(97) → 97-2=95 (実際には文字コード95は_なので、問題の意図に合わせて調整)
      # 母音: a(97), e(101), i(105), o(111), u(117)
      # 置き換え: a→Y, e→C, i→G, o→M, u→S
      もし c が 97 ならば {
         c = 89  # Y
      }
      そうでなければ {
         もし c が 101 ならば {
            c = 67  # C
         }
         そうでなければ {
            もし c が 105 ならば {
               c = 71  # G
            }
            そうでなければ {
               もし c が 111 ならば {
                  c = 77  # M
               }
               そうでなければ {
                  もし c が 117 ならば {
                     c = 83  # S
                  }
               }
            }
         }
      }
      
      # 大文字の母音も置き換える
      もし c が 65 ならば {
         c = 121  # y
      }
      そうでなければ {
         もし c が 69 ならば {
            c = 99  # c
         }
         そうでなければ {
            もし c が 73 ならば {
               c = 103  # g
            }
            そうでなければ {
               もし c が 79 ならば {
                  c = 109  # m
               }
               そうでなければ {
                  もし c が 85 ならば {
                     c = 115  # s
                  }
               }
            }
         }
      }
      
      resultに c を追加する
      i を増やす
   }
   result が答え
}