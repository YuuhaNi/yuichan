標準ライブラリを使う

count_upper = 入力 s に対し {
   count = 0
   n = sの大きさ
   i = 0
   n回くり返す {
      もし剰余(i,2)が0ならば {
         c = s[i]
         # 大文字の母音: A=65, E=69, I=73, O=79, U=85
         もしcが65ならば {
            countを増やす
         }
         そうでなければ {
            もしcが69ならば {
               countを増やす
            }
            そうでなければ {
               もしcが73ならば {
                  countを増やす
               }
               そうでなければ {
                  もしcが79ならば {
                     countを増やす
                  }
                  そうでなければ {
                     もしcが85ならば {
                        countを増やす
                     }
                  }
               }
            }
         }
      }
      iを増やす
   }
   countが答え
}

# テスト