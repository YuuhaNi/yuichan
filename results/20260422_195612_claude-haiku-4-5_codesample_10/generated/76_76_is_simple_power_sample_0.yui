標準ライブラリを使う

is_simple_power = 入力 x, n に対し {
   もし x が 1 ならば {
      真が答え
   }
   そうでなければ {
      もし n が 1 ならば {
         偽が答え
      }
      そうでなければ {
         current = x
         # current が 1 より大きい間、n で割り続ける
         100回くり返す {
            もし current が 1 ならば {
               くり返しを抜ける
            }
            もし 剰余(current, n) が 0 ならば {
               current = 商(current, n)
            }
            そうでなければ {
               偽が答え
            }
         }
         もし current が 1 ならば {
            真が答え
         }
         そうでなければ {
            偽が答え
         }
      }
   }
}