標準ライブラリを使う

fib4 = 入力 n に対し {
   もし n が 0 ならば {
      0 が答え
   }
   そうでなければ {
      もし n が 1 ならば {
         0 が答え
      }
      そうでなければ {
         もし n が 2 ならば {
            2 が答え
         }
         そうでなければ {
            もし n が 3 ならば {
               0 が答え
            }
            そうでなければ {
               # n >= 4 の場合、ループで計算
               a = 0
               b = 0
               c = 2
               d = 0
               i = 4
               n 回くり返す {
                  もし i が n より大きい ならば {
                     くり返しを抜ける
                  }
                  next = 和(a, b, c, d)
                  a = b
                  b = c
                  c = d
                  d = next
                  i を増やす
               }
               d が答え
            }
         }
      }
   }
}