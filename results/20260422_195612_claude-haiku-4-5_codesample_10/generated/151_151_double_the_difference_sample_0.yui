標準ライブラリを使う

double_the_difference = 入力 lst に対し {
   sum = 0
   n = lst の大きさ
   i = 0
   n 回くり返す {
      num = lst[i]
      # 整数判定: 整数かつ正の数かつ奇数かを確認
      もし 整数判定(num) ならば {
         もし num が 0 より大きい ならば {
            # 奇数判定: 2で割った余りが1なら奇数
            もし 剰余(num, 2) が 1 に等しい ならば {
               sum = 和(sum, 積(num, num))
            }
         }
      }
      i を増やす
   }
   sum が答え
}