標準ライブラリを使う

strange_sort_list = 入力 lst に対し {
   # 空リストの場合はそのまま返す
   もし lst の大きさ が 0 ならば {
      lst が答え
   }
   
   # リストをソート
   sorted = ソート(lst)
   result = []
   
   left = 0
   right = 差(sorted の大きさ, 1)
   
   # left と right が交差するまでループ
   くり返す {
      もし left が right より大きい ならば {
         くり返しを抜ける
      }
      
      # 左端（最小値）を追加
      result に sorted[left] を追加する
      left を増やす
      
      もし left が right より大きい ならば {
         くり返しを抜ける
      }
      
      # 右端（最大値）を追加
      result に sorted[right] を追加する
      right を減らす
   }
   
   result が答え
}