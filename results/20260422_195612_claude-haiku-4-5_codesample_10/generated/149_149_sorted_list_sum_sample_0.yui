標準ライブラリを使う

sorted_list_sum = 入力 lst に対し {
   # ステップ1: 奇数の長さを持つ文字列を削除
   filtered = []
   n = lst の大きさ
   i = 0
   n 回くり返す {
      s = lst[i]
      len = s の大きさ
      # 長さが偶数かどうかを判定 (剰余が 0 なら偶数)
      もし 剰余(len, 2) が 0 ならば {
         filtered に s を追加する
      }
      i を増やす
   }

   # ステップ2: バブルソートで長さ昇順、同じ長さならアルファベット順に並べ替え
   m = filtered の大きさ
   i = 0
   m 回くり返す {
      j = 0
      差(m, 1) 回くり返す {
         s1 = filtered[j]
         s2 = filtered[差(j, 1)]
         len1 = s1 の大きさ
         len2 = s2 の大きさ
         
         # 長さで比較、同じなら文字列で比較
         もし len1 が len2 より大きい ならば {
            # スワップ
            temp = filtered[j]
            filtered[j] = filtered[差(j, 1)]
            filtered[差(j, 1)] = temp
         }
         そうでなければ {
            もし len1 が len2 と等しい ならば {
               もし s1 が s2 より大きい ならば {
                  # スワップ
                  temp = filtered[j]
                  filtered[j] = filtered[差(j, 1)]
                  filtered[差(j, 1)] = temp
               }
            }
         }
         j を増やす
      }
      i を増やす
   }

   filtered が答え
}

# テスト