標準ライブラリを使う

sort_array = 入力 array に対し {
   # 空配列の場合はそのまま返す
   もし array の大きさ が 0 ならば {
      array が答え
   }
   そうでなければ {
      # コピーを作成
      sorted = array
      
      # 最初の要素と最後の要素を取得
      first = array[0]
      last = array[差(array の大きさ, 1)]
      
      # 最初と最後の要素の和を計算
      sum = 和(first, last)
      
      # 和が奇数か偶数かで判定
      もし 剰余(sum, 2) が 0 でないならば {
         # 奇数の場合は昇順でソート
         sorted を昇順ソートする
      }
      そうでなければ {
         # 偶数の場合は降順でソート
         sorted を降順ソートする
      }
      
      sorted が答え
   }
}