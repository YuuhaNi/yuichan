標準ライブラリを使う

fizz_buzz = 入力 n に対し {
   count = 0
   i = 0
   n 回くり返す {
      もし i が 11 で割り切れるならば {
         s = 文字列化(i)
         もし s が "7" を含むならば {
            count を増やす
         }
      }
      そうでなければ {
         もし i が 13 で割り切れるならば {
            s = 文字列化(i)
            もし s が "7" を含むならば {
               count を増やす
            }
         }
      }
      i を増やす
   }
   count が答え
}