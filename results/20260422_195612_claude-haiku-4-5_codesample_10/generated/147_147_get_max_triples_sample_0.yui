標準ライブラリを使う

get_max_triples = 入力 n に対し {
   # 配列 a を作成: a[i] = i*i - i + 1 (i は 1 から n)
   a = []
   i = 1
   n回くり返す {
      val = 差(積(i, i), i)
      val = 和(val, 1)
      aにvalを追加する
      iを増やす
   }
   
   # 三つ組の個数をカウント
   count = 0
   i = 0
   n回くり返す {
      j = 和(i, 1)
      n回くり返す {
         もしjがnより小さいならば {
            k = 和(j, 1)
            n回くり返す {
               もしkがnより小さいならば {
                  # a[i] + a[j] + a[k] が 3 の倍数か判定
                  sum = 和(a[i], a[j])
                  sum = 和(sum, a[k])
                  remainder = 剰余(sum, 3)
                  もしremainder が 0 ならば {
                     countを増やす
                  }
                  kを増やす
               }
               そうでなければ {
                  くり返しを抜ける
               }
            }
            jを増やす
         }
         そうでなければ {
            くり返しを抜ける
         }
      }
      iを増やす
   }
   
   countが答え
}