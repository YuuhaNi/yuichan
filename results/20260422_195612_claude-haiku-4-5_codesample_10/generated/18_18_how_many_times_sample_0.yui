標準ライブラリを使う

how_many_times = 入力 string, substring に対し {
   もし substring の大きさ が 0 ならば {
      0 が答え
   }
   そうでなければ {
      count = 0
      max_i = 差(string の大きさ, substring の大きさ)
      和(max_i, 1) 回くり返す {
         i = 0
         match = 真
         substring の大きさ 回くり返す {
            もし string[和(i, i)] が substring[i] でないならば {
               match = 偽
            }
            i を増やす
         }
         もし match が 真 ならば {
            count を増やす
         }
      }
      count が答え
   }
}
標準ライブラリを使う

how_many_times = 入力 string, substring に対し {
   もし substring の大きさ が 0 ならば {
      0 が答え
   }
   そうでなければ {
      count = 0
      i = 0
      slen = string の大きさ
      sublen = substring の大きさ
      差(slen, sublen) を増やす 回くり返す {
         match = 真
         j = 0
         sublen 回くり返す {
            もし string[和(i, j)] が substring[j] でないならば {
               match = 偽
            }
            j を増やす
         }
         もし match が 真 ならば {
            count を増やす
         }
         i を増やす
      }
      count が答え
   }
}