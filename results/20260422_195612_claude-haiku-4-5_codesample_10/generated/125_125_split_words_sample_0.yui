標準ライブラリを使う

split_words = 入力 txt に対し {
   # 空白で分割できるか確認
   もし " " が txt に含まれるならば {
      txt を " " で分割したものが答え
   }
   そうでなければ {
      # カンマで分割できるか確認
      もし "," が txt に含まれるならば {
         txt を "," で分割したものが答え
      }
      そうでなければ {
         # アルファベットの奇数順の小文字の数を数える
         count = 0
         n = txt の大きさ
         i = 0
         n 回くり返す {
            c = txt[i]
            # 小文字 a..z の判定
            もし c が 97 以上ならば {
               もし c が 122 以下ならば {
                  # 'a' = 97 なので offset = c - 97
                  offset = 差(c, 97)
                  # offset が奇数かどうか判定 (1, 3, 5, ...)
                  もし 剰余(offset, 2) が 1 と等しいならば {
                     count を増やす
                  }
               }
            }
            i を増やす
         }
         count が答え
      }
   }
}