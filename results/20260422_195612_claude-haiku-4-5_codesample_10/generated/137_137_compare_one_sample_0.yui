標準ライブラリを使う

compare_one = 入力 a, b に対し {
   # a を数値に変換
   a_str = 文字列化(a)
   a_num = 小数化(a_str)
   もし a_num が値なし ならば {
      a_num = 小数化(a_str の "," を "." に置き換える)
   }
   
   # b を数値に変換
   b_str = 文字列化(b)
   b_num = 小数化(b_str)
   もし b_num が値なし ならば {
      b_num = 小数化(b_str の "," を "." に置き換える)
   }
   
   # 値が同じ場合は値なしを返す
   もし a_num が b_num と等しい ならば {
      値なし が答え
   }
   
   # a の方が大きい場合は a を返す
   もし a_num が b_num より大きい ならば {
      a が答え
   }
   
   # b の方が大きい場合は b を返す
   b が答え
}