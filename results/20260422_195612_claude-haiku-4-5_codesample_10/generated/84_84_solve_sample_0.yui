標準ライブラリを使う

solve = 入力 N に対し {
   # N を文字列に変換して、各桁の数字を足す
   s = 文字列化(N)
   digit_sum = 0
   n = sの大きさ
   i = 0
   n回くり返す {
      c = s[i]
      # 文字コード '0'=48 なので、文字コードから 48 を引いて数値に変換
      digit = 差(c, 48)
      digit_sum = 和(digit_sum, digit)
      i を増やす
   }
   
   # digit_sum を 2 進数に変換
   もし digit_sum が 0 ならば {
      "0" が答え
   }
   そうでなければ {
      binary = ""
      n = digit_sum
      100回くり返す {
         もし n が 0 ならば {
            くり返しを抜ける
         }
         remainder = 剰余(n, 2)
         binary に 文字列化(remainder) を追加する
         n = 商(n, 2)
      }
      
      # 逆順にする
      result = ""
      len = binary の大きさ
      i = 0
      len回くり返す {
         result に binary[差(差(len, 1), i)] を追加する
         i を増やす
      }
      result が答え
   }
}