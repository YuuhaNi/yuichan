標準ライブラリを使う

is_prime = 入力 n に対し {
   もし n が 2 より小さいならば {
      偽が答え
   }
   もし n が 2 ならば {
      真が答え
   }
   もし n が 2 で割り切れるならば {
      偽が答え
   }
   
   i = 3
   limit = 整数化(平方根(n)) + 1
   
   limit 回くり返す {
      もし i が limit より大きいならば {
         くり返しを抜ける
      }
      もし n が i で割り切れるならば {
         偽が答え
      }
      i = 和(i, 2)
   }
   
   真が答え
}