標準ライブラリを使う

check_dict_case = 入力 dict に対し {
   keys = dict の キー
   n = keys の 大きさ
   
   # 空の辞書の場合は False を返す
   もし n が 0 ならば {
      偽が答え
   }
   
   # すべてのキーが文字列かどうかを確認
   i = 0
   n 回 くり返す {
      key = keys[i]
      もし 文字列判定(key) が 偽 ならば {
         偽が答え
      }
      i を増やす
   }
   
   # すべてのキーが小文字か大文字かを判定
   # 最初のキーで判定方向を決める
   first_key = keys[0]
   is_lowercase = 真
   
   i = 0
   n 回 くり返す {
      key = keys[i]
      
      # キーの各文字をチェック
      m = key の 大きさ
      j = 0
      m 回 くり返す {
         c = key[j]
         # 大文字 A..Z (65..90)
         もし c が 65 以上 ならば {
            もし c が 90 以下 ならば {
               is_lowercase = 偽
            }
         }
         j を増やす
      }
      i を増やす
   }
   
   # すべてのキーが大文字であるかを確認
   is_uppercase = 真
   i = 0
   n 回 くり返す {
      key = keys[i]
      m = key の 大きさ
      j = 0
      m 回 くり返す {
         c = key[j]
         # 小文字 a..z (97..122)
         もし c が 97 以上 ならば {
            もし c が 122 以下 ならば {
               is_uppercase = 偽
            }
         }
         j を増やす
      }
      i を増やす
   }
   
   # すべてが小文字なら True、すべてが大文字なら True、それ以外は False
   もし is_lowercase が 真 ならば {
      真が答え
   }
   そうでなければ {
      もし is_uppercase が 真 ならば {
         真が答え
      }
      そうでなければ {
         偽が答え
      }
   }
}