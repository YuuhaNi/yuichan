標準ライブラリを使う

fix_spaces = 入力 text に対し {
   result = ""
   n = text の大きさ
   i = 0
   
   n 回くり返す {
      c = text[i]
      
      # 空白文字かどうかを判定 (空白のコード値は 32)
      もし c が 32 ならば {
         # 連続した空白の開始位置
         space_count = 1
         j = 和(i, 1)
         
         # 連続した空白の個数を数える
         n 回くり返す {
            もし j が n 以上 ならば {
               くり返しを抜ける
            }
            もし text[j] が 32 ならば {
               space_count を増やす
               j を増やす
            }
            そうでなければ {
               くり返しを抜ける
            }
         }
         
         # 連続した空白が 2 個以上なら - に、そうでなければ _ に置換
         もし space_count が 2 以上 ならば {
            result に 45 を追加する
         }
         そうでなければ {
            result に 95 を追加する
         }
         
         # i をスキップ
         i = 差(j, 1)
      }
      そうでなければ {
         result に c を追加する
      }
      
      i を増やす
   }
   
   result が答え
}