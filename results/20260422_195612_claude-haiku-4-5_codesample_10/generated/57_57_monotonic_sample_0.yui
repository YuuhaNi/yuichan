標準ライブラリを使う

monotonic = 入力 l に対し {
   n = l の大きさ
   もし n が 1 以下ならば {
      真が答え
   }
   
   # 単調増加か単調減少かを判定するため、最初と最後の要素を比較
   increasing = 真
   decreasing = 真
   
   i = 0
   差(n, 1) 回くり返す {
      current = l[i]
      next = l[和(i, 1)]
      
      # 単調増加をチェック
      もし current が next より大きいならば {
         increasing = 偽
      }
      
      # 単調減少をチェック
      もし current が next より小さいならば {
         decreasing = 偽
      }
      
      i を増やす
   }
   
   もし increasing が真 または decreasing が真 ならば {
      真が答え
   }
   そうでなければ {
      偽が答え
   }
}