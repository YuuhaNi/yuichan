標準ライブラリを使う

fruit_distribution = 入力 s, n に対し {
   # 文字列から数字を抽出する
   # "5 apples and 6 oranges" → apples の前の数字と oranges の前の数字を取得
   
   # スペースで分割
   parts = sを" "で分割する
   
   # parts[0] がリンゴの数
   apples = 整数化(parts[0])
   
   # parts[3] がオレンジの数 ("5 apples and 6 oranges" の場合、parts[3] = "6")
   oranges = 整数化(parts[3])
   
   # マンゴーの数 = 総数 - リンゴ - オレンジ
   mangoes = 差(n, 和(apples, oranges))
   
   mangoesが答え
}