標準ライブラリを使う

is_multiply_prime = 入力 a に対し {
   # a を素因数分解して、ちょうど 3 つの素数の積かを判定する
   # 素因数の個数をカウント
   factor_count = 0
   n = a
   
   # 2 で割り切れる限り割る
   0回くり返す {
      もし n が 2 で割り切れるならば {
         n = 商(n, 2)
         factor_count を増やす
      }
      そうでなければ {
         くり返しを抜ける
      }
   }
   
   # 3 以上の奇数で割り切れる限り割る
   d = 3
   100回くり返す {
      もし d が n より大きいならば {
         くり返しを抜ける
      }
      0回くり返す {
         もし n が d で割り切れるならば {
            n = 商(n, d)
            factor_count を増やす
         }
         そうでなければ {
            くり返しを抜ける
         }
      }
      d = 和(d, 2)
   }
   
   # n が 1 より大きければ、n 自身が素因数
   もし n が 1 より大きいならば {
      factor_count を増やす
   }
   
   # ちょうど 3 つの素因数があれば真
   もし factor_count が 3 ならば {
      真が答え
   }
   そうでなければ {
      偽が答え
   }
}