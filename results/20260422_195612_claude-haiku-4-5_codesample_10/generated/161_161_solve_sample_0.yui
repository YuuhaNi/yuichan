標準ライブラリを使う

solve = 入力 s に対し {
   # アルファベットが含まれているかチェック
   has_alpha = 偽
   n = sの大きさ
   i = 0
   n回くり返す {
      c = s[i]
      # 大文字 A..Z (65..90) または小文字 a..z (97..122)
      もし(cが65以上ならば{cが90以下})そうでなければ{cが97以上ならば{cが122以下}}ならば {
         has_alpha = 真
      }
      iを増やす
   }
   
   # アルファベットが一つも含まれていない場合は逆順にする
   もし has_alpha が 偽 ならば {
      result = ""
      i = 差(n, 1)
      n回くり返す {
         もし i が 0 以上 ならば {
            result に s[i] を追加する
            i を減らす
         }
      }
      result が答え
   }
   
   # アルファベットが含まれている場合は大文字小文字を反転
   result = ""
   i = 0
   n回くり返す {
      c = s[i]
      nc = c
      # 大文字 A..Z
      もし c が 65 以上 ならば {
         もし c が 90 以下 ならば {
            nc = 和(差(c, 65), 97)
         }
      }
      # 小文字 a..z
      もし c が 97 以上 ならば {
         もし c が 122 以下 ならば {
            nc = 差(c, 32)
         }
      }
      result に nc を追加する
      i を増やす
   }
   result が答え
}