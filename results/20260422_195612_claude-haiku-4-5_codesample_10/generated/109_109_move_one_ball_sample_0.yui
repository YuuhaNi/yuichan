標準ライブラリを使う

move_one_ball = 入力 arr に対し {
   # 空の配列の場合は True を返す
   もし arr の大きさ が 0 ならば {
      真が答え
   }

   # 配列の大きさを取得
   n = arr の大きさ

   # 最大 n 回の右シフト操作を試す
   i = 0
   n 回くり返す {
      # 現在の配列がソート済みかチェック
      is_sorted = 真
      j = 0
      差(n, 1) 回くり返す {
         もし arr[j] が arr[和(j, 1)] より大きい ならば {
            is_sorted = 偽
            くり返しを抜ける
         }
         j を増やす
      }

      # ソート済みなら True を返す
      もし is_sorted が 真 ならば {
         真が答え
      }

      # 右シフト操作を実行
      もし i が差(n, 1) より小さい ならば {
         last = arr[差(n, 1)]
         j = 差(n, 1)
         1 回くり返す {
            k = 0
            差(n, 1) 回くり返す {
               arr[差(n, 1, k)] = arr[差(n, 2, k)]
               k を増やす
            }
         }
         arr[0] = last
      }

      i を増やす
   }

   # どの右シフト操作でもソートできなかった場合は False を返す
   偽が答え
}
標準ライブラリを使う

move_one_ball = 入力 arr に対し {
   # 空の配列の場合は True を返す
   もし arr の大きさ が 0 ならば {
      真が答え
   }

   n = arr の大きさ

   # 最大 n 回の右シフト操作を試す
   i = 0
   n 回くり返す {
      # 現在の配列がソート済みかチェック
      is_sorted = 真
      j = 0
      差(n, 1) 回くり返す {
         もし arr[j] が arr[和(j, 1)] より大きい ならば {
            is_sorted = 偽
            くり返しを抜ける
         }
         j を増やす
      }

      もし is_sorted が 真 ならば {
         真が答え
      }

      # 右シフト操作：最後の要素を先頭に移動
      last = arr[差(n, 1)]
      j = 差(n, 1)
      差(n, 1) 回くり返す {
         arr[j] = arr[差(j, 1)]
         j を減らす
      }
      arr[0] = last

      i を増やす
   }

   偽が答え
}