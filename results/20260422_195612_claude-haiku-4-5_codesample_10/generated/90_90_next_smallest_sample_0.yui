標準ライブラリを使う

next_smallest = 入力 lst に対し {
   n = lstの大きさ
   もし n が 2 より小さいならば {
      値なし が答え
   }
   
   # 最小値と2番目に小さい値を追跡する
   min1 = lst[0]
   min2 = 値なし
   
   i = 1
   n 回くり返す {
      x = lst[i]
      
      もし x が min1 より小さいならば {
         # x が最小値より小さい場合、現在の min1 が min2 になる
         min2 = min1
         min1 = x
      }
      そうでなければ {
         # x が min1 と異なり、min2 がまだ設定されていないか x が min2 より小さい場合
         もし x が min1 と異なるならば {
            もし min2 が 値なし ならば {
               min2 = x
            }
            そうでなければ {
               もし x が min2 より小さいならば {
                  min2 = x
               }
            }
         }
      }
      
      i を増やす
   }
   
   min2 が答え
}