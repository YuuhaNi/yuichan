標準ライブラリを使う

get_odd_collatz = 入力 n に対し {
   odds = []
   current = n
   
   # コラッツ数列を生成して奇数を集める
   くり返す {
      # 現在の値が奇数なら odds に追加
      もし剰余(current, 2)が1ならば {
         odds に current を追加する
      }
      
      # current が 1 に達したら終了
      もし current が 1 ならば {
         くり返しを抜ける
      }
      
      # 次の項を計算
      もし剰余(current, 2)が0ならば {
         # 偶数: 2で割る
         current = 商(current, 2)
      }
      そうでなければ {
         # 奇数: 3倍+1
         current = 和(積(current, 3), 1)
      }
   }
   
   # ソート（昇順）
   # 簡易的なバブルソート
   len = odds の大きさ
   i = 0
   len 回くり返す {
      j = 0
      差(len, 1) 回くり返す {
         もし odds[j] が odds[和(j, 1)] より大きいならば {
            # スワップ
            temp = odds[j]
            odds[j] = odds[和(j, 1)]
            odds[和(j, 1)] = temp
         }
         j を増やす
      }
      i を増やす
   }
   
   odds が答え
}