標準ライブラリを使う

common = 入力 l1, l2 に対し {
   # l1 と l2 の共通要素を見つける
   result = []
   seen = []
   
   # l1 の各要素について
   n1 = l1の大きさ
   i = 0
   n1回くり返す {
      x = l1[i]
      # x が l2 に含まれているか確認
      もし x が l2 のいずれか ならば {
         # まだ result に追加されていないか確認
         もし x が seen のいずれでもない ならば {
            result に x を追加する
            seen に x を追加する
         }
      }
      i を増やす
   }
   
   # result をソート
   result を昇順ソートする
   
   result が答え
}