標準ライブラリを使う

is_happy = 入力 s に対し {
   # 文字列の長さが3未満なら False
   もし s の大きさ が 3 より小さい ならば {
      偽 が答え
   }
   
   # 連続する3文字をチェック
   n = s の大きさ
   i = 0
   差(n, 2) 回 くり返す {
      c1 = s[i]
      c2 = s[和(i, 1)]
      c3 = s[和(i, 2)]
      
      # 3文字が全て異なるかチェック
      もし c1 が c2 と等しい ならば {
         偽 が答え
      }
      もし c2 が c3 と等しい ならば {
         偽 が答え
      }
      もし c1 が c3 と等しい ならば {
         偽 が答え
      }
      
      i を増やす
   }
   
   # すべてのチェックを通過したら True
   真 が答え
}