標準ライブラリを使う

decode_cyclic = 入力 s に対し {
   result = ""
   n = s の大きさ
   i = 0
   n 回くり返す {
      c = s[i]
      # 3文字ごとに循環させるので、位置を3で割った余りで判定
      pos = 剰余(i, 3)
      もし pos が 0 ならば {
         # 位置 0: 1文字進める
         nc = 和(c, 1)
      }
      そうでなければ {
         もし pos が 1 ならば {
            # 位置 1: 2文字進める
            nc = 和(c, 2)
         }
         そうでなければ {
            # 位置 2: 3文字進める
            nc = 和(c, 3)
         }
      }
      result に nc を追加する
      i を増やす
   }
   result が答え
}