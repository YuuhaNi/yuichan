標準ライブラリを使う

prime_length = 入力 string に対し {
   n = string の大きさ
   
   # 2 未満は素数ではない
   もし n が 2 より小さいならば {
      偽が答え
   }
   
   # 2 は素数
   もし n が 2 ならば {
      真が答え
   }
   
   # 偶数は素数ではない
   もし 剰余(n, 2) が 0 ならば {
      偽が答え
   }
   
   # 3 以上の奇数で割り切れるかチェック
   i = 3
   limit = 整数化(積(n, 0.5)) + 1
   
   limit 回くり返す {
      もし i が limit より大きいならば {
         くり返しを抜ける
      }
      
      もし 剰余(n, i) が 0 ならば {
         偽が答え
      }
      
      i = 和(i, 2)
   }
   
   真が答え
}