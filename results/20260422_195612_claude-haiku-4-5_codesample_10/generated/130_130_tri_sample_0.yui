標準ライブラリを使う

tri = 入力 n に対し {
   # メモ化用のオブジェクト
   memo = {}
   
   # トリボナッチ数を計算する内部関数
   calc = 入力 k に対し {
      # メモに存在すれば返す
      もし memo に k が含まれるならば {
         memo[k] が答え
      }
      
      # 基本ケース: k = 1
      もし k が 1 ならば {
         memo[k] = 3
         3 が答え
      }
      
      # k が偶数の場合
      もし 剰余(k, 2) が 0 ならば {
         result = 和(1, 商(k, 2))
         memo[k] = result
         result が答え
      }
      
      # k が奇数の場合 (k > 1)
      そうでなければ {
         a = calc(差(k, 1))
         b = calc(k)
         c = calc(和(k, 1))
         result = 和(a, 和(b, c))
         memo[k] = result
         result が答え
      }
   }
   
   # 最初の n+1 個の値をリストに格納
   result = []
   i = 1
   n を増やす
   n 回くり返す {
      result に calc(i) を追加する
      i を増やす
   }
   
   result が答え
}