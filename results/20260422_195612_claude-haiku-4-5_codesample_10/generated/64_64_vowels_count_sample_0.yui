標準ライブラリを使う

# 文字列内の母音の個数を数える関数
vowels_count = 入力 s に対し {
   count = 0
   n = s の大きさ
   i = 0
   n 回くり返す {
      c = s[i]
      もし c が "a" ならば {
         count を増やす
      }
      そうでなければ {
         もし c が "e" ならば {
            count を増やす
         }
         そうでなければ {
            もし c が "i" ならば {
               count を増やす
            }
            そうでなければ {
               もし c が "o" ならば {
                  count を増やす
               }
               そうでなければ {
                  もし c が "u" ならば {
                     count を増やす
                  }
               }
            }
         }
      }
      i を増やす
   }
   count が答え
}

# テスト: 基本ケース