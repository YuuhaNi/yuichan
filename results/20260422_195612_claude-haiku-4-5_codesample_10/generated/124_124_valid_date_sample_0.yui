標準ライブラリを使う

valid_date = 入力 date に対し {
   # 空文字列チェック
   もし date が "" ならば {
      偽が答え
   }
   
   # ハイフンの個数をチェック (ハイフンが正確に2個必要)
   hyphen_count = 0
   n = date の大きさ
   i = 0
   n 回くり返す {
      c = date[i]
      もし c が 45 ならば {  # ハイフンのコード値は 45
         hyphen_count を増やす
      }
      i を増やす
   }
   
   もし hyphen_count が 2 でないならば {
      偽が答え
   }
   
   # mm-dd-yyyy 形式で分割
   parts = date を "-" で分割する
   
   もし parts の大きさ が 3 でないならば {
      偽が答え
   }
   
   month_str = parts[0]
   day_str = parts[1]
   year_str = parts[2]
   
   # 各部分が数字のみで構成されているかチェック
   もし month_str の大きさ が 2 でないならば {
      偽が答え
   }
   もし day_str の大きさ が 2 でないならば {
      偽が答え
   }
   もし year_str の大きさ が 4 でないならば {
      偽が答え
   }
   
   # 文字列を数値に変換
   month = 整数化(month_str)
   day = 整数化(day_str)
   year = 整数化(year_str)
   
   # 月の範囲チェック
   もし month が 1 未満ならば {
      偽が答え
   }
   もし month が 12 より大きいならば {
      偽が答え
   }
   
   # 日の範囲チェック (月ごとの最大日数)
   max_day = 0
   
   もし month が 1 ならば {
      max_day = 31
   }
   そうでなければ {
      もし month が 2 ならば {
         max_day = 29
      }
      そうでなければ {
         もし month が 3 ならば {
            max_day = 31
         }
         そうでなければ {
            もし month が 4 ならば {
               max_day = 30
            }
            そうでなければ {
               もし month が 5 ならば {
                  max_day = 31
               }
               そうでなければ {
                  もし month が 6 ならば {
                     max_day = 30
                  }
                  そうでなければ {
                     もし month が 7 ならば {
                        max_day = 31
                     }
                     そうでなければ {
                        もし month が 8 ならば {
                           max_day = 31
                        }
                        そうでなければ {
                           もし month が 9 ならば {
                              max_day = 30
                           }
                           そうでなければ {
                              もし month が 10 ならば {
                                 max_day = 31
                              }
                              そうでなければ {
                                 もし month が 11 ならば {
                                    max_day = 30
                                 }
                                 そうでなければ {
                                    もし month が 12 ならば {
                                       max_day = 31
                                    }
                                 }
                              }
                           }
                        }
                     }
                  }
               }
            }
         }
      }
   }
   
   # 日の範囲チェック
   もし day が 1 未満ならば {
      偽が答え
   }
   もし day が max_day より大きいならば {
      偽が答え
   }
   
   # すべてのチェックに合格
   真が答え
}