標準ライブラリを使う

flip_case = 入力 string に対し {
   result = ""
   n = stringの大きさ
   i = 0
   n回くり返す {
      c = string[i]
      # 大文字 A..Z (65..90)
      もし c が 65 以上 ならば {
         もし c が 90 以下 ならば {
            result に 和(c, 32) を追加する
            i を増やす
            くり返しを続ける
         }
      }
      # 小文字 a..z (97..122)
      もし c が 97 以上 ならば {
         もし c が 122 以下 ならば {
            result に 差(c, 32) を追加する
            i を増やす
            くり返しを続ける
         }
      }
      # アルファベット以外はそのまま
      result に c を追加する
      i を増やす
   }
   result が答え
}