標準ライブラリを使う

will_it_fly = 入力 q, w に対し {
   # 要素の合計を計算
   total = 0
   n = qの大きさ
   i = 0
   n回くり返す {
      total = 和(total, q[i])
      i を増やす
   }
   
   # 合計が最大荷重を超えていたら False
   もし total が w より大きい ならば {
      偽が答え
   }
   
   # 回文かどうかを判定
   is_palindrome = 真
   i = 0
   商(n, 2)回くり返す {
      もし q[i] が q[差(n, 和(i, 1))] でない ならば {
         is_palindrome = 偽
         くり返しを抜ける
      }
      i を増やす
   }
   
   # 合計が最大荷重以下で、かつ回文なら True
   もし is_palindrome ならば {
      真が答え
   }
   そうでなければ {
      偽が答え
   }
}