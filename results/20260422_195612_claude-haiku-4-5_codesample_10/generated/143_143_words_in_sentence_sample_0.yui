標準ライブラリを使う

# 素数判定関数
is_prime = 入力 n に対し {
   もし n が 2 より小さいならば {
      偽が答え
   }
   もし n が 2 ならば {
      真が答え
   }
   もし 剰余(n, 2) が 0 ならば {
      偽が答え
   }
   i = 3
   くり返す {
      もし 積(i, i) が n より大きいならば {
         くり返しを抜ける
      }
      もし 剰余(n, i) が 0 ならば {
         偽が答え
      }
      i = 和(i, 2)
   }
   真が答え
}

words_in_sentence = 入力 sentence に対し {
   # 空白で分割して単語の配列を作る
   words = sentence を " " で分割する
   
   result = ""
   n = words の大きさ
   i = 0
   n 回くり返す {
      word = words[i]
      len = word の大きさ
      
      # 単語の長さが素数かどうか判定
      もし is_prime(len) ならば {
         もし result が "" ならば {
            result = word
         }
         そうでなければ {
            result = "{result} {word}"
         }
      }
      
      i を増やす
   }
   
   result が答え
}