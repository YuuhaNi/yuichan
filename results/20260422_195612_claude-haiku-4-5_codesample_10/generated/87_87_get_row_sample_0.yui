標準ライブラリを使う

get_row = 入力 lst, x に対し {
   result = []
   row_idx = 0
   lst の大きさ 回くり返す {
      row = lst[row_idx]
      col_idx = 0
      row の大きさ 回くり返す {
         もし row[col_idx] が x ならば {
            result に [row_idx, col_idx] を追加する
         }
         col_idx を増やす
      }
      row_idx を増やす
   }
   
   # result を行の昇順、同じ行内では列の降順でソート
   # バブルソートで実装
   n = result の大きさ
   i = 0
   n 回くり返す {
      j = 0
      差(n, 1) 回くり返す {
         pair1 = result[j]
         pair2 = result[和(j, 1)]
         row1 = pair1[0]
         col1 = pair1[1]
         row2 = pair2[0]
         col2 = pair2[1]
         
         # 行で比較、行が同じなら列で比較（降順）
         もし row1 が row2 より大きい ならば {
            # スワップ
            temp = result[j]
            result[j] = result[和(j, 1)]
            result[和(j, 1)] = temp
         }
         そうでなければ {
            もし row1 が row2 と等しい ならば {
               もし col1 が col2 より小さい ならば {
                  # スワップ（列は降順）
                  temp = result[j]
                  result[j] = result[和(j, 1)]
                  result[和(j, 1)] = temp
               }
            }
         }
         j を増やす
      }
      i を増やす
   }
   
   result が答え
}