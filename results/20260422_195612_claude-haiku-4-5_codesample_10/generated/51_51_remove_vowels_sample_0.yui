標準ライブラリを使う

remove_vowels = 入力 text に対し {
   result = ""
   n = textの大きさ
   i = 0
   n回くり返す {
      c = text[i]
      もし c が "a" 以外 ならば {
         もし c が "e" 以外 ならば {
            もし c が "i" 以外 ならば {
               もし c が "o" 以外 ならば {
                  もし c が "u" 以外 ならば {
                     もし c が "A" 以外 ならば {
                        もし c が "E" 以外 ならば {
                           もし c が "I" 以外 ならば {
                              もし c が "O" 以外 ならば {
                                 もし c が "U" 以外 ならば {
                                    result に c を追加する
                                 }
                              }
                           }
                        }
                     }
                  }
               }
            }
         }
      }
      i を増やす
   }
   result が答え
}