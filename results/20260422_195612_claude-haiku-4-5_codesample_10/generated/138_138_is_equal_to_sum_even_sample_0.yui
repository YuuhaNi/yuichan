標準ライブラリを使う

is_equal_to_sum_even = 入力 n に対し {
   # 4つの正の偶数の最小合計は 2+2+2+2=8
   もし n が 8 より小さい ならば {
      偽が答え
   }
   
   # n を4つの正の偶数に分割できるかを調べる
   # a, b, c, d を正の偶数とすると、a+b+c+d = n
   # 最小値は各々2なので、n >= 8 が必要
   # a, b, c を決めると d = n - a - b - c となり、
   # d が正の偶数であることを確認すればよい
   
   found = 偽
   
   # a は 2 から n-6 まで（2刻み）
   a = 2
   n_minus_6 = 差(n, 6)
   
   くり返す {
      もし a が n_minus_6 より大きい ならば {
         くり返しを抜ける
      }
      
      # b は 2 から n-a-4 まで（2刻み）
      b = 2
      n_minus_a_4 = 差(差(n, a), 4)
      
      くり返す {
         もし b が n_minus_a_4 より大きい ならば {
            くり返しを抜ける
         }
         
         # c は 2 から n-a-b-2 まで（2刻み）
         c = 2
         n_minus_a_b_2 = 差(差(差(n, a), b), 2)
         
         くり返す {
            もし c が n_minus_a_b_2 より大きい ならば {
               くり返しを抜ける
            }
            
            # d = n - a - b - c
            d = 差(差(差(n, a), b), c)
            
            # d が正の偶数かチェック
            もし d が 2 以上 ならば {
               もし 剰余(d, 2) が 0 ならば {
                  found = 真
                  くり返しを抜ける
               }
            }
            
            c = 和(c, 2)
         }
         
         もし found が 真 ならば {
            くり返しを抜ける
         }
         
         b = 和(b, 2)
      }
      
      もし found が 真 ならば {
         くり返しを抜ける
      }
      
      a = 和(a, 2)
   }
   
   found が答え
}