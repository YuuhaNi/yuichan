標準ライブラリを使う

fibfib = 入力 n に対し {
    もし 整数判定(n) でなければ {
        エラー("mismatch-argument")
    }

    もし n == 0 なら {
        返す 0
    }
    もし n == 1 なら {
        返す 0
    }
    もし n == 2 なら {
        返す 1
    }

    a = 0
    b = 0
    c = 1
    i = 3

    繰り返し i <= n の間 {
        next = 和(a, b, c)
        a = b
        b = c
        c = next
        i = 和(i, 1)
    }

    返す c
}