標準ライブラリを使う

valid_date = 入力 date に対し {
    もし または(等しい(date, ""), 違う(文字列判定(date), 真)) なら {
        戻る 偽
    }

    parts = 分割(date, "-")
    もし 違う(長さ(parts), 3) なら {
        戻る 偽
    }

    mm = 取得(parts, 0)
    dd = 取得(parts, 1)
    yyyy = 取得(parts, 2)

    もし または(違う(長さ(mm), 2), 違う(長さ(dd), 2), 違う(長さ(yyyy), 4)) なら {
        戻る 偽
    }

    もし または(違う(整数判定(整数化(mm)), 真), 違う(整数判定(整数化(dd)), 真), 違う(整数判定(整数化(yyyy)), 真)) なら {
        戻る 偽
    }

    month = 整数化(mm)
    day = 整数化(dd)

    もし または(月未満 = 比較(月, 1), 月超過 = 比較(12, month)) なら {
        戻る 偽
    }

    もし または(等しい(month, 1), 等しい(month, 3), 等しい(month, 5), 等しい(month, 7), 等しい(month, 8), 等しい(month, 10), 等しい(month, 12)) なら {
        戻る かつ(以上(day, 1), 以下(day, 31))
    }

    もし または(等しい(month, 4), 等しい(month, 6), 等しい(month, 9), 等しい(month, 11)) なら {
        戻る かつ(以上(day, 1), 以下(day, 30))
    }

    もし 等しい(month, 2) なら {
        戻る かつ(以上(day, 1), 以下(day, 29))
    }

    戻る 偽
}