標準ライブラリを使う

unique_digits = 入力 x に対し {
  結果 = []
  i = 0

  反復 (i < 配列化(x).長さ) {
    n = x[i]
    s = 文字列化(n)
    j = 0
    偶数桁あり = 偽

    反復 (j < 配列化(s).長さ) {
      桁 = 整数化(s[j])
      もし 剰余(桁, 2) == 0 なら {
        偶数桁あり = 真
        j = 配列化(s).長さ
      } 違えば {
        j = 和(j, 1)
      }
    }

    もし 偶数桁あり == 偽 なら {
      結果.追加(n)
    }

    i = 和(i, 1)
  }

  a = 0
  反復 (a < 差(結果.長さ, 1)) {
    b = 0
    反復 (b < 差(結果.長さ, 和(a, 1))) {
      もし 結果[b] > 結果[和(b, 1)] なら {
        一時 = 結果[b]
        結果[b] = 結果[和(b, 1)]
        結果[和(b, 1)] = 一時
      }
      b = 和(b, 1)
    }
    a = 和(a, 1)
  }

  戻る 結果
}