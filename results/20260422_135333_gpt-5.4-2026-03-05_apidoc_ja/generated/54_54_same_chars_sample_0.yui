標準ライブラリを使う

same_chars = 入力 s0, s1 に対し {
  a = 配列化(s0)
  b = 配列化(s1)

  i = 0
  その間(差(i, 長さ(a))) {
    c = a[i]
    もし 含むか(b, c) なら {
    } でなければ {
      戻る 偽
    }
    i = 和(i, 1)
  }

  j = 0
  その間(差(j, 長さ(b))) {
    c = b[j]
    もし 含むか(a, c) なら {
    } でなければ {
      戻る 偽
    }
    j = 和(j, 1)
  }

  戻る 真
}