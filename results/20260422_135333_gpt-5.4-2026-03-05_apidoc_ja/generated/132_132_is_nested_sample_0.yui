標準ライブラリを使う

is_nested = 入力 string に対し {
  depth = 0
  nested = 偽

  i = 0
  反復 (i < 文字列長(string)) {
    ch = string[i]

    もし (ch == "[") なら {
      depth = 和(depth, 1)
      もし (depth >= 2) なら {
        nested = 真
      }
    } 違えば もし (ch == "]") なら {
      もし (depth > 0) なら {
        depth = 差(depth, 1)
      }
    }

    i = 和(i, 1)
  }

  戻る nested
}