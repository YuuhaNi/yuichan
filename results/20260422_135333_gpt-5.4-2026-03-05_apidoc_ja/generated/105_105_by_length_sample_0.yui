標準ライブラリを使う

by_length = 入力 arr に対し {
    もし 配列判定(arr) == 偽 なら {
        戻る []
    }

    結果 = []
    残り = 9

    反復 (残り > 0) {
        i = 0
        反復 (i < 長さ(arr)) {
            値 = arr[i]
            もし 値 == 残り なら {
                もし 値 == 1 なら {
                    結果 = 結果 + ["One"]
                } 違えば もし 値 == 2 なら {
                    結果 = 結果 + ["Two"]
                } 違えば もし 値 == 3 なら {
                    結果 = 結果 + ["Three"]
                } 違えば もし 値 == 4 なら {
                    結果 = 結果 + ["Four"]
                } 違えば もし 値 == 5 なら {
                    結果 = 結果 + ["Five"]
                } 違えば もし 値 == 6 なら {
                    結果 = 結果 + ["Six"]
                } 違えば もし 値 == 7 なら {
                    結果 = 結果 + ["Seven"]
                } 違えば もし 値 == 8 なら {
                    結果 = 結果 + ["Eight"]
                } 違えば もし 値 == 9 なら {
                    結果 = 結果 + ["Nine"]
                }
            }
            i = 和(i, 1)
        }
        残り = 差(残り, 1)
    }

    戻る 結果
}