標準ライブラリを使う

unique = 入力 l に対し {
    結果 = []
    i = 0

    反復 i < 配列長(l) の間 {
        v = l[i]
        ある = 偽
        j = 0

        反復 j < 配列長(結果) の間 {
            もし 結果[j] == v なら {
                ある = 真
            }
            j = 和(j, 1)
        }

        もし ある == 偽 なら {
            位置 = 0
            反復 位置 < 配列長(結果) かつ 結果[位置] < v の間 {
                位置 = 和(位置, 1)
            }

            新しい結果 = []
            j = 0
            反復 j < 位置 の間 {
                新しい結果 = 結合(新しい結果, [結果[j]])
                j = 和(j, 1)
            }

            新しい結果 = 結合(新しい結果, [v])

            反復 j < 配列長(結果) の間 {
                新しい結果 = 結合(新しい結果, [結果[j]])
                j = 和(j, 1)
            }

            結果 = 新しい結果
        }

        i = 和(i, 1)
    }

    結果
}