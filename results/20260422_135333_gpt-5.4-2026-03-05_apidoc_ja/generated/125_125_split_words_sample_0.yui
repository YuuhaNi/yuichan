標準ライブラリを使う

split_words = 入力 txt に対し {
    もし txt に " " が含まれる なら {
        txt を " " で分割する
    } そうでなく もし txt に "," が含まれる なら {
        txt を "," で分割する
    } そうでなければ {
        count = 0
        chars = 配列化(txt)
        i = 0
        繰り返し i < 長さ(chars) の間 {
            code = chars[i] - 97
            もし 剰余(code, 2) == 0 なら {
                count = 和(count, 1)
            }
            i = 和(i, 1)
        }
        count
    }
}