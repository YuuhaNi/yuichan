標準ライブラリを使う

get_max_triples = 入力 n に対し {
    a = []
    i = 1
    間 i 以下 n の間 {
        a = a + [差(積(i, i), i, -1)]
        i = 和(i, 1)
    }

    result = []
    i = 0
    間 i 未満 差(n, 2) の間 {
        j = 和(i, 1)
        間 j 未満 差(n, 1) の間 {
            k = 和(j, 1)
            間 k 未満 n の間 {
                x = a[i]
                y = a[j]
                z = a[k]
                もし 剰余(和(x, y, z), 3) が 0 なら {
                    result = result + [[x, y, z]]
                }
                k = 和(k, 1)
            }
            j = 和(j, 1)
        }
        i = 和(i, 1)
    }

    result
}