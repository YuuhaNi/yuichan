標準ライブラリを使う

search = 入力 lst に対し {
  counts = {}
  i = 0

  (i < 長さ(lst)) の間 {
    x = lst[i]
    もし x が counts に含まれる なら {
      counts[x] = 和(counts[x], 1)
    } そうでなければ {
      counts[x] = 1
    }
    i = 和(i, 1)
  }

  keys = 配列化(counts)
  ans = -1
  i = 0

  (i < 長さ(keys)) の間 {
    k = 整数化(keys[i])
    c = counts[keys[i]]
    もし (c >= k) かつ (k > ans) なら {
      ans = k
    }
    i = 和(i, 1)
  }

  ans
}