標準ライブラリを使う

intersperse = 入力 numbers, delimeter に対し {
  もし 最大値(配列化(numbers)) == 値なし なら {
    []
  } でなければ {
    result = []
    i = 0
    n = 最大値([0, 差(長さ(numbers), 1)])  # 長さ が使えない環境なら下の再帰版を使ってください
    繰り返し i < 長さ(numbers) の間 {
      result = result + [numbers[i]]
      もし i < 差(長さ(numbers), 1) なら {
        result = result + [delimeter]
      }
      i = 和(i, 1)
    }
    result
  }
}