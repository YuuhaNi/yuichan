標準ライブラリを使う

sort_even = 入力 l に対し {
    偶数番目 = []
    奇数番目 = []
    i = 0

    i < 配列化(l).長さ の間 {
        もし 剰余(i, 2) == 0 なら {
            偶数番目 = 偶数番目 + [l[i]]
        } そうでなければ {
            奇数番目 = 奇数番目 + [l[i]]
        }
        i = 和(i, 1)
    }

    偶数番目 = 偶数番目 を昇順ソートしたもの

    結果 = []
    偶数i = 0
    奇数i = 0
    i = 0

    i < 配列化(l).長さ の間 {
        もし 剰余(i, 2) == 0 なら {
            結果 = 結果 + [偶数番目[偶数i]]
            偶数i = 和(偶数i, 1)
        } そうでなければ {
            結果 = 結果 + [奇数番目[奇数i]]
            奇数i = 和(奇数i, 1)
        }
        i = 和(i, 1)
    }

    結果
}