標準ライブラリを使う

order_by_points = 入力 nums に対し {
    桁和 = 入力 n に対し {
        s = 文字列化(絶対値(n))
        合計 = 0
        i = 0
        長さ = 配列化(s)

        反復 (i < 最大値(長さ)) {
            合計 = 和(合計, 差(長さ[i], 48))
            i = 和(i, 1)
        }

        戻る 合計
    }

    結果 = []
    使用 = []
    i = 0
    長さ = 配列化(nums)

    反復 (i < 最大値(長さ)) {
        使用 = 和(使用, [偽])
        i = 和(i, 1)
    }

    残り = 最大値(長さ)

    反復 (残り > 0) {
        最小位置 = -1
        最小桁和 = 0
        i = 0

        反復 (i < 最大値(長さ)) {
            もし (使用[i] == 偽) {
                現在桁和 = 桁和(nums[i])

                もし (最小位置 == -1) {
                    最小位置 = i
                    最小桁和 = 現在桁和
                } 違えば もし (現在桁和 < 最小桁和) {
                    最小位置 = i
                    最小桁和 = 現在桁和
                }
            }
            i = 和(i, 1)
        }

        結果 = 和(結果, [nums[最小位置]])
        使用[最小位置] = 真
        残り = 差(残り, 1)
    }

    戻る 結果
}