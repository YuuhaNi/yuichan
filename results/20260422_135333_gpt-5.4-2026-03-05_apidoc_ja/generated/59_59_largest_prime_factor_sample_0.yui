標準ライブラリを使う

largest_prime_factor = 入力 n に対し {
    最大 = 1
    d = 2

    反復 (真) {
        もし 剰余(n, d) == 0 なら {
            最大 = d
            n = 商(n, d)
        } でなければ {
            もし 積(d, d) > n なら {
                もし n > 1 なら {
                    最大 = n
                }
                戻る 最大
            }
            d = 和(d, 1)
        }
    }
}