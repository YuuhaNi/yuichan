標準ライブラリを使う

get_row = 入力 lst, x に対し {
  結果 = []
  行 = 0

  lst の各要素を row について繰り返す {
    列 = 0
    見つけた = []

    row の各要素を value について繰り返す {
      もし value == x なら {
        見つけた = 和(見つけた, [[行, 列]])
      }
      列 = 和(列, 1)
    }

    長さ = 差(0, 0)
    見つけた の各要素を _ について繰り返す {
      長さ = 和(長さ, 1)
    }

    もし 長さ > 0 なら {
      i = 差(長さ, 1)
      繰り返す {
        もし i < 0 なら {
          抜ける
        }
        結果 = 和(結果, [見つけた[i]])
        i = 差(i, 1)
      }
    }

    行 = 和(行, 1)
  }

  戻る 結果
}