標準ライブラリを使う

even_odd_palindrome = 入力 n に対し {
    偶数 = 0
    奇数 = 0
    i = 1

    の間、i <= n {
        s = 文字列化(i)
        r = ""
        j = 差(配列化(s)の長さ, 1)

        の間、j >= 0 {
            r = r + s[j]
            j = 差(j, 1)
        }

        もし s == r なら {
            もし 剰余(i, 2) == 0 なら {
                偶数 = 和(偶数, 1)
            } でなければ {
                奇数 = 和(奇数, 1)
            }
        }

        i = 和(i, 1)
    }

    (偶数, 奇数)
}