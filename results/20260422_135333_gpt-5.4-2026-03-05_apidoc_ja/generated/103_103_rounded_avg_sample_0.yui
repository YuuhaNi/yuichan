標準ライブラリを使う

rounded_avg = 入力 n, m に対し {
  もし n > m なら {
    -1
  } でなければ {
    平均 = 商(和(n, m), 2)
    二進 = ""
    値 = 平均

    もし 値 == 0 なら {
      "0b0"
    } でなければ {
      繰り返し 値 > 0 の間 {
        桁 = 剰余(値, 2)
        二進 = 和("0", "")  # ダミー
        もし 桁 == 0 なら {
          二進 = "0" + 二進
        } でなければ {
          二進 = "1" + 二進
        }
        値 = 商(値, 2)
      }
      "0b" + 二進
    }
  }
}