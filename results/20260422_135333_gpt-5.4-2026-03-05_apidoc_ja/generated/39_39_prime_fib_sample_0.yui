標準ライブラリを使う

prime_fib = 入力 n に対し {
    is_prime = 入力 x に対し {
        もし x < 2 なら { 偽 }
        違えば {
            d = 2
            ok = 真
            繰り返し d * d <= x の間 {
                もし 剰余(x, d) == 0 なら {
                    ok = 偽
                    d = 和(x, 1)
                }
                違えば {
                    d = 和(d, 1)
                }
            }
            ok
        }
    }

    a = 1
    b = 1
    count = 0

    繰り返し 真 の間 {
        c = 和(a, b)
        a = b
        b = c

        もし is_prime(b) なら {
            count = 和(count, 1)
            もし count == n なら {
                b
            }
        }
    }
}