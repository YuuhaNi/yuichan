標準ライブラリを使う

monotonic = 入力 l に対し {
    もし 最大値(l) が l[0] なら {
        i = 1
        反復 i < 長さ(l) の間 {
            もし l[i - 1] < l[i] なら {
                偽 を返す
            }
            i = 和(i, 1)
        }
        真 を返す
    }

    もし 最小値(l) が l[0] なら {
        i = 1
        反復 i < 長さ(l) の間 {
            もし l[i - 1] > l[i] なら {
                偽 を返す
            }
            i = 和(i, 1)
        }
        真 を返す
    }

    偽 を返す
}