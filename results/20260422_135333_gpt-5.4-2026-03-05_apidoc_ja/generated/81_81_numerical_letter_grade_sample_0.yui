標準ライブラリを使う

numerical_letter_grade = 入力 grades に対し {
  result = []

  grades の各要素 g について {
    もし g == 4.0 なら {
      result に "A+" を追加
    } でなければ もし g > 3.7 なら {
      result に "A" を追加
    } でなければ もし g > 3.3 なら {
      result に "A-" を追加
    } でなければ もし g > 3.0 なら {
      result に "B+" を追加
    } でなければ もし g > 2.7 なら {
      result に "B" を追加
    } でなければ もし g > 2.3 なら {
      result に "B-" を追加
    } でなければ もし g > 2.0 なら {
      result に "C+" を追加
    } でなければ もし g > 1.7 なら {
      result に "C" を追加
    } でなければ もし g > 1.3 なら {
      result に "C-" を追加
    } でなければ もし g > 1.0 なら {
      result に "D+" を追加
    } でなければ もし g > 0.7 なら {
      result に "D" を追加
    } でなければ もし g > 0.0 なら {
      result に "D-" を追加
    } でなければ {
      result に "E" を追加
    }
  }

  result
}