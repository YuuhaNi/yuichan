標準ライブラリを使う

sort_numbers = 入力 numbers に対し {
    words = ["", "zero", "one", "two", "three", "four", "five", "six", "seven", "eight", "nine"]
    result = ""
    first = 真

    i = 0
    繰り返し(i < 10) {
        target = words[i]
        j = 0
        start = 0

        繰り返し(start < 長さ(numbers)) {
            k = start
            token = ""

            繰り返し(k < 長さ(numbers) かつ numbers[k] != " ") {
                token = token + numbers[k]
                k = k + 1
            }

            もし(token == target) {
                もし(first) {
                    result = token
                    first = 偽
                } 違えば {
                    result = result + " " + token
                }
            }

            start = k + 1
        }

        i = i + 1
    }

    result
}