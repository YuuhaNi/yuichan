標準ライブラリを使う

select_words = 入力 s, n に対し {
  単語一覧 = s.split(" ")
  結果 = []

  単語一覧 の各要素を w で繰り返す {
    子音数 = 0
    i = 0

    i < w.length の間 {
      c = w[i]
      小文字 = c.lower()

      もし (
        小文字 != "a" かつ
        小文字 != "e" かつ
        小文字 != "i" かつ
        小文字 != "o" かつ
        小文字 != "u"
      ) なら {
        子音数 = 子音数 + 1
      }

      i = i + 1
    }

    もし 子音数 == n なら {
      結果.push(w)
    }
  }

  戻す 結果
}