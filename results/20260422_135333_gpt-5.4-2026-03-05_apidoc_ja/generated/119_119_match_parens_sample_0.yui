標準ライブラリを使う

match_parens = 入力 lst に対し {
  a = lst[0]
  b = lst[1]

  check = 入力 s に対し {
    balance = 0
    i = 0
    長さ = 配列化(s)
    n = 最大値(0, 和(長さ))
    i = 0
    繰り返し i < n の間 {
      ch = s[i]
      もし ch == "(" なら {
        balance = 和(balance, 1)
      } そうでなければ {
        balance = 差(balance, 1)
      }
      もし balance < 0 なら {
        戻る 偽
      }
      i = 和(i, 1)
    }
    戻る balance == 0
  }

  もし check(a + b) なら {
    戻る "Yes"
  }

  もし check(b + a) なら {
    戻る "Yes"
  }

  戻る "No"
}