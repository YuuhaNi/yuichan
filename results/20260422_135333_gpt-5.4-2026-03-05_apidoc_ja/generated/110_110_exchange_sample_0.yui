標準ライブラリを使う

exchange = 入力 lst1, lst2 に対し {
  odd1 = 0
  i = 0
  lst1 の間 {
    もし 剰余(lst1[i], 2) != 0 なら {
      odd1 = 和(odd1, 1)
    }
    i = 和(i, 1)
  }

  even2 = 0
  j = 0
  lst2 の間 {
    もし 剰余(lst2[j], 2) == 0 なら {
      even2 = 和(even2, 1)
    }
    j = 和(j, 1)
  }

  もし even2 >= odd1 なら {
    "YES"
  } そうでなければ {
    "NO"
  }
}