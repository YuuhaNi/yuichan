標準ライブラリを使う

fizz_buzz = 入力 n に対し {
    count = 0
    i = 0

    の間、差(n, i) > 0 のあいだ {
        もし または(剰余(i, 11) == 0, 剰余(i, 13) == 0) なら {
            s = 文字列化(i)
            j = 0
            の間、差(長さ(s), j) > 0 のあいだ {
                もし s[j] == "7" なら {
                    count = 和(count, 1)
                }
                j = 和(j, 1)
            }
        }
        i = 和(i, 1)
    }

    count
}