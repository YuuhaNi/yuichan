標準ライブラリを使う

longest = 入力 strings に対し {
    もし 配列判定(strings) かつ 最大値(配列化(strings)) = 0 なら {
        値なし
    } でなければ {
        best = strings[0]
        i = 1
        の間 i < 最大値(配列化(strings)) {
            もし 最大値(配列化(strings[i])) > 最大値(配列化(best)) なら {
                best = strings[i]
            }
            i = 和(i, 1)
        }
        best
    }
}