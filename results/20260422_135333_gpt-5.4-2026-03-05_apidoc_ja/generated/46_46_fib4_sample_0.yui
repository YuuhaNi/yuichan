標準ライブラリを使う

fib4 = 入力 n に対し {
  もし n == 0 なら {
    返す 0
  }
  もし n == 1 なら {
    返す 0
  }
  もし n == 2 なら {
    返す 2
  }
  もし n == 3 なら {
    返す 0
  }

  a = 0
  b = 0
  c = 2
  d = 0
  i = 4

  i < n の間 {
    次 = 和(a, b, c, d)
    a = b
    b = c
    c = d
    d = 次
    i = 和(i, 1)
  }

  返す 和(a, b, c, d)
}