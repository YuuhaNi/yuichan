標準ライブラリを使う

reverse_delete = 入力 s, c に対し {
    残す = []
    i = 0

    反復 (i < 長さ(s)) {
        ch = s[i]
        j = 0
        含まれる = 偽

        反復 (j < 長さ(c)) {
            もし (ch == c[j]) なら {
                含まれる = 真
            }
            j = 和(j, 1)
        }

        もし (含まれる == 偽) なら {
            残す = 結合(残す, [ch])
        }

        i = 和(i, 1)
    }

    結果 = ""
    i = 0
    反復 (i < 長さ(残す)) {
        結果 = 結果 + 残す[i]
        i = 和(i, 1)
    }

    左 = 0
    右 = 差(長さ(結果), 1)
    回文 = 真

    反復 (左 < 右) {
        もし (結果[左] != 結果[右]) なら {
            回文 = 偽
        }
        左 = 和(左, 1)
        右 = 差(右, 1)
    }

    戻る (結果, 回文)
}