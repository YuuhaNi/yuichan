標準ライブラリを使う

decode_shift = 入力 s に対し {
  codes = 配列化(s)
  out = []
  i = 0
  反復 (i < 長さ(codes)) {
    c = codes[i]

    もし ((c >= 65) かつ (c <= 90)) なら {
      out = 結合(out, [剰余(c - 65 + 5, 26) + 65])
    } 違えば もし ((c >= 97) かつ (c <= 122)) なら {
      out = 結合(out, [剰余(c - 97 + 5, 26) + 97])
    } 違えば {
      out = 結合(out, [c])
    }

    i = i + 1
  }
  文字列化(out)
}