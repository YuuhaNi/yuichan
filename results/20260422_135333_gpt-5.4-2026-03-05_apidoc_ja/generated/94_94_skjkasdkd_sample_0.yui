標準ライブラリを使う

skjkasdkd = 入力 lst に対し {
    素数判定 = 入力 n に対し {
        もし n < 2 なら {
            戻る 偽
        }
        i = 2
        ループ { 
            もし i * i > n なら {
                戻る 真
            }
            もし 剰余(n, i) == 0 なら {
                戻る 偽
            }
            i = 和(i, 1)
        }
    }

    最大素数 = 0
    i = 0

    ループ {
        もし i >= 配列長(lst) なら {
            抜ける
        }

        値 = lst[i]
        もし 素数判定(値) かつ 値 > 最大素数 なら {
            最大素数 = 値
        }

        i = 和(i, 1)
    }

    文字 = 文字列化(最大素数)
    合計 = 0
    i = 0

    ループ {
        もし i >= 文字列長(文字) なら {
            抜ける
        }

        合計 = 和(合計, 整数化(文字[i]))
        i = 和(i, 1)
    }

    戻る 合計
}