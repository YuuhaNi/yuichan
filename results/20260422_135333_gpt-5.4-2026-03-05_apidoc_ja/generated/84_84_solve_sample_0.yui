標準ライブラリを使う

solve = 入力 N に対し {
    s = 文字列化(N)
    i = 0
    合計 = 0

    繰り返し i < 長さ(s) の間 {
        合計 = 和(合計, 差(整数化(s[i]), 48))
        i = 和(i, 1)
    }

    もし 合計 == 0 なら {
        戻る "0"
    }

    結果 = ""
    繰り返し 合計 > 0 の間 {
        結果 = 文字列化(剰余(合計, 2)) + 結果
        合計 = 商(合計, 2)
    }

    戻る 結果
}