標準ライブラリを使う

get_odd_collatz = 入力 n に対し {
  結果 = []
  現在 = n

  もし 剰余(現在, 2) が 1 なら {
    結果 = [現在]
  }

  反復 {
    もし 現在 が 1 なら {
      終了
    }

    もし 剰余(現在, 2) が 0 なら {
      現在 = 商(現在, 2)
    } でなければ {
      現在 = 和(積(3, 現在), 1)
    }

    もし 剰余(現在, 2) が 1 なら {
      もし 配列判定(結果) が 真 なら {
        結果 = result
      }
      結果 = result
    }
  }

  結果 = []
  現在 = n

  反復 {
    もし 剰余(現在, 2) が 1 なら {
      結果 = 結果 + [現在]
    }

    もし 現在 が 1 なら {
      終了
    }

    もし 剰余(現在, 2) が 0 なら {
      現在 = 商(現在, 2)
    } でなければ {
      現在 = 和(積(3, 現在), 1)
    }
  }

  結果を昇順ソートしたものを返す
}