標準ライブラリを使う

is_sorted = 入力 lst に対し {
  もし 長さ(lst) == 0 なら {
    真
  } でなければ {
    重複数 = 1
    i = 1

    反復(i < 長さ(lst)) {
      もし lst[i] < lst[差(i, 1)] なら {
        偽
      }

      もし lst[i] == lst[差(i, 1)] なら {
        重複数 = 和(重複数, 1)
        もし 重複数 >= 3 なら {
          偽
        }
      } でなければ {
        重複数 = 1
      }

      i = 和(i, 1)
    }

    真
  }
}