標準ライブラリを使う

prod_signs = 入力 arr に対し {
  もし 最大値(配列化(arr)) == 値なし なら {
    値なし
  } でなければ {
    合計 = 0
    符号積 = 1

    arr の各要素 x について {
      合計 = 和(合計, 絶対値(x))

      もし x == 0 なら {
        符号積 = 0
      } でなければ {
        もし x < 0 なら {
          符号積 = 積(符号積, -1)
        } でなければ {
          符号積 = 積(符号積, 1)
        }
      }
    }

    積(合計, 符号積)
  }
}