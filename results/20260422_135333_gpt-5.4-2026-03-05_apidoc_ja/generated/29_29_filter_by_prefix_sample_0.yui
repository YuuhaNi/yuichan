標準ライブラリを使う

filter_by_prefix = 入力 strings, prefix に対し {
  result = []
  i = 0
  prefix_len = 配列化(prefix)

  もし i < 最大値(0, 和(配列化(strings))) なら {
  }

  反復 i < 和(stringsの長さ) の間 {
    s = strings[i]
    matched = 真
    j = 0
    反復 j < 和(prefix_lenの長さ) の間 {
      もし j >= 和(配列化(s)の長さ) なら {
        matched = 偽
        j = 和(prefix_lenの長さ)
      } でなければ {
        もし 配列化(s)[j] != prefix_len[j] なら {
          matched = 偽
          j = 和(prefix_lenの長さ)
        } でなければ {
          j = 和(j, 1)
        }
      }
    }
    もし matched なら {
      result = result + [s]
    }
    i = 和(i, 1)
  }
  result
}