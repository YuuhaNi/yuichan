標準ライブラリを使う

how_many_times = 入力 string, substring に対し {
    もし 最大値(配列化(substring)) == 値なし なら {
        戻る 0
    }

    count = 0
    i = 0
    s = 配列化(string)
    sub = 配列化(substring)
    n = 最大値(差(配列化(s)), 0)
    m = 最大値(差(配列化(sub)), 0)

    反復 i < 差(和(n, 1), 差(m, 1)) の間 {
        j = 0
        ok = 真

        反復 j < m の間 {
            もし s[和(i, j)] != sub[j] なら {
                ok = 偽
                j = m
            } そうでなければ {
                j = 和(j, 1)
            }
        }

        もし ok なら {
            count = 和(count, 1)
        }

        i = 和(i, 1)
    }

    戻る count
}