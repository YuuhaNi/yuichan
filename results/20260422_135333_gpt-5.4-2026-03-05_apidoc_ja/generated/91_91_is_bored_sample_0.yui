標準ライブラリを使う

is_bored = 入力 S に対し {
  文一覧 = []
  現在 = ""

  区切り判定 = 入力 C に対し {
    もし C == "." なら { 戻る 真 }
    もし C == "?" なら { 戻る 真 }
    もし C == "!" なら { 戻る 真 }
    戻る 偽
  }

  i = 0
  反復 (i < 長さ(S)) {
    文字 = S[i]

    もし 区切り判定(文字) なら {
      文一覧 = 文一覧 + [現在]
      現在 = ""
    } そうでなければ {
      現在 = 現在 + 文字
    }

    i = i + 1
  }

  もし 現在 != "" なら {
    文一覧 = 文一覧 + [現在]
  }

  数 = 0
  j = 0
  反復 (j < 長さ(文一覧)) {
    文 = 文一覧[j]

    もし 長さ(文) >= 2 なら {
      もし 文[0] == "I" かつ 文[1] == " " なら {
        数 = 数 + 1
      }
    }

    j = j + 1
  }

  戻る 数
}