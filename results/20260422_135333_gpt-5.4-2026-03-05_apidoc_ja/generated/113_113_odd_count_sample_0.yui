標準ライブラリを使う

odd_count = 入力 lst に対し {
  結果 = []

  lst の各要素を s について繰り返す {
    個数 = 0

    s の各要素を c について繰り返す {
      もし c == "1" または c == "3" または c == "5" または c == "7" または c == "9" なら {
        個数 = 和(個数, 1)
      }
    }

    n = 文字列化(個数)
    文 = "the number of odd elements in the string i of the input."

    文 = 置換(文, "i", n)
    結果 = 結果 に 文 を追加したもの
  }

  結果
}