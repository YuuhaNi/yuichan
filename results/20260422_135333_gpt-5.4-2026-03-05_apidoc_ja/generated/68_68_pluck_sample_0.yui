標準ライブラリを使う

pluck = 入力 arr に対し {
  もし 和(arr) == 値なし なら {
    戻る []
  }

  最小値候補 = 値なし
  最小位置 = 値なし
  i = 0

  繰り返し i < 配列の長さ(arr) の間 {
    値 = arr[i]
    もし 剰余(値, 2) == 0 なら {
      もし 最小値候補 == 値なし または 値 < 最小値候補 なら {
        最小値候補 = 値
        最小位置 = i
      }
    }
    i = 和(i, 1)
  }

  もし 最小値候補 == 値なし なら {
    戻る []
  }

  戻る [最小値候補, 最小位置]
}