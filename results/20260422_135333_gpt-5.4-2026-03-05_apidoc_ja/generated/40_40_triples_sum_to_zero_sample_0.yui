標準ライブラリを使う

triples_sum_to_zero = 入力 l に対し {
    もし 配列判定(l) でなければ {
        偽
    } そうでなくもし 最小値([配列化(l).長さ, 3]) != 3 なら {
        偽
    } そうでなければ {
        i = 0
        その間 i < l.長さ の間 {
            j = 和(i, 1)
            その間 j < l.長さ の間 {
                k = 和(j, 1)
                その間 k < l.長さ の間 {
                    もし 和(l[i], l[j], l[k]) == 0 なら {
                        真
                    }
                    k = 和(k, 1)
                }
                j = 和(j, 1)
            }
            i = 和(i, 1)
        }
        偽
    }
}