標準ライブラリを使う

move_one_ball = 入力 arr に対し {
  もし 最大値(配列化(arr)) == 0 なら {
    戻る 真
  }

  n = 最大値(配列化(arr))
  breaks = 0
  i = 0

  繰り返し i < 差(n, 1) の間 {
    もし arr[i] > arr[和(i, 1)] なら {
      breaks = 和(breaks, 1)
    }
    i = 和(i, 1)
  }

  もし arr[差(n, 1)] > arr[0] なら {
    breaks = 和(breaks, 1)
  }

  戻る breaks <= 1
}