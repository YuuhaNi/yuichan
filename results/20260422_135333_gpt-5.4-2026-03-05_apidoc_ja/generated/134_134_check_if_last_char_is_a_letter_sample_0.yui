標準ライブラリを使う

check_if_last_char_is_a_letter = 入力 txt に対し {
    もし 文字列判定(txt) でなければ {
        戻る 偽
    }

    chars = 配列化(txt)
    n = 最大値(0, 差(長さ(chars), 0))

    もし n == 0 なら {
        戻る 偽
    }

    last = chars[差(n, 1)]

    もし last == 32 なら {
        戻る 偽
    }

    もし n == 1 なら {
        もし かつ(last >= 65, last <= 90) または かつ(last >= 97, last <= 122) なら {
            戻る 真
        } でなければ {
            戻る 偽
        }
    }

    prev = chars[差(n, 2)]

    is_letter = または(
        かつ(last >= 65, last <= 90),
        かつ(last >= 97, last <= 122)
    )

    もし is_letter でなければ {
        戻る 偽
    }

    もし prev == 32 なら {
        戻る 真
    } でなければ {
        戻る 偽
    }
}