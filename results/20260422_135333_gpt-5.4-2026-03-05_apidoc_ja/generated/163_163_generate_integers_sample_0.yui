標準ライブラリを使う

generate_integers = 入力 a, b に対し {
  小さい = 最小値(a, b)
  大きい = 最大値(a, b)
  結果 = []

  もし 剰余(小さい, 2) != 0 なら {
    小さい = 和(小さい, 1)
  }

  もし 差(大きい, 小さい) < 2 なら {
    戻る 結果
  }

  現在 = 小さい
  もし 現在 == 大きい なら {
    戻る 結果
  }

  繰り返し {
    もし 現在 >= 大きい なら {
      止める
    }
    結果 に 現在 を追加
    現在 = 和(現在, 2)
  }

  戻る 結果
}