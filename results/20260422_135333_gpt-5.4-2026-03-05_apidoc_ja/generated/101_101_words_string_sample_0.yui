標準ライブラリを使う

words_string = 入力 s に対し {
  結果 = []
  現在 = ""

  i = 0
  反復 (i < 配列化(s) の長さ) {
    文字 = 文字列化([配列化(s)[i]])
    もし (文字 == "," または 文字 == " ") なら {
      もし (現在 != "") なら {
        結果 = 結果 に 現在 を追加
        現在 = ""
      }
    } 違えば {
      現在 = 現在 + 文字
    }
    i = i + 1
  }

  もし (現在 != "") なら {
    結果 = 結果 に 現在 を追加
  }

  戻す 結果
}