標準ライブラリを使う

bf = 入力 planet1, planet2 に対し {
  惑星一覧 = ["Mercury", "Venus", "Earth", "Mars", "Jupiter", "Saturn", "Uranus", "Neptune"]

  i1 = -1
  i2 = -1
  i = 0

  反復 (i < 8) {
    もし (惑星一覧[i] == planet1) {
      i1 = i
    }
    もし (惑星一覧[i] == planet2) {
      i2 = i
    }
    i = 和(i, 1)
  }

  もし ((i1 == -1) または (i2 == -1)) {
    戻る ()
  }

  もし (i1 > i2) {
    tmp = i1
    i1 = i2
    i2 = tmp
  }

  結果 = []
  i = 和(i1, 1)

  反復 (i < i2) {
    結果 = 結果 + [惑星一覧[i]]
    i = 和(i, 1)
  }

  戻る 結果
}