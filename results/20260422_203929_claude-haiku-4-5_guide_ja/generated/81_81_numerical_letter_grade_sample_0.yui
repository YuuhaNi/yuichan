標準ライブラリを使う

numerical_letter_grade = 入力 grades に対し {
   result = []
   i = 0
   gradesの大きさ回くり返す{
      gpa = grades[i]
      
      もし gpa が 4.0 ならば {
         resultに "A+" を追加する
      } そうでなければ {
         もし gpa が 3.7 より大きい ならば {
            resultに "A" を追加する
         } そうでなければ {
            もし gpa が 3.3 より大きい ならば {
               resultに "A-" を追加する
            } そうでなければ {
               もし gpa が 3.0 より大きい ならば {
                  resultに "B+" を追加する
               } そうでなければ {
                  もし gpa が 2.7 より大きい ならば {
                     resultに "B" を追加する
                  } そうでなければ {
                     もし gpa が 2.3 より大きい ならば {
                        resultに "B-" を追加する
                     } そうでなければ {
                        もし gpa が 2.0 より大きい ならば {
                           resultに "C+" を追加する
                        } そうでなければ {
                           もし gpa が 1.7 より大きい ならば {
                              resultに "C" を追加する
                           } そうでなければ {
                              もし gpa が 1.3 より大きい ならば {
                                 resultに "C-" を追加する
                              } そうでなければ {
                                 もし gpa が 1.0 より大きい ならば {
                                    resultに "D+" を追加する
                                 } そうでなければ {
                                    もし gpa が 0.7 より大きい ならば {
                                       resultに "D" を追加する
                                    } そうでなければ {
                                       もし gpa が 0.0 より大きい ならば {
                                          resultに "D-" を追加する
                                       } そうでなければ {
                                          resultに "E" を追加する
                                       }
                                    }
                                 }
                              }
                           }
                        }
                     }
                  }
               }
            }
         }
      }
      
      iを増やす
   }
   
   resultが答え
}