標準ライブラリを使う

triples_sum_to_zero = 入力 l に対し {
   n = lの大きさ
   
   もしnが3より小さいならば{
      偽が答え
   }
   
   i = 0
   n回くり返す{
      もしiがnより大きい以上ならば{
         くり返しを抜ける
      }
      
      j = 和(i, 1)
      n回くり返す{
         もしjがnより大きい以上ならば{
            くり返しを抜ける
         }
         
         k = 和(j, 1)
         n回くり返す{
            もしkがnより大きい以上ならば{
               くり返しを抜ける
            }
            
            もし和(l[i], l[j], l[k])が0ならば{
               真が答え
            }
            
            kを増やす
         }
         
         jを増やす
      }
      
      iを増やす
   }
   
   偽が答え
}