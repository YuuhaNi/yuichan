標準ライブラリを使う

skjkasdkd = 入力 lst に対し {
   # 素数判定関数
   is_prime = 入力 n に対し {
      もし n が 2 より小さい ならば {
         偽 が答え
      }
      もし n が 2 ならば {
         真 が答え
      }
      もし 剰余(n, 2) が 0 ならば {
         偽 が答え
      }
      i = 3
      i_sq = 積(i, i)
      i_sq が n より大きい ならば {
         真 が答え
      }
      i_sq が n 以下 ならば {
         i_sq = 積(i, i)
         もし i_sq が n より大きい ならば {
            くり返しを抜ける
         }
         もし 剰余(n, i) が 0 ならば {
            偽 が答え
         }
         i = 和(i, 2)
      }
      真 が答え
   }
   
   # 桁数の和を計算する関数
   digit_sum = 入力 n に対し {
      s = 文字列化(n)
      sum = 0
      i = 0
      s の大きさ 回 くり返す {
         digit = 整数化(s[i])
         sum = 和(sum, 差(digit, 48))
         i を増やす
      }
      sum が答え
   }
   
   # リストから最大素数を見つける
   max_prime = 値なし
   i = 0
   lst の大きさ 回 くり返す {
      num = lst[i]
      もし is_prime(num) が 真 ならば {
         もし max_prime が 値なし ならば {
            max_prime = num
         }
         そうでなければ {
            もし num が max_prime より大きい ならば {
               max_prime = num
            }
         }
      }
      i を増やす
   }
   
   # 最大素数の桁数の和を返す
   digit_sum(max_prime) が答え
}