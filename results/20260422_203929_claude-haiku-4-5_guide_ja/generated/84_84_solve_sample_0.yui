標準ライブラリを使う

solve = 入力 N に対し {
   # N を文字列に変換して各桁を処理
   s = 文字列化(N)
   sum = 0
   i = 0
   sの大きさ回くり返す{
      # 各文字を整数に変換して合計に加える
      digit = 整数化(文字列化(s[i]))
      sum = 和(sum, digit)
      iを増やす
   }
   
   # sum を2進数に変換
   もしsumが0ならば{
      "0"が答え
   }
   
   binary = ""
   n = sum
   n回くり返す{
      もしnが0ならば{
         くり返しを抜ける
      }
      remainder = 剰余(n, 2)
      binary = 文字列化(remainder) + binary
      n = 商(n, 2)
   }
   
   binaryが答え
}