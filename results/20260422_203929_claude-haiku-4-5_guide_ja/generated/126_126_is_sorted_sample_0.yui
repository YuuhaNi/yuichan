標準ライブラリを使う

is_sorted = 入力 lst に対し {
   もし lst の大きさ が 1 以下 ならば {
      真 が 答え
   }
   
   i = 0
   前の値 = lst[0]
   重複カウント = 0
   
   lst の大きさ 回 くり返す {
      もし i が 0 ならば {
         i を増やす
         くり返しを抜ける
      }
      
      現在の値 = lst[i]
      
      もし 現在の値 が 前の値 より小さい ならば {
         偽 が 答え
      }
      
      もし 現在の値 が 前の値 ならば {
         重複カウント を増やす
         もし 重複カウント が 1 より大きい ならば {
            偽 が 答え
         }
      } そうでなければ {
         重複カウント = 0
      }
      
      前の値 = 現在の値
      i を増やす
   }
   
   真 が 答え
}