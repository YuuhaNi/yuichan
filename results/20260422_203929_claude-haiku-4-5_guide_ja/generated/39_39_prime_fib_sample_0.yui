標準ライブラリを使う

is_prime = 入力 x に対し {
   もし x が 2 より小さい ならば {
      偽 が 答え
   }
   もし x が 2 ならば {
      真 が 答え
   }
   i = 2
   x 回 くり返す {
      もし i が x より大きい ならば {
         くり返しを抜ける
      }
      もし 剰余(x, i) が 0 ならば {
         偽 が 答え
      }
      i を増やす
   }
   真 が 答え
}

prime_fib = 入力 n に対し {
   count = 0
   a = 1
   b = 1
   
   1000000 回 くり返す {
      c = 和(a, b)
      もし is_prime(c) ならば {
         count を増やす
         もし count が n ならば {
            c が 答え
         }
      }
      a = b
      b = c
   }
}