標準ライブラリを使う

solve = 入力 s に対し {
   # アルファベットが含まれているかチェック
   has_alpha = 偽
   i = 0
   s の大きさ 回くり返す {
      c = s[i]
      # 大文字 A-Z: 65-90, 小文字 a-z: 97-122
      もし c が 65 以上 ならば {
         もし c が 90 以下 ならば {
            has_alpha = 真
         }
      }
      もし c が 97 以上 ならば {
         もし c が 122 以下 ならば {
            has_alpha = 真
         }
      }
      i を増やす
   }

   # アルファベットが含まれていない場合は逆順にする
   もし has_alpha が 偽 ならば {
      result = ""
      i = 差(s の大きさ, 1)
      s の大きさ 回くり返す {
         もし i が 0 以上 ならば {
            result に s[i] を追加する
            i を減らす
         }
      }
      result が答え
   }

   # アルファベットが含まれている場合は大文字小文字を反転
   result = ""
   i = 0
   s の大きさ 回くり返す {
      c = s[i]
      # 大文字 A-Z: 65-90
      もし c が 65 以上 ならば {
         もし c が 90 以下 ならば {
            # 大文字を小文字に (c + 32)
            result に 和(c, 32) を追加する
            i を増やす
            くり返しを抜ける
         }
      }
      # 小文字 a-z: 97-122
      もし c が 97 以上 ならば {
         もし c が 122 以下 ならば {
            # 小文字を大文字に (c - 32)
            result に 差(c, 32) を追加する
            i を増やす
            くり返しを抜ける
         }
      }
      # アルファベット以外はそのまま
      result に c を追加する
      i を増やす
   }

   result が答え
}