標準ライブラリを使う

prime_length = 入力 string に対し {
   len = stringの大きさ
   
   # 長さが2未満なら素数ではない
   もしlenが2より小さいならば{
      偽が答え
   }
   
   # 2は素数
   もしlenが2ならば{
      真が答え
   }
   
   # 偶数は素数ではない
   i = 0
   もしlen[0]が0ならば{
      偽が答え
   }
   
   # 3以上の奇数で割り切れるかチェック
   divisor = 3
   len回くり返す{
      もしdivisorが積(divisor, divisor)より大きいならば{
         くり返しを抜ける
      }
      もし剰余(len, divisor)が0ならば{
         偽が答え
      }
      divisorを増やす
      divisorを増やす
   }
   
   真が答え
}