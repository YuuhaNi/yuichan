標準ライブラリを使う

sort_array = 入力 array に対し {
   # 配列が空または要素が1つ以下の場合はそのまま返す
   もし array の大きさ が 0 ならば {
      array が答え
   }
   もし array の大きさ が 1 ならば {
      array が答え
   }

   # 配列のコピーを作成
   result = []
   i = 0
   array の大きさ 回くり返す {
      result に array[i] を追加する
      i を増やす
   }

   # 最初の要素と最後の要素の和を計算
   first = result[0]
   last = result[差(result の大きさ, 1)]
   sum = 和(first, last)

   # 和が奇数か偶数かで昇順・降順を判定
   # 奇数判定：剰余(sum, 2) が 1 なら奇数
   remainder = 剰余(sum, 2)

   # バブルソートで昇順にソート
   j = 0
   result の大きさ 回くり返す {
      k = 0
      差(result の大きさ, 1) 回くり返す {
         もし remainder が 1 ならば {
            # 昇順：左が右より大きければ入れ替え
            もし result[k] が result[和(k, 1)] より大きい ならば {
               temp = result[k]
               result[k] = result[和(k, 1)]
               result[和(k, 1)] = temp
            }
         } そうでなければ {
            # 降順：左が右より小さければ入れ替え
            もし result[k] が result[和(k, 1)] より小さい ならば {
               temp = result[k]
               result[k] = result[和(k, 1)]
               result[和(k, 1)] = temp
            }
         }
         k を増やす
      }
      j を増やす
   }

   result が答え
}