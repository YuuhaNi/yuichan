標準ライブラリを使う

get_max_triples = 入力 n に対し {
   # 配列 a を作成: a[i] = i * i - i + 1
   a = []
   i = 0
   n回くり返す {
      iを増やす
      value = 差(積(i, i), i)
      valueを増やす
      aにvalueを追加する
   }
   
   # 三つ組の個数をカウント
   count = 0
   i = 0
   n回くり返す {
      j = 0
      n回くり返す {
         もしjがiより小さいならば {
            jを増やす
            続ける
         }
         k = 0
         n回くり返す {
            もしkがjより小さいならば {
               kを増やす
               続ける
            }
            # a[i] + a[j] + a[k] が3の倍数か判定
            sum = 和(a[i], a[j], a[k])
            remainder = 剰余(sum, 3)
            もしremainder が 0 ならば {
               countを増やす
            }
            kを増やす
         }
         jを増やす
      }
      iを増やす
   }
   
   countが答え
}