標準ライブラリを使う

valid_date = 入力 date に対し {
   # 空文字列チェック
   もし date の大きさ が 0 ならば {
      偽が答え
   }

   # フォーマットチェック: mm-dd-yyyy
   # ハイフンが正確に2つあるか確認
   hyphen_count = 0
   i = 0
   date の大きさ 回くり返す {
      もし date[i] が 45 ならば {
         # 45 は '-' の文字コード
         hyphen_count を増やす
      }
      i を増やす
   }
   もし hyphen_count が 2 以外 ならば {
      偽が答え
   }

   # mm-dd-yyyy に分割
   parts = []
   current = ""
   i = 0
   date の大きさ 回くり返す {
      char = date[i]
      もし char が 45 ならば {
         # ハイフン区切り
         parts に current を追加する
         current = ""
      } そうでなければ {
         current に char を追加する
      }
      i を増やす
   }
   parts に current を追加する

   # 3つのパートに分かれているか確認
   もし parts の大きさ が 3 以外 ならば {
      偽が答え
   }

   # 月、日、年を取得
   month_str = parts[0]
   day_str = parts[1]
   year_str = parts[2]

   # 各パートが数字のみで構成されているか確認
   month = 整数化(month_str)
   day = 整数化(day_str)
   year = 整数化(year_str)

   # 月の検証: 1～12
   もし month が 1 より小さい ならば {
      偽が答え
   }
   もし month が 12 より大きい ならば {
      偽が答え
   }

   # 日の検証
   valid_day = 偽

   # 31日の月: 1,3,5,7,8,10,12
   もし month が 1 ならば {
      もし day が 1 以上 ならば {
         もし day が 31 以下 ならば {
            valid_day = 真
         }
      }
   }
   もし month が 3 ならば {
      もし day が 1 以上 ならば {
         もし day が 31 以下 ならば {
            valid_day = 真
         }
      }
   }
   もし month が 5 ならば {
      もし day が 1 以上 ならば {
         もし day が 31 以下 ならば {
            valid_day = 真
         }
      }
   }
   もし month が 7 ならば {
      もし day が 1 以上 ならば {
         もし day が 31 以下 ならば {
            valid_day = 真
         }
      }
   }
   もし month が 8 ならば {
      もし day が 1 以上 ならば {
         もし day が 31 以下 ならば {
            valid_day = 真
         }
      }
   }
   もし month が 10 ならば {
      もし day が 1 以上 ならば {
         もし day が 31 以下 ならば {
            valid_day = 真
         }
      }
   }
   もし month が 12 ならば {
      もし day が 1 以上 ならば {
         もし day が 31 以下 ならば {
            valid_day = 真
         }
      }
   }

   # 30日の月: 4,6,9,11
   もし month が 4 ならば {
      もし day が 1 以上 ならば {
         もし day が 30 以下 ならば {
            valid_day = 真
         }
      }
   }
   もし month が 6 ならば {
      もし day が 1 以上 ならば {
         もし day が 30 以下 ならば {
            valid_day = 真
         }
      }
   }
   もし month が 9 ならば {
      もし day が 1 以上 ならば {
         もし day が 30 以下 ならば {
            valid_day = 真
         }
      }
   }
   もし month が 11 ならば {
      もし day が 1 以上 ならば {
         もし day が 30 以下 ならば {
            valid_day = 真
         }
      }
   }

   # 2月: 1～29日
   もし month が 2 ならば {
      もし day が 1 以上 ならば {
         もし day が 29 以下 ならば {
            valid_day = 真
         }
      }
   }

   valid_day が答え
}