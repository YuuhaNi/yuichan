標準ライブラリを使う

is_multiply_prime = 入力 a に対し {
   # 素因数分解して、ちょうど3つの素数の積かどうかを判定
   count = 0
   n = a
   
   # 2で割り切れる回数をカウント
   2回くり返す{
      もしn が 0 以外ならば{
         もし剰余(n, 2)が0ならば{
            countを増やす
            n = 商(n, 2)
         }そうでなければ{
            くり返しを抜ける
         }
      }
   }
   
   # 3以上の奇数で割り切れる回数をカウント
   i = 3
   100回くり返す{
      もしiがnより大きいならば{
         くり返しを抜ける
      }
      100回くり返す{
         もしn が 0 以外ならば{
            もし剰余(n, i)が0ならば{
               countを増やす
               n = 商(n, i)
            }そうでなければ{
               くり返しを抜ける
            }
         }
      }
      i = 和(i, 2)
   }
   
   # nが1より大きければ、nそのものが素因数
   もしnが1より大きいならば{
      countを増やす
   }
   
   # ちょうど3つの素因数があれば真
   もしcountが3ならば{
      真が答え
   }そうでなければ{
      偽が答え
   }
}