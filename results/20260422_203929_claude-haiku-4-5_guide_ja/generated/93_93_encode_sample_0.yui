標準ライブラリを使う

encode = 入力 message に対し {
   result = ""
   i = 0
   messageの大きさ回くり返す {
      char = message[i]
      
      # 大文字小文字を入れ替える
      もしchar[0]が65以上ならば {
         もしchar[0]が90以下ならば {
            # 大文字 A-Z (65-90) → 小文字に
            char = 文字列化(和(char[0], 32))
         }
      }
      そうでなければ {
         もしchar[0]が97以上ならば {
            もしchar[0]が122以下ならば {
               # 小文字 a-z (97-122) → 大文字に
               char = 文字列化(差(char[0], 32))
            }
         }
      }
      
      # 母音を置き換える
      もしchar[0]が97ならば {
         # 'a' → 2つ前は '_' (95) だが、実際には母音の2つ前の文字
         # a(97) → 2つ前 = 95 (underscore) だが、問題の意図は
         # a → _ ではなく a → 2つ前の母音の位置の文字
         # a,e,i,o,u の2つ前は: _(95), c(99), g(103), m(109), s(115)
         char = "_"
      }
      そうでなければ {
         もしchar[0]が101ならば {
            # 'e' → 2つ前 = 'c'
            char = "c"
         }
         そうでなければ {
            もしchar[0]が105ならば {
               # 'i' → 2つ前 = 'g'
               char = "g"
            }
            そうでなければ {
               もしchar[0]が111ならば {
                  # 'o' → 2つ前 = 'm'
                  char = "m"
               }
               そうでなければ {
                  もしchar[0]が117ならば {
                     # 'u' → 2つ前 = 's'
                     char = "s"
                  }
                  そうでなければ {
                     もしchar[0]が65ならば {
                        # 'A' → 'a'に変換後 → '_'
                        char = "_"
                     }
                     そうでなければ {
                        もしchar[0]が69ならば {
                           # 'E' → 'e'に変換後 → 'C'
                           char = "C"
                        }
                        そうでなければ {
                           もしchar[0]が73ならば {
                              # 'I' → 'i'に変換後 → 'G'
                              char = "G"
                           }
                           そうでなければ {
                              もしchar[0]が79ならば {
                                 # 'O' → 'o'に変換後 → 'M'
                                 char = "M"
                              }
                              そうでなければ {
                                 もしchar[0]が85ならば {
                                    # 'U' → 'u'に変換後 → 'S'
                                    char = "S"
                                 }
                              }
                           }
                        }
                     }
                  }
               }
            }
         }
      }
      
      resultにcharを追加する
      iを増やす
   }
   
   resultが答え
}