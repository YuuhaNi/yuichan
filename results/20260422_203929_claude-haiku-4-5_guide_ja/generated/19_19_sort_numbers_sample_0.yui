標準ライブラリを使う

sort_numbers = 入力 numbers に対し {
   # 英単語を数値にマッピングするオブジェクト
   word_to_num = {
      "zero": 0,
      "one": 1,
      "two": 2,
      "three": 3,
      "four": 4,
      "five": 5,
      "six": 6,
      "seven": 7,
      "eight": 8,
      "nine": 9
   }
   
   # 数値を英単語にマッピングするオブジェクト
   num_to_word = {
      "0": "zero",
      "1": "one",
      "2": "two",
      "3": "three",
      "4": "four",
      "5": "five",
      "6": "six",
      "7": "seven",
      "8": "eight",
      "9": "nine"
   }
   
   # 入力文字列を単語の配列に分割
   words = []
   current_word = ""
   i = 0
   numbersの大きさ回くり返す {
      char = numbers[i]
      もし char が 32 ならば {
         # スペース（文字コード32）の場合
         もし current_word の大きさ が 0 以外 ならば {
            words に current_word を追加する
            current_word = ""
         }
      } そうでなければ {
         current_word に char を追加する
      }
      i を増やす
   }
   # 最後の単語を追加
   もし current_word の大きさ が 0 以外 ならば {
      words に current_word を追加する
   }
   
   # 単語を数値に変換
   nums = []
   i = 0
   words の大きさ 回くり返す {
      word = words[i]
      num = word_to_num[word]
      nums に num を追加する
      i を増やす
   }
   
   # バブルソートで昇順にソート
   i = 0
   nums の大きさ 回くり返す {
      j = 0
      差(nums の大きさ, 1) 回くり返す {
         もし nums[j] が nums[差(j, -1)] より大きい ならば {
            # スワップ
            temp = nums[j]
            nums[j] = nums[差(j, -1)]
            nums[差(j, -1)] = temp
         }
         j を増やす
      }
      i を増やす
   }
   
   # ソート済みの数値を英単語に変換して結合
   result = ""
   i = 0
   nums の大きさ 回くり返す {
      num_str = 文字列化(nums[i])
      word = num_to_word[num_str]
      もし i が 0 ならば {
         result = word
      } そうでなければ {
         result = "{result} {word}"
      }
      i を増やす
   }
   
   result が答え
}