標準ライブラリを使う

prod_signs = 入力 arr に対し {
   もし arr の大きさ が 0 ならば {
      値なし が答え
   }
   
   abs_sum = 0
   sign_prod = 1
   
   arr の大きさ 回くり返す {
      i = 0
      arr の大きさ 回くり返す {
         もし i が arr の大きさ 以上 ならば {
            くり返しを抜ける
         }
         
         num = arr[i]
         abs_sum = 和(abs_sum, 絶対値(num))
         
         もし num が 0 ならば {
            sign_prod = 0
         } そうでなければ {
            もし num より小さい が 0 ならば {
               sign_prod = 積(sign_prod, -1)
            }
         }
         
         i を増やす
      }
      くり返しを抜ける
   }
   
   積(abs_sum, sign_prod) が答え
}