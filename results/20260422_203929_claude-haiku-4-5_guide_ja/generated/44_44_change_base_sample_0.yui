標準ライブラリを使う

change_base = 入力 x, base に対し {
   もし x が 0 ならば {
      "0" が答え
   }
   
   result = ""
   
   x 回くり返す {
      余り = 剰余(x, base)
      result に 文字列化(余り) を追加する
      x = 商(x, base)
      
      もし x が 0 ならば {
         くり返しを抜ける
      }
   }
   
   # 結果を逆順にする
   reversed = ""
   result の大きさ 回くり返す {
      i = 差(result の大きさ, 1)
      reversed に result[i] を追加する
      result の大きさ を減らす
   }
   
   reversed が答え
}