標準ライブラリを使う

maximum = 入力 arr, k に対し {
   result = []
   i = 0
   k回くり返す{
      max_val = 値なし
      max_idx = 0
      j = 0
      arrの大きさ回くり返す{
         もしj がresultのいずれでもないならば{
            もしmax_valが値なしならば{
               max_val = arr[j]
               max_idx = j
            }そうでなければ{
               もしarr[j]がmax_valより大きいならば{
                  max_val = arr[j]
                  max_idx = j
               }
            }
         }
         jを増やす
      }
      resultにmax_valを追加する
      iを増やす
   }
   result が答え
}