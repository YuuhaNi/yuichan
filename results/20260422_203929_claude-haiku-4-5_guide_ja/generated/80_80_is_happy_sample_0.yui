標準ライブラリを使う

is_happy = 入力 s に対し {
   # 文字列の長さが3未満なら偽
   もし s の大きさ が 3 より小さい ならば {
      偽 が答え
   }
   
   # 連続する3文字をチェック
   i = 0
   s の大きさ 回 くり返す {
      # i+2がs の大きさ以上なら終了
      もし 和(i, 2) が s の大きさ 以上 ならば {
         くり返しを抜ける
      }
      
      # 連続する3文字を取得
      char1 = s[i]
      char2 = s[和(i, 1)]
      char3 = s[和(i, 2)]
      
      # 3文字がすべて異なるかチェック
      もし char1 が char2 ならば {
         偽 が答え
      }
      もし char2 が char3 ならば {
         偽 が答え
      }
      もし char1 が char3 ならば {
         偽 が答え
      }
      
      i を増やす
   }
   
   # すべてのチェックを通過したら真
   真 が答え
}