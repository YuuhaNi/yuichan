標準ライブラリを使う

rounded_avg = 入力 n, m に対し {
   もし n が m より大きい ならば {
      -1 が答え
   }
   
   # n から m までの合計を計算
   合計 = 0
   i = n
   もし m が n 以上 ならば {
      差(m, n)を増やす
      差(m, n)回くり返す {
         合計を i を追加する
         i を増やす
      }
   }
   
   # 個数を計算
   個数 = 差(m, n)
   個数を増やす
   
   # 平均を計算して四捨五入
   平均 = 商(和(合計, 商(個数, 2)), 個数)
   
   # 2進数文字列に変換
   2進数 = "0b"
   ビット = 平均
   ビット回くり返す {
      もし ビット[0] が 1 ならば {
         2進数に "1" を追加する
      } そうでなければ {
         2進数に "0" を追加する
      }
      ビット を右シフト(ビット, 1) に置き換える
   }
   
   2進数 が答え
}
標準ライブラリを使う

rounded_avg = 入力 n, m に対し {
   もし n が m より大きい ならば {
      -1 が答え
   }
   
   # (n + m) / 2 を四捨五入
   合計 = 和(n, m)
   平均 = 商(合計, 2)
   
   # 2進数文字列に変換
   2進数 = "0b"
   i = 0
   平均の大きさ回くり返す {
      もし 平均[i] が 1 ならば {
         2進数に "1" を追加する
      } そうでなければ {
         2進数に "0" を追加する
      }
      i を増やす
   }
   
   2進数 が答え
}