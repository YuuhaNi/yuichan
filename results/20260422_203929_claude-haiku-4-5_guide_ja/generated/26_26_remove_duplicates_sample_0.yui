標準ライブラリを使う

remove_duplicates = 入力 numbers に対し {
   result = []
   i = 0
   numbers の大きさ 回くり返す {
      current = numbers[i]
      count = 0
      j = 0
      numbers の大きさ 回くり返す {
         もし numbers[j] が current ならば {
            count を増やす
         }
         j を増やす
      }
      もし count が 1 ならば {
         result に current を追加する
      }
      i を増やす
   }
   result が答え
}