標準ライブラリを使う

sort_third = 入力 l に対し {
   # インデックスが3で割り切れる要素を抽出
   third_elements = []
   i = 0
   l の大きさ 回くり返す {
      もし 剰余(i, 3) が 0 ならば {
         third_elements に l[i] を追加する
      }
      i を増やす
   }
   
   # third_elements をソート（バブルソート）
   j = 0
   third_elements の大きさ 回くり返す {
      k = 0
      差(third_elements の大きさ, 1) 回くり返す {
         もし third_elements[k] が third_elements[和(k, 1)] より大きい ならば {
            temp = third_elements[k]
            third_elements[k] = third_elements[和(k, 1)]
            third_elements[和(k, 1)] = temp
         }
         k を増やす
      }
      j を増やす
   }
   
   # 結果を構築
   result = []
   i = 0
   third_index = 0
   l の大きさ 回くり返す {
      もし 剰余(i, 3) が 0 ならば {
         result に third_elements[third_index] を追加する
         third_index を増やす
      }
      そうでなければ {
         result に l[i] を追加する
      }
      i を増やす
   }
   
   result が答え
}