標準ライブラリを使う

is_nested = 入力 string に対し {
   depth = 0
   max_depth = 0
   i = 0
   
   stringの大きさ回くり返す {
      char = string[i]
      
      もし char が 91 ならば {
         # 91 は '[' の文字コード
         depthを増やす
         もし depth が max_depth より大きい ならば {
            max_depth = depth
         }
      }
      
      もし char が 93 ならば {
         # 93 は ']' の文字コード
         depth を減らす
      }
      
      i を増やす
   }
   
   もし max_depth が 2 以上 ならば {
      真 が答え
   }
   そうでなければ {
      偽 が答え
   }
}