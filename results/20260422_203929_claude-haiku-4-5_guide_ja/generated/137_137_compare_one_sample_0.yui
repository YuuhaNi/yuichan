標準ライブラリを使う

compare_one = 入力 a, b に対し {
   # a を数値に変換
   a_num = 0
   a_type = 0
   もし整数判定(a)ならば {
      a_num = a
      a_type = 1
   } そうでなければ {
      もし小数判定(a)ならば {
         a_num = a
         a_type = 2
      } そうでなければ {
         もし文字列判定(a)ならば {
            # カンマをピリオドに置換
            a_str = a
            i = 0
            a_strの大きさ回くり返す {
               もしa_str[i]が44ならば {
                  a_str[i] = 46
               }
               iを増やす
            }
            a_num = 小数化(文字列化(a_str))
            a_type = 3
         }
      }
   }

   # b を数値に変換
   b_num = 0
   b_type = 0
   もし整数判定(b)ならば {
      b_num = b
      b_type = 1
   } そうでなければ {
      もし小数判定(b)ならば {
         b_num = b
         b_type = 2
      } そうでなければ {
         もし文字列判定(b)ならば {
            # カンマをピリオドに置換
            b_str = b
            i = 0
            b_strの大きさ回くり返す {
               もしb_str[i]が44ならば {
                  b_str[i] = 46
               }
               iを増やす
            }
            b_num = 小数化(文字列化(b_str))
            b_type = 3
         }
      }
   }

   # 値が同じかチェック
   もしa_numが b_num ならば {
      値なしが答え
   }

   # 大きい方を返す
   もしa_numがb_numより大きいならば {
      aが答え
   } そうでなければ {
      bが答え
   }
}