標準ライブラリを使う

is_bored = 入力 S に対し {
   count = 0
   i = 0
   
   Sの大きさ回くり返す{
      もしiがSの大きさ以上ならば{
         くり返しを抜ける
      }
      
      # 文の開始位置を探す（前の文の終わり以降の最初の非空白文字）
      もしS[i]が32以外ならば{
         # 現在位置がスペース以外なら、文の開始の可能性
         もしS[i]が73ならば{
            # 'I' の文字コードは 73
            もしiが差(Sの大きさ,1)以下ならば{
               もしS[和(i,1)]が32ならば{
                  # 次の文字がスペース（32）なら "I " で始まる
                  countを増やす
               }
            }
         }
      }
      
      # 次の文の区切り文字（. ? !）を探す
      i回くり返す{
         iを増やす
         もしiがSの大きさ以上ならば{
            くり返しを抜ける
         }
         もしS[i]が46ならば{
            # '.' の文字コードは 46
            くり返しを抜ける
         }
         もしS[i]が63ならば{
            # '?' の文字コードは 63
            くり返しを抜ける
         }
         もしS[i]が33ならば{
            # '!' の文字コードは 33
            くり返しを抜ける
         }
      }
      
      iを増やす
      
      # スペースをスキップ
      iを増やす回くり返す{
         もしiがSの大きさ以上ならば{
            くり返しを抜ける
         }
         もしS[i]が32以外ならば{
            くり返しを抜ける
         }
         iを増やす
      }
   }
   
   countが答え
}