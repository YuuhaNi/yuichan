標準ライブラリを使う

hex_key = 入力 num に対し {
   # 素数である16進数の桁: 2, 3, 5, 7, B(11), D(13)
   primes = ["2", "3", "5", "7", "B", "D"]
   
   count = 0
   i = 0
   numの大きさ回くり返す{
      current_char = num[i]
      
      # 現在の文字が素数リストに含まれているかチェック
      j = 0
      primesの大きさ回くり返す{
         もしcurrent_charがprimes[j]ならば{
            countを増やす
            くり返しを抜ける
         }
         jを増やす
      }
      
      iを増やす
   }
   
   countが答え
}