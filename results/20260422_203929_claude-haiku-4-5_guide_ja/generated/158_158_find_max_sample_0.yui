標準ライブラリを使う

find_max = 入力 words に対し {
   max_word = ""
   max_unique = 0
   
   words の大きさ回くり返す {
      i = 0
      word = words[i]
      unique_chars = []
      
      word の大きさ回くり返す {
         char = word[i]
         found = 偽
         
         unique_chars の大きさ回くり返す {
            j = 0
            もし unique_chars[j] が char ならば {
               found = 真
               くり返しを抜ける
            }
            j を増やす
         }
         
         もし found が 偽 ならば {
            unique_chars に char を追加する
         }
         
         i を増やす
      }
      
      unique_count = unique_chars の大きさ
      
      もし unique_count が max_unique より大きい ならば {
         max_unique = unique_count
         max_word = word
      }
      そうでなければ {
         もし unique_count が max_unique ならば {
            もし word が max_word より小さい ならば {
               max_word = word
            }
         }
      }
      
      i を増やす
   }
   
   max_word が答え
}