標準ライブラリを使う

cycpattern_check = 入力 a, b に対し {
   # b の長さが a の長さより大きい場合は False
   もし b の大きさが a の大きさより大きいならば {
      偽が答え
   }

   # b を2倍にした文字列を作る（回転パターンをすべて含む）
   doubled = ""
   i = 0
   積(2, b の大きさ) 回くり返す {
      もし i が b の大きさ以上ならば {
         doubled に b[差(i, b の大きさ)] を追加する
      } そうでなければ {
         doubled に b[i] を追加する
      }
      i を増やす
   }

   # a が doubled の部分文字列かどうかを確認
   j = 0
   a の大きさ 回くり返す {
      match = 真
      k = 0
      a の大きさ 回くり返す {
         もし doubled[和(j, k)] が a[k] 以外ならば {
            match = 偽
            くり返しを抜ける
         }
         k を増やす
      }
      もし match が 真 ならば {
         真が答え
      }
      j を増やす
   }

   偽が答え
}