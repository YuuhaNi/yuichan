標準ライブラリを使う

pluck = 入力 arr に対し {
   もし arr の大きさ が 0 ならば {
      [] が答え
   }
   
   smallest_even = 値なし
   smallest_index = 値なし
   
   i = 0
   arr の大きさ 回くり返す {
      value = arr[i]
      remainder = 剰余(value, 2)
      
      もし remainder が 0 ならば {
         もし smallest_even が 値なし ならば {
            smallest_even = value
            smallest_index = i
         } そうでなければ {
            もし value が smallest_even より小さい ならば {
               smallest_even = value
               smallest_index = i
            }
         }
      }
      
      i を増やす
   }
   
   もし smallest_even が 値なし ならば {
      [] が答え
   } そうでなければ {
      [smallest_even, smallest_index] が答え
   }
}