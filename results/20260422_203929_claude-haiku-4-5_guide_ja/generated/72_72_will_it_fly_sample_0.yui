標準ライブラリを使う

will_it_fly = 入力 q, w に対し {
   # 要素の合計を計算
   total = 0
   i = 0
   qの大きさ回くり返す{
      totalに q[i] を追加する
      iを増やす
   }
   
   # 合計が最大荷重を超えているかチェック
   もし total が w より大きい ならば {
      偽が答え
   }
   
   # 回文かどうかをチェック
   left = 0
   right = 差(qの大きさ, 1)
   balanced = 真
   
   qの大きさ回くり返す {
      もし left が right 以上 ならば {
         くり返しを抜ける
      }
      
      もし q[left] が q[right] 以外 ならば {
         balanced = 偽
         くり返しを抜ける
      }
      
      leftを増やす
      rightを減らす
   }
   
   balanced が答え
}