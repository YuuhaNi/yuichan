標準ライブラリを使う

move_one_ball = 入力 arr に対し {
   # 配列が空の場合は真を返す
   もしarrの大きさが0ならば{
      真が答え
   }

   # 配列の大きさを取得
   n = arrの大きさ
   
   # n回まで右シフト操作を試す
   i = 0
   n回くり返す{
      # 現在の配列がソート済みかチェック
      is_sorted = 真
      j = 0
      差(n, 1)回くり返す{
         もしarr[j]がarr[差(j, -1)]より大きいならば{
            is_sorted = 偽
            くり返しを抜ける
         }
         jを増やす
      }
      
      # ソート済みなら真を返す
      もしis_sortedが真ならば{
         真が答え
      }
      
      # 右シフト操作を実行
      last = arr[差(n, 1)]
      k = 差(n, 1)
      k回くり返す{
         arr[k] = arr[差(k, 1)]
         kを減らす
      }
      arr[0] = last
      
      iを増やす
   }
   
   # どの右シフト操作でもソートできなかった場合は偽を返す
   偽が答え
}