標準ライブラリを使う

count_upper = 入力 s に対し {
   count = 0
   i = 0
   s の大きさ 回くり返す {
      もし i が 2 で割り切れるならば {
         char = s[i]
         もし char が "A" のいずれかならば {
            count を増やす
         }
         もし char が "E" のいずれかならば {
            count を増やす
         }
         もし char が "I" のいずれかならば {
            count を増やす
         }
         もし char が "O" のいずれかならば {
            count を増やす
         }
         もし char が "U" のいずれかならば {
            count を増やす
         }
      }
      i を増やす
   }
   count が答え
}