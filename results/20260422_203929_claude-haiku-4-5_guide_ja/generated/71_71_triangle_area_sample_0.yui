標準ライブラリを使う

triangle_area = 入力 a, b, c に対し {
   # 三角形の有効性を確認
   # 任意の2辺の和が3辺より大きいかチェック
   もし和(a, b)がcより小さいならば {
      -1が答え
   }
   もし和(b, c)がaより小さいならば {
      -1が答え
   }
   もし和(a, c)がbより小さいならば {
      -1が答え
   }
   
   # ヘロンの公式を使用して面積を計算
   # s = (a + b + c) / 2
   s = 商(和(a, b, c), 2)
   
   # 面積 = √(s(s-a)(s-b)(s-c))
   area = 平方根(積(s, 差(s, a), 差(s, b), 差(s, c)))
   
   # 小数点以下2桁で四捨五入
   # 100倍して四捨五入し、100で割る
   rounded = 商(整数化(和(積(area, 100), 0.5)), 100)
   
   小数化(rounded)が答え
}