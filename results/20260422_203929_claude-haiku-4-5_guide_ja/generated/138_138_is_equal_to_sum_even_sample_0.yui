標準ライブラリを使う

is_equal_to_sum_even = 入力 n に対し {
   # 4つの正の偶数の最小合計は 2+2+2+2=8
   もし n が 8 より小さい ならば {
      偽が答え
   }
   
   # n を4つの正の偶数に分割できるかを調べる
   # a, b, c, d >= 2 (偶数の最小値) で a+b+c+d = n
   # つまり a+b+c = n-d で、d は 2 以上 n-6 以下
   
   a = 2
   n より小さい 回 くり返す {
      もし a が n 以上 ならば {
         くり返しを抜ける
      }
      
      b = 2
      n より小さい 回 くり返す {
         もし 和(a, b) が n 以上 ならば {
            くり返しを抜ける
         }
         
         c = 2
         n より小さい 回 くり返す {
            もし 和(a, b, c) が n 以上 ならば {
               くり返しを抜ける
            }
            
            d = 差(n, a, b, c)
            もし d が 2 以上 ならば {
               もし 剰余(d, 2) が 0 ならば {
                  真が答え
               }
            }
            
            c を 増やす
            c を 増やす
         }
         
         b を 増やす
         b を 増やす
      }
      
      a を 増やす
      a を 増やす
   }
   
   偽が答え
}