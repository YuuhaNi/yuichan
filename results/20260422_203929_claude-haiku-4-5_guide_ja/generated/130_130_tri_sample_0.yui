標準ライブラリを使う

tri = 入力 n に対し {
   # トリボナッチ数列を計算する関数
   tri_calc = 入力 k に対し {
      もし k が 1 ならば {
         3 が答え
      }
      そうでなければ {
         # k が偶数かどうかを判定
         もし 剰余(k, 2) が 0 ならば {
            # k が偶数の場合: 1 + k / 2
            和(1, 商(k, 2)) が答え
         }
         そうでなければ {
            # k が奇数の場合: tri(k-1) + tri(k-2) + tri(k+1)
            和(tri_calc(差(k, 1)), tri_calc(差(k, 2)), tri_calc(和(k, 1))) が答え
         }
      }
   }
   
   # 最初の n + 1 個の数をリストに格納
   result = []
   i = 1
   n回くり返す {
      result に tri_calc(i) を追加する
      i を増やす
   }
   result に tri_calc(1) を追加する
   
   result が答え
}