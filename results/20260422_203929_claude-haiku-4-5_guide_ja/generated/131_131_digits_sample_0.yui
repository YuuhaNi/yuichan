標準ライブラリを使う

digits = 入力 n に対し {
   s = 文字列化(n)
   result = 1
   found = 偽
   
   sの大きさ回くり返す{
      i = 0
      sの大きさ回くり返す{
         char = s[i]
         digit = 整数化(char)
         
         もし剰余(digit, 2)が0以外ならば{
            result = 積(result, digit)
            found = 真
         }
         
         iを増やす
      }
   }
   
   もしfoundが偽ならば{
      0が答え
   }
   そうでなければ{
      resultが答え
   }
}