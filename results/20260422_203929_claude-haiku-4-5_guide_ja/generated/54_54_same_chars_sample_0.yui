標準ライブラリを使う

same_chars = 入力 s0, s1 に対し {
   # s0 と s1 に含まれる一意の文字を集める
   chars0 = []
   chars1 = []
   
   # s0 の各文字をチェック
   s0の大きさ回くり返す{
      i = 0
      found = 偽
      charsの大きさ回くり返す{
         もしchars0[i]がs0[i]ならば{
            found = 真
            くり返しを抜ける
         }
         iを増やす
      }
      もしfoundが偽ならば{
         chars0にs0[i]を追加する
      }
   }
   
   # s1 の各文字をチェック
   s1の大きさ回くり返す{
      i = 0
      found = 偽
      chars1の大きさ回くり返す{
         もしchars1[i]がs1[i]ならば{
            found = 真
            くり返しを抜ける
         }
         iを増やす
      }
      もしfoundが偽ならば{
         chars1にs1[i]を追加する
      }
   }
   
   # chars0 と chars1 のサイズが異なれば偽
   もしchars0の大きさがchars1の大きさ以外ならば{
      偽が答え
   }
   
   # chars0 の各文字が chars1 に含まれているかチェック
   chars0の大きさ回くり返す{
      i = 0
      found = 偽
      chars1の大きさ回くり返す{
         もしchars0[i]がchars1[i]ならば{
            found = 真
            くり返しを抜ける
         }
         iを増やす
      }
      もしfoundが偽ならば{
         偽が答え
      }
   }
   
   真が答え
}