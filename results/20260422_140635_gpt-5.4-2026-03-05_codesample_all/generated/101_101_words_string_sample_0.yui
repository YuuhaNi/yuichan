標準ライブラリを使う

words_string = 入力 s に対し {
   result=[]
   current=""
   i=0
   n=sの大きさ

   n回くり返す{
      c=s[i]
      もしcが","のいずれかならば{
         もしcurrentが""以外ならば{
            resultにcurrentを追加する
            current=""
         }
      }
      そうでなければ{
         もしcが" "のいずれかならば{
            もしcurrentが""以外ならば{
               resultにcurrentを追加する
               current=""
            }
         }
         そうでなければ{
            currentにcを追加する
         }
      }
      iを増やす
   }

   もしcurrentが""以外ならば{
      resultにcurrentを追加する
   }

   resultが答え
}