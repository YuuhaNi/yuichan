標準ライブラリを使う

maximum = 入力 arr, k に対し {
   sorted=bubble_sort(arr)
   n=sortedの大きさ
   start=差(n,k)
   result=[]
   i=start
   k回くり返す{
      resultにsorted[i]を追加する
      iを増やす
   }
   resultが答え
}

bubble_sort=入力Aに対し{
   n=Aの大きさ
   n回くり返す{
      i=0
      差(n,1)回くり返す{
         j=和(i,1)
         もしA[i]がA[j]より大きいならば{
            tmp=A[i]
            A[i]=A[j]
            A[j]=tmp
         }
         iを増やす
      }
   }
   Aが答え
}