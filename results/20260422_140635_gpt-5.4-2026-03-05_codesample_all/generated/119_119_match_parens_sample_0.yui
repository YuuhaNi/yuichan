標準ライブラリを使う

match_parens = 入力 lst に対し {
   a=lst[0]
   b=lst[1]

   # 順序 1: a + b を調べる
   ok1=1
   bal=0

   i=0
   aの大きさ回くり返す{
      c=a[i]
      もしcが40ならば{
         balを増やす
      }
      そうでなければ{
         balを減らす
      }
      もしbalが0より小さいならば{
         ok1=0
      }
      iを増やす
   }

   i=0
   bの大きさ回くり返す{
      c=b[i]
      もしcが40ならば{
         balを増やす
      }
      そうでなければ{
         balを減らす
      }
      もしbalが0より小さいならば{
         ok1=0
      }
      iを増やす
   }

   もしbalが0以外ならば{
      ok1=0
   }

   もしok1が1ならば{
      "Yes"が答え
   }

   # 順序 2: b + a を調べる
   ok2=1
   bal=0

   i=0
   bの大きさ回くり返す{
      c=b[i]
      もしcが40ならば{
         balを増やす
      }
      そうでなければ{
         balを減らす
      }
      もしbalが0より小さいならば{
         ok2=0
      }
      iを増やす
   }

   i=0
   aの大きさ回くり返す{
      c=a[i]
      もしcが40ならば{
         balを増やす
      }
      そうでなければ{
         balを減らす
      }
      もしbalが0より小さいならば{
         ok2=0
      }
      iを増やす
   }

   もしbalが0以外ならば{
      ok2=0
   }

   もしok2が1ならば{
      "Yes"が答え
   }

   "No"が答え
}