標準ライブラリを使う

is_bored = 入力 S に対し {
   count=0
   start=1
   i=0
   n=Sの大きさ

   n回くり返す{
      c=S[i]

      もしstartが1ならば{
         もしcが73ならば{
            j=和(i,1)
            もしjがnより小さいならば{
               もしS[j]が32ならば{
                  countを増やす
               }
            }
         }
      }

      もしcが46ならば{
         start=1
      }
      もしcが63ならば{
         start=1
      }
      もしcが33ならば{
         start=1
      }

      もしcが46以外ならば{
         もしcが63以外ならば{
            もしcが33以外ならば{
               もしcが32以外ならば{
                  start=0
               }
            }
         }
      }

      iを増やす
   }

   countが答え
}