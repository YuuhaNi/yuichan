標準ライブラリを使う

is_multiply_prime = 入力 a に対し {
   # 3つの素数 p,q,r の積 a = p*q*r を全探索する
   p=2
   99回くり返す{
      もしpがaより大きいならば{
         くり返しを抜ける
      }

      # p が素数か判定
      p_prime=1
      d=2
      p回くり返す{
         もしdがpより小さいならば{
            もし剰余(p,d)が0ならば{
               p_prime=0
            }
         }
         dを増やす
      }

      もしp_primeが1ならば{
         q=2
         99回くり返す{
            pq=積(p,q)
            もしpqがaより大きいならば{
               くり返しを抜ける
            }

            # q が素数か判定
            q_prime=1
            d=2
            q回くり返す{
               もしdがqより小さいならば{
                  もし剰余(q,d)が0ならば{
                     q_prime=0
                  }
               }
               dを増やす
            }

            もしq_primeが1ならば{
               もし剰余(a,pq)が0ならば{
                  r=商(a,pq)

                  # r が素数か判定
                  もしrが2以上ならば{
                     r_prime=1
                     d=2
                     r回くり返す{
                        もしdがrより小さいならば{
                           もし剰余(r,d)が0ならば{
                              r_prime=0
                           }
                        }
                        dを増やす
                     }
                     もしr_primeが1ならば{
                        真が答え
                     }
                  }
               }
            }
            qを増やす
         }
      }
      pを増やす
   }
   偽が答え
}