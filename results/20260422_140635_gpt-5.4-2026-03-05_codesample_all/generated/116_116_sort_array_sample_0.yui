標準ライブラリを使う

# 非負整数の配列を、
# 1. 2進表現における 1 の個数が少ない順
# 2. 1 の個数が同じなら数値が小さい順
# でソートする

# 整数 n の 2 進表現に含まれる 1 の個数を数える
bit_count=入力nに対し{
   x=絶対値(n)
   count=0
   # 0 のときは 1 の個数は 0
   xの大きさ回くり返す{
      もしx[0]が1ならば{
         countを増やす
      }
      x=rshift(x,1)
   }
   countが答え
}

sort_array = 入力 arr に対し {
   n=arrの大きさ
   n回くり返す{
      i=0
      差(n,1)回くり返す{
         j=和(i,1)
         a=arr[i]
         b=arr[j]
         ca=bit_count(a)
         cb=bit_count(b)

         swap=0
         もしcaがcbより大きいならば{
            swap=1
         }
         もしcaがcbならば{
            もしaがbより大きいならば{
               swap=1
            }
         }

         もしswapが1ならば{
            tmp=arr[i]
            arr[i]=arr[j]
            arr[j]=tmp
         }
         iを増やす
      }
   }
   arrが答え
}