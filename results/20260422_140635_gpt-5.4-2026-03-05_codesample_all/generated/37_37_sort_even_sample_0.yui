標準ライブラリを使う

sort_even = 入力 l に対し {
   evens=[]
   i=0
   n=lの大きさ

   # 偶数インデックスの要素を集める
   n回くり返す{
      もし剰余(i,2)が0ならば{
         evensにl[i]を追加する
      }
      iを増やす
   }

   # 偶数インデックス部分だけソート
   evens=bubble_sort(evens)

   # 元の配列に戻す
   result=[]
   i=0
   j=0
   n回くり返す{
      もし剰余(i,2)が0ならば{
         resultにevens[j]を追加する
         jを増やす
      }
      そうでなければ{
         resultにl[i]を追加する
      }
      iを増やす
   }

   resultが答え
}

bubble_sort=入力Aに対し{
   n=Aの大きさ
   n回くり返す{
      i=0
      差(n,1)回くり返す{
         j=和(i,1)
         もしA[i]がA[j]より大きいならば{
            tmp=A[i]
            A[i]=A[j]
            A[j]=tmp
         }
         iを増やす
      }
   }
   Aが答え
}