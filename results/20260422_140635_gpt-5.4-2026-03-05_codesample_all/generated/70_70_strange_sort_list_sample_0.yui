標準ライブラリを使う

strange_sort_list = 入力 lst に対し {
   sorted=bubble_sort(lst)
   n=sortedの大きさ
   result=[]
   left=0
   right=差(n,1)

   n回くり返す{
      もしleftがright以下ならば{
         resultにsorted[left]を追加する
         leftを増やす
      }
      もしleftがright以下ならば{
         resultにsorted[right]を追加する
         rightを減らす
      }
   }
   resultが答え
}

bubble_sort=入力Aに対し{
   n=Aの大きさ
   n回くり返す{
      i=0
      差(n,1)回くり返す{
         j=和(i,1)
         もしA[i]がA[j]より大きいならば{
            tmp=A[i]
            A[i]=A[j]
            A[j]=tmp
         }
         iを増やす
      }
   }
   Aが答え
}