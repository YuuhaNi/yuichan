標準ライブラリを使う

compare_one = 入力 a, b に対し {
   # 文字列なら "," を "." に置き換えてから小数化する
   もし文字列判定(a)ならば{
      sa=replace(a,",",".")
      va=小数化(sa)
   }
   そうでなければ{
      va=小数化(a)
   }

   もし文字列判定(b)ならば{
      sb=replace(b,",",".")
      vb=小数化(sb)
   }
   そうでなければ{
      vb=小数化(b)
   }

   もしvaがvbより大きいならば{
      aが答え
   }
   もしvbがvaより大きいならば{
      bが答え
   }
   値なしが答え
}