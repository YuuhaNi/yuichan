標準ライブラリを使う

check_dict_case = 入力dictに対し{
   keys=dictのキー列
   n=keysの大きさ

   # 空辞書は False
   もしnが0ならば{
      偽が答え
   }

   all_lower=1
   all_upper=1

   i=0
   n回くり返す{
      k=keys[i]

      # キーは文字列でなければならない
      もし文字列判定(k)が偽ならば{
         偽が答え
      }

      j=0
      kの大きさ回くり返す{
         c=k[j]

         # 小文字 a..z 以外があれば all_lower ではない
         もしcが97より小さいならば{
            all_lower=0
         }
         もしcが122より大きいならば{
            all_lower=0
         }

         # 大文字 A..Z 以外があれば all_upper ではない
         もしcが65より小さいならば{
            all_upper=0
         }
         もしcが90より大きいならば{
            all_upper=0
         }

         jを増やす
      }
      iを増やす
   }

   # すべて小文字なら True
   もしall_lowerが1ならば{
      真が答え
   }

   # すべて大文字なら False
   もしall_upperが1ならば{
      偽が答え
   }

   # それ以外も False
   偽が答え
}