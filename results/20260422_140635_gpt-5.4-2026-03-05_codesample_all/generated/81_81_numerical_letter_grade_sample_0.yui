標準ライブラリを使う

numerical_letter_grade=入力gradesに対し{
   result=[]
   n=gradesの大きさ
   i=0
   n回くり返す{
      g=grades[i]
      letter="E"

      もしgが4.0ならば{
         letter="A+"
      }
      そうでなければ{
         もしgが3.7より大きいならば{
            letter="A"
         }
         そうでなければ{
            もしgが3.3より大きいならば{
               letter="A-"
            }
            そうでなければ{
               もしgが3.0より大きいならば{
                  letter="B+"
               }
               そうでなければ{
                  もしgが2.7より大きいならば{
                     letter="B"
                  }
                  そうでなければ{
                     もしgが2.3より大きいならば{
                        letter="B-"
                     }
                     そうでなければ{
                        もしgが2.0より大きいならば{
                           letter="C+"
                        }
                        そうでなければ{
                           もしgが1.7より大きいならば{
                              letter="C"
                           }
                           そうでなければ{
                              もしgが1.3より大きいならば{
                                 letter="C-"
                              }
                              そうでなければ{
                                 もしgが1.0より大きいならば{
                                    letter="D+"
                                 }
                                 そうでなければ{
                                    もしgが0.7より大きいならば{
                                       letter="D"
                                    }
                                    そうでなければ{
                                       もしgが0.0より大きいならば{
                                          letter="D-"
                                       }
                                    }
                                 }
                              }
                           }
                        }
                     }
                  }
               }
            }
         }
      }

      resultにletterを追加する
      iを増やす
   }
   resultが答え
}