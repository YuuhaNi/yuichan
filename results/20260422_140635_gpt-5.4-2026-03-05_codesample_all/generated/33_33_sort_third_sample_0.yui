標準ライブラリを使う

sort_third = 入力 l に対し {
   result=[]
   thirds=[]
   n=lの大きさ
   i=0

   n回くり返す{
      もし剰余(i,3)が0ならば{
         thirdsにl[i]を追加する
      }
      iを増やす
   }

   thirds=bubble_sort(thirds)

   ti=0
   i=0
   n回くり返す{
      もし剰余(i,3)が0ならば{
         resultにthirds[ti]を追加する
         tiを増やす
      }
      そうでなければ{
         resultにl[i]を追加する
      }
      iを増やす
   }

   resultが答え
}

bubble_sort=入力Aに対し{
   n=Aの大きさ
   n回くり返す{
      i=0
      差(n,1)回くり返す{
         j=和(i,1)
         もしA[i]がA[j]より大きいならば{
            tmp=A[i]
            A[i]=A[j]
            A[j]=tmp
         }
         iを増やす
      }
   }
   Aが答え
}