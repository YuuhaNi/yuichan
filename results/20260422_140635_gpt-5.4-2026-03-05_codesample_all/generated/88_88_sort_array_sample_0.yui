標準ライブラリを使う

sort_array = 入力 array に対し {
   n=arrayの大きさ

   # 元の配列を変更しないためコピーを作る
   result=[]
   i=0
   n回くり返す{
      resultにarray[i]を追加する
      iを増やす
   }

   # 要素数 0 または 1 ならそのまま返す
   もしnが1以下ならば{
      resultが答え
   }

   # 先頭と末尾の和の偶奇で並び順を決める
   first=array[0]
   last=array[差(n,1)]
   s=和(first,last)
   parity=剰余(s,2)

   # バブルソート
   n回くり返す{
      i=0
      差(n,1)回くり返す{
         j=和(i,1)

         # parity=1 なら昇順、parity=0 なら降順
         swap=0
         もしparityが1ならば{
            もしresult[i]がresult[j]より大きいならば{
               swap=1
            }
         }
         そうでなければ{
            もしresult[i]がresult[j]より小さいならば{
               swap=1
            }
         }

         もしswapが1ならば{
            tmp=result[i]
            result[i]=result[j]
            result[j]=tmp
         }
         iを増やす
      }
   }

   resultが答え
}