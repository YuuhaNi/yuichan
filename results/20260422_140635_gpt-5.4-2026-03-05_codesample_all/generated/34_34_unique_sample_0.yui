標準ライブラリを使う

unique = 入力 l に対し {
   result=[]
   i=0
   lの大きさ回くり返す{
      x=l[i]
      もしxがresultのいずれでもないならば{
         resultにxを追加する
      }
      iを増やす
   }
   bubble_sort(result)が答え
}

bubble_sort=入力Aに対し{
   n=Aの大きさ
   n回くり返す{
      i=0
      差(n,1)回くり返す{
         j=和(i,1)
         もしA[i]がA[j]より大きいならば{
            tmp=A[i]
            A[i]=A[j]
            A[j]=tmp
         }
         iを増やす
      }
   }
   Aが答え
}