標準ライブラリを使う

anti_shuffle = 入力 s に対し {
   result=""
   word=""
   i=0
   n=sの大きさ

   n回くり返す{
      c=s[i]
      もしcが32ならば{
         sorted=bubble_sort(word)
         k=0
         sortedの大きさ回くり返す{
            resultにsorted[k]を追加する
            kを増やす
         }
         resultにcを追加する
         word=""
      }
      そうでなければ{
         wordにcを追加する
      }
      iを増やす
   }

   sorted=bubble_sort(word)
   k=0
   sortedの大きさ回くり返す{
      resultにsorted[k]を追加する
      kを増やす
   }

   resultが答え
}

bubble_sort=入力Aに対し{
   n=Aの大きさ
   n回くり返す{
      i=0
      差(n,1)回くり返す{
         j=和(i,1)
         もしA[i]がA[j]より大きいならば{
            tmp=A[i]
            A[i]=A[j]
            A[j]=tmp
         }
         iを増やす
      }
   }
   Aが答え
}