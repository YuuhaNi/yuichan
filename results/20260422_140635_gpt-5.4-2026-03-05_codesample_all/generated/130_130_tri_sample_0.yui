標準ライブラリを使う

tri = 入力 n に対し {
   result=[1]
   もしnが0ならば{
      resultが答え
   }

   i=1
   n回くり返す{
      もし剰余(i,2)が0ならば{
         x=和(1,商(i,2))
      }
      そうでなければ{
         もしiが1ならば{
            x=3
         }
         そうでなければ{
            next=和(1,商(和(i,1),2))
            x=和(result[差(i,1)],和(result[差(i,2)],next))
         }
      }
      resultにxを追加する
      iを増やす
   }
   resultが答え
}