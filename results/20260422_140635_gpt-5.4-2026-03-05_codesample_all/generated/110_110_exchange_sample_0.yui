標準ライブラリを使う

exchange = 入力 lst1, lst2 に対し {
   odd1=0
   even2=0

   i=0
   lst1の大きさ回くり返す{
      もし剰余(lst1[i],2)が0以外ならば{
         odd1を増やす
      }
      iを増やす
   }

   j=0
   lst2の大きさ回くり返す{
      もし剰余(lst2[j],2)が0ならば{
         even2を増やす
      }
      jを増やす
   }

   もしeven2がodd1以上ならば{
      "YES"が答え
   }
   そうでなければ{
      "NO"が答え
   }
}