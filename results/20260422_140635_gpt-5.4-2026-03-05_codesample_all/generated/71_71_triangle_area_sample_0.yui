標準ライブラリを使う

triangle_area = 入力 a, b, c に対し {
   ok=1
   ab=和(a,b)
   ac=和(a,c)
   bc=和(b,c)

   もしabがc以下ならば{
      ok=0
   }
   もしacがb以下ならば{
      ok=0
   }
   もしbcがa以下ならば{
      ok=0
   }

   もしokが0ならば{
      -1が答え
   }

   s=商(小数化(和(a,和(b,c))),小数化(2))
   area2=積(s,積(差(s,a),積(差(s,b),差(s,c))))
   area=平方根(area2)
   rounded=商(整数化(和(積(area,100),0.5)),100.0)
   roundedが答え
}