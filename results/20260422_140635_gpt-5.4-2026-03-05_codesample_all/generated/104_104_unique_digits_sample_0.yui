標準ライブラリを使う

unique_digits = 入力 x に対し {
   result=[]
   n=xの大きさ
   i=0
   n回くり返す{
      v=x[i]
      s=文字列化(v)
      digits=sの大きさ
      even=剰余(digits,2)
      もしevenが1ならば{
         resultにvを追加する
      }
      iを増やす
   }
   bubble_sort(result)が答え
}

bubble_sort=入力Aに対し{
   n=Aの大きさ
   n回くり返す{
      i=0
      差(n,1)回くり返す{
         j=和(i,1)
         もしA[i]がA[j]より大きいならば{
            tmp=A[i]
            A[i]=A[j]
            A[j]=tmp
         }
         iを増やす
      }
   }
   Aが答え
}