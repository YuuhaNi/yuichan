標準ライブラリを使う

valid_date=入力dateに対し{
   # 1. 空文字列は無効
   もしdateの大きさが0ならば{
      偽が答え
   }

   # 2. 形式 mm-dd-yyyy か確認する
   もしdateの大きさが10以外ならば{
      偽が答え
   }
   もしdate[2]が45以外ならば{
      偽が答え
   }
   もしdate[5]が45以外ならば{
      偽が答え
   }

   # 3. 数字だけで構成されているか確認する
   i=0
   10回くり返す{
      c=date[i]
      もしiが2以外ならば{
         もしiが5以外ならば{
            もしcが48より小さいならば{
               偽が答え
            }
            もしcが57より大きいならば{
               偽が答え
            }
         }
      }
      iを増やす
   }

   # 4. 月・日を取り出す
   m1=差(date[0],48)
   m2=差(date[1],48)
   month=和(積(m1,10),m2)

   d1=差(date[3],48)
   d2=差(date[4],48)
   day=和(積(d1,10),d2)

   # 5. 月の範囲確認
   もしmonthが1より小さいならば{
      偽が答え
   }
   もしmonthが12より大きいならば{
      偽が答え
   }

   # 6. 日の範囲確認
   もしdayが1より小さいならば{
      偽が答え
   }

   # 31日ある月
   もしmonthが1ならば{
      もしdayが31以下ならば{ 真が答え }
      偽が答え
   }
   もしmonthが3ならば{
      もしdayが31以下ならば{ 真が答え }
      偽が答え
   }
   もしmonthが5ならば{
      もしdayが31以下ならば{ 真が答え }
      偽が答え
   }
   もしmonthが7ならば{
      もしdayが31以下ならば{ 真が答え }
      偽が答え
   }
   もしmonthが8ならば{
      もしdayが31以下ならば{ 真が答え }
      偽が答え
   }
   もしmonthが10ならば{
      もしdayが31以下ならば{ 真が答え }
      偽が答え
   }
   もしmonthが12ならば{
      もしdayが31以下ならば{ 真が答え }
      偽が答え
   }

   # 30日ある月
   もしmonthが4ならば{
      もしdayが30以下ならば{ 真が答え }
      偽が答え
   }
   もしmonthが6ならば{
      もしdayが30以下ならば{ 真が答え }
      偽が答え
   }
   もしmonthが9ならば{
      もしdayが30以下ならば{ 真が答え }
      偽が答え
   }
   もしmonthが11ならば{
      もしdayが30以下ならば{ 真が答え }
      偽が答え
   }

   # 2月
   もしmonthが2ならば{
      もしdayが29以下ならば{ 真が答え }
      偽が答え
   }

   偽が答え
}