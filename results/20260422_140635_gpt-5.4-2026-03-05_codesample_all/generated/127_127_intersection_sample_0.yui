標準ライブラリを使う

intersection = 入力 interval1, interval2 に対し {
   a1=interval1[0]
   b1=interval1[1]
   a2=interval2[0]
   b2=interval2[1]

   left=a1
   もしa2がleftより大きいならば{
      left=a2
   }

   right=b1
   もしb2がrightより小さいならば{
      right=b2
   }

   # 閉区間の共通部分 [left,right] の長さは right-left
   len=差(right,left)

   もしlenが2より小さいならば{
      "NO"が答え
   }

   is_prime=1
   d=2
   差(len,2)回くり返す{
      もし剰余(len,d)が0ならば{
         is_prime=0
      }
      dを増やす
   }

   もしis_primeが1ならば{
      "YES"が答え
   }
   そうでなければ{
      "NO"が答え
   }
}