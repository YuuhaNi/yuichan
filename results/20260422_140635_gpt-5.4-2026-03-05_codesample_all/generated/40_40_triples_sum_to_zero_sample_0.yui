標準ライブラリを使う

triples_sum_to_zero = 入力 l に対し {
   n=lの大きさ
   もしnが3より小さいならば{
      偽が答え
   }

   i=0
   n回くり返す{
      j=和(i,1)
      rem1=差(n,j)
      rem1回くり返す{
         k=和(j,1)
         rem2=差(n,k)
         rem2回くり返す{
            s=和(l[i],l[j],l[k])
            もしsが0ならば{
               真が答え
            }
            kを増やす
         }
         jを増やす
      }
      iを増やす
   }
   偽が答え
}