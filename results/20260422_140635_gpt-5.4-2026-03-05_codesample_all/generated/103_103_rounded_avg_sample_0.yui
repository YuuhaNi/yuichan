標準ライブラリを使う

rounded_avg = 入力 n, m に対し {
   もしnがmより大きいならば{
      差(0,1)が答え
   }

   count=和(差(m,n),1)
   total=商(積(和(n,m),count),2)

   q=商(total,count)
   r=剰余(total,count)

   doubled=積(r,2)
   もしdoubledがcount以上ならば{
      qを増やす
   }

   bits=""
   x=q

   もしxが0ならば{
      bits="0"
   }
   そうでなければ{
      もしxが1以上ならば{
         1000回くり返す{
            もしxが0より大きいならば{
               d=剰余(x,2)
               もしdが0ならば{
                  bits=文字列補間("{d}{bits}")
               }
               そうでなければ{
                  bits=文字列補間("{d}{bits}")
               }
               x=商(x,2)
            }
         }
      }
   }

   文字列補間("0b{bits}")が答え
}