標準ライブラリを使う

any_int = 入力 x, y, z に対し {
   もし整数判定(x)ならば{
      もし整数判定(y)ならば{
         もし整数判定(z)ならば{
            s1=和(x,y)
            s2=和(x,z)
            s3=和(y,z)
            もしs1がzならば{
               真が答え
            }
            もしs2がyならば{
               真が答え
            }
            もしs3がxならば{
               真が答え
            }
         }
      }
   }
   偽が答え
}