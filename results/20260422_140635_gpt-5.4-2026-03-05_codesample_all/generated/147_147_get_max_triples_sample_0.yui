標準ライブラリを使う

get_max_triples = 入力 n に対し {
   a=[]
   i=1
   n回くり返す{
      x=和(差(積(i,i),i),1)
      aにxを追加する
      iを増やす
   }

   count=0
   i=0
   n回くり返す{
      j=和(i,1)
      remj=差(n,j)
      remj回くり返す{
         k=和(j,1)
         remk=差(n,k)
         remk回くり返す{
            s=和(a[i],a[j],a[k])
            もし剰余(s,3)が0ならば{
               countを増やす
            }
            kを増やす
         }
         jを増やす
      }
      iを増やす
   }
   countが答え
}