標準ライブラリを使う

check_if_last_char_is_a_letter = 入力 txt に対し {
   n=txtの大きさ
   もしnが0ならば{
      偽が答え
   }

   last=txt[差(n,1)]

   is_letter=0
   もしlastが65以上ならば{
      もしlastが90以下ならば{
         is_letter=1
      }
   }
   もしlastが97以上ならば{
      もしlastが122以下ならば{
         is_letter=1
      }
   }

   もしis_letterが0ならば{
      偽が答え
   }

   もしnが1ならば{
      真が答え
   }

   prev=txt[差(n,2)]
   もしprevが32ならば{
      真が答え
   }

   偽が答え
}