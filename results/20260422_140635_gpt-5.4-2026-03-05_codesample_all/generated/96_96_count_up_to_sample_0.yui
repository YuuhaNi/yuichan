標準ライブラリを使う

count_up_to=入力nに対し{
   result=[]
   i=2
   n回くり返す{
      もしiがnより小さいならば{
         prime=1
         j=2
         i回くり返す{
            もしjがiより小さいならば{
               もし剰余(i,j)が0ならば{
                  prime=0
               }
            }
            jを増やす
         }
         もしprimeが1ならば{
            resultにiを追加する
         }
      }
      iを増やす
   }
   resultが答え
}