標準ライブラリを使う

solve = 入力 N に対し {
   s=文字列化(N)
   sum=0
   i=0
   sの大きさ回くり返す{
      c=s[i]
      d=差(c,48)
      sum=和(sum,d)
      iを増やす
   }

   もしsumが0ならば{
      "0"が答え
   }

   result=""
   x=sum
   20回くり返す{
      もしxが0より大きいならば{
         bit=剰余(x,2)
         c=和(bit,48)
         resultにcを追加する
         x=商(x,2)
      }
   }
   reverse(result)が答え
}