標準ライブラリを使う

flip_case = 入力 string に対し {
   result=""
   n=stringの大きさ
   i=0
   n回くり返す{
      c=string[i]
      nc=c

      # 英大文字 A..Z → 小文字
      もしcが65以上ならば{
         もしcが90以下ならば{
            nc=和(c,32)
         }
      }

      # 英小文字 a..z → 大文字
      もしcが97以上ならば{
         もしcが122以下ならば{
            nc=差(c,32)
         }
      }

      resultにncを追加する
      iを増やす
   }
   resultが答え
}