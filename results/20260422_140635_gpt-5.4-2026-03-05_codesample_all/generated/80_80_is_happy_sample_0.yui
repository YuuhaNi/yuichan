標準ライブラリを使う

is_happy = 入力 s に対し {
   n=sの大きさ
   もしnが3より小さいならば{
      偽が答え
   }

   i=0
   limit=差(n,2)
   limit回くり返す{
      a=s[i]
      b=s[和(i,1)]
      c=s[和(i,2)]
      もしaがb以外ならば{
         もしaがc以外ならば{
            もしbがc以外ならば{
               真が答え
            }
         }
      }
      iを増やす
   }
   偽が答え
}