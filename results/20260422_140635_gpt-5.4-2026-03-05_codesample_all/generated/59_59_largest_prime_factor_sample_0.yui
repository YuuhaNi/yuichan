標準ライブラリを使う

largest_prime_factor = 入力 n に対し {
   d=2
   last=1
   もし剰余(n,2)が0ならば{
      last=2
      もし剰余(n,d)が0ならば{
         n=商(n,d)
      }
      剰余(n,d)が0の間くり返す{
         n=商(n,d)
      }
   }
   d=3
   平方根(n)がd以上の間くり返す{
      もし剰余(n,d)が0ならば{
         last=d
         n=商(n,d)
         剰余(n,d)が0の間くり返す{
            n=商(n,d)
         }
      }
      d=和(d,2)
   }
   もしnが1より大きいならば{
      nが答え
   }
   lastが答え
}