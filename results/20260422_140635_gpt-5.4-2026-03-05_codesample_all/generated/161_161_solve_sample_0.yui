標準ライブラリを使う

solve=入力sに対し{
   result=""
   found=0
   n=sの大きさ
   i=0
   n回くり返す{
      c=s[i]
      nc=c

      # 大文字 A..Z → 小文字
      もしcが65以上ならば{
         もしcが90以下ならば{
            nc=和(c,32)
            found=1
         }
      }

      # 小文字 a..z → 大文字
      もしcが97以上ならば{
         もしcが122以下ならば{
            nc=差(c,32)
            found=1
         }
      }

      resultにncを追加する
      iを増やす
   }

   もしfoundが0ならば{
      reverse(result)が答え
   }

   resultが答え
}