標準ライブラリを使う

find_closest_elements = 入力 numbers に対し {
   sorted=bubble_sort(numbers)
   n=sortedの大きさ

   best_a=sorted[0]
   best_b=sorted[1]
   best_d=絶対値(差(best_b,best_a))

   i=1
   差(n,1)回くり返す{
      a=sorted[i]
      b=sorted[和(i,1)]
      d=絶対値(差(b,a))
      もしdがbest_dより小さいならば{
         best_a=a
         best_b=b
         best_d=d
      }
      iを増やす
   }
   [best_a,best_b]が答え
}

bubble_sort=入力Aに対し{
   n=Aの大きさ
   n回くり返す{
      i=0
      差(n,1)回くり返す{
         j=和(i,1)
         もしA[i]がA[j]より大きいならば{
            tmp=A[i]
            A[i]=A[j]
            A[j]=tmp
         }
         iを増やす
      }
   }
   Aが答え
}