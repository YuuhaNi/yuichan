標準ライブラリを使う

cycpattern_check=入力a,bに対し{
   n=bの大きさ

   # 空文字列は常に部分文字列
   もしnが0ならば{
      真が答え
   }

   # b を 2 回つないだ文字列を作る
   # b の回転文字列はすべて (b+b) の部分文字列になる
   doubled=""
   i=0
   n回くり返す{
      doubledにb[i]を追加する
      iを増やす
   }
   i=0
   n回くり返す{
      doubledにb[i]を追加する
      iを増やす
   }

   limit=和(差(n,1),1)
   i=0
   limit回くり返す{
      rot=""
      j=0
      n回くり返す{
         rotにdoubled[和(i,j)]を追加する
         jを増やす
      }
      もしfind(a,rot)が0以上ならば{
         真が答え
      }
      iを増やす
   }

   偽が答え
}