標準ライブラリを使う

split_words=入力txtに対し{
   # まず空白区切りを試す
   words=txtを" "で分割
   もしwordsの大きさが1より大きいならば{
      wordsが答え
   }

   # 空白が無ければカンマ区切りを試す
   parts=txtを","で分割
   もしpartsの大きさが1より大きいならば{
      partsが答え
   }

   # 空白もカンマも無ければ、奇数順の小文字を数える
   count=0
   i=0
   txtの大きさ回くり返す{
      c=txt[i]
      もしcが97以上ならば{
         もしcが122以下ならば{
            idx=差(c,97)
            parity=剰余(idx,2)
            もしparityが1ならば{
               countを増やす
            }
         }
      }
      iを増やす
   }
   countが答え
}