標準ライブラリを使う

hex_key = 入力 num に対し {
   count = 0
   i = 0
   numの大きさ回くり返す {
      digit = num[i]
      もしdigitが"2"ならば {
         countを増やす
      }
      そうでなければ {
         もしdigitが"3"ならば {
            countを増やす
         }
         そうでなければ {
            もしdigitが"5"ならば {
               countを増やす
            }
            そうでなければ {
               もしdigitが"7"ならば {
                  countを増やす
               }
               そうでなければ {
                  もしdigitが"B"ならば {
                     countを増やす
                  }
                  そうでなければ {
                     もしdigitが"D"ならば {
                        countを増やす
                     }
                  }
               }
            }
         }
      }
      iを増やす
   }
   countが答え
}