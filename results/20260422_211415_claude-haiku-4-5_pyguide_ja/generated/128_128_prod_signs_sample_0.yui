標準ライブラリを使う

prod_signs = 入力 arr に対し {
   もしarrの大きさが0ならば{
      値なしが答え
   }
   
   abs_sum = 0
   sign_prod = 1
   i = 0
   arrの大きさ回くり返す{
      num = arr[i]
      abs_sum = 和(abs_sum, 絶対値(num))
      
      もしnumが0ならば{
         sign_prod = 0
      }そうでなければ{
         もしnumが0より小さいならば{
            sign_prod = 積(sign_prod, -1)
         }
      }
      
      iを増やす
   }
   
   積(abs_sum, sign_prod)が答え
}