標準ライブラリを使う

encode = 入力 message に対し {
   result = ""
   i = 0
   messageの大きさ回くり返す {
      char = message[i]
      
      # 母音判定と置き換え
      もしcharが"a"ならば {
         char = "Y"[0]
      } そうでなければ {
         もしcharが"e"ならば {
            char = "C"[0]
         } そうでなければ {
            もしcharが"i"ならば {
               char = "G"[0]
            } そうでなければ {
               もしcharが"o"ならば {
                  char = "M"[0]
               } そうでなければ {
                  もしcharが"u"ならば {
                     char = "S"[0]
                  } そうでなければ {
                     もしcharが"A"ならば {
                        char = "y"[0]
                     } そうでなければ {
                        もしcharが"E"ならば {
                           char = "c"[0]
                        } そうでなければ {
                           もしcharが"I"ならば {
                              char = "g"[0]
                           } そうでなければ {
                              もしcharが"O"ならば {
                                 char = "m"[0]
                              } そうでなければ {
                                 もしcharが"U"ならば {
                                    char = "s"[0]
                                 }
                              }
                           }
                        }
                     }
                  }
               }
            }
         }
      }
      
      # 大文字小文字の入れ替え
      もし整数判定(char)ならば {
         # 文字コードの場合、大文字小文字を判定して変換
         もしcharが65以上ならば {
            もしcharが90以下ならば {
               # 大文字 A-Z (65-90) → 小文字に変換
               char = 和(char, 32)
            } そうでなければ {
               もしcharが97以上ならば {
                  もしcharが122以下ならば {
                     # 小文字 a-z (97-122) → 大文字に変換
                     char = 差(char, 32)
                  }
               }
            }
         }
      }
      
      resultにchar を追加する
      iを増やす
   }
   
   resultが答え
}