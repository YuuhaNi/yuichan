標準ライブラリを使う

is_equal_to_sum_even = 入力 n に対し {
   もし n が 8 より小さいならば {
      偽が答え
   }
   
   count = 0
   a = 2
   a回くり返す {
      もし a が n より大きいならば {
         くり返しを抜ける
      }
      b = 2
      b回くり返す {
         もし和(a, b)が n より大きいならば {
            くり返しを抜ける
         }
         c = 2
         c回くり返す {
            もし和(a, b, c)が n より大きいならば {
               くり返しを抜ける
            }
            d = 差(n, a, b, c)
            もし d が 2 以上ならば {
               もし 剰余(d, 2) が 0 ならば {
                  countを増やす
               }
            }
            c = 和(c, 2)
         }
         b = 和(b, 2)
      }
      a = 和(a, 2)
   }
   
   もし count が 0 より大きいならば {
      真が答え
   }
   そうでなければ {
      偽が答え
   }
}