標準ライブラリを使う

get_max_triples = 入力 n に対し {
   a = []
   i = 0
   n回くり返す {
      iを増やす
      value = 差(積(i, i), i)
      valueを増やす
      aにvalueを追加する
   }
   
   count = 0
   i = 0
   n回くり返す {
      もしiが差(n, 2)より大きいならば {
         くり返しを抜ける
      }
      j = 和(i, 1)
      n回くり返す {
         もしjが差(n, 1)より大きいならば {
            くり返しを抜ける
         }
         k = 和(j, 1)
         n回くり返す {
            もしkがnより大きいならば {
               くり返しを抜ける
            }
            sum = 和(a[i], a[j], a[k])
            remainder = 剰余(sum, 3)
            もしremainderが0ならば {
               countを増やす
            }
            kを増やす
         }
         jを増やす
      }
      iを増やす
   }
   
   countが答え
}