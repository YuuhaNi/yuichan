標準ライブラリを使う

total_match = 入力 lst1, lst2 に対し {
   count1 = 0
   count2 = 0
   
   lst1の大きさ回くり返す{
      i = 0
      lst1の大きさ回くり返す{
         もしiが lst1の大きさより小さいならば{
            count1 = 和(count1, lst1[i]の大きさ)
            iを増やす
         }
         そうでなければ{
            くり返しを抜ける
         }
      }
      くり返しを抜ける
   }
   
   lst2の大きさ回くり返す{
      i = 0
      lst2の大きさ回くり返す{
         もしiが lst2の大きさより小さいならば{
            count2 = 和(count2, lst2[i]の大きさ)
            iを増やす
         }
         そうでなければ{
            くり返しを抜ける
         }
      }
      くり返しを抜ける
   }
   
   もしcount1がcount2より小さいならば{
      lst1が答え
   }
   そうでなければ{
      lst2が答え
   }
}