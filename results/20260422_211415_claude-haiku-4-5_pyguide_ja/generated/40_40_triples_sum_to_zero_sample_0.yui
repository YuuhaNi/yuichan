標準ライブラリを使う

triples_sum_to_zero = 入力 l に対し {
   n = lの大きさ
   i = 0
   n回くり返す {
      もし i が n 以上ならば {
         くり返しを抜ける
      }
      j = 0
      n回くり返す {
         もし j が n 以上ならば {
            くり返しを抜ける
         }
         もし j が i ならば {
            jを増やす
         }そうでなければ {
            k = 0
            n回くり返す {
               もし k が n 以上ならば {
                  くり返しを抜ける
               }
               もし k が i ならば {
                  kを増やす
               }そうでなければ {
                  もし k が j ならば {
                     kを増やす
                  }そうでなければ {
                     sum = 和(l[i], l[j], l[k])
                     もし sum が 0 ならば {
                        真が答え
                     }
                     kを増やす
                  }
               }
            }
            jを増やす
         }
      }
      iを増やす
   }
   偽が答え
}