標準ライブラリを使う

is_bored = 入力 S に対し {
   count = 0
   i = 0
   Sの大きさ回くり返す{
      もし i が Sの大きさ以上ならば{
         くり返しを抜ける
      }
      
      # 文の開始を探す（'.'、'?'、'!'の直後またはi=0）
      もし i が 0 ならば{
         sentence_start = 真
      }そうでなければ{
         prev_char = S[差(i, 1)]
         sentence_start = 偽
         もし prev_char が "."[0] ならば{ sentence_start = 真 }
         そうでなければ{
            もし prev_char が "?"[0] ならば{ sentence_start = 真 }
            そうでなければ{
               もし prev_char が "!"[0] ならば{ sentence_start = 真 }
            }
         }
      }
      
      # 文の開始がスペースなら次の文字へ
      もし sentence_start が 真 ならば{
         もし S[i] が " "[0] ならば{
            i を増やす
         }
      }
      
      # "I "で始まる文をチェック
      もし i が Sの大きさより小さいならば{
         もし S[i] が "I"[0] ならば{
            もし 和(i, 1) が Sの大きさより小さいならば{
               もし S[和(i, 1)] が " "[0] ならば{
                  count を増やす
               }
            }
         }
      }
      
      i を増やす
   }
   
   count が答え
}