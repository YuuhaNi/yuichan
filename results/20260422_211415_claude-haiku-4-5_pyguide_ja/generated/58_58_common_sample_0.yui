標準ライブラリを使う

common = 入力 l1, l2 に対し {
   result = []
   i = 0
   l1の大きさ回くり返す{
      elem = l1[i]
      もしelemがl2のいずれかならば{
         もしelemがresultのいずれでもないならば{
            resultにelemを追加する
         }
      }
      iを増やす
   }
   
   # ソート（バブルソート）
   j = 0
   resultの大きさ回くり返す{
      k = 0
      差(resultの大きさ, 1)回くり返す{
         もしresult[k]がresult[差(k, 1)]より大きいならば{
            temp = result[k]
            result[k] = result[差(k, 1)]
            result[差(k, 1)] = temp
         }
         kを増やす
      }
      jを増やす
   }
   
   result
}