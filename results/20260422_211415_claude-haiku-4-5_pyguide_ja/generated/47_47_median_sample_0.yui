標準ライブラリを使う

median = 入力 l に対し {
   # リストをソート（バブルソート）
   sorted = l
   i = 0
   sortedの大きさ回くり返す {
      j = 0
      差(sortedの大きさ, 1)回くり返す {
         もしsorted[j]がsorted[差(j, 1)]より大きいならば {
            temp = sorted[j]
            sorted[j] = sorted[差(j, 1)]
            sorted[差(j, 1)] = temp
         }
         jを増やす
      }
      iを増やす
   }
   
   # 中央値を計算
   n = sortedの大きさ
   mid = 商(n, 2)
   
   もしn が 2 で割り切れるならば {
      # 偶数個の場合：中央の2つの平均
      left = sorted[差(mid, 1)]
      right = sorted[mid]
      商(和(left, right), 2)が答え
   } そうでなければ {
      # 奇数個の場合：中央の値
      sorted[mid]が答え
   }
}