標準ライブラリを使う

move_one_ball = 入力 arr に対し {
   もし arr の大きさ が 0 ならば {
      真が答え
   }

   n = arr の大きさ
   n 回くり返す {
      is_sorted = 真
      差(n, 1) 回くり返す {
         i = 0
         差(n, 1) 回くり返す {
            もし arr[i] が arr[和(i, 1)] より大きいならば {
               is_sorted = 偽
               くり返しを抜ける
            }
            i を増やす
         }
         もし is_sorted が 偽 ならば {
            くり返しを抜ける
         }
      }

      もし is_sorted が 真 ならば {
         真が答え
      }

      last = arr[差(n, 1)]
      i = 差(n, 1)
      i 回くり返す {
         arr[i] = arr[差(i, 1)]
         i を減らす
      }
      arr[0] = last
   }

   偽が答え
}