標準ライブラリを使う

split_words = 入力 txt に対し {
   # 空白で分割できるかチェック
   space_count = 0
   i = 0
   txt の大きさ 回くり返す {
      もし txt[i] が " "[0] ならば {
         space_count を増やす
      }
      i を増やす
   }
   
   もし space_count が 0 より大きいならば {
      # 空白で分割
      result = []
      current_word = ""
      i = 0
      txt の大きさ 回くり返す {
         もし txt[i] が " "[0] ならば {
            もし current_word の大きさ が 0 より大きいならば {
               result に current_word を追加する
               current_word = ""
            }
         } そうでなければ {
            current_word に txt[i] を追加する
         }
         i を増やす
      }
      もし current_word の大きさ が 0 より大きいならば {
         result に current_word を追加する
      }
      result が答え
   }
   
   # カンマで分割できるかチェック
   comma_count = 0
   i = 0
   txt の大きさ 回くり返す {
      もし txt[i] が ",")[0] ならば {
         comma_count を増やす
      }
      i を増やす
   }
   
   もし comma_count が 0 より大きいならば {
      # カンマで分割
      result = []
      current_word = ""
      i = 0
      txt の大きさ 回くり返す {
         もし txt[i] が ",")[0] ならば {
            もし current_word の大きさ が 0 より大きいならば {
               result に current_word を追加する
               current_word = ""
            }
         } そうでなければ {
            current_word に txt[i] を追加する
         }
         i を増やす
      }
      もし current_word の大きさ が 0 より大きいならば {
         result に current_word を追加する
      }
      result が答え
   }
   
   # アルファベットの奇数順の小文字の数を数える
   count = 0
   i = 0
   txt の大きさ 回くり返す {
      char_code = txt[i]
      # 'a' = 97, 'z' = 122
      もし char_code が 97 以上ならば {
         もし char_code が 122 以下ならば {
            # 小文字の位置を計算 (a=0, b=1, ..., z=25)
            position = 差(char_code, 97)
            # 奇数順かチェック (1, 3, 5, ... = b, d, f, ...)
            remainder = 剰余(position, 2)
            もし remainder が 1 ならば {
               count を増やす
            }
         }
      }
      i を増やす
   }
   count が答え
}