標準ライブラリを使う

same_chars = 入力 s0, s1 に対し {
   # s0 と s1 の各文字をソートして比較する
   # 同じ文字セットなら、ソート後は同じ文字列になる
   
   # s0 をソート
   arr0 = 配列化(s0)
   i = 0
   arr0の大きさ回くり返す {
      j = 和(i, 1)
      arr0の大きさ回くり返す {
         もしjがarr0の大きさ以上ならば {
            くり返しを抜ける
         }
         もしarr0[i]がarr0[j]より大きいならば {
            tmp = arr0[i]
            arr0[i] = arr0[j]
            arr0[j] = tmp
         }
         jを増やす
      }
      iを増やす
   }
   
   # s1 をソート
   arr1 = 配列化(s1)
   i = 0
   arr1の大きさ回くり返す {
      j = 和(i, 1)
      arr1の大きさ回くり返す {
         もしjがarr1の大きさ以上ならば {
            くり返しを抜ける
         }
         もしarr1[i]がarr1[j]より大きいならば {
            tmp = arr1[i]
            arr1[i] = arr1[j]
            arr1[j] = tmp
         }
         jを増やす
      }
      iを増やす
   }
   
   # ソート後の配列が同じかどうか判定
   もしarr0の大きさがarr1の大きさ以外ならば {
      偽が答え
   }
   
   i = 0
   arr0の大きさ回くり返す {
      もしarr0[i]がarr1[i]以外ならば {
         偽が答え
      }
      iを増やす
   }
   
   真が答え
}