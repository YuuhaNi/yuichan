標準ライブラリを使う

anti_shuffle = 入力 s に対し {
   result = ""
   word = ""
   i = 0
   sの大きさ回くり返す{
      c = s[i]
      もしcが32ならば{
         # 空白を検出したら、wordをソートしてresultに追加
         sorted_word = sort_word(word)
         result = 和(result, sorted_word)
         resultに32を追加する
         word = ""
      }そうでなければ{
         wordにcを追加する
      }
      iを増やす
   }
   # 最後の単語を処理
   もしwordの大きさが0より大きいならば{
      sorted_word = sort_word(word)
      result = 和(result, sorted_word)
   }
   resultが答え
}

sort_word = 入力 word に対し {
   # 単語の文字をASCII値でソート
   chars = 配列化(word)
   n = charsの大きさ
   
   # バブルソート
   n回くり返す{
      j = 0
      差(n, 1)回くり返す{
         もしchars[j]がchars[差(j, 1)]より大きいならば{
            temp = chars[j]
            chars[j] = chars[差(j, 1)]
            chars[差(j, 1)] = temp
         }
         jを増やす
      }
   }
   
   # 配列を文字列に変換
   sorted_str = ""
   i = 0
   n回くり返す{
      sortedにchars[i]を追加する
      iを増やす
   }
   sorted_strが答え
}