標準ライブラリを使う

sort_array = 入力 array に対し {
   もし array の大きさ が 0 ならば {
      array が答え
   }
   そうでなければ {
      first = array[0]
      last = array[差(array の大きさ, 1)]
      sum = 和(first, last)
      remainder = 剰余(sum, 2)
      
      # コピーを作成
      result = []
      i = 0
      array の大きさ 回くり返す {
         result に array[i] を追加する
         i を増やす
      }
      
      # バブルソート（昇順）
      もし remainder が 1 ならば {
         n = result の大きさ
         n 回くり返す {
            j = 0
            差(n, 1) 回くり返す {
               もし result[j] が result[差(j, 1)] より大きいならば {
                  temp = result[j]
                  result[j] = result[差(j, 1)]
                  result[差(j, 1)] = temp
               }
               j を増やす
            }
         }
      }
      そうでなければ {
         # バブルソート（降順）
         n = result の大きさ
         n 回くり返す {
            j = 0
            差(n, 1) 回くり返す {
               もし result[j] が result[差(j, 1)] より小さいならば {
                  temp = result[j]
                  result[j] = result[差(j, 1)]
                  result[差(j, 1)] = temp
               }
               j を増やす
            }
         }
      }
      
      result が答え
   }
}