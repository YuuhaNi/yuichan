標準ライブラリを使う

sorted_list_sum = 入力 lst に対し {
   result = []
   
   # ステップ1: 奇数の長さを持つ文字列を削除
   i = 0
   lstの大きさ回くり返す {
      word = lst[i]
      len_word = wordの大きさ
      
      # 長さが偶数かどうかを判定（2で割った剰余が0）
      remainder = 剰余(len_word, 2)
      もしreminderが0ならば {
         resultにwordを追加する
      }
      
      iを増やす
   }
   
   # ステップ2: resultを長さで昇順、同じ長さならアルファベット順にソート
   # バブルソートで実装
   result_size = resultの大きさ
   
   result_size回くり返す {
      j = 0
      差(result_size, 1)回くり返す {
         word1 = result[j]
         word2 = result[差(j, 1)]
         
         len1 = word1の大きさ
         len2 = word2の大きさ
         
         # 長さで比較
         もしlen1がlen2より大きいならば {
            # スワップ
            temp = result[j]
            result[j] = result[差(j, 1)]
            result[差(j, 1)] = temp
         }そうでなければ {
            # 長さが同じ場合、アルファベット順で比較
            もしlen1がlen2ならば {
               もしword1がword2より大きいならば {
                  # スワップ
                  temp = result[j]
                  result[j] = result[差(j, 1)]
                  result[差(j, 1)] = temp
               }
            }
         }
         
         jを増やす
      }
   }
   
   resultが答え
}