標準ライブラリを使う

is_sorted = 入力 lst に対し {
   size = lst の大きさ
   もし size が 1 以下ならば {
      真が答え
   }
   
   i = 0
   size 回くり返す {
      もし i が size より大きいならば {
         くり返しを抜ける
      }
      
      もし i が 0 ならば {
         i を増やす
      } そうでなければ {
         prev = lst[差(i, 1)]
         curr = lst[i]
         
         もし curr が prev より小さいならば {
            偽が答え
         }
         
         もし curr が prev ならば {
            もし i が差(size, 1)より大きいならば {
               next = lst[和(i, 1)]
               もし next が curr ならば {
                  偽が答え
               }
            } そうでなければ {
               偽が答え
            }
         }
         
         i を増やす
      }
   }
   
   真が答え
}