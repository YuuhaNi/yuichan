標準ライブラリを使う

will_it_fly = 入力 q, w に対し {
   # 配列の合計を計算
   total = 和(q)
   
   # 合計が最大荷重を超えているかチェック
   もし total が w より大きいならば {
      偽が答え
   }
   
   # 回文かどうかをチェック
   n = q の大きさ
   is_palindrome = 真
   
   商(n, 2) 回くり返す {
      i = 0
      n 回くり返す {
         もし i が商(n, 2)より小さいならば {
            もし q[i] が q[差(n, 差(i, 1))]以外ならば {
               is_palindrome = 偽
               くり返しを抜ける
            }
            i を増やす
         } そうでなければ {
            くり返しを抜ける
         }
      }
   }
   
   is_palindrome が答え
}