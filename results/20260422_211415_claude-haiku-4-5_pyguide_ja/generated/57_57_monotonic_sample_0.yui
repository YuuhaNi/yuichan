標準ライブラリを使う

monotonic = 入力 l に対し {
   n = lの大きさ
   もしnが2より小さいならば{
      真が答え
   }
   
   increasing = 真
   decreasing = 真
   
   差(n, 1)回くり返す{
      i = 0
      差(n, 1)回くり返す{
         もしl[i]がl[和(i, 1)]より大きいならば{
            increasingを減らす
         }
         もしl[i]がl[和(i, 1)]より小さいならば{
            decreasingを減らす
         }
         iを増やす
      }
   }
   
   もしincreasingが真ならば{
      真が答え
   }
   もしdecreasingが真ならば{
      真が答え
   }
   偽が答え
}