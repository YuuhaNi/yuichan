標準ライブラリを使う

largest_prime_factor = 入力 n に対し {
   largest = 1
   divisor = 2
   
   n回くり返す {
      もし divisor が n より大きいならば {
         くり返しを抜ける
      }
      
      もし 剰余(n, divisor) が 0 ならば {
         largest = divisor
         n = 商(n, divisor)
      } そうでなければ {
         divisor を増やす
      }
   }
   
   largest が答え
}