標準ライブラリを使う

is_prime = 入力 num に対し {
   もし num が 2 より小さいならば {
      偽が答え
   }
   もし num が 2 ならば {
      真が答え
   }
   i = 2
   num回くり返す {
      もし i が num より大きいならば {
         くり返しを抜ける
      }
      もし 剰余(num, i) が 0 ならば {
         偽が答え
      }
      i を増やす
   }
   真が答え
}

prime_fib = 入力 n に対し {
   count = 0
   a = 1
   b = 1
   1000回くり返す {
      c = 和(a, b)
      a = b
      b = c
      もし is_prime(b) が真ならば {
         count を増やす
         もし count が n ならば {
            b が答え
         }
      }
   }
}