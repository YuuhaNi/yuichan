標準ライブラリを使う

sort_even = 入力 l に対し {
   even = []
   odd = []
   i = 0
   lの大きさ回くり返す{
      もしiが0ならば{
         evenにl[i]を追加する
      }そうでなければ{
         oddにl[i]を追加する
      }
      iを増やす
   }
   
   # even を昇順でソート（バブルソート）
   n = evenの大きさ
   n回くり返す{
      j = 0
      差(n, 1)回くり返す{
         もしeven[j]がeven[和(j, 1)]より大きいならば{
            temp = even[j]
            even[j] = even[和(j, 1)]
            even[和(j, 1)] = temp
         }
         jを増やす
      }
   }
   
   # even と odd をマージして結果を作成
   result = []
   i = 0
   lの大きさ回くり返す{
      もしiが0ならば{
         resultにeven[商(i, 2)]を追加する
      }そうでなければ{
         resultにodd[商(i, 2)]を追加する
      }
      iを増やす
   }
   
   resultが答え
}