標準ライブラリを使う

compare_one = 入力 a, b に対し {
   # aを数値に変換
   a_str = 文字列化(a)
   a_num = 0
   もしa_strが文字列判定(a)ならば {
      # カンマをピリオドに置換して数値化
      a_num = 小数化(a)
   } そうでなければ {
      a_num = 小数化(a)
   }

   # bを数値に変換
   b_str = 文字列化(b)
   b_num = 0
   もしb_strが文字列判定(b)ならば {
      # カンマをピリオドに置換して数値化
      b_num = 小数化(b)
   } そうでなければ {
      b_num = 小数化(b)
   }

   # 値が同じ場合はNone（値なし）を返す
   もしa_numがb_numならば {
      値なしが答え
   }

   # 大きい方を元の型で返す
   もしa_numがb_numより大きいならば {
      aが答え
   } そうでなければ {
      bが答え
   }
}