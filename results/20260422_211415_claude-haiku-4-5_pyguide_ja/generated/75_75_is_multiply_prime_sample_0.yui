標準ライブラリを使う

is_prime = 入力 n に対し {
   もし n が 2 より小さいならば {
      偽が答え
   }
   i = 2
   n回くり返す {
      もし i が n より大きいならば {
         くり返しを抜ける
      }
      もし 剰余(n, i) が 0 ならば {
         偽が答え
      }
      i を増やす
   }
   真が答え
}

is_multiply_prime = 入力 a に対し {
   count = 0
   i = 2
   100回くり返す {
      もし i が a より大きいならば {
         くり返しを抜ける
      }
      もし 剰余(a, i) が 0 ならば {
         もし is_prime(i) が真ならば {
            count を増やす
            a = 商(a, i)
            i を減らす
         }
      }
      i を増やす
   }
   もし count が 3 ならば {
      真が答え
   }
   偽が答え
}