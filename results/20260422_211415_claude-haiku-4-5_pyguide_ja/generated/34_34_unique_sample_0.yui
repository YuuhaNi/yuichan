標準ライブラリを使う

unique = 入力 l に対し {
   result = []
   i = 0
   lの大きさ回くり返す{
      item = l[i]
      もしitemがresultのいずれでもないならば{
         resultにitemを追加する
      }
      iを増やす
   }
   
   # ソート（バブルソート）
   n = resultの大きさ
   n回くり返す{
      j = 0
      差(n, 1)回くり返す{
         もしresult[j]がresult[差(j, 1)]より大きいならば{
            temp = result[j]
            result[j] = result[差(j, 1)]
            result[差(j, 1)] = temp
         }
         jを増やす
      }
   }
   
   resultが答え
}