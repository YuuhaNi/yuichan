標準ライブラリを使う

words_string = 入力 s に対し {
   result = []
   word = ""
   i = 0
   sの大きさ回くり返す{
      c = s[i]
      
      もしcが32ならば{
         もしwordの大きさが0より大きいならば{
            resultにwordを追加する
            word = ""
         }
      }そうでなければ{
         もしcが44ならば{
            もしwordの大きさが0より大きいならば{
               resultにwordを追加する
               word = ""
            }
         }そうでなければ{
            wordにcを追加する
         }
      }
      
      iを増やす
   }
   
   もしwordの大きさが0より大きいならば{
      resultにwordを追加する
   }
   
   result が答え
}