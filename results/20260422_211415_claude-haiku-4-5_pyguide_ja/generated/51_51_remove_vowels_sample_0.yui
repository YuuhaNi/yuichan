標準ライブラリを使う

remove_vowels = 入力 text に対し {
   result = ""
   i = 0
   textの大きさ回くり返す {
      c = text[i]
      もし c が "a"[0] ならば {
         iを増やす
      } そうでなければ {
         もし c が "e"[0] ならば {
            iを増やす
         } そうでなければ {
            もし c が "i"[0] ならば {
               iを増やす
            } そうでなければ {
               もし c が "o"[0] ならば {
                  iを増やす
               } そうでなければ {
                  もし c が "u"[0] ならば {
                     iを増やす
                  } そうでなければ {
                     もし c が "A"[0] ならば {
                        iを増やす
                     } そうでなければ {
                        もし c が "E"[0] ならば {
                           iを増やす
                        } そうでなければ {
                           もし c が "I"[0] ならば {
                              iを増やす
                           } そうでなければ {
                              もし c が "O"[0] ならば {
                                 iを増やす
                              } そうでなければ {
                                 もし c が "U"[0] ならば {
                                    iを増やす
                                 } そうでなければ {
                                    resultに c を追加する
                                    iを増やす
                                 }
                              }
                           }
                        }
                     }
                  }
               }
            }
         }
      }
   }
   result が答え
}