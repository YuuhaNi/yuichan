標準ライブラリを使う

rounded_avg = 入力 n, m に対し {
   もしnがmより大きいならば {
      -1が答え
   }
   
   合計 = 和(n, m)
   個数 = 差(m, n)
   個数を増やす
   
   平均 = 商(合計, 個数)
   余り = 剰余(合計, 個数)
   
   もし余りが0より大きいならば {
      もし積(2, 余り)がm以上ならば {
         平均を増やす
      }
   }
   
   結果 = ""
   もし平均が0ならば {
      結果 = "0b0"
   } そうでなければ {
      temp = 平均
      binary = ""
      
      temp回くり返す {
         もしtempが0ならば {
            くり返しを抜ける
         }
         
         r = 剰余(temp, 2)
         もしrが0ならば {
            binaryに"0"を追加する
         } そうでなければ {
            binaryに"1"を追加する
         }
         
         temp = 商(temp, 2)
      }
      
      結果 = "0b"
      i = 差(binaryの大きさ, 1)
      差(binaryの大きさ, 1)回くり返す {
         もしiが0以上ならば {
            結果に文字列化(binary[i])を追加する
            iを減らす
         }
      }
   }
   
   結果が答え
}