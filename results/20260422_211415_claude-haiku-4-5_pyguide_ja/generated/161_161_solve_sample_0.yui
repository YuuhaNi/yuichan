標準ライブラリを使う

solve = 入力 s に対し {
   has_alpha = 偽
   result = ""
   
   s の大きさ 回くり返す {
      i = 0
      s の大きさ 回くり返す {
         c = s[i]
         # 大文字A-Z: 65-90、小文字a-z: 97-122
         もし c が 65 以上ならば {
            もし c が 90 以下ならば {
               # 大文字 → 小文字に変換
               has_alpha = 真
               result に 和(c, 32) を追加する
               くり返しを抜ける
            }
         }
         もし c が 97 以上ならば {
            もし c が 122 以下ならば {
               # 小文字 → 大文字に変換
               has_alpha = 真
               result に 差(c, 32) を追加する
               くり返しを抜ける
            }
         }
         # アルファベットでない場合はそのまま
         result に c を追加する
         くり返しを抜ける
      }
      i を増やす
   }
   
   # アルファベットが含まれていない場合は逆順にする
   もし has_alpha が 偽 ならば {
      result = ""
      i = 差(s の大きさ, 1)
      s の大きさ 回くり返す {
         もし i が 0 以上ならば {
            result に s[i] を追加する
            i を減らす
         }
      }
   }
   
   result が答え
}