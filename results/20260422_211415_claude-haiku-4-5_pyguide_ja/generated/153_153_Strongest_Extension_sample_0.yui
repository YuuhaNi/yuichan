標準ライブラリを使う

Strongest_Extension = 入力 class_name, extensions に対し {
   max_strength = 0
   max_index = 0
   i = 0
   
   extensions の大きさ回くり返す {
      ext = extensions[i]
      cap = 0
      sm = 0
      j = 0
      
      ext の大きさ回くり返す {
         char = ext[j]
         もし char が 65 以上ならば {
            もし char が 90 以下ならば {
               cap を増やす
            }
         }
         もし char が 97 以上ならば {
            もし char が 122 以下ならば {
               sm を増やす
            }
         }
         j を増やす
      }
      
      strength = 差(cap, sm)
      
      もし i が 0 ならば {
         max_strength = strength
         max_index = 0
      } そうでなければ {
         もし strength が max_strength より大きいならば {
            max_strength = strength
            max_index = i
         }
      }
      
      i を増やす
   }
   
   strongest_ext = extensions[max_index]
   result = "{class_name}.{strongest_ext}"
   result が答え
}