標準ライブラリを使う

is_happy = 入力 s に対し {
   もしsの大きさが3より小さいならば{
      偽が答え
   }
   
   i = 0
   差(sの大きさ, 2)回くり返す{
      c1 = s[i]
      c2 = s[和(i, 1)]
      c3 = s[和(i, 2)]
      
      もしc1がc2ならば{
         偽が答え
      }
      もしc2がc3ならば{
         偽が答え
      }
      もしc1がc3ならば{
         偽が答え
      }
      
      iを増やす
   }
   
   真が答え
}