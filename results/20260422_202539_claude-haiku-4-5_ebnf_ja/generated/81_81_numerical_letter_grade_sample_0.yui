標準ライブラリを使う

numerical_letter_grade = 入力 grades に対し {
    result = []
    grades の大きさ 回 くり返す {
        gpa = grades[0]
        
        もし gpa が 4.0 ならば {
            result に "A+" を追加する
        } そうでなければ {
            もし gpa が 3.7 より大きい ならば {
                result に "A" を追加する
            } そうでなければ {
                もし gpa が 3.3 より大きい ならば {
                    result に "A-" を追加する
                } そうでなければ {
                    もし gpa が 3.0 より大きい ならば {
                        result に "B+" を追加する
                    } そうでなければ {
                        もし gpa が 2.7 より大きい ならば {
                            result に "B" を追加する
                        } そうでなければ {
                            もし gpa が 2.3 より大きい ならば {
                                result に "B-" を追加する
                            } そうでなければ {
                                もし gpa が 2.0 より大きい ならば {
                                    result に "C+" を追加する
                                } そうでなければ {
                                    もし gpa が 1.7 より大きい ならば {
                                        result に "C" を追加する
                                    } そうでなければ {
                                        もし gpa が 1.3 より大きい ならば {
                                            result に "C-" を追加する
                                        } そうでなければ {
                                            もし gpa が 1.0 より大きい ならば {
                                                result に "D+" を追加する
                                            } そうでなければ {
                                                もし gpa が 0.7 より大きい ならば {
                                                    result に "D" を追加する
                                                } そうでなければ {
                                                    もし gpa が 0.0 より大きい ならば {
                                                        result に "D-" を追加する
                                                    } そうでなければ {
                                                        result に "E" を追加する
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        
        grades を grades[1] に追加する
    }
    
    result が 答え
}