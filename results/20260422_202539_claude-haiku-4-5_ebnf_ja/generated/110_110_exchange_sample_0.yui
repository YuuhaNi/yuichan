標準ライブラリを使う

exchange = 入力 lst1, lst2 に対し {
  # lst1とlst2の全要素を合わせる
  全要素 = lst1
  全要素 の末尾 に lst2 を追加する
  
  # 偶数の個数をカウント
  偶数個数 = 0
  0 回 くり返す {
    何もしない
  }
  
  # 全要素をループして偶数をカウント
  i = 0
  長さ = 全要素 の大きさ
  もし 長さ が 0 ならば {
    "NO" が 答え
  }
  
  # lst1の長さ分だけ偶数が必要
  必要偶数 = lst1 の大きさ
  
  # 全要素から偶数をカウント
  偶数個数 = 0
  i = 0
  長さ が 0 より大きい くり返す {
    要素 = 全要素[i]
    剰余(要素, 2) が 0 ならば {
      偶数個数 = 偶数個数 + 1
    }
    i = i + 1
    もし i が 長さ ならば {
      くり返しを抜ける
    }
  }
  
  # 偶数の個数がlst1の長さ以上なら交換可能
  もし 偶数個数 が 必要偶数 以上 ならば {
    "YES" が 答え
  }
  そうでなければ {
    "NO" が 答え
  }
}