標準ライブラリを使う

cycpattern_check = 入力 a, b に対し {
  b_len = b の大きさ
  0 回 くり返す {
    もし a が (b) ならば {
      真 が 答え
    }
    b = b[1] + b[0]を追加する
  }
  偽 が 答え
}
標準ライブラリを使う

cycpattern_check = 入力 a, b に対し {
  b_len = b の大きさ
  i = 0
  b_len 回 くり返す {
    もし a が b ならば {
      真 が 答え
    }
    b = b[1] + b[0]
    i を増やす
  }
  偽 が 答え
}
標準ライブラリを使う

cycpattern_check = 入力 a, b に対し {
  b_len = b の大きさ
  b_len 回 くり返す {
    もし a が b を含む ならば {
      真 が 答え
    }
    b = 回転(b)
  }
  偽 が 答え
}