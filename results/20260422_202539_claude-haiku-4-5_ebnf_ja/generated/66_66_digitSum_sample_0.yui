標準ライブラリを使う

digitSum = 入力 s に対し {
    合計 = 0
    0 回 くり返す {
        何もしない
    }
    s の大きさ 回 くり返す {
        文字 = s[0]
        コード = 文字コード(文字)
        もし コード が 65 以上 ならば {
            もし コード が 90 以下 ならば {
                合計 = 和(合計, コード)
            }
        }
        s = 部分文字列(s, 1)
    }
    合計 が 答え
}