標準ライブラリを使う

sum_squares = 入力 lst に対し {
  合計 = 0
  インデックス = 0
  lst の大きさ 回 くり返す {
    剰余値 = 剰余(インデックス, 12)
    
    もし 剰余値 が 0 ならば {
      要素 = インデックス に lst を インデックス付きで取得する
      二乗値 = 積(要素, 要素)
      合計 = 和(合計, 二乗値)
    } そうでなければ {
      もし 剰余値 が 4 ならば {
        要素 = インデックス に lst を インデックス付きで取得する
        三乗値 = 積(積(要素, 要素), 要素)
        合計 = 和(合計, 三乗値)
      }
    }
    
    インデックス = 和(インデックス, 1)
  }
  
  合計 が 答え
}