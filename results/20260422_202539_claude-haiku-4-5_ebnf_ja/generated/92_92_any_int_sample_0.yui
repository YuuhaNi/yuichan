標準ライブラリを使う

any_int = 入力 x, y, z に対し {
  もし x が整数か(x)が真 ならば {
    もし y が整数か(y)が真 ならば {
      もし z が整数か(z)が真 ならば {
        もし x が和(y, z)が真 ならば {
          真が答え
        }
        もし y が和(x, z)が真 ならば {
          真が答え
        }
        もし z が和(x, y)が真 ならば {
          真が答え
        }
      }
    }
  }
  偽が答え
}