標準ライブラリを使う

next_smallest = 入力 lst に対し {
  もし lst の大きさ が 2 より小さい ならば {
    値なし が 答え
  }
  
  最小値 = lst[0]
  次小値 = 値なし
  
  lst の大きさ 回 くり返す {
    現在値 = lst[くり返し番号]
    
    もし 現在値 が 最小値 より小さい ならば {
      次小値 = 最小値
      最小値 = 現在値
    } そうでなければ {
      もし 現在値 が 次小値 より大きい ならば {
        もし 次小値 が 値なし ならば {
          次小値 = 現在値
        } そうでなければ {
          もし 現在値 が 次小値 より小さい ならば {
            次小値 = 現在値
          }
        }
      }
    }
  }
  
  次小値 が 答え
}