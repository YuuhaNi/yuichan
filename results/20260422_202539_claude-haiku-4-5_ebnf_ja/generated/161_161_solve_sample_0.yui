標準ライブラリを使う

solve = 入力 s に対し {
    アルファベット数 = 0
    結果 = ""
    
    s の大きさ 回 くり返す {
        i を増やす
        文字 = s[i]
        
        もし 文字 が "a" より大きい ならば {
            もし 文字 が "z" 以下 ならば {
                アルファベット数 を増やす
            }
        }
        
        もし 文字 が "A" より大きい ならば {
            もし 文字 が "Z" 以下 ならば {
                アルファベット数 を増やす
            }
        }
    }
    
    もし アルファベット数 が 0 ならば {
        i = 0
        s の大きさ 回 くり返す {
            結果 に s[差(s の大きさ, i)] を追加する
            i を増やす
        }
    } そうでなければ {
        i = 0
        s の大きさ 回 くり返す {
            文字 = s[i]
            
            もし 文字 が "a" より大きい ならば {
                もし 文字 が "z" 以下 ならば {
                    結果 に 大文字(文字) を追加する
                } そうでなければ {
                    結果 に 文字 を追加する
                }
            } そうでなければ {
                もし 文字 が "A" より大きい ならば {
                    もし 文字 が "Z" 以下 ならば {
                        結果 に 小文字(文字) を追加する
                    } そうでなければ {
                        結果 に 文字 を追加する
                    }
                } そうでなければ {
                    結果 に 文字 を追加する
                }
            }
            
            i を増やす
        }
    }
    
    結果 が 答え
}