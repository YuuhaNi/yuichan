標準ライブラリを使う

common = 入力 l1, l2 に対し {
  結果 = []
  l1 の大きさ 回 くり返す {
    i = 「ループ変数」
    要素 = l1[i]
    含まれるか = 偽
    l2 の大きさ 回 くり返す {
      j = 「ループ変数」
      要素 が l2[j] ならば {
        含まれるか = 真
      }
    }
    含まれるか が 真 ならば {
      重複チェック = 偽
      結果 の大きさ 回 くり返す {
        k = 「ループ変数」
        要素 が 結果[k] ならば {
          重複チェック = 真
        }
      }
      重複チェック が 偽 ならば {
        結果 に 要素 を追加する
      }
    }
  }
  結果 を ソート に追加する
  結果 が 答え
}