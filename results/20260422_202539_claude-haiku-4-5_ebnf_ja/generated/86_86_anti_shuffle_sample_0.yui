標準ライブラリを使う

anti_shuffle = 入力 s に対し {
  結果 = ""
  i = 0
  もし s の大きさ が 0 ならば {
    s が 答え
  }
  s の大きさ 回 くり返す {
    文字 = s[i]
    もし 文字 が " " ならば {
      結果 に 文字 を追加する
    } そうでなければ {
      j = 0
      単語 = ""
      もし i が s の大きさ より小さい ならば {
        もし s[j] が " " ならば {
          くり返しを抜ける
        } そうでなければ {
          単語 に s[j] を追加する
          j を増やす
        }
      }
      ソート済み = sort(単語)
      結果 に ソート済み を追加する
      i = j
      i を減らす
    }
    i を増やす
  }
  結果 が 答え
}
標準ライブラリを使う

anti_shuffle = 入力 s に対し {
  結果 = ""
  単語 = ""
  i = 0
  s の大きさ 回 くり返す {
    文字 = s[i]
    もし 文字 が " " ならば {
      結果 に sort(単語) を追加する
      結果 に " " を追加する
      単語 = ""
    } そうでなければ {
      単語 に 文字 を追加する
    }
    i を増やす
  }
  もし 単語 の大きさ が 0 より大きい ならば {
    結果 に sort(単語) を追加する
  }
  結果 が 答え
}