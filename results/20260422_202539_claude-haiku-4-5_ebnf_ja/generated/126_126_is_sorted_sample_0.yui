標準ライブラリを使う

is_sorted = 入力 lst に対し {
    i = 0
    もし lst の大きさ が 0 ならば {
        真 が 答え
    }
    
    くり返す lst の大きさ 減らす 1 回 くり返す {
        もし i が 0 ならば {
            i を増やす
            何もしない
        } そうでなければ {
            現在値 = lst[i]
            前値 = lst[i 減らす 1]
            
            もし 現在値 が 前値 ならば {
                次カウント = 0
                j = i
                くり返す lst の大きさ 減らす i 回 くり返す {
                    もし lst[j] が 現在値 ならば {
                        次カウント を増やす
                    }
                    j を増やす
                }
                
                もし 次カウント が 2 より大きい ならば {
                    偽 が 答え
                }
            }
            
            もし 現在値 が 前値 より小さい ならば {
                偽 が 答え
            }
            
            i を増やす
        }
    }
    
    真 が 答え
}