標準ライブラリを使う

get_max_triples = 入力 n に対し {
    a = []
    1 回 くり返す {
        何もしない
    }
    i = 1 {
        i が n より小さい ならば {
            値 = 積(i, i) を差(i) に追加する
            値を1に追加する
            a に値を追加する
            i を増やす
        } そうでなければ {
            くり返しを抜ける
        }
    }
    
    count = 0
    i = 0 {
        i が n より小さい ならば {
            j = 和(i, 1) {
                j が n より小さい ならば {
                    k = 和(j, 1) {
                        k が n より小さい ならば {
                            sum = 和(a[i], 和(a[j], a[k]))
                            remainder = 剰余(sum, 3)
                            もし remainder が 0 ならば {
                                count を増やす
                            }
                            k を増やす
                        } そうでなければ {
                            くり返しを抜ける
                        }
                    }
                    j を増やす
                } そうでなければ {
                    くり返しを抜ける
                }
            }
            i を増やす
        } そうでなければ {
            くり返しを抜ける
        }
    }
    
    count が 答え
}