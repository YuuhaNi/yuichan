標準ライブラリを使う

check_dict_case = 入力 dict に対し {
    keys = dict
    keys の大きさ が 0 ならば {
        偽 が 答え
    }
    
    is_all_lower = 真
    is_all_upper = 真
    
    keys の大きさ 回 くり返す {
        key = keys[0]
        
        もし key が string ならば {
            もし key が 「[a-z]+」 ならば {
                is_all_upper = 偽
            }
            もし key が 「[A-Z]+」 ならば {
                is_all_lower = 偽
            }
        }
        そうでなければ {
            偽 が 答え
        }
    }
    
    もし is_all_lower が 真 ならば {
        真 が 答え
    }
    そうでなければ {
        もし is_all_upper が 真 ならば {
            真 が 答え
        }
        そうでなければ {
            偽 が 答え
        }
    }
}