標準ライブラリを使う

is_equal_to_sum_even = 入力 n に対し {
  もし n が 8 より小さい ならば {
    偽 が 答え
  }
  
  カウント = 0
  a = 2
  もし a が n より小さい ならば {
    a を増やす
    a を増やす
    b = 2
    もし b が n より小さい ならば {
      b を増やす
      b を増やす
      c = 2
      もし c が n より小さい ならば {
        c を増やす
        c を増やす
        d = 差(n, 和(a, 和(b, c)))
        もし d が 2 以上 ならば {
          もし 剰余(d, 2) が 0 ならば {
            真 が 答え
          }
        }
      }
    }
  }
  
  偽 が 答え
}