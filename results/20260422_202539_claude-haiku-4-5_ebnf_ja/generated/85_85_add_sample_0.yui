標準ライブラリを使う

add = 入力 lst に対し {
  合計 = 0
  インデックス = 1
  
  インデックス が lst の大きさ より小さい ならば {
    くり返しを抜ける
  }
  
  インデックス が lst の大きさ より小さい ならば {
    要素 = lst[インデックス]
    
    もし 要素 が 0 が 要素 を 2 で 剰余 ならば {
      合計 = 合計 を 要素 に足す
    }
    
    インデックス = インデックス を 1 に足す
  }
  
  合計 が 答え
}
標準ライブラリを使う

add = 入力 lst に対し {
  合計 = 0
  インデックス = 1
  
  インデックス が lst の大きさ より小さい ならば {
    もし lst[インデックス] が 0 が lst[インデックス] を 2 で 剰余 ならば {
      合計 = 合計 を lst[インデックス] に足す
    }
    インデックス を増やす
  }
  
  合計 が 答え
}