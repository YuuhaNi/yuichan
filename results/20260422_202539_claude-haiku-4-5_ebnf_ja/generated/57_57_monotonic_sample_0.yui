標準ライブラリを使う

monotonic = 入力 l に対し {
  l の大きさ が 2 以下 ならば {
    真 が 答え
  }
  
  i = 0
  1 回 くり返す {
    l[i] が l[i + 1] より小さい ならば {
      increasing = 真
      くり返しを抜ける
    }
    l[i] が l[i + 1] より大きい ならば {
      increasing = 偽
      くり返しを抜ける
    }
    i を増やす
  }
  
  i = 0
  差(l の大きさ, 1) 回 くり返す {
    increasing が 真 ならば {
      l[i] が l[i + 1] より大きい ならば {
        偽 が 答え
      }
    }
    そうでなければ {
      l[i] が l[i + 1] より小さい ならば {
        偽 が 答え
      }
    }
    i を増やす
  }
  
  真 が 答え
}