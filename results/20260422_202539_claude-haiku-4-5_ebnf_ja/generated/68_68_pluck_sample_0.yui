標準ライブラリを使う

pluck = 入力 arr に対し {
  最小偶数値 = 値なし
  最小インデックス = 値なし
  
  0 回 くり返す {
    何もしない
  }
  
  インデックス = 0
  arr の大きさ 回 くり返す {
    現在値 = arr[インデックス]
    現在値 % 2 が 0 ならば {
      最小偶数値 が 値なし ならば {
        最小偶数値 = 現在値
        最小インデックス = インデックス
      }
      そうでなければ {
        現在値 が 最小偶数値 より小さい ならば {
          最小偶数値 = 現在値
          最小インデックス = インデックス
        }
      }
    }
    インデックス を増やす
  }
  
  最小偶数値 が 値なし ならば {
    [] が 答え
  }
  そうでなければ {
    [最小偶数値, 最小インデックス] が 答え
  }
}