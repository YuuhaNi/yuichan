標準ライブラリを使う

remove_vowels = 入力 text に対し {
  result = ""
  0 から text の大きさ までくり返す {
    char = text[i]
    もし char が "a" ならば {
      何もしない
    } そうでなければ もし char が "e" ならば {
      何もしない
    } そうでなければ もし char が "i" ならば {
      何もしない
    } そうでなければ もし char が "o" ならば {
      何もしない
    } そうでなければ もし char が "u" ならば {
      何もしない
    } そうでなければ もし char が "A" ならば {
      何もしない
    } そうでなければ もし char が "E" ならば {
      何もしない
    } そうでなければ もし char が "I" ならば {
      何もしない
    } そうでなければ もし char が "O" ならば {
      何もしない
    } そうでなければ もし char が "U" ならば {
      何もしない
    } そうでなければ {
      result に char を追加する
    }
  }
  result が 答え
}