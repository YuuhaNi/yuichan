標準ライブラリを使う

count_upper = 入力 s に対し {
  count = 0
  0 回 くり返す {
    何もしない
  }
  i = 0
  s の大きさ 回 くり返す {
    もし i が 2 ならば {
      char = s[i]
      もし char が "A" ならば {
        count を増やす
      }
      もし char が "E" ならば {
        count を増やす
      }
      もし char が "I" ならば {
        count を増やす
      }
      もし char が "O" ならば {
        count を増やす
      }
      もし char が "U" ならば {
        count を増やす
      }
    }
    i を増やす
  }
  count が 答え
}