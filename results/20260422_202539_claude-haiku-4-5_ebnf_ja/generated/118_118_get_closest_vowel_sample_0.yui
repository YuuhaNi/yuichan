標準ライブラリを使う

get_closest_vowel = 入力 word に対し {
  母音 = "aeiouAEIOU"
  結果 = ""
  
  i = 1 に対し {
    word の大きさ が 2 より小さい ならば {
      くり返しを抜ける
    }
    
    現在文字 = word[i]
    前文字 = word[i - 1]
    次文字 = word[i + 1]
    
    前が子音 = 母音 に 前文字 が含まれるか が 偽 ならば {
      次が子音 = 母音 に 次文字 が含まれるか が 偽 ならば {
        現在が母音 = 母音 に 現在文字 が含まれるか が 真 ならば {
          結果 = 現在文字
        }
      }
    }
    
    i を増やす
  }
  
  結果 が 答え
}
標準ライブラリを使う

get_closest_vowel = 入力 word に対し {
  母音 = "aeiouAEIOU"
  
  i = 1 に対し {
    word の大きさ が 2 より小さい ならば {
      くり返しを抜ける
    }
    
    もし 母音 に word[i - 1] が含まれるか が 偽 ならば {
      もし 母音 に word[i + 1] が含まれるか が 偽 ならば {
        もし 母音 に word[i] が含まれるか が 真 ならば {
          word[i] が 答え
        }
      }
    }
    
    i を増やす
  }
  
  "" が 答え
}