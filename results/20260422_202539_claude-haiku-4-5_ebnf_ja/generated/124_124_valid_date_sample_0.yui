標準ライブラリを使う

valid_date = 入力 date に対し {
  もし date が "" ならば {
    偽 が 答え
  }
  
  parts = split(date, "-")
  
  もし parts の大きさ が 3 以外 ならば {
    偽 が 答え
  }
  
  month = to_number(parts[0])
  day = to_number(parts[1])
  year = to_number(parts[2])
  
  もし month が 1 より小さい ならば {
    偽 が 答え
  }
  
  もし month が 12 より大きい ならば {
    偽 が 答え
  }
  
  もし month が 1 ならば {
    もし day が 1 より小さい ならば {
      偽 が 答え
    }
    もし day が 31 より大きい ならば {
      偽 が 答え
    }
  }
  
  もし month が 2 ならば {
    もし day が 1 より小さい ならば {
      偽 が 答え
    }
    もし day が 29 より大きい ならば {
      偽 が 答え
    }
  }
  
  もし month が 3 ならば {
    もし day が 1 より小さい ならば {
      偽 が 答え
    }
    もし day が 31 より大きい ならば {
      偽 が 答え
    }
  }
  
  もし month が 4 ならば {
    もし day が 1 より小さい ならば {
      偽 が 答え
    }
    もし day が 30 より大きい ならば {
      偽 が 答え
    }
  }
  
  もし month が 5 ならば {
    もし day が 1 より小さい ならば {
      偽 が 答え
    }
    もし day が 31 より大きい ならば {
      偽 が 答え
    }
  }
  
  もし month が 6 ならば {
    もし day が 1 より小さい ならば {
      偽 が 答え
    }
    もし day が 30 より大きい ならば {
      偽 が 答え
    }
  }
  
  もし month が 7 ならば {
    もし day が 1 より小さい ならば {
      偽 が 答え
    }
    もし day が 31 より大きい ならば {
      偽 が 答え
    }
  }
  
  もし month が 8 ならば {
    もし day が 1 より小さい ならば {
      偽 が 答え
    }
    もし day が 31 より大きい ならば {
      偽 が 答え
    }
  }
  
  もし month が 9 ならば {
    もし day が 1 より小さい ならば {
      偽 が 答え
    }
    もし day が 30 より大きい ならば {
      偽 が 答え
    }
  }
  
  もし month が 10 ならば {
    もし day が 1 より小さい ならば {
      偽 が 答え
    }
    もし day が 31 より大きい ならば {
      偽 が 答え
    }
  }
  
  もし month が 11 ならば {
