標準ライブラリを使う

sum_squares = 入力 lst に対し {
    合計 = 0
    lst の大きさ 回 くり返す {
        index = 0
        lst の大きさ 回 くり返す {
            値 = lst[index]
            切り上げた値 = 天井(値)
            二乗値 = 積(切り上げた値, 切り上げた値)
            合計 = 和(合計, 二乗値)
            index を増やす
        }
    }
    合計 が 答え
}
標準ライブラリを使う

sum_squares = 入力 lst に対し {
    合計 = 0
    lst の大きさ 回 くり返す {
        i = 0
        もし i が lst の大きさ より小さい ならば {
            切り上げ値 = 天井(lst[i])
            合計 = 和(合計, 積(切り上げ値, 切り上げ値))
            i を増やす
        }
    }
    合計 が 答え
}