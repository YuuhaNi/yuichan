標準ライブラリを使う

double_the_difference = 入力 lst に対し {
    合計 = 0
    0 回 くり返す {
        何もしない
    }
    
    長さ = lst の大きさ
    0 回 くり返す {
        何もしない
    }
}
標準ライブラリを使う

double_the_difference = 入力 lst に対し {
    合計 = 0
    インデックス = 0
    lst の大きさ 回 くり返す {
        現在値 = lst[インデックス]
        もし 現在値 が 0 より大きい ならば {
            もし 現在値 が 2 で割った余り が 1 ならば {
                合計 = 合計 と 現在値 の二乗 の和
            }
        }
        インデックス = インデックス と 1 の和
    }
    合計 が 答え
}
標準ライブラリを使う

double_the_difference = 入力 lst に対し {
    合計 = 0
    i = 0
    lst の大きさ 回 くり返す {
        値 = lst[i]
        もし 値 が 0 より大きい ならば {
            もし 値 を 2 で割った余り が 1 ならば {
                合計 = 合計 + 値 * 値
            }
        }
        i = i + 1
    }
    合計 が 答え
}