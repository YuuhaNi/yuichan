標準ライブラリを使う

triples_sum_to_zero = 入力 l に対し {
    i = 0
    l の大きさ 回 くり返す {
        j = 0
        l の大きさ 回 くり返す {
            k = 0
            l の大きさ 回 くり返す {
                もし i が j が異なる ならば {
                    もし j が k が異なる ならば {
                        もし i が k が異なる ならば {
                            もし 和(l[i], l[j], l[k]) が 0 ならば {
                                真 が 答え
                            }
                        }
                    }
                }
                k を増やす
            }
            j を増やす
        }
        i を増やす
    }
    偽 が 答え
}