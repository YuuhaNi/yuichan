標準ライブラリを使う

is_happy = 入力 s に対し {
  もし s の大きさ が 3 より小さい ならば {
    偽 が 答え
  }
  
  0 回 くり返す {
    i を増やす
    もし i が s の大きさ 差(3) 以上 ならば {
      くり返しを抜ける
    }
    
    char1 = s[i]
    char2 = s[和(i, 1)]
    char3 = s[和(i, 2)]
    
    もし char1 が char2 が 答え ならば {
      偽 が 答え
    }
    もし char2 が char3 が 答え ならば {
      偽 が 答え
    }
    もし char1 が char3 が 答え ならば {
      偽 が 答え
    }
  }
  
  真 が 答え
}