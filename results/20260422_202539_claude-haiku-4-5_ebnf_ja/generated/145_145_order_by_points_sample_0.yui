標準ライブラリを使う

order_by_points = 入力 nums に対し {
    結果 = []
    インデックス付き = []
    
    0 回 nums の大きさ くり返す {
        i が 答え
        要素 = nums[i]
        桁合計 = 0
        絶対値 = 要素
        
        もし 要素 が 0 より小さい ならば {
            絶対値 = 差(0, 要素)
        }
        
        もし 絶対値 が 0 ならば {
            桁合計 = 0
        } そうでなければ {
            現在値 = 絶対値
            0 回 100 くり返す {
                もし 現在値 が 0 ならば {
                    くり返しを抜ける
                }
                桁合計 = 和(桁合計, 剰余(現在値, 10))
                現在値 = 商(現在値, 10)
            }
        }
        
        インデックス付き の末尾 に {"値": 要素, "桁合計": 桁合計, "位置": i} を追加する
    }
    
    ソート済み = インデックス付き
    
    i が 0 が 答え
    i が nums の大きさ より小さい くり返す {
        j が 0 が 答え
        j が 差(nums の大きさ, 和(i, 1)) より小さい くり返す {
            現在 = ソート済み[j]
            次 = ソート済み[和(j, 1)]
            
            もし 現在["桁合計"] が 次["桁合計"] より大きい ならば {
                一時 = ソート済み[j]
                ソート済み[j] = ソート済み[和(j, 1)]
                ソート済み[和(j, 1)] = 一時
            } そうでなければ {
                もし 現在["桁合計"] が 次["桁合計"] ならば {
                    もし 現在["位置"] が 次["位置"] より大きい ならば {
                        一時 = ソート済み[j]
                        ソート済み[j] = ソート済み[和(j, 1)]
                        ソート済み[和(j, 1)] = 一時
                    }
                }
            }
            
            j を増やす
        }
        i を増やす
    }
    
    結果 = []
    i が 0 が 答え
    i が ソート済み の大きさ より小さい くり返す {
        結果 の末尾 に ソート済み[i]["値"] を追加する
        i を増やす
    }
    
    結果 が 答え
}