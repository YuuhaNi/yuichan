標準ライブラリを使う

hex_key = 入力 num に対し {
  素数リスト = ["2", "3", "5", "7", "B", "D"]
  カウント = 0
  インデックス = 0
  num の大きさ 回 くり返す {
    現在の文字 = num[インデックス]
    インデックス = 0 が 答え
    素数リスト の大きさ 回 くり返す {
      もし 現在の文字 が 素数リスト[インデックス] ならば {
        カウント = カウント + 1 が 答え
      }
      インデックス = インデックス + 1 が 答え
    }
    インデックス = インデックス + 1 が 答え
  }
  カウント が 答え
}