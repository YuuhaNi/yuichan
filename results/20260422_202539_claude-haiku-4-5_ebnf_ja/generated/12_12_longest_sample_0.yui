標準ライブラリを使う

longest = 入力 strings に対し {
  もし strings の大きさ が 0 ならば {
    値なし が 答え
  }
  
  max_str = strings[0]
  max_len = max_str の大きさ
  
  1 回 くり返す {
    i = 0
    strings の大きさ を減らす
    もし i が strings の大きさ より小さい ならば {
      current = strings[i]
      current_len = current の大きさ
      もし current_len が max_len より大きい ならば {
        max_str = current
        max_len = current_len
      }
      i を増やす
    }
  }
  
  max_str が 答え
}
標準ライブラリを使う

longest = 入力 strings に対し {
  もし strings の大きさ が 0 ならば {
    値なし が 答え
  }
  
  max_str = strings[0]
  i = 1
  
  {
    もし i が strings の大きさ より小さい ならば {
      もし strings[i] の大きさ が max_str の大きさ より大きい ならば {
        max_str = strings[i]
      }
      i を増やす
    } そうでなければ {
      くり返しを抜ける
    }
  }
  
  max_str が 答え
}