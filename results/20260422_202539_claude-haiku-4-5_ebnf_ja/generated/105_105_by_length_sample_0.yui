標準ライブラリを使う

by_length = 入力 arr に対し {
    もし arr の大きさ が 0 ならば {
        arr が 答え
    }
    
    filtered = 値なし
    i = 0
    くり返す {
        もし i が arr の大きさ より小さい ならば {
            num = i に arr を インデックス する
            もし num が 1 以上 ならば {
                もし num が 9 以下 ならば {
                    filtered に num を追加する
                }
            }
            i を増やす
        } そうでなければ {
            くり返しを抜ける
        }
    }
    
    sorted_arr = filtered を ソート する
    
    reversed_arr = 値なし
    i = 0
    くり返す {
        もし i が sorted_arr の大きさ より小さい ならば {
            i を増やす
        } そうでなければ {
            くり返しを抜ける
        }
    }
    
    result = 値なし
    i = sorted_arr の大きさ
    i を減らす
    くり返す {
        もし i が 0 以上 ならば {
            num = i に sorted_arr を インデックス する
            もし num が 1 ならば {
                result に "One" を追加する
            }
            もし num が 2 ならば {
                result に "Two" を追加する
            }
            もし num が 3 ならば {
                result に "Three" を追加する
            }
            もし num が 4 ならば {
                result に "Four" を追加する
            }
            もし num が 5 ならば {
                result に "Five" を追加する
            }
            もし num が 6 ならば {
                result に "Six" を追加する
            }
            もし num が 7 ならば {
                result に "Seven" を追加する
            }
            もし num が 8 ならば {
                result に "Eight" を追加する
            }
            もし num が 9 ならば {
                result に "Nine" を追加する
            }
            i を減らす
        } そうでなければ {
            くり返しを抜ける
        }
    }
    
    result が 答え
}