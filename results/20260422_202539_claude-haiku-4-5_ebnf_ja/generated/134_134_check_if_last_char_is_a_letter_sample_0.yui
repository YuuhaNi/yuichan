標準ライブラリを使う

check_if_last_char_is_a_letter = 入力 txt に対し {
    もし txt の大きさ が 0 ならば {
        偽 が 答え
    }
    
    最後の文字 = txt[差(txt の大きさ, 1)]
    
    もし 最後の文字 が " " ならば {
        偽 が 答え
    }
    
    もし txt の大きさ が 1 ならば {
        最後の文字 が 文字か判定(最後の文字) ならば {
            真 が 答え
        }
        そうでなければ {
            偽 が 答え
        }
    }
    
    一つ前の文字 = txt[差(txt の大きさ, 2)]
    
    もし 最後の文字 が 文字か判定(最後の文字) が 真 ならば {
        もし 一つ前の文字 が " " ならば {
            真 が 答え
        }
        そうでなければ {
            偽 が 答え
        }
    }
    
    偽 が 答え
}