標準ライブラリを使う

solve = 入力 N に対し {
  合計 = 0
  現在値 = N
  
  もし N が 0 ならば {
    "0" が答え
  } そうでなければ {
    N を文字列に変換 が 数字リスト
    数字リスト の大きさ を 0 ならば {
      何もしない
    } そうでなければ {
      0 回 くり返す {
        何もしない
      }
    }
    
    合計 = 0
    現在値 = 0
    
    N を文字列に変換 の各文字 に対し {
      合計 = 合計 + 現在値
    }
    
    結果 = ""
    合計 が 0 ならば {
      "0" が答え
    } そうでなければ {
      合計 回 くり返す {
        剰余値 = 合計 % 2
        もし 剰余値 が 0 ならば {
          結果 = "0" + 結果
        } そうでなければ {
          結果 = "1" + 結果
        }
        合計 = 合計 / 2
      }
      結果 が 答え
    }
  }
}
標準ライブラリを使う

solve = 入力 N に対し {
  合計 = 0
  N を文字列に変換 の各文字 に対し {
    合計 = 合計 + (現在の文字を数値に変換)
  }
  
  もし 合計 が 0 ならば {
    "0" が答え
  } そうでなければ {
    結果 = ""
    合計 回 くり返す {
      もし 合計 % 2 が 0 ならば {
        結果 = "0" + 結果
      } そうでなければ {
        結果 = "1" + 結果
      }
      合計 = 合計 / 2
    }
    結果 が 答え
  }
}