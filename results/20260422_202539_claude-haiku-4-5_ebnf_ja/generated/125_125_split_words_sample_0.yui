標準ライブラリを使う

split_words = 入力 txt に対し {
  もし txt が " " を含む ならば {
    txt を " " で分割する が 答え
  }
  そうでなければ {
    もし txt が "," を含む ならば {
      txt を "," で分割する が 答え
    }
    そうでなければ {
      count = 0
      i = 0
      txt の大きさ を n に対し {
        n 回 くり返す {
          char = txt[i]
          code = char の文字コード
          もし code が 97 以上 ならば {
            もし code が 122 以下 ならば {
              pos = 差(code, 97)
              もし 剰余(pos, 2) が 1 ならば {
                count を増やす
              }
            }
          }
          i を増やす
        }
      }
      count が 答え
    }
  }
}