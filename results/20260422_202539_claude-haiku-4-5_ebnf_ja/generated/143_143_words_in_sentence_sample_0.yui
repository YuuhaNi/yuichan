標準ライブラリを使う

words_in_sentence = 入力 sentence に対し {
    words = 分割(sentence, " ")
    result = ""
    0 回目 = 値なし
    
    words の大きさ 回 くり返す {
        word = words[0回目]
        length = word の大きさ
        
        もし 素数か(length) ならば {
            もし result が "" ならば {
                result = word
            } そうでなければ {
                result の末尾 に " " を追加する
                result の末尾 に word を追加する
            }
        }
        
        0回目 を増やす
    }
    
    result が 答え
}

素数か = 入力 n に対し {
    もし n が 2 より小さい ならば {
        偽 が 答え
    }
    
    もし n が 2 ならば {
        真 が 答え
    }
    
    i = 2
    n 回 くり返す {
        もし 剰余(n, i) が 0 ならば {
            偽 が 答え
        }
        
        もし 積(i, i) が n より大きい ならば {
            くり返しを抜ける
        }
        
        i を増やす
    }
    
    真 が 答え
}