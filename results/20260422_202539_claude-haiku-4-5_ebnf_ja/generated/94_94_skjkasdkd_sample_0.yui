標準ライブラリを使う

素数判定 = 入力 n に対し {
  もし n が 2 より小さい ならば {
    偽 が 答え
  }
  もし n が 2 ならば {
    真 が 答え
  }
  もし n が 2 で割った余り が 0 ならば {
    偽 が 答え
  }
  i = 3
  もし i * i が n 以下 ならば {
    i * i 回 くり返す {
      もし n が i で割った余り が 0 ならば {
        偽 が 答え
      }
      i を増やす
    }
  }
  真 が 答え
}

最大素数を求める = 入力 lst に対し {
  最大素数 = 0
  lst の大きさ 回 くり返す {
    現在値 = lst[0]
    もし 素数判定(現在値) が 真 ならば {
      もし 現在値 が 最大素数 より大きい ならば {
        最大素数 = 現在値
      }
    }
  }
  最大素数 が 答え
}

桁数の和を求める = 入力 n に対し {
  桁数和 = 0
  n が 0 ならば {
    0 が 答え
  }
  n を文字列に変換(n) の大きさ 回 くり表す {
    桁数和 = 桁数和 + 1
  }
  桁数和 が 答え
}

main = 入力 lst に対し {
  最大素数 = 最大素数を求める(lst)
  結果 = 桁数の和を求める(最大素数)
  結果 が 答え
}